  el.innerHTML = sorted.map(([date,{cards:cs,diff}])=>`
    <div class="rev-cal-row">
      <div class="rev-cal-date" style="color:${diff<0?'var(--red)':diff===0?'var(--gold)':'var(--muted3)'}">${date}</div>
