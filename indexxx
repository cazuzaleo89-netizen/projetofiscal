<script>
// ═══ STATE ═══════════════════════════════════
const COLORS=['#22d3ee','#06b6d4','#00d4ff','#8b5cf6','#10b981','#39ff14','#3b82f6','#84cc16','#ef4444','#a78bfa'];
let selColor=COLORS[0];
const state={disciplines:[],sessions:[],schedule:{},completedSlots:{},dailyGoal:4,dailyQGoal:20,streak:0,lastStudyDate:null,questionSessions:[],questionGoals:[],planDone:{},mwResults:{},mwWeeks:[],
  resumos:[],
  srsCards:[],
  edital:{weights:{},concurso:''},
  filaRevisao:[],
  tecCaderno:{url:'',cadernoBase:'',idPasta:''},
  tecCadernos:[],
  tecAutoStart:true, tecAutoPause:true, tecRichWidget:true,
  wrongHistory:{},
  missoesCiclo:null,
  xp:0, level:1, achievements:[], focusStreak:0, lastFocusDate:null,
  // min per question by discipline id (editável)
  speedSettings:{}
};
let timer={running:false,paused:false,seconds:0,subject:'',subjectId:'',interval:null};
let tecTabWindow=null; // referência ao tab TEC para postMessage reverso
let tecTabInactiveTimer=null;
let tecLastActivityAt=Date.now();
let editingSlot=null;

// ═══ PERSIST ══════════════════════════════════
function saveState(){state.dailyGoal=parseInt(document.getElementById('daily-goal').value)||4;localStorage.setItem('af_v1',JSON.stringify(state));updateAll();}
function loadState(){const r=localStorage.getItem('af_v1');if(r)Object.assign(state,JSON.parse(r));document.getElementById('daily-goal').value=state.dailyGoal||4;document.getElementById('cfg-daily-goal').value=state.dailyGoal||4;if(!state.disciplines.length)seedDefaults();}
function seedDefaults(){state.disciplines=[{id:'trib-fixed',name:'Dir. Tributário',color:'#22d3ee',weeklyGoal:20},{id:'adm-fixed',name:'Dir. Administrativo',color:'#8b5cf6',weeklyGoal:25},{id:uid(),name:'Português',color:'#00d4ff',weeklyGoal:8},{id:uid(),name:'Raciocínio Lógico',color:'#10b981',weeklyGoal:6}];}
function uid(){return Math.random().toString(36).slice(2,9);}
function syncGoal(){const v=parseInt(document.getElementById('cfg-daily-goal').value)||4;document.getElementById('daily-goal').value=v;saveState();}

// ═══ NAV ══════════════════════════════════════
const PAGE_META={arena:{icon:'⚔',title:'Arena — Modo Foco'},consistencia:{icon:'🔥',title:'Consistência de Estudo'},'problemáticas':{icon:'⚠️',title:'Questões Problemáticas — Reincidências'},dashboard:{icon:'◈',title:'Dashboard'},cronometro:{icon:'◷',title:'Cronômetro'},missoes:{icon:'⚡',title:'Painel de Missões Ativas'},sessao:{icon:'🎯',title:'Sessão de Questões'},filarev:{icon:'⏱',title:'Fila de Revisão por Link'},questoes:{icon:'✎',title:'Questões & Desempenho'},estatisticas:{icon:'◧',title:'Estatísticas'},progresso:{icon:'◎',title:'Progresso'},registros:{icon:'≡',title:'Histórico de Sessões'},revisoes:{icon:'🔁',title:'Revisão Espaçada'},resumos:{icon:'📖',title:'Resumos de Estudo'},metas:{icon:'◉',title:'Metas Semanais'},disciplinas:{icon:'⊞',title:'Disciplinas'},config:{icon:'⚙',title:'Configurações'},importar:{icon:'⬆',title:'Importar Edital'}};


// ═══ TIMER ════════════════════════════════════
function startTimer(){const sel=document.getElementById('active-subject-select').value;if(!sel){flash('Selecione uma disciplina!','var(--gold)');return;}const d=state.disciplines.find(x=>x.id===sel);timer={running:true,paused:false,seconds:0,subject:d?d.name:'',subjectId:d?d.id:'',interval:setInterval(tickTimer,1000)};updateTimerUI();}
function pauseTimer(){if(!timer.running||timer.paused)return;timer.paused=true;clearInterval(timer.interval);updateTimerUI();}
function resumeTimer(){if(!timer.paused)return;timer.paused=false;timer.interval=setInterval(tickTimer,1000);updateTimerUI();}
function stopTimer(){
  if(!timer.running)return;clearInterval(timer.interval);
  if(timer.seconds>5){const now=new Date();state.sessions.push({id:uid(),subjectId:timer.subjectId,subject:timer.subject,seconds:timer.seconds,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});updateStreak(now.toDateString());saveState();flash('Sessão registrada! '+formatTime(timer.seconds),'#10b981');}
  timer={running:false,paused:false,seconds:0,subject:'',subjectId:'',interval:null};
  document.getElementById('timer-digits').textContent='00:00:00';document.getElementById('timer-digits').className='t-digits';
  updateTimerUI();renderAll();
}
function tickTimer(){timer.seconds++;document.getElementById('timer-digits').textContent=formatTime(timer.seconds);}
function updateTimerUI(){
  const bs=document.getElementById('btn-start'),bp=document.getElementById('btn-pause'),br=document.getElementById('btn-resume'),bst=document.getElementById('btn-stop');
  const lbl=document.getElementById('timer-label'),sd=document.getElementById('timer-subject-display'),dig=document.getElementById('timer-digits');
  const wrap=document.getElementById('timer-wrap-el');
  if(!timer.running){
    bs.style.display='';bp.style.display='none';br.style.display='none';bst.style.display='none';
    lbl.textContent='Pronto para estudar';sd.textContent='Selecione uma disciplina';
    dig.className='t-digits';sd.className='t-disc';
    if(wrap){wrap.classList.remove('mode-running','mode-paused');}
  } else if(timer.paused){
    bs.style.display='none';bp.style.display='none';br.style.display='';bst.style.display='';
    lbl.textContent='Pausado';dig.className='t-digits paused';sd.className='t-disc paused';
    if(wrap){wrap.classList.remove('mode-running');wrap.classList.add('mode-paused');}
  } else {
    bs.style.display='none';bp.style.display='';br.style.display='none';bst.style.display='';
    lbl.textContent='Estudando agora…';sd.textContent=timer.subject.toUpperCase();
    dig.className='t-digits running';sd.className='t-disc active';
    if(wrap){wrap.classList.remove('mode-paused');wrap.classList.add('mode-running');}
  }
}
function updateActiveSubject(){const sel=document.getElementById('active-subject-select').value;const d=state.disciplines.find(x=>x.id===sel);if(d&&timer.running){timer.subject=d.name;timer.subjectId=d.id;document.getElementById('timer-subject-display').textContent=d.name.toUpperCase();}}
function quickRegisterQ(){
  const total=parseInt(document.getElementById('t-q-total').value),correct=parseInt(document.getElementById('t-q-correct').value),sel=document.getElementById('active-subject-select').value;
  if(!sel){flash('Selecione a disciplina no cronômetro!','#f0b429');return;}if(!total||total<1){flash('Informe o total!','#f0b429');return;}if(isNaN(correct)||correct<0||correct>total){flash('Acertos inválidos!','#f0b429');return;}
  const d=state.disciplines.find(x=>x.id===sel);const now=new Date();
  state.questionSessions.push({id:uid(),subjectId:sel,subject:d?d.name:'',total,correct,banca:'—',obs:'',date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
  document.getElementById('t-q-total').value='';document.getElementById('t-q-correct').value='';
  saveState();flash(`${correct}/${total} registrado (${Math.round(correct/total*100)}%)`,'#10b981');
}

// ═══ FORMAT ═══════════════════════════════════
function formatTime(sec){return[Math.floor(sec/3600),Math.floor((sec%3600)/60),sec%60].map(x=>x.toString().padStart(2,'0')).join(':');}
function formatHM(sec){const h=Math.floor(sec/3600),m=Math.floor((sec%3600)/60);return h?`${h}h ${m.toString().padStart(2,'0')}m`:`${m}m`;}

// ═══ STATS ════════════════════════════════════
function updateStats(){
  const today=new Date().toDateString(),wa=Date.now()-7*86400000;
  let tot=0,todS=0,wkS=0;
  state.sessions.forEach(s=>{tot+=s.seconds;const d=new Date(s.date);if(d.toDateString()===today)todS+=s.seconds;if(d>=wa)wkS+=s.seconds;});
  ['h-today','sb-today'].forEach(id=>set(id,formatHM(todS)));
  set('h-week',formatHM(wkS));set('h-total',formatHM(tot));
  set('d-total',Math.floor(tot/3600)+'h');set('d-total-sub',formatHM(wkS)+' esta semana');
  set('d-sessions',state.sessions.length);
  set('d-sessions-sub',state.sessions.filter(s=>new Date(s.date).toDateString()===today).length+' hoje');
  set('d-streak',state.streak||0);
  set('t-today-h',formatHM(todS));
  set('t-today-s',state.sessions.filter(s=>new Date(s.date).toDateString()===today).length);
  const goal=(state.dailyGoal||4)*3600,pct=Math.min(100,Math.round(todS/goal*100));
  set('d-goal-pct',pct+'%');setStyle('d-goal-bar','width',pct+'%');
  set('d-goal-done',formatHM(todS)+' estudadas');set('d-goal-target','meta: '+(state.dailyGoal||4)+'h');
  // Meta de questões do dia
  const todayQ = state.questionSessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.total,0);
  const todayQCorr = state.questionSessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.correct,0);
  const qGoal = state.dailyQGoal||20;
  const qPct = Math.min(100,Math.round(todayQ/qGoal*100));
  const qGoalEl = document.getElementById('d-q-goal-val'); if(qGoalEl) qGoalEl.textContent=qGoal;
  const qPctEl = document.getElementById('d-q-today-pct');
