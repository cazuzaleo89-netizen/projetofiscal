// ── Missions (regenerated daily) ───────────────
function arenaGetDailyMissions(){
  const today = new Date().toDateString();
  const seed = today.split(' ').reduce((a,s)=>a+s.charCodeAt(0),0);
  const rng = (n) => { let x = Math.sin(seed + n) * 10000; return x - Math.floor(x); };

  const pool = [
    {id:'study_30min', icon:'⏱', name:'Estudar 30 minutos',        xp:15, check:()=>{ const today=new Date().toDateString(); return state.sessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.seconds,0)>=1800; }},
    {id:'study_60min', icon:'⏰', name:'Estudar 1 hora hoje',       xp:30, check:()=>{ const today=new Date().toDateString(); return state.sessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.seconds,0)>=3600; }},
    {id:'q20',         icon:'❓', name:'Resolver 20 questões',      xp:20, check:()=>{ const today=new Date().toDateString(); return state.questionSessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.total,0)>=20; }},
    {id:'q50',         icon:'🎯', name:'Resolver 50 questões',      xp:35, check:()=>{ const today=new Date().toDateString(); return state.questionSessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.total,0)>=50; }},
    {id:'focus_block', icon:'🧘', name:'Completar 1 bloco de foco', xp:25, check:()=>{ const today=new Date().toDateString(); return (state.focusHistory||[]).some(f=>f.completed&&new Date(f.date).toDateString()===today); }},
    {id:'meta_done',   icon:'✅', name:'Concluir 1 meta semanal',   xp:40, check:()=>{ const today=new Date().toDateString(); return Object.values(state.mwResults||{}).some(r=>new Date(r.date).toDateString()===today); }},
    {id:'review_done', icon:'🔁', name:'Fazer 1 revisão espaçada',  xp:20, check:()=>{ return (state.srsCards||[]).some(c=>(c.history||[]).some(h=>new Date(h.date).toDateString()===new Date().toDateString())); }},
    {id:'acc_70',      icon:'🏹', name:'Acertar ≥70% hoje',         xp:30, check:()=>{ const today=new Date().toDateString(); const qs=state.questionSessions.filter(s=>new Date(s.date).toDateString()===today); const t=qs.reduce((a,s)=>a+s.total,0);const c=qs.reduce((a,s)=>a+s.correct,0); return t>=10&&c/t>=0.7; }},
    {id:'streak_keep', icon:'🔥', name:'Manter a sequência ativa',  xp:10, check:()=>{ const today=new Date().toDateString(); return state.lastStudyDate===today||(state.sessions.some(s=>new Date(s.date).toDateString()===today)); }},
  ];

  // Pick 4 missions deterministically based on day
  const indices = [];
  let i=0;
  while(indices.length<4){ const idx=Math.floor(rng(i++)*pool.length); if(!indices.includes(idx))indices.push(idx); }
  return indices.map(i=>pool[i]);
}

// ── XP & Level system ─────────────────────────
function arenaEnsure(){
  if(!state.xp) state.xp=0;
  if(!state.level) state.level=1;
  if(!state.achievements) state.achievements=[];
  if(!state.focusHistory) state.focusHistory=[];
  if(!state.arenaData) state.arenaData={missionsCompleted:0};
}

function arenaGetLevel(xp){
  let lvl=ARENA_LEVELS[0];
  for(const l of ARENA_LEVELS){ if(xp>=l.min) lvl=l; else break; }
  return lvl;
}

function arenaXpToNextLevel(xp){
  const levels=ARENA_LEVELS;
  for(let i=0;i<levels.length-1;i++){
    if(xp>=levels[i].min&&xp<levels[i+1].min){
      const current=levels[i].min, next=levels[i+1].min;
      return {current, next, progress:xp-current, needed:next-current, idx:i+1};
    }
  }
  return {current:xp, next:xp, progress:0, needed:1, idx:ARENA_LEVELS.length};
}

function arenaAddXP(amount, reason, icon='⚡'){
  arenaEnsure();
  state.xp = (state.xp||0) + amount;
  if(!state.xpHistory) state.xpHistory=[];
  const now=new Date();
  state.xpHistory.unshift({
    amount, reason, icon,
    date:now.toISOString(),
    dateStr:now.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})
  });
  if(state.xpHistory.length>50) state.xpHistory=state.xpHistory.slice(0,50);

  // Level up check
  const prevLevel = state.level||1;
  const newLevelData = arenaGetLevel(state.xp);
  const newLevel = ARENA_LEVELS.indexOf(newLevelData)+1;
  if(newLevel>prevLevel){
    state.level=newLevel;
    setTimeout(()=>arenaLevelUpEffect(newLevelData),300);
  }

  saveState();
  arenaShowXPPopup(amount, icon);
  arenaCheckAchievements();

  // Refresh if on arena page
  const arenaPage=document.getElementById('page-arena');
  if(arenaPage&&arenaPage.classList.contains('active')) arenaRender();
  // Update nav badge
  arenaUpdateNavBadge();
}

function arenaShowXPPopup(amount, icon){
  const popup=document.createElement('div');
  popup.className='arena-xp-popup';
  popup.textContent=`${icon} +${amount} XP`;
  popup.style.cssText=`left:50%;top:40%;`;
  document.body.appendChild(popup);
  setTimeout(()=>popup.remove(),1600);
}

function arenaLevelUpEffect(levelData){
  flash(`🎉 LEVEL UP! ${levelData.label} — "${levelData.title}"`, '#a78bfa');
}

