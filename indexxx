function dashWeekNav(dir){
  const weeks=state.mwWeeks||[];
  dashWeekIdx=Math.max(0,Math.min(weeks.length-1,dashWeekIdx+dir));
  const sel=document.getElementById('dash-week-select');
  if(sel)sel.value=dashWeekIdx;
  renderDashMetas();
