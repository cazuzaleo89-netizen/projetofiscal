function mwCdStart(){
  const secs=mwCdGetSecs();
  if(secs<=0){flash('Defina um tempo maior que zero!','#f0b429');return;}
  mwCd.totalSecs=secs;mwCd.remainSecs=secs;mwCd.running=true;mwCd.paused=false;
  mwCd.interval=setInterval(mwCdTick,1000);
  mwCdShowRunning();mwCdUpdateDisplay();mwCdUpdateUI();mwCdUpdateAccent();
}
function mwCdPause(){if(!mwCd.running||mwCd.paused)return;mwCd.paused=true;clearInterval(mwCd.interval);mwCdUpdateUI();mwCdUpdateAccent();}
function mwCdResume(){if(!mwCd.paused)return;mwCd.paused=false;mwCd.interval=setInterval(mwCdTick,1000);mwCdUpdateUI();mwCdUpdateAccent();}
function mwCdStop(){
  clearInterval(mwCd.interval);
  const elapsed=mwCd.totalSecs-mwCd.remainSecs;
  if(elapsed>5&&mwActiveBlock){
    const now=new Date();
    state.sessions.push({id:uid(),subjectId:mwActiveBlock.discId,subject:mwActiveBlock.disc,
      seconds:elapsed,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),
      timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
    updateStreak(now.toDateString());saveState();
    // also fill time fields in register panel
    const hEl=document.getElementById('mw-t-h'),mEl=document.getElementById('mw-t-m'),sEl=document.getElementById('mw-t-s');
    if(hEl)hEl.value=Math.floor(elapsed/3600)||0;
    if(mEl)mEl.value=Math.floor((elapsed%3600)/60)||0;
    if(sEl)sEl.value=elapsed%60||0;
    const shEl=document.getElementById('mw-study-h'),smEl=document.getElementById('mw-study-m');
    if(shEl)shEl.value=Math.floor(elapsed/3600)||0;
    if(smEl)smEl.value=Math.floor((elapsed%3600)/60)||0;
    mwUpdateStudyPreview();
    flash('Tempo salvo! Registre o resultado abaixo.','#10b981');
  }
  mwCd.running=false;mwCd.paused=false;mwCd.remainSecs=0;
  mwCdShowSetup();mwCdUpdateUI();mwCdUpdateAccent();
  set('mw-cd-status','Configure o tempo acima');
}

function mwCdTick(){
  if(mwCd.remainSecs<=0){mwCdFinished();return;}
  mwCd.remainSecs--;
  mwCdUpdateDisplay();
  if(mwCd.remainSecs<=0)mwCdFinished();
}

function mwCdFinished(){
  clearInterval(mwCd.interval);mwCd.running=false;mwCd.paused=false;
  // alarm
  const card=document.getElementById('mw-timer-card');
  if(card){card.style.boxShadow='0 0 0 3px var(--red)';setTimeout(()=>card.style.boxShadow='',3000);}
  // sound
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    [0,.25,.5,.75,1.0].forEach((t,i)=>{
      const osc=ctx.createOscillator(),gain=ctx.createGain();
      osc.connect(gain);gain.connect(ctx.destination);
      osc.frequency.value=i%2===0?880:660;
      gain.gain.setValueAtTime(0.35,ctx.currentTime+t);
      gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+t+0.2);
      osc.start(ctx.currentTime+t);osc.stop(ctx.currentTime+t+0.22);
    });
  }catch(e){}
  // save session
  if(mwActiveBlock&&mwCd.totalSecs>5){
    const now=new Date();
    state.sessions.push({id:uid(),subjectId:mwActiveBlock.discId,subject:mwActiveBlock.disc,
      seconds:mwCd.totalSecs,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),
      timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
    updateStreak(now.toDateString());saveState();
    // fill time fields
    const s=mwCd.totalSecs;
    const hEl=document.getElementById('mw-t-h'),mEl=document.getElementById('mw-t-m'),sEl=document.getElementById('mw-t-s');
    if(hEl)hEl.value=Math.floor(s/3600)||0;
    if(mEl)mEl.value=Math.floor((s%3600)/60)||0;
    if(sEl)sEl.value=s%60||0;
    const shEl=document.getElementById('mw-study-h'),smEl=document.getElementById('mw-study-m');
    if(shEl)shEl.value=Math.floor(s/3600)||0;
    if(smEl)smEl.value=Math.floor((s%3600)/60)||0;
    mwUpdateStudyPreview();
  }
  set('mw-cd-digits','00:00');set('mw-cd-status','⏰ Tempo esgotado!');
  set('mw-cd-label','concluído');
  mwCdUpdateUI();mwCdShowSetup();mwCdUpdateAccent();
  flash('⏰ Tempo esgotado! Registre o resultado.','#10b981');
}

function mwCdUpdateDisplay(){
  const h=Math.floor(mwCd.remainSecs/3600);
  const m=Math.floor((mwCd.remainSecs%3600)/60);
  const s=mwCd.remainSecs%60;
  const str=h>0?`${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`:`${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  set('mw-cd-digits',str);
  const ring=document.getElementById('mw-cd-ring');
  if(ring){
    const pct=mwCd.totalSecs>0?mwCd.remainSecs/mwCd.totalSecs:0;
    ring.style.strokeDashoffset=(MW_CD_CIRC*(1-pct)).toFixed(1);
    ring.style.stroke=pct>0.5?'var(--purple)':pct>0.2?'var(--gold)':'var(--red)';
    const digEl=document.getElementById('mw-cd-digits');
    if(digEl)digEl.style.color=pct<=0.2?'var(--red)':'var(--text)';
  }
  const pct=mwCd.totalSecs>0?Math.round(mwCd.remainSecs/mwCd.totalSecs*100):0;
  set('mw-cd-label',mwCd.paused?'pausado':`${pct}% restante`);
}

function mwCdShowRunning(){
