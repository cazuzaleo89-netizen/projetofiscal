function missoesRender() {
  missoesEnsure();
  const ciclo = state.missoesCiclo;
  const missions = ciclo.missions || [];

  // Cycle progress
  const total = missions.length;
  const done  = missions.filter(m=>m.status==='done').length;
  const pct   = total > 0 ? Math.round(done/total*100) : 0;
  set('missoes-ciclo-nome', ciclo.nome || 'Avanço do Ciclo');
  set('missoes-ciclo-label', `${done} de ${total} missões concluídas`);
  set('missoes-ciclo-sub', `${pct}% concluído`);
  const bar = document.getElementById('missoes-ciclo-bar');
  if (bar) bar.style.width = pct + '%';

  // KPIs
  const totalSecs = state.sessions.reduce((a,s)=>a+s.seconds,0);
  const totalQ    = state.questionSessions.reduce((a,s)=>a+s.total,0);
  const totalC    = state.questionSessions.reduce((a,s)=>a+s.correct,0);
  const taxa      = totalQ > 0 ? Math.round(totalC/totalQ*100) : null;
  set('missoes-kpi-pend', total - done);
  set('missoes-kpi-tempo', formatHM(totalSecs));
  set('missoes-kpi-taxa', taxa !== null ? taxa + '%' : '—');
  set('missoes-kpi-taxa-sub', totalQ > 0 ? `${totalQ} resolvidas no ciclo` : 'Sem questões ainda');

  missoesUpdateNavBadge();

  if (missoesTab === 'ativas') missoesRenderDays();
}

function missoesRenderDays() {
  missoesEnsure();
  const el = document.getElementById('missoes-days-list');
  if (!el) return;
  const missions = state.missoesCiclo.missions || [];

  if (!missions.length) {
    el.innerHTML = `<div class="card"><div class="empty" style="padding:2rem;">
      <div style="font-size:2rem;margin-bottom:.75rem;">⚡</div>
      <div style="font-size:.88rem;font-weight:700;margin-bottom:.4rem;">Nenhuma missão ainda</div>
      <div style="font-size:.72rem;color:var(--muted2);line-height:1.6;">Clique em <strong>⚡ Gerar Missões</strong> para criar automaticamente com base no seu edital e disciplinas.<br>Ou ajuste as configurações na aba <strong>Central de Calibragem</strong>.</div>
    </div></div>`;
    return;
  }

  // Group by day
  const byDay = {};
  missions.forEach(m => {
    const key = m.date || `day-${m.dayIdx}`;
    if (!byDay[key]) byDay[key] = {date:m.date, dayIdx:m.dayIdx, missions:[]};
    byDay[key].missions.push(m);
  });

  const today = new Date().toISOString().split('T')[0];
  el.innerHTML = '';

  Object.entries(byDay).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([dateKey, group]) => {
    const dateObj = group.date ? new Date(group.date + 'T12:00:00') : null;
    const isToday = group.date === today;
    const isPast  = group.date && group.date < today;
    const dayName = dateObj ? DAYS_PT[dateObj.getDay() === 0 ? 6 : dateObj.getDay()-1] : `Dia ${group.dayIdx+1}`;
    const dateStr = dateObj ? dateObj.toLocaleDateString('pt-BR',{day:'numeric',month:'long'}) : '';
    const doneCnt = group.missions.filter(m=>m.status==='done').length;
    const totalCnt= group.missions.length;
    const progPct = totalCnt > 0 ? doneCnt/totalCnt*100 : 0;

    const section = document.createElement('div');
    section.className = `missoes-day-section${isToday?' today':''}`;

    section.innerHTML = `
      <div class="missoes-day-header">
        <div>
          <div class="missoes-day-name">${dayName}</div>
          <div class="missoes-day-date">${dateStr}${isToday?' — Hoje':isPast?' — Concluído':''}</div>
        </div>
