/* ── Timer ─────────────────────────────────────── */
function sqTickTimer() {
  if(!sqSession) return;
  const elapsed = Math.floor((Date.now() - sqSession.startTime) / 1000);
  const h=Math.floor(elapsed/3600), m=Math.floor((elapsed%3600)/60), s=elapsed%60;
  const el = document.getElementById('sq-session-timer');
  if(el) el.textContent=`${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  // Pace
  if(sqSession.totalAnswered>0){
    const pace = (elapsed/60/sqSession.totalAnswered).toFixed(1);
    const pe = document.getElementById('sq-pace-live');
    if(pe) pe.textContent=`ritmo: ${pace} min/questão`;
  }
  // Update queue timers every second
  sqRenderQueue();
}

/* ── Stats ─────────────────────────────────────── */
function sqUpdateStats() {
  if(!sqSession) return;
  const answered = sqSession.totalAnswered;
  const total    = sqSession.total;
  const correct  = sqSession.correct;
  const wrong    = sqSession.wrong;
  const rate     = answered ? Math.round(correct/answered*100) : null;
  const rc       = rate===null?'var(--cyan)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
  const pending  = sqSession.reviewQueue.filter(item=>{const q=sqSession.questions[item.num-1];return q&&(q.status==='wrong'||q.status==='review_pending');}).length;

  set('sq-live-correct', correct);
  set('sq-live-wrong',   wrong);
  set('sq-live-rate',    rate!==null?rate+'%':'—');
  set('sq-live-pending', pending);
  document.getElementById('sq-live-rate').style.color = rc;

  const progPct = Math.round(answered/total*100);
  set('sq-progress-label', `${answered} / ${total} questões respondidas`);
  set('sq-progress-pct', progPct+'%');
  setStyle('sq-progress-bar', 'width', progPct+'%');
}

/* ── End session ────────────────────────────────── */
function sqEndSession() {
  if(!sqSession) return;
  clearInterval(sqSession.timerInterval);
  clearInterval(sqSession.queueInterval);
  document.removeEventListener('keydown', sqKeyHandler);

  const elapsed = Math.floor((Date.now()-sqSession.startTime)/1000);
  const {correct,wrong,discId,discName,discColor,topic,total} = sqSession;
  const answered = correct+wrong;

  // Save to state
  if(answered>0){
    const now=new Date();
    state.questionSessions.push({
      id:uid(), subjectId:discId, subject:discName,
      total:answered, correct,
      banca:'Sessão Manual', obs:topic,
      date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
      timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
    });
    if(elapsed>30){
      state.sessions.push({
        id:uid(), subjectId:discId, subject:discName,
        seconds:elapsed,
        date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
        timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
      });
    }
    updateStreak(now.toDateString());
    saveState();
    arenaAddXP(Math.ceil(answered*0.2)+(correct/answered>=0.7?10:0),`Sessão: ${answered}q — ${Math.round(correct/answered*100)}% acerto`,'🎯');
  }

  sqSession = null;
  document.getElementById('sq-setup').style.display = '';
  document.getElementById('sq-active').style.display = 'none';
  document.getElementById('sq-review-alert').style.display = 'none';
  sqInit();

  if(answered>0){
    const rate=Math.round(correct/answered*100);
    flash(`Sessão concluída! ${correct}/${answered} (${rate}%) — ${Math.floor(elapsed/60)} min`,'#10b981');
  }
  updateStats();
}

/* ── Keyboard shortcuts ─────────────────────────── */
function sqKeyHandler(e) {
  if(!sqSession) return;
  // Don't trigger if typing in an input
  if(['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)) return;
  switch(e.key.toLowerCase()) {
    case 'c': case '1': sqMark(true); break;
    case 'e': case '0': sqMark(false); break;
    case 'arrowright': sqSkip(); break;
    case 'r': sqStartReview(); break;
  }
}

