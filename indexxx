    document.getElementById('res-modal-title').textContent='Editar Resumo';
    document.getElementById('res-modal-title-inp').value = r.title||'';
    document.getElementById('res-modal-tags').value = (r.tags||[]).join(', ');
    if(msel) msel.value = r.metaId||'';
    if(dsel) dsel.value = r.discId||'';
    resSetType(r.type||'text');
    if(r.type==='text'){
      document.getElementById('res-editor').innerHTML = r.content||'';
    } else {
      resImageData = r.imageData||null;
      if(r.imageData||r.imageUrl){
