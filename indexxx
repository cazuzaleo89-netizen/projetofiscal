function _sqShowReturnPanel() {
  document.getElementById('sq-tec-return').style.display = '';
  document.getElementById('sq-tec-meta-preview').style.display = 'none';
  // Hide setup fields
  document.querySelector('#sq-mode-tec > .card:first-child').style.display = 'none';

  set('sq-return-meta-name', sqTecSession.metaName);

  // Live elapsed timer
  sqTecSession.returnTimerInterval = setInterval(()=>{
    if(!sqTecSession) return;
    const secs = Math.floor((Date.now()-sqTecSession.startTime)/1000);
    const h=Math.floor(secs/3600),m=Math.floor((secs%3600)/60),s=secs%60;
    const el=document.getElementById('sq-return-timer');
    if(el) el.textContent=`${h.toString().padStart(2,'0')}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
    sqTecSession.elapsed = secs;
  }, 1000);

  // Pre-fill with meta's goal as total
  const totalInp = document.getElementById('sq-ret-total');
  if(totalInp && sqTecSession.total) totalInp.value = sqTecSession.total;

  // Try to pull result from extension storage
  if(typeof chrome!=='undefined' && chrome?.storage?.local) {
    chrome.storage.local.get(['pendingResults'], data=>{
      const pending = (data.pendingResults||[]);
      const match = pending.find(r=>r.metaId===sqTecSession?.metaId);
      if(match) {
        set('sq-auto-total',   match.total);
        set('sq-auto-correct', match.correct);
        const rate = Math.round(match.correct/match.total*100);
        const rc = rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
        const rateEl = document.getElementById('sq-auto-rate');
        if(rateEl){ rateEl.textContent=rate+'%'; rateEl.style.color=rc; }
        document.getElementById('sq-auto-result').style.display='';
        // Pre-fill fields
        const tot=document.getElementById('sq-ret-total');
        const cor=document.getElementById('sq-ret-correct');
        if(tot) tot.value=match.total;
        if(cor) cor.value=match.correct;
        sqReturnPreview();
        sqTecSession.elapsed = match.elapsed||sqTecSession.elapsed;
      }
    });
  }
}

function sqReturnPreview() {
  const total   = parseInt(document.getElementById('sq-ret-total')?.value)||0;
  const correct = parseInt(document.getElementById('sq-ret-correct')?.value)||0;
  const preview = document.getElementById('sq-return-rate-preview');
  if(!preview) return;
  if(total>0 && !isNaN(correct) && correct>=0 && correct<=total){
    const rate = Math.round(correct/total*100);
    const rc = rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    preview.style.display='';
    preview.style.color=rc;
    preview.textContent=`${correct}/${total} — ${rate}% de acerto`;
  } else {
    preview.style.display='none';
  }
}

function sqConfirmReturn() {
  const total   = parseInt(document.getElementById('sq-ret-total')?.value)||0;
  const correct = parseInt(document.getElementById('sq-ret-correct')?.value)||0;

  if(!total||total<1){flash('Informe o total de questões!','#f0b429');return;}
  if(isNaN(correct)||correct<0||correct>total){flash('Acertos inválidos!','#f0b429');return;}

  if(!sqTecSession){flash('Sessão não encontrada.','#ef4444');return;}

  clearInterval(sqTecSession.returnTimerInterval);
  const elapsed = sqTecSession.elapsed||0;
  const {discId,discName,metaName,metaId,discColor} = sqTecSession;

  // Save to state
  const now = new Date();
  state.questionSessions.push({
    id:uid(), subjectId:discId, subject:discName,
    total, correct, banca:'Tec Concursos', obs:metaName.slice(0,60),
    date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
    timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
  });
  if(elapsed>30){
    state.sessions.push({
      id:uid(), subjectId:discId, subject:discName,
      seconds:elapsed,
      date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
      timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
    });
  }
  // Save to mwResults if meta found
  let meta=null;
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ if(m.id===metaId) meta=m; }));
  if(meta){
    if(!state.mwResults) state.mwResults={};
    const minPerQ = elapsed>0&&total>0 ? +(elapsed/60/total).toFixed(2) : null;
    state.mwResults[meta.id]={
      resolved:total, correct,
      manualTimeSeconds:elapsed, timeSeconds:elapsed,
      studyTimeSeconds:elapsed, sessionSeconds:elapsed,
      minPerQuestion:minPerQ, obs:'',
      date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
      blockName:meta.name, disc:discName, totalQ:meta.total, link:meta.link||''
    };
    // Clear from extension pending if present
    if(typeof chrome!=='undefined'&&chrome?.storage?.local){
      chrome.storage.local.get(['pendingResults'],data=>{
        const pending=(data.pendingResults||[]).filter(r=>r.metaId!==metaId);
        chrome.storage.local.set({pendingResults:pending});
      });
    }
  }

  updateStreak(now.toDateString());
  saveState();
  arenaAddXP(Math.ceil(total*0.2)+(correct/total>=0.7?15:0),`Tec Concursos: ${metaName.slice(0,30)} — ${Math.round(correct/total*100)}% acerto`,'🔗');

  // Now start visual session with the total
  sqTecSession = null;
  _sqResetReturnPanel();

  // Ask if they want to do the visual session
  if(confirm(`Resultado salvo! ✅\n${correct}/${total} (${Math.round(correct/total*100)}%)\n\nAbrir a sessão visual de revisão (com grade de questões + fila de 11 min)?`)){
    // Set up manual session with this data
    sqMode='manual';
    const discSel=document.getElementById('sq-disc-sel');
    if(discSel) discSel.value=discId;
    const totalInp=document.getElementById('sq-total-inp');
    if(totalInp) totalInp.value=total;
    const topicInp=document.getElementById('sq-topic-inp');
    if(topicInp) topicInp.value=metaName;
    sqStartSession();
  } else {
    renderAll(); updateStats();
    flash(`✅ Salvo! ${correct}/${total} — ${Math.round(correct/total*100)}% acerto`,'#10b981');
    sqInit();
  }
}

