// Extrai palavras-chave do enunciado/descrição da questão
// Remove stopwords PT, palavras curtas e pega os termos mais distintivos
function tecExtractKeywords(text) {
  if (!text) return '';
  const stop = new Set(['para','pelo','pela','pelos','pelas','pela','sobre','entre','desde','contra','perante','onde','quando','quanto','quanta','quantos','quantas','quem','como','porque','que','dos','das','uma','umas','uns','aos','seu','sua','seus','suas','este','esta','esse','essa','isso','isto','esses','essas','estes','estas','aquele','aquela','aqueles','aquelas','aquilo','meu','minha','meus','minhas','seria','sera','será','foi','são','tem','tinha','tinham','tive','teve','tiveram','ser','estar','está','estão','estava','estavam','tenho','temos','possui','possuem','deve','devem','pode','podem','poderia','poderiam','assim','também','tambem','ainda','apenas','somente','muito','muita','muitos','muitas','pouco','pouca','poucos','poucas','sempre','nunca','jamais','antes','depois','agora','hoje','ontem','amanha','amanhã','aqui','ali','lá','la','cada','toda','todo','todos','todas','outro','outra','outros','outras','mesmo','mesma','mesmos','mesmas','enquanto','porém','porem','contudo','todavia','entretanto','logo','então','entao','portanto','consoante','conforme','segundo','exceto','salvo','não','nao','sim','nem','ou','mas','mais','menos','foram','faz','fez','fazem','fazia','fica','ficam','sendo','tendo','sido','feito','aquele','tudo','nada','algum','alguma','alguns','algumas','nenhum','nenhuma','outros','assinale','correta','incorreta','correto','incorreto','alternativa','alternativas','julgue','seguinte','seguintes','item','itens','enunciado','questão','questao','letra','marque','indique','considere','considerando','observe','analise','assinale-se','julgue-se','acerca','quanto','sobre','referente','relativos','relativa','relativo','relativas','seguinte','seguintes','seguir','abaixo','acima','assertiva','assertivas','proposição','proposições','proposicao','proposicoes','afirmação','afirmações','afirmacao','afirmacoes']);
  const words = String(text)
    .toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g,'') // remove acentos
    .replace(/[^a-z0-9\s]/g,' ')
    .split(/\s+/)
    .filter(w => w.length >= 5 && !stop.has(w) && !/^\d+$/.test(w));
  // Remove duplicatas mantendo ordem; limita a 5 palavras mais distintivas
  const seen = new Set();
  const unique = [];
  for (const w of words) { if(!seen.has(w)){seen.add(w);unique.push(w);} if(unique.length>=5)break; }
  return unique.join(' ');
}

function tecCadrSearch(materia, assunto, desc) {
  tecCadrEnsure();
  const keywords = tecExtractKeywords(desc || '');
  const terms = {
    materia: materia || '',
    assunto: assunto || '',
    keywords: keywords,
    naoRespondidas: true
  };
  try { localStorage.setItem('pfTecSearch', JSON.stringify(terms)); } catch(e) {}
  window.open('https://www.tecconcursos.com.br/questoes/filtrar', '_blank');
  const tema = assunto || materia || '';
  const kwLabel = keywords ? ' + palavras-chave: "' + keywords + '"' : '';
  flash('🔍 Banco TEC aberto! Clique no ⚡ Monitor para filtrar: "' + tema + '"' + kwLabel + ' (Não Respondidas).', '#22d3ee', 9000);
}

