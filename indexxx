// ── SUMMARY ────────────────────────────────────
function renderMwSummary(){
  const week=(state.mwWeeks||[])[mwActiveWeek];if(!week)return;
  let doneCnt=0,totalQs=0,resolvedQs=0,correctQs=0,timeSec=0,studyTimeSec=0,paceTotal=0,paceCnt=0;
  week.metas.forEach(m=>{
    totalQs+=m.goal||0;
    const r=state.mwResults&&state.mwResults[m.id];
    if(r){
      doneCnt++;resolvedQs+=r.resolved;correctQs+=r.correct;
      timeSec+=(r.timeSeconds||0);
      studyTimeSec+=(r.studyTimeSeconds||r.timeSeconds||0);
      if(r.minPerQuestion&&r.minPerQuestion>0){paceTotal+=r.minPerQuestion;paceCnt++;}
    }
  });
  const pct=week.metas.length?Math.round(doneCnt/week.metas.length*100):0;
  const rate=resolvedQs?Math.round(correctQs/resolvedQs*100):null;
  const avgPace=paceCnt?+(paceTotal/paceCnt).toFixed(1):null;
  const displayTime=studyTimeSec>0?studyTimeSec:timeSec;
  set('mw-stat-metas',doneCnt+'/'+week.metas.length);
  set('mw-stat-done',doneCnt);
  set('mw-stat-rate',rate!==null?rate+'%':'—');
  set('mw-stat-qs',resolvedQs+'/'+totalQs);
  set('mw-stat-time',formatHM(displayTime));
  set('mw-stat-pct',pct+'%');
  setStyle('mw-stat-bar','width',pct+'%');
  const paceEl=document.getElementById('mw-stat-pace');
  if(paceEl){
    paceEl.textContent=avgPace?avgPace+' min/q':'—';
    if(avgPace)paceEl.style.color=avgPace<=2?'var(--green)':avgPace<=3?'var(--gold)':avgPace<=4?'var(--orange)':'var(--red)';
  }
}

// ── WEEK LOG ───────────────────────────────────
function renderMwWeekLog(){
  const list=document.getElementById('mw-week-log');if(!list)return;
  const week=(state.mwWeeks||[])[mwActiveWeek];if(!week){list.innerHTML='<div class="empty">Sem dados.</div>';return;}
  const results=week.metas.map(m=>({meta:m,res:state.mwResults&&state.mwResults[m.id]})).filter(x=>x.res);
  if(!results.length){list.innerHTML='<div class="empty">Nenhum resultado registrado nesta semana.</div>';return;}
  list.innerHTML='';
  results.forEach(({meta,res})=>{
    const rate=Math.round(res.correct/res.resolved*100);
    const rc=rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const timeSec=res.manualTimeSeconds||res.timeSeconds||0;
    const studySec=res.studyTimeSeconds||0;
    const paceStr=mwFormatPace(res.resolved,timeSec);
    const paceColor=mwPaceColor(res.resolved,timeSec);
    // show study time if different from question time
    const timeLabel=studySec&&studySec!==timeSec
      ?`📖 ${formatHM(studySec)} · ⏱ ${formatHM(timeSec)}`
      :timeSec?`⏱ ${formatHM(timeSec)}`:'sem tempo';
