function frSetInterval(mins, btn) {
  frIntervalMins = mins;
  document.querySelectorAll('#fr-interval-chips .est-chip').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  // Show/hide custom input
  const wrap = document.getElementById('fr-custom-wrap');
  if (wrap) wrap.style.display = mins === 0 ? '' : 'none';
  frUpdateDuePreview();
}

function frUpdateDuePreview() {
  const mins = frIntervalMins === 0
    ? (parseInt(document.getElementById('fr-custom-mins')?.value) || 0)
    : frIntervalMins;
  const label = document.getElementById('fr-due-label');
  const time  = document.getElementById('fr-due-time');
  if (!mins) { if(label) label.textContent = '—'; return; }
  const due = new Date(Date.now() + mins * 60000);
  if (label) label.textContent = mins < 60 ? `${mins} minutos` : `${Math.floor(mins/60)}h${(mins%60).toString().padStart(2,'0')}m`;
  if (time)  time.textContent  = due.toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'});
}

async function frPasteLink() {
  try {
    const text = await navigator.clipboard.readText();
    const inp = document.getElementById('fr-link-inp');
    if (inp) inp.value = text.trim();
  } catch(e) {
    flash('Permita acesso à área de transferência ou cole manualmente.', '#f0b429');
