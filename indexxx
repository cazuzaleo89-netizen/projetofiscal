/* ── Image handling ─── */
function resLoadImage(input){
  const file = input.files[0];
  if(!file) return;
  if(file.size > 5*1024*1024){ flash('Imagem muito grande! Máx. 5MB.','#ef4444'); return; }
  const reader = new FileReader();
  reader.onload = e => {
    resImageData = e.target.result;
    document.getElementById('res-img-el').src = resImageData;
    document.getElementById('res-img-preview').style.display='';
    document.getElementById('res-img-drop').style.display='none';
  };
  reader.readAsDataURL(file);
}
function resLoadImageUrl(url){
  if(!url) return;
  document.getElementById('res-img-el').src = url;
  document.getElementById('res-img-preview').style.display='';
  document.getElementById('res-img-drop').style.display='none';
}
function resClearImage(){
  resImageData=null;
  const el=document.getElementById('res-img-el'); if(el)el.src='';
  const prev=document.getElementById('res-img-preview'); if(prev)prev.style.display='none';
  const drop=document.getElementById('res-img-drop'); if(drop)drop.style.display='';
  const inp=document.getElementById('res-img-input'); if(inp)inp.value='';
  const url=document.getElementById('res-img-url'); if(url)url.value='';
}

/* ── Formatting toolbar ─── */
function resFmt(cmd){
  const ed = document.getElementById('res-editor');
  if(!ed) return;
  ed.focus();
  const sel = window.getSelection();
  if(cmd==='h2'||cmd==='h3'){
    document.execCommand('formatBlock',false,cmd);
  } else if(cmd==='ul'){
    document.execCommand('insertUnorderedList',false,null);
  } else if(cmd==='ol'){
    document.execCommand('insertOrderedList',false,null);
  } else if(cmd==='highlight'){
    document.execCommand('backColor',false,'rgba(240,165,0,0.25)');
  } else if(cmd==='code'){
    const text = sel.toString();
    if(text){ document.execCommand('insertHTML',false,`<code>${text}</code>`); }
  } else if(cmd==='blockquote'){
    document.execCommand('formatBlock',false,'blockquote');
  } else {
    document.execCommand(cmd,false,null);
  }
}
function resFmtColor(color){
  document.getElementById('res-editor')?.focus();
  document.execCommand('foreColor',false,color);
}

/* ── Save ─── */
function saveResumo(){
  resEnsure();
  const title = document.getElementById('res-modal-title-inp').value.trim();
  if(!title){ flash('Informe o título!','#f0b429'); return; }
  const discId = document.getElementById('res-modal-disc').value;
  const disc   = state.disciplines.find(d=>d.id===discId);
  const metaId = document.getElementById('res-modal-meta').value;
  let metaName='', metaObj=null;
  if(metaId)(state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ if(m.id===metaId){metaName=m.name;metaObj=m;} }));

  const tags = document.getElementById('res-modal-tags').value
    .split(',').map(t=>t.trim()).filter(Boolean);

  const cp = document.getElementById('res-color-picker');
  const selCol = cp?.querySelector('.cdot.sel')?.dataset.color || disc?.color || RES_COLORS[0];

  const imageUrl = document.getElementById('res-img-url').value.trim();

  const now = new Date();
  const entry = {
    id: resEditingId||uid(),
    title,
    discId: discId||'',
    discName: disc?.name||metaObj?.disc||'',
    discColor: disc?.color||metaObj?.color||selCol,
    metaId: metaId||'',
    metaName,
    type: resType,
    content: resType==='text' ? (document.getElementById('res-editor').innerHTML||'') : '',
    imageData: resType==='image' ? (resImageData||null) : null,
    imageUrl:  resType==='image' ? (imageUrl||null) : null,
    tags,
    color: selCol,
    date: now.toISOString(),
    dateStr: now.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'numeric'}),
  };

  const wasEditing = !!resEditingId;
  if(resEditingId){
    const idx = state.resumos.findIndex(x=>x.id===resEditingId);
    if(idx>=0) state.resumos[idx]={...state.resumos[idx],...entry};
  } else {
    state.resumos.unshift(entry);
  }

  saveState();
  document.getElementById('res-modal').classList.remove('open');
  resEditingId=null; resImageData=null;
  renderResumos();
  flash(wasEditing?'Resumo atualizado! ✓':'Resumo salvo! ✓','#10b981');
}

