function tecCadEnsure(){if(!Array.isArray(state.tecCadernos))state.tecCadernos=[];}

function tecCadRegistrarAuto(data){
  tecCadEnsure();
  const materia=(data.materia||'').trim();
  const assunto=(data.assunto||'').trim();
  if(!materia&&!assunto)return;
  const existing=state.tecCadernos.find(c=>c.materia.toLowerCase()===materia.toLowerCase()&&c.assunto.toLowerCase()===assunto.toLowerCase());
  const now=new Date().toISOString();
  if(existing){
    existing.ultimaVez=now;
    // Atualiza totalQuestoes se o novo valor for maior que zero
    if(data.totalQuestoes>0)existing.totalQuestoes=data.totalQuestoes;
    if(data.caderno&&!existing.caderno)existing.caderno=data.caderno;
    saveState();tecCadRender();return;
  }
  let discId='',discName='';
  if(materia){
    const matLower=materia.toLowerCase().replace(/^dir\.\s*/,'');
    const disc=state.disciplines.find(d=>{const n=d.name.toLowerCase().replace(/^dir\.\s*/,'');return n.includes(matLower)||matLower.includes(n);});
    if(disc){discId=disc.id;discName=disc.name;}
  }
  state.tecCadernos.unshift({id:uid(),caderno:data.caderno||'',materia,discId,discName:discName||materia,assunto,subassuntos:[],totalQuestoes:data.totalQuestoes||0,fonte:'auto',registradoEm:now,ultimaVez:now,sessoes:[]});
  saveState();tecCadRender();tecCadUpdateKpis();
  flash('📋 Assunto registrado: '+(assunto||materia).slice(0,50),'#818cf8',4000);
}

function tecCadModalOpen(){
  tecCadEnsure();
  const sel=document.getElementById('teccad-m-materia');
  if(sel){sel.innerHTML='<option value="">— selecione a disciplina —</option>';state.disciplines.forEach(d=>sel.appendChild(new Option(d.name,d.id)));}
  // Pré-preenche com dados do Monitor TEC (se disponível)
  try{
    const inv=(typeof _cronInv!=='undefined'?_cronInv:null)||{};
    const assInp=document.getElementById('teccad-m-assunto');
    const cadInp=document.getElementById('teccad-m-caderno');
    const totInp=document.getElementById('teccad-m-total');
    if(assInp&&!assInp.value&&inv.assunto)assInp.value=inv.assunto;
    if(cadInp&&!cadInp.value&&inv.caderno)cadInp.value=inv.caderno;
    if(totInp&&!totInp.value&&inv.total>0)totInp.value=inv.total;
    if(sel&&!sel.value&&inv.materia){
      const matLower=inv.materia.toLowerCase().replace(/^dir\.\s*/,'');
      const disc=state.disciplines.find(d=>{const n=d.name.toLowerCase().replace(/^dir\.\s*/,'');return n.includes(matLower)||matLower.includes(n);});
      if(disc)sel.value=disc.id;
    }
  }catch(e){}
  const modal=document.getElementById('teccad-modal');
  if(modal)modal.style.display='flex';
}

function tecCadModalClose(){
  const modal=document.getElementById('teccad-modal');
  if(modal)modal.style.display='none';
  ['teccad-m-assunto','teccad-m-subassuntos','teccad-m-caderno','teccad-m-total'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
}

function tecCadModalSave(){
  tecCadEnsure();
  const discId=(document.getElementById('teccad-m-materia')?.value||'').trim();
  const assunto=(document.getElementById('teccad-m-assunto')?.value||'').trim();
  const subRaw=(document.getElementById('teccad-m-subassuntos')?.value||'').trim();
  const total=parseInt(document.getElementById('teccad-m-total')?.value)||0;
  const caderno=(document.getElementById('teccad-m-caderno')?.value||'').trim();
  if(!assunto){flash('Informe o assunto!','#f0b429');return;}
  const disc=state.disciplines.find(d=>d.id===discId);
  const materia=disc?disc.name:'';
  const subassuntos=subRaw?subRaw.split(',').map(s=>s.trim()).filter(Boolean):[];
  const now=new Date().toISOString();
  const existing=state.tecCadernos.find(c=>c.materia.toLowerCase()===materia.toLowerCase()&&c.assunto.toLowerCase()===assunto.toLowerCase());
  if(existing){
    existing.subassuntos=[...new Set([...existing.subassuntos,...subassuntos])];
    if(total>0)existing.totalQuestoes=total;
    if(caderno)existing.caderno=caderno;
    existing.ultimaVez=now;
    saveState();tecCadRender();tecCadUpdateKpis();tecCadModalClose();
    flash('✅ Assunto atualizado!','#10b981');return;
  }
  state.tecCadernos.unshift({id:uid(),caderno,materia,discId,discName:disc?disc.name:'',assunto,subassuntos,totalQuestoes:total,fonte:'manual',registradoEm:now,ultimaVez:now,sessoes:[]});
  saveState();tecCadRender();tecCadUpdateKpis();tecCadModalClose();
  flash('✅ Assunto cadastrado!','#818cf8');
}

function tecCadDelete(id){
  tecCadEnsure();
  if(!confirm('Remover este assunto?'))return;
  state.tecCadernos=state.tecCadernos.filter(c=>c.id!==id);
  saveState();tecCadRender();tecCadUpdateKpis();
}

function tecCadEditTotal(id){
  tecCadEnsure();
  const c=state.tecCadernos.find(x=>x.id===id);
  if(!c)return;
  const novo=prompt('Total de questoes no caderno TEC:\n'+c.assunto, c.totalQuestoes||'');
  if(novo===null)return;
  c.totalQuestoes=parseInt(novo)||0;
  saveState();tecCadRender();tecCadUpdateKpis();
  flash('Quantidade: '+c.totalQuestoes+' questoes','#818cf8');
}

let _tecCadFilter='';

function tecCadSetFilter(materia,btn){
  _tecCadFilter=materia;
  document.querySelectorAll('.teccad-chip').forEach(b=>{b.style.background='var(--surf3)';b.style.color='var(--muted3)';b.style.borderColor='var(--border2)';});
  if(btn){btn.style.background='rgba(129,140,248,.15)';btn.style.color='var(--purple)';btn.style.borderColor='rgba(129,140,248,.4)';}
  tecCadRender();
}

function tecCadUpdateKpis(){
  tecCadEnsure();
  const list=state.tecCadernos;
  const totalQ=list.reduce((a,c)=>a+(c.totalQuestoes||0),0);
  let totAns=0,totCorr=0;
  list.forEach(c=>{(c.sessoes||[]).forEach(s=>{totAns+=s.total||0;totCorr+=s.correct||0;});});
  const rate=totAns>0?Math.round(totCorr/totAns*100)+'%':'—';
  const kTotal=document.getElementById('teccad-k-total');
  const kQ=document.getElementById('teccad-k-questoes');
  const kRate=document.getElementById('teccad-k-rate');
  if(kTotal)kTotal.textContent=list.length;
  if(kQ)kQ.textContent=totalQ||'—';
  if(kRate)kRate.textContent=rate;
}

function tecCadRender(){
  tecCadEnsure();
  const el=document.getElementById('teccad-list');
  if(!el)return;
  const filterEl=document.getElementById('teccad-filter-chips');
  if(filterEl){
    const materias=[...new Set(state.tecCadernos.map(c=>c.materia).filter(Boolean))];
    filterEl.innerHTML='<button class="teccad-chip" onclick="tecCadSetFilter(\'\',this)" style="font-size:.55rem;padding:2px 9px;border-radius:10px;cursor:pointer;font-family:var(--ff);background:'+(_tecCadFilter===''?'rgba(129,140,248,.15)':'var(--surf3)')+';color:'+(_tecCadFilter===''?'var(--purple)':'var(--muted3)')+';border:1px solid '+(_tecCadFilter===''?'rgba(129,140,248,.4)':'var(--border2)')+';">Todas</button>'+
    materias.map(function(m){return '<button class="teccad-chip" onclick="tecCadSetFilter(\''+m.replace(/'/g,"\\'")+"',this)\" style=\"font-size:.55rem;padding:2px 9px;border-radius:10px;cursor:pointer;font-family:var(--ff);background:"+(_tecCadFilter===m?'rgba(129,140,248,.15)':'var(--surf3)')+';color:'+(_tecCadFilter===m?'var(--purple)':'var(--muted3)')+';border:1px solid '+(_tecCadFilter===m?'rgba(129,140,248,.4)':'var(--border2)')+';">'+m.replace('Dir. ','')+'</button>';}).join('');
  }
  const filtered=_tecCadFilter?state.tecCadernos.filter(function(c){return c.materia===_tecCadFilter;}):state.tecCadernos;
  if(!filtered.length){
    el.innerHTML='<div style="font-size:.72rem;color:var(--muted2);text-align:center;padding:.75rem 0;">Nenhum assunto'+(_tecCadFilter?' para esta matéria':'')+'.<br><span style="font-size:.65rem;color:var(--muted);">Conecte o Monitor ⚡ ou clique em <strong>+ Adicionar</strong>.</span></div>';
    tecCadUpdateKpis();return;
  }
  el.innerHTML=filtered.map(function(c){
    var totAns=0,totCorr=0;
    (c.sessoes||[]).forEach(function(s){totAns+=s.total||0;totCorr+=s.correct||0;});
    var rate=totAns>0?Math.round(totCorr/totAns*100):null;
    var rc=rate===null?'var(--muted2)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    var disc=state.disciplines.find(function(d){return d.id===c.discId;});
    var color=disc?disc.color:'#818cf8';
    var fonteIcon=c.fonte==='auto'?'⚡':'✎';
    var dateStr=c.ultimaVez?new Date(c.ultimaVez).toLocaleDateString('pt-BR'):'—';
    var subHtml=c.subassuntos&&c.subassuntos.length?'<div style="display:flex;flex-wrap:wrap;gap:.25rem;margin-top:.35rem;">'+c.subassuntos.map(function(s){return '<span style="font-size:.55rem;padding:1px 7px;border-radius:10px;background:var(--surf3);border:1px solid var(--border);color:var(--muted2);">'+s+'</span>';}).join('')+'</div>':'';
    var materia=c.materia||'';
    var assunto=c.assunto||'';
    return '<div style="background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.65rem .8rem;transition:border-color .15s;" onmouseenter="this.style.borderColor=\'var(--border2)\'" onmouseleave="this.style.borderColor=\'var(--border)\'">'
      +'<div style="display:flex;align-items:flex-start;gap:.5rem;">'
      +'<div style="width:7px;height:7px;border-radius:50%;background:'+color+';flex-shrink:0;margin-top:4px;box-shadow:0 0 6px '+color+'88;"></div>'
      +'<div style="flex:1;min-width:0;">'
      +'<div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;margin-bottom:.15rem;">'
      +'<span style="font-size:.78rem;font-weight:700;">'+(assunto||'—')+'</span>'
      +'<span style="font-size:.52rem;padding:1px 5px;border-radius:4px;background:'+(c.fonte==='auto'?'rgba(74,108,247,.12)':'rgba(129,140,248,.12)')+';color:'+(c.fonte==='auto'?'var(--cyan)':'var(--purple)')+';border:1px solid '+(c.fonte==='auto'?'rgba(74,108,247,.25)':'rgba(129,140,248,.25)')+';">'+fonteIcon+' '+(c.fonte==='auto'?'Auto':'Manual')+'</span>'
      +'</div>'
      +'<div style="font-size:.6rem;color:var(--muted2);">'+(c.discName||materia||'—')+' · <span style="cursor:pointer;border-bottom:1px dashed var(--muted);" title="Clique para editar quantidade" onclick="tecCadEditTotal(\'' + c.id + '\')">'+( c.totalQuestoes>0?c.totalQuestoes+' questões':'?q ✎')+'</span> · '+dateStr+'</div>'
      +(c.caderno?'<div style="font-size:.58rem;color:var(--muted);margin-top:.15rem;">📚 '+c.caderno.slice(0,55)+'</div>':'')
      +subHtml
      +'</div>'
      +'<div style="display:flex;flex-direction:column;align-items:flex-end;gap:.3rem;flex-shrink:0;">'
      +(rate!==null?'<span style="font-family:var(--mono);font-size:.88rem;font-weight:700;color:'+rc+';">'+rate+'%</span><span style="font-size:.55rem;color:var(--muted2);">'+totCorr+'/'+totAns+'q</span>':'<span style="font-size:.6rem;color:var(--muted2);">sem dados</span>')
      +'<div style="display:flex;gap:.25rem;margin-top:.15rem;">'
      +'<button onclick="tecCadrSearch(\''+materia.replace(/'/g,"\\'")+'\',\''+assunto.replace(/'/g,"\\'")+'\');" title="Buscar no TEC" style="background:none;border:1px solid rgba(34,211,238,.3);border-radius:5px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:#22d3ee;">🔍</button>'
      +'<button onclick="tecCadDelete(\''+c.id+'\')" title="Remover" style="background:none;border:1px solid rgba(248,113,113,.25);border-radius:5px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:var(--red);">✕</button>'
      +'</div>'
      +'</div>'
      +'</div>'
      +'</div>';
  }).join('');
  tecCadUpdateKpis();
}


function filarevInit() {
  frRender();
  cadrRender();
  tecCadrLoadSaved();
  tecCadRender();
  tecCadUpdateKpis();
  frUpdateDuePreview();
  // Populate disc select
  const sel = document.getElementById('fr-disc-sel');
  if (sel) {
    sel.innerHTML = '<option value="">— selecione —</option>';
    state.disciplines.forEach(d => sel.appendChild(new Option(d.name, d.id)));
  }
  // Request notification permission
  if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
  }
  // Live countdown refresh
  clearInterval(frQueueInterval);
  frQueueInterval = setInterval(() => {
