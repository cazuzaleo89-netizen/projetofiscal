// ── STUDY HOURS PREVIEW ────────────────────────
function mwUpdateStudyPreview(){
  const h=parseInt(document.getElementById('mw-study-h').value)||0;
  const m=parseInt(document.getElementById('mw-study-m').value)||0;
  const preview=document.getElementById('mw-study-preview');
  if(!preview)return;
  const total=h*60+m;
  if(total>0){
    const label=h>0&&m>0?`${h}h ${m.toString().padStart(2,'0')}min`:h>0?`${h}h`:`${m}min`;
    preview.textContent=label;preview.style.display='';
  } else {preview.style.display='none';}
}
function mwGetStudySecs(){
  const h=parseInt(document.getElementById('mw-study-h').value)||0;
  const m=parseInt(document.getElementById('mw-study-m').value)||0;
  return h*3600+m*60;
}
function mwGetManualTimeSecs(){
  const h=parseInt(document.getElementById('mw-t-h').value)||0;
  const m=parseInt(document.getElementById('mw-t-m').value)||0;
  const s=parseInt(document.getElementById('mw-t-s').value)||0;
  return h*3600+m*60+s;
}
function mwFormatPace(resolved,timeSecs){
  if(!resolved||!timeSecs)return '—';
  const minPerQ=timeSecs/60/resolved;
  if(minPerQ<1)return `${(60/minPerQ).toFixed(0)} q/h (${minPerQ.toFixed(1)} min/q)`;
  return `${minPerQ.toFixed(1)} min/q`;
}
function mwPaceColor(resolved,timeSecs){
  if(!resolved||!timeSecs)return 'var(--muted)';
  const minPerQ=timeSecs/60/resolved;
  if(minPerQ<=2)return 'var(--green)';
  if(minPerQ<=3)return 'var(--gold)';
  if(minPerQ<=4)return 'var(--orange)';
  return 'var(--red)';
}
function mwCalcPace(){
  const qty=parseInt(document.getElementById('mw-q-total').value)||0;
  const timeSec=mwGetManualTimeSecs();
  const banner=document.getElementById('mw-pace-banner');
  if(!qty||!timeSec){if(banner)banner.style.display='none';return;}
  const minPerQ=timeSec/60/qty;
  const qPerH=(60/minPerQ).toFixed(0);
  const valEl=document.getElementById('mw-pace-value');
  const detEl=document.getElementById('mw-pace-detail');
  const lblEl=document.getElementById('mw-pace-label');
  const markerEl=document.getElementById('mw-pace-marker');
  // format pace value
  if(valEl)valEl.textContent=minPerQ.toFixed(1);
  if(valEl)valEl.style.color=mwPaceColor(qty,timeSec);
  const h=Math.floor(timeSec/3600),m=Math.floor((timeSec%3600)/60),s=timeSec%60;
  const tStr=h?`${h}h${m.toString().padStart(2,'0')}m`:`${m}min${s?` ${s}s`:''}`;
  if(detEl)detEl.textContent=`${qty} questões em ${tStr} · ritmo: ${qPerH} questões/hora`;
  // label
  const rating=minPerQ<=1.5?'🚀 Muito rápido':minPerQ<=2.5?'✅ Bom ritmo':minPerQ<=3.5?'⚡ Ritmo normal':minPerQ<=4.5?'🐢 Ritmo lento':'⚠️ Muito lento';
  if(lblEl)lblEl.textContent=rating;
  if(lblEl)lblEl.style.color=mwPaceColor(qty,timeSec);
  // marker position (1min=far left, 5min=far right, clamp)
  if(markerEl){const pct=Math.min(100,Math.max(0,(minPerQ-1)/4*100));markerEl.style.left=pct+'%';}
  if(banner)banner.style.display='';
}

// ── REGISTER RESULT ────────────────────────────
function mwRegisterResult(){
  if(!mwActiveBlock){flash('Selecione uma meta!','#f0b429');return;}
  const total=parseInt(document.getElementById('mw-q-total').value);
  const correct=parseInt(document.getElementById('mw-q-correct').value);
  const obs=document.getElementById('mw-q-obs').value.trim();
  if(!total||total<1){flash('Informe as questões resolvidas!','#f0b429');return;}
  if(isNaN(correct)||correct<0||correct>total){flash('Acertos inválidos!','#f0b429');return;}

  // Manual question time (for pace calculation)
  const manualSecs=mwGetManualTimeSecs();
  const finalSecs=manualSecs>0?manualSecs:(mwTimer.seconds||0);

  // Study hours (total session time — reading + review + questions)
  const studySecs=mwGetStudySecs();
  // Use study hours for the sessions log (which tracks time studied per discipline)
  // If study hours set, use that; otherwise fall back to question time
  const sessionSecs=studySecs>0?studySecs:finalSecs;

  if(!state.mwResults)state.mwResults={};
  const now=new Date();
  const minPerQ=finalSecs>0?+(finalSecs/60/total).toFixed(2):null;

  state.mwResults[mwActiveBlock.id]={
    resolved:total, correct,
    manualTimeSeconds:finalSecs,
    timeSeconds:finalSecs,
    studyTimeSeconds:studySecs,     // total study session time
    sessionSeconds:sessionSecs,     // what gets added to study log
    minPerQuestion:minPerQ,
    obs,
    date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
    blockName:mwActiveBlock.name, disc:mwActiveBlock.disc,
    totalQ:mwActiveBlock.total, link:mwActiveBlock.link||''
  };

  // Save study session (use study hours if provided, else question time)
  if(sessionSecs>0){
    // Check if a session for this block already exists today and remove it before re-adding
    const today=now.toDateString();
    state.sessions=state.sessions.filter(s=>!(s.subjectId===mwActiveBlock.discId&&s.blockId===mwActiveBlock.id));
    state.sessions.push({
      id:uid(), subjectId:mwActiveBlock.discId, subject:mwActiveBlock.disc,
      seconds:sessionSecs, blockId:mwActiveBlock.id,
      date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
      timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
    });
    updateStreak(now.toDateString());
  }

  // Add to question sessions
  state.questionSessions.push({
    id:uid(), subjectId:mwActiveBlock.discId, subject:mwActiveBlock.disc,
    total, correct, banca:'Tec Concursos',
    obs:mwActiveBlock.name.slice(0,60),
    date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
    timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
  });

  // Clear all fields
  ['mw-q-total','mw-q-correct','mw-q-obs','mw-t-h','mw-t-m','mw-t-s','mw-study-h','mw-study-m'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.value='';
  });
  const pb=document.getElementById('mw-pace-banner');if(pb)pb.style.display='none';
  const sp=document.getElementById('mw-study-preview');if(sp)sp.style.display='none';
  mwTimer.seconds=0;document.getElementById('mw-timer-dig').textContent='00:00:00';

  const rate=Math.round(correct/total*100);
  const paceMsg=minPerQ?` · ${minPerQ.toFixed(1)} min/q`:'';
  const studyMsg=studySecs>0?` · ${formatHM(studySecs)} estudo`:'';
  saveState();renderMwBlocks();renderWeekSelector();renderMwSummary();renderMwWeekLog();
  renderDashMetas(); // refresh dashboard
  flash(`✓ ${correct}/${total} (${rate}%)${paceMsg}${studyMsg}`,'#10b981');
}

function mwClearResult(id){
  if(!confirm('Apagar resultado desta meta?'))return;
  if(state.mwResults)delete state.mwResults[id];
  saveState();renderMwBlocks();renderWeekSelector();renderMwSummary();renderMwWeekLog();
}

