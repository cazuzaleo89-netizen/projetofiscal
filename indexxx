// ═══════════════════════════════════════════════
// REVISÃO ESPAÇADA — SM-2
// ═══════════════════════════════════════════════
// state.srsCards = [{
//   id, metaId, metaName, discId, discName, discColor,
//   rate,             // last accuracy %
//   interval,         // days until next review
//   easeFactor,       // SM-2 ease factor (starts at 2.5)
//   repetitions,      // number of successful reviews
//   nextReview,       // ISO date string
//   lastReview,       // ISO date string
//   history:[{date,grade,interval,rate}]
// }]

let revFilter = 'all';
const SM2_EASE_DEFAULT = 2.5;
const SM2_EASE_MIN = 1.3;

/* ── SM-2 Helpers ──────────────────────────── */
function srsEnsure(){ if(!state.srsCards) state.srsCards=[]; }

// Convert accuracy % to SM-2 grade (0-5)
function srsRateToGrade(rate){
  if(rate >= 90) return 5;
  if(rate >= 80) return 4;
  if(rate >= 70) return 3;
  if(rate >= 60) return 2;
  if(rate >= 50) return 1;
  return 0;
}

// SM-2 algorithm: returns {interval, easeFactor, repetitions}
function sm2Calc(grade, prevInterval, prevEase, prevReps){
  let ease = prevEase || SM2_EASE_DEFAULT;
  let reps = prevReps || 0;
  let interval;

  if(grade >= 3){
    if(reps === 0)       interval = 1;
    else if(reps === 1)  interval = 6;
    else                 interval = Math.round(prevInterval * ease);
    reps++;
  } else {
    reps = 0;
    interval = 1;
  }

  // Update ease factor
  ease = ease + (0.1 - (5 - grade) * (0.08 + (5 - grade) * 0.02));
  if(ease < SM2_EASE_MIN) ease = SM2_EASE_MIN;

  return {interval: Math.max(1, interval), easeFactor: +ease.toFixed(3), repetitions: reps};
}

// Get or create card for a meta
function srsGetOrCreate(meta, rate){
  srsEnsure();
  let card = state.srsCards.find(c=>c.metaId===meta.id);
  if(!card){
    const grade = srsRateToGrade(rate);
    const {interval, easeFactor, repetitions} = sm2Calc(grade, 1, SM2_EASE_DEFAULT, 0);
    const next = new Date();
    next.setDate(next.getDate() + interval);
    card = {
      id: uid(),
      metaId: meta.id,
      metaName: meta.name,
      discId: meta.discId,
      discName: meta.disc,
      discColor: meta.color||'#5a6a8a',
      rate, interval, easeFactor, repetitions,
      nextReview: next.toISOString(),
      lastReview: new Date().toISOString(),
      history: [{date: new Date().toISOString(), grade, interval, rate}]
    };
    state.srsCards.push(card);
  }
  return card;
}

// Auto-sync: when a mwResult is saved, update or create SRS card
function srsAutoSync(){
  srsEnsure();
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{
    const r = state.mwResults&&state.mwResults[m.id];
    if(!r||!r.resolved) return;
    const rate = Math.round(r.correct/r.resolved*100);
    const existing = state.srsCards.find(c=>c.metaId===m.id);
    if(!existing){
      srsGetOrCreate(m, rate);
    } else {
      // Update rate if result changed
      existing.rate = rate;
    }
  }));
}

// Apply a review result (grade 0-5 or label)
function srsApplyReview(cardId, grade){
  srsEnsure();
  const card = state.srsCards.find(c=>c.id===cardId);
  if(!card) return;

  const {interval, easeFactor, repetitions} = sm2Calc(
    grade, card.interval, card.easeFactor, card.repetitions
  );

  const next = new Date();
  next.setDate(next.getDate() + interval);

  card.interval = interval;
  card.easeFactor = easeFactor;
  card.repetitions = repetitions;
  card.lastReview = new Date().toISOString();
  card.nextReview = next.toISOString();
  if(!card.history) card.history = [];
  card.history.push({date:new Date().toISOString(), grade, interval, rate:card.rate});

  saveState();
  renderRevisoes();

  const labels = {0:'Falhou — repetindo em 1 dia',1:'Difícil',2:'Razoável',3:'Bom',4:'Fácil',5:'Muito fácil'};
  const colors = {0:'#ef4444',1:'#fb923c',2:'#f0a500',3:'#38bdf8',4:'#34d399',5:'#34d399'};
  flash(`${card.metaName.slice(0,40)} → próxima revisão em ${interval} dia${interval!==1?'s':''}`, colors[grade]||'#10b981');
}

// Get status of a card relative to today
function srsStatus(card){
  const today = new Date(); today.setHours(0,0,0,0);
  const next = new Date(card.nextReview); next.setHours(0,0,0,0);
  const diff = Math.round((next-today)/(1000*60*60*24));
  if(diff < 0)  return {key:'overdue', label:`${Math.abs(diff)}d atrasada`, days:diff};
  if(diff === 0) return {key:'today',   label:'Hoje',                         days:0};
  if(diff <= 7)  return {key:'week',    label:`em ${diff} dia${diff>1?'s':''}`, days:diff};
  return           {key:'ok',      label:`em ${diff} dias`,              days:diff};
}

// Mastery level based on interval
function srsMastery(card){
  const i = card.interval||1;
  if(i >= 21) return {pct:100, color:'var(--green)',   label:'Dominado'};
  if(i >= 14) return {pct:75,  color:'var(--cyan)',    label:'Bom'};
  if(i >= 6)  return {pct:50,  color:'var(--gold)',    label:'Aprendendo'};
  if(i >= 3)  return {pct:25,  color:'var(--orange)',  label:'Iniciando'};
  return              {pct:10,  color:'var(--red)',     label:'Fraco'};
}

/* ── Init & Render ─────────────────────────── */
function revisaoInit(){
  srsEnsure();
  srsAutoSync();

  // Populate discipline filter
  const df = document.getElementById('rev-disc-filter');
  if(df){
    const prev = df.value;
    df.innerHTML = '<option value="">Todas as disciplinas</option>';
    state.disciplines.forEach(d=>df.appendChild(new Option(d.name,d.id)));
    if(prev) df.value = prev;
  }
  renderRevisoes();
}

function revSetFilter(f, btn){
  revFilter = f;
  document.querySelectorAll('#rev-filter-chips .est-chip').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  renderRevisoes();
}

function renderRevisoes(){
  srsEnsure();
  srsAutoSync();

  const discF = document.getElementById('rev-disc-filter')?.value||'';
  const today = new Date(); today.setHours(0,0,0,0);
  const week7 = new Date(today); week7.setDate(week7.getDate()+7);

  // Compute stats
  let overdue=0, todayC=0, weekC=0, done=0;
  state.srsCards.forEach(card=>{
    if(discF && card.discId!==discF) return;
    const st = srsStatus(card);
    if(st.key==='overdue') overdue++;
    else if(st.key==='today') todayC++;
    else if(st.key==='week') weekC++;
    if(card.interval>=21) done++;
  });
  set('rev-k-overdue', overdue);
  set('rev-k-today', todayC);
  set('rev-k-week', weekC);
  set('rev-k-done', done);

  // Filter & sort cards
  let cards = [...state.srsCards];
  if(discF) cards = cards.filter(c=>c.discId===discF);
  if(revFilter!=='all') cards = cards.filter(c=>srsStatus(c).key===revFilter);

  // Sort: overdue first, then today, then by date
  cards.sort((a,b)=>{
    const sa=srsStatus(a), sb=srsStatus(b);
    const order={overdue:0,today:1,week:2,ok:3};
    if(order[sa.key]!==order[sb.key]) return order[sa.key]-order[sb.key];
    return new Date(a.nextReview)-new Date(b.nextReview);
  });

  // Render list
  const list = document.getElementById('rev-list');
  if(!list) return;

  if(!state.srsCards.length){
    list.innerHTML=`<div class="card"><div class="empty" style="padding:2.5rem;">
      <div style="font-size:2rem;margin-bottom:.75rem;">🔁</div>
      <div style="font-size:.85rem;font-weight:700;margin-bottom:.4rem;">Nenhuma revisão agendada ainda</div>
      <div style="font-size:.72rem;line-height:1.6;">As revisões são criadas automaticamente quando você registra resultados nas <strong>Metas Semanais</strong>.<br>Registre seu desempenho em pelo menos uma meta para começar!</div>
    </div></div>`;
    renderRevCalendar([]); return;
  }

  if(!cards.length){
    list.innerHTML=`<div class="card"><div class="empty">Nenhuma revisão neste filtro. 🎉</div></div>`;
    renderRevCalendar(state.srsCards); return;
  }

  list.innerHTML='';
  cards.forEach(card=>{
    const st = srsStatus(card);
    const mastery = srsMastery(card);
    const rateColor = card.rate>=70?'var(--green)':card.rate>=50?'var(--gold)':'var(--red)';
    const nextDate = new Date(card.nextReview).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
    const lastDate = card.lastReview ? new Date(card.lastReview).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit'}) : '—';

    // Ring calculation (shows interval progress)
    const maxInterval = 30;
    const ringPct = Math.min(card.interval/maxInterval, 1);
    const R = 22, C = 2*Math.PI*R;

    const el = document.createElement('div');
    el.className = `rev-item status-${st.key}`;
    el.innerHTML = `
      <div style="display:flex;align-items:flex-start;gap:.85rem;">
        <!-- Ring -->
        <div class="rev-ring-wrap">
          <svg width="52" height="52" viewBox="0 0 52 52">
            <circle class="rev-ring-bg" cx="26" cy="26" r="${R}"/>
            <circle class="rev-ring-fill" cx="26" cy="26" r="${R}"
              stroke="${mastery.color}"
              stroke-dasharray="${C.toFixed(1)}"
              stroke-dashoffset="${(C*(1-ringPct)).toFixed(1)}"/>
          </svg>
          <div class="rev-ring-label" style="color:${mastery.color};">
            <span style="font-size:.65rem;font-weight:800;">${card.interval}d</span>
            <span style="font-size:.45rem;color:var(--muted2);">intervalo</span>
          </div>
        </div>

        <!-- Content -->
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:.45rem;flex-wrap:wrap;margin-bottom:.3rem;">
            <span class="rev-badge ${st.key}">${st.label}</span>
            <span style="font-size:.55rem;color:${card.discColor};font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">${card.discName.replace('Dir. ','')}</span>
          </div>
          <div style="font-size:.82rem;font-weight:700;margin-bottom:.3rem;line-height:1.3;">${card.metaName.slice(0,75)}${card.metaName.length>75?'…':''}</div>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;font-size:.62rem;color:var(--muted2);">
            <span>Último acerto: <strong style="color:${rateColor};font-family:var(--mono)">${card.rate}%</strong></span>
            <span>Revisões: <strong style="color:var(--text);font-family:var(--mono)">${card.repetitions}</strong></span>
            <span>Estudado: <strong style="color:var(--muted3)">${lastDate}</strong></span>
            <span>Próxima: <strong style="color:var(--${st.key==='overdue'?'red':st.key==='today'?'gold':'cyan'})">${nextDate}</strong></span>
          </div>
          <!-- Mastery bar -->
          <div class="rev-mastery-bar">
            <div class="rev-mastery-fill" style="width:${mastery.pct}%;background:${mastery.color};"></div>
          </div>
          <div style="font-size:.52rem;color:var(--muted2);margin-top:2px;">${mastery.label} · fator ${card.easeFactor?.toFixed(1)||'2.5'}</div>
        </div>
      </div>

      <!-- Review result buttons (show for overdue/today, collapsible for others) -->
      <div class="rev-result-row" ${st.key==='ok'?'style="display:none"':''} id="rev-btns-${card.id}">
        <button class="rev-result-btn r-fail" onclick="srsApplyReview('${card.id}',0)">😵 Falhou</button>
        <button class="rev-result-btn r-hard" onclick="srsApplyReview('${card.id}',1)">😓 Difícil</button>
        <button class="rev-result-btn r-ok"   onclick="srsApplyReview('${card.id}',2)">😐 Razoável</button>
        <button class="rev-result-btn r-good" onclick="srsApplyReview('${card.id}',3)">😊 Bom</button>
        <button class="rev-result-btn r-easy" onclick="srsApplyReview('${card.id}',4)">🚀 Fácil</button>
      </div>
      ${st.key==='ok'?`<div style="margin-top:.5rem;"><button onclick="toggleRevBtns('${card.id}')" style="background:none;border:1px solid var(--border);border-radius:7px;padding:.22rem .65rem;font-size:.62rem;color:var(--muted2);cursor:pointer;transition:all .15s;" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted2)'">▾ Revisar agora mesmo</button></div>`:''}`;

    list.appendChild(el);
  });

  renderRevCalendar(state.srsCards.filter(c=>!discF||c.discId===discF));
}

function toggleRevBtns(cardId){
  const row = document.getElementById('rev-btns-'+cardId);
  if(!row) return;
  row.style.display = row.style.display==='none'?'flex':'none';
}

function renderRevCalendar(cards){
  const el = document.getElementById('rev-calendar');
  if(!el) return;
  if(!cards.length){el.innerHTML='<div style="font-size:.72rem;color:var(--muted2);text-align:center;padding:.75rem;">Nenhuma revisão agendada.</div>';return;}

  // Group by date, next 14 days
  const today = new Date(); today.setHours(0,0,0,0);
  const groups = {};
  cards.forEach(card=>{
    const d = new Date(card.nextReview); d.setHours(0,0,0,0);
    const diff = Math.round((d-today)/(1000*60*60*24));
    if(diff > 14 || diff < -30) return;
    const key = d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
    const label = diff < 0 ? `${key} (atrasada)` : diff===0 ? `${key} (hoje)` : key;
    if(!groups[label]) groups[label]={cards:[],diff};
    groups[label].cards.push(card);
  });

  const sorted = Object.entries(groups).sort((a,b)=>a[1].diff-b[1].diff).slice(0,10);
