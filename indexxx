function sqCheckQueue() {
  if(!sqSession) return;
  const now = Date.now();

  // Find newly due items (just became ready this tick)
  const newlyDue = sqSession.reviewQueue.filter(item => {
    const q = sqSession.questions[item.num - 1];
    return q && q.status === 'wrong' && item.dueAt <= now;
  });

  if(newlyDue.length > 0) {
    const nums = newlyDue.map(i=>`Q${i.num}`).join(', ');

    // 1. Visual alert panel
    const alertEl   = document.getElementById('sq-review-alert');
    const alertText = document.getElementById('sq-review-alert-text');
    if(alertEl) alertEl.style.display = '';
    if(alertText) alertText.textContent = `${nums} ${newlyDue.length>1?'estão prontas':'está pronta'} para revisão`;

    // 2. Mark cells as review_pending
    newlyDue.forEach(item => {
      const q = sqSession.questions[item.num - 1];
      if(q && q.status === 'wrong') { q.status = 'review_pending'; sqUpdateCell(q); }
    });

    // 3. Sound alert
    sqPlayAlertSound();

    // 4. Browser notification (if tab not focused)
    if(document.hidden || !document.hasFocus()) {
      sqBrowserNotify(nums);
      sqFlashTitle(nums);
    }

    // 5. Screen flash pulse
    sqPulseAlert(nums);

    // 6. Flash message in UI
    flash(`🔄 Revisão disponível: ${nums}`, '#f0a500');

    // 7. Scroll review alert into view if off-screen
    if(alertEl) alertEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  sqRenderQueue();
}


function sqRenderQueue() {
  if(!sqSession) return;
  const list = document.getElementById('sq-queue-list');
  const empty = document.getElementById('sq-queue-empty');
  const count = document.getElementById('sq-queue-count');
  const now = Date.now();
  const queue = sqSession.reviewQueue.filter(item => {
    const q = sqSession.questions[item.num-1];
    return q && (q.status==='wrong'||q.status==='review_pending');
  });
  if(count) count.textContent = `(${queue.length})`;
  if(!queue.length) {
    if(list) list.innerHTML='';
    if(empty) empty.style.display='';
    return;
  }
  if(empty) empty.style.display='none';
  if(!list) return;
  list.innerHTML = queue.map(item => {
    const q = sqSession.questions[item.num-1];
    const msLeft = item.dueAt - now;
    const isReady = msLeft <= 0;
    const secLeft = Math.ceil(msLeft/1000);
    const minLeft = Math.floor(secLeft/60);
    const timeStr = isReady ? '⏰ Pronta!' : `${minLeft}m${(secLeft%60).toString().padStart(2,'0')}s`;
    return `<div class="sq-queue-item${isReady?' ready':''}">
      <div style="width:28px;height:28px;border-radius:7px;background:${isReady?'rgba(240,165,0,.15)':'var(--surf3)'};
        border:1px solid ${isReady?'rgba(240,165,0,.4)':'var(--border)'};
        display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:.65rem;font-weight:700;
        color:${isReady?'var(--gold)':'var(--muted2)'};flex-shrink:0;">Q${item.num}</div>
      <div style="flex:1;font-size:.7rem;color:${isReady?'var(--gold)':'var(--muted2)'};">${isReady?'Pronta para revisão':'Aguardando intervalo'}</div>
      <div class="sq-queue-timer${isReady?' urgent':''}">${timeStr}</div>
      ${isReady?`<button class="btn btn-ghost" style="font-size:.6rem;padding:.2rem .5rem;" onclick="sqReviewQuestion(${item.num})">Revisar</button>`:''}
    </div>`;
  }).join('');
}

function sqStartReview() {
  // Jump to first ready review question
  if(!sqSession) return;
  const now = Date.now();
  const ready = sqSession.reviewQueue.find(item => {
    const q = sqSession.questions[item.num-1];
    return q && q.status==='review_pending' && item.dueAt<=now;
  });
  if(!ready) return;
  sqReviewQuestion(ready.num);
  document.getElementById('sq-review-alert').style.display = 'none';
}

function sqReviewQuestion(num) {
  if(!sqSession) return;
  const q = sqSession.questions[num-1];
  if(!q) return;
  sqSession.currentIdx = num-1;
  q.status = 'pending'; // temporarily pending for answer
  q.answeredAt = null;
  sqUpdateCurrentIndicator();
  // Override sqMark to handle review marking
  sqSession._reviewing = num;
  flash(`Revise a Questão ${num}!`,'#f0a500');
}

