  whEnsure();
  const all=Object.values(state.wrongHistory);
  const matMap={};
  all.forEach(q=>{
    const m=q.materia||'Sem matéria';
    if(!matMap[m])matMap[m]={erros:0,questoes:0,reinc:0};
    matMap[m].questoes++;
    matMap[m].erros+=q.erros;
    if(q.erros>=2)matMap[m].reinc++;
  });
  const entries=Object.entries(matMap).sort((a,b)=>b[1].erros-a[1].erros);
  if(!entries.length){el.innerHTML='<div style="font-size:.65rem;color:var(--muted2);">Nenhum dado ainda.</div>';return;}
  const maxErros=Math.max(...entries.map(e=>e[1].erros),1);
  el.innerHTML=entries.map(([m,d])=>{
    const pct=Math.round(d.erros/maxErros*100);
    const disc=state.disciplines.find(x=>x.name.toLowerCase().includes(m.toLowerCase().replace(/^dir\.\s*/,'').split(' ')[0]));
    const color=disc?disc.color:'#ef4444';
