let tecSession = {
  active: false,
  paused: false,
  meta: null,
  startTime: null,
  seconds: 0,
  interval: null,
  tabRef: null,
  qCorrect: 0,
  qWrong: 0,
};

// Launch: select meta, auto-start timer, open Tec Concursos
// Global map of all metas for safe ID-based lookup
const _tecMetaMap = {};
function tecRegisterMetas(){
  _tecMetaMap.__clear = true;
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ _tecMetaMap[m.id]=m; }));
}
function tecLaunchById(id){
  const meta = _tecMetaMap[id];
  if(!meta){ flash('Meta não encontrada. Recarregue a página.','#ef4444'); return; }
  if(!meta.link){ flash('Esta meta não tem link do Tec Concursos.','#f0b429'); return; }
  tecLaunch(meta);
}
function tecLaunch(meta){
  // Select the meta in the panel
  selectMwBlock(meta);

  // Start the mw chrono timer automatically
  if(!mwTimer.running){
    mwSwitchMode('chrono');
    setTimeout(()=>{
      const sb=document.getElementById('mw-btn-start');
      if(sb&&!sb.disabled) mwStartTimer();
    }, 80);
  }

  // Track our own session for the return banner
  tecSession.active = true;
  tecSession.meta = meta;
  tecSession.startTime = Date.now();
  tecSession.seconds = 0;
  clearInterval(tecSession.interval);
  tecSession.interval = setInterval(tecTick, 1000);

  // Open Tec Concursos in new tab
  tecSession.tabRef = window.open(meta.link, '_blank');

  // Show studying pill in topbar
  const pill = document.getElementById('tec-studying-pill');
  if(pill) pill.classList.add('visible');

  // Update btn appearance
  updateTecBtnState(meta.id, true);

  // Listen for when user comes back to this tab
  document.addEventListener('visibilitychange', tecOnReturn, {once: false});
  window.addEventListener('focus', tecOnFocus, {once: false});

  flash(`▶ Abrindo Tec Concursos — cronômetro iniciado!`, '#10b981');
}

function tecTick(){
  if(!tecSession.active || tecSession.paused) return;
  tecSession.seconds++;
  const t = document.getElementById('tec-pill-time');
  if(t) t.textContent = formatTime(tecSession.seconds);
  const rb = document.getElementById('tec-rb-timer');
  if(rb) rb.textContent = formatTime(tecSession.seconds);
}

function tecTogglePause(){
  if(!tecSession.active) return;
  tecSession.paused = !tecSession.paused;

  if(tecSession.paused){
    // Pause the mwTimer too
    if(mwTimer.running && !mwTimer.paused) mwPauseTimer();
    // Pause mwCd too if running
    if(mwCd.running && !mwCd.paused) mwCdPause();
  } else {
    // Resume
    if(mwTimer.running && mwTimer.paused) mwResumeTimer();
    if(mwCd.running && mwCd.paused) mwCdResume();
  }

  tecUpdatePauseUI();
}

function tecUpdatePauseUI(){
  const paused = tecSession.paused;

  // Topbar pill
  const pip = document.getElementById('tec-pill-pip');
  const pauseBtn = document.getElementById('tec-pill-pause-btn');
  if(pip) pip.style.background = paused ? 'var(--gold)' : 'var(--green)';
  if(pip) pip.style.boxShadow  = paused ? '0 0 6px var(--gold)' : '0 0 6px var(--green)';
  if(pauseBtn){ pauseBtn.textContent = paused ? '▶' : '⏸'; pauseBtn.style.color = paused ? 'var(--gold)' : 'var(--green)'; }

  // Banner dot and label
  const dot = document.getElementById('tec-rb-dot');
  const lbl = document.getElementById('tec-rb-status-label');
  const bannerBtn = document.getElementById('tec-rb-pause-btn');
  if(dot){ dot.style.background = paused ? 'var(--gold)' : 'var(--green)'; dot.style.boxShadow = paused ? '0 0 6px var(--gold)' : '0 0 6px var(--green)'; }
  if(lbl) lbl.textContent = paused ? '⏸ Pausado' : 'Sessão em andamento';
  if(bannerBtn){ bannerBtn.textContent = paused ? '▶ Retomar' : '⏸ Pausar'; bannerBtn.className = paused ? 'btn btn-green' : 'btn btn-amber'; }

  // Timer display color
  const timer = document.getElementById('tec-rb-timer');
  if(timer) timer.style.color = paused ? 'var(--gold)' : 'var(--green)';
}

// Show return banner when user comes back
let tecReturnShown = false;
function tecOnReturn(){
  if(!tecSession.active || tecReturnShown) return;
  if(document.visibilityState === 'visible') showReturnBanner();
}
function tecOnFocus(){
  if(!tecSession.active || tecReturnShown) return;
  setTimeout(()=>{ if(document.hasFocus()) showReturnBanner(); }, 400);
}

function showReturnBanner(){
  if(!tecSession.active) return;
  tecReturnShown = true;
  const banner = document.getElementById('tec-return-banner');
  const nameEl = document.getElementById('tec-rb-meta-name');
  if(banner) banner.style.display = '';
  if(nameEl && tecSession.meta) nameEl.textContent = `${tecSession.meta.disc} — ${tecSession.meta.name.slice(0,80)}`;
  // Pre-fill questões from meta goal
  const tot = document.getElementById('tec-rb-total');
  if(tot && tecSession.meta?.goal && !tot.value) tot.value = tecSession.meta.goal;
}

function hideTecBanner(){
  const banner = document.getElementById('tec-return-banner');
  if(banner) banner.style.display = 'none';
}

function tecReopenTab(){
  if(tecSession.tabRef && !tecSession.tabRef.closed){
    tecSession.tabRef.focus();
  } else if(tecSession.meta?.link){
    tecSession.tabRef = window.open(tecSession.meta.link, '_blank');
  }
  hideTecBanner();
  tecReturnShown = false;
}

function tecFinishSession(){
  const total   = parseInt(document.getElementById('tec-rb-total').value);
  const correct = parseInt(document.getElementById('tec-rb-correct').value);

  if(!total || total < 1){ flash('Informe as questões resolvidas!', '#f0b429'); return; }
  if(isNaN(correct) || correct < 0 || correct > total){ flash('Acertos inválidos!', '#f0b429'); return; }

  // Stop the mw timer (which saves the session)
  if(mwTimer.running) mwStopTimer();

  // Fill register form and save
  const tot = document.getElementById('mw-q-total');
  const cor = document.getElementById('mw-q-correct');
  if(tot) tot.value = total;
  if(cor) cor.value = correct;

  // Set study hours from tecSession time
  const s = tecSession.seconds;
  const shEl = document.getElementById('mw-study-h');
  const smEl = document.getElementById('mw-study-m');
  if(shEl) shEl.value = Math.floor(s/3600)||0;
  if(smEl) smEl.value = Math.floor((s%3600)/60)||0;
  mwUpdateStudyPreview();

  // Auto-register
  mwRegisterResult();

  // Cleanup
  tecCleanup();
  flash(`✔ Sessão concluída! ${correct}/${total} (${Math.round(correct/total*100)}%)`, '#10b981');
}

function tecCancelSession(){
  if(!confirm('Cancelar esta sessão? O tempo não será salvo.')) return;
  if(mwTimer.running){ clearInterval(mwTimer.interval); mwTimer={running:false,paused:false,seconds:0,interval:null}; document.getElementById('mw-timer-dig').textContent='00:00:00'; updateMwTimerUI(); }
  tecCleanup();
  flash('Sessão cancelada.', '#ef4444');
}

function tecCleanup(){
  clearInterval(tecSession.interval);
  const pill = document.getElementById('tec-studying-pill');
  if(pill) pill.classList.remove('visible');
  if(tecSession.meta) updateTecBtnState(tecSession.meta.id, false);
  document.removeEventListener('visibilitychange', tecOnReturn);
  window.removeEventListener('focus', tecOnFocus);
  // Reset pill pip color
  const pip = document.getElementById('tec-pill-pip');
  if(pip){ pip.style.background='var(--green)'; pip.style.boxShadow='0 0 6px var(--green)'; }
  const pauseBtn = document.getElementById('tec-pill-pause-btn');
  if(pauseBtn){ pauseBtn.textContent='⏸'; pauseBtn.style.color='var(--green)'; }
  tecSession = {active:false,paused:false,meta:null,startTime:null,seconds:0,interval:null,tabRef:null,qCorrect:0,qWrong:0};
  tecReturnShown = false;
  const qc = document.getElementById('tec-pill-qcount');
  if(qc){ qc.style.display='none'; qc.textContent=''; }
  hideTecBanner();
}

function tecKeyQ(type){
  if(!tecSession.active || tecSession.paused) return;
  if(type==='correct') tecSession.qCorrect++;
  else tecSession.qWrong++;
  tecUpdateQCount();
  // Brief flash feedback
  const pill = document.getElementById('tec-studying-pill');
  if(pill){ pill.style.boxShadow = type==='correct' ? '0 0 12px rgba(52,211,153,.6)' : '0 0 12px rgba(248,113,113,.5)'; setTimeout(()=>{ if(pill) pill.style.boxShadow=''; }, 300); }
}

function tecUpdateQCount(){
  const c = tecSession.qCorrect, w = tecSession.qWrong, tot = c + w;
  const el = document.getElementById('tec-pill-qcount');
  if(el){
    if(tot > 0){
      el.style.display = '';
      const pct = tot > 0 ? Math.round(c/tot*100) : 0;
      el.innerHTML = `<span style="color:var(--green)">✓${c}</span> <span style="color:var(--red)">✗${w}</span> <span style="color:var(--muted3)">${pct}%</span>`;
    } else {
      el.style.display = 'none';
    }
  }
  // Sync banner kb counter
  const kbPanel = document.getElementById('tec-rb-kbcount');
  const kbC = document.getElementById('tec-kb-correct');
  const kbW = document.getElementById('tec-kb-wrong');
  if(kbC) kbC.textContent = c;
  if(kbW) kbW.textContent = w;
  if(kbPanel) kbPanel.style.display = tot > 0 ? 'flex' : 'none';
  // Pre-fill return banner inputs
  const totInp = document.getElementById('tec-rb-total');
  const corInp = document.getElementById('tec-rb-correct');
  if(totInp && tot > 0) totInp.value = tot;
  if(corInp && tot > 0) corInp.value = c;
  tecUpdateRbRate();
}

function tecUpdateRbRate(){
  const tot = parseInt(document.getElementById('tec-rb-total')?.value);
  const cor = parseInt(document.getElementById('tec-rb-correct')?.value);
  const el = document.getElementById('tec-rb-rate-preview');
  if(!el) return;
  if(tot > 0 && !isNaN(cor) && cor >= 0 && cor <= tot){
    const pct = Math.round(cor/tot*100);
    el.style.display = '';
    el.style.color = pct >= 70 ? 'var(--green)' : pct >= 50 ? 'var(--gold)' : 'var(--red)';
    el.textContent = `${pct}% de acerto · ${cor} de ${tot} questões`;
  } else {
    el.style.display = 'none';
  }
}

function updateTecBtnState(id, running){
  const btn = document.getElementById('tec-btn-'+id);
  if(!btn) return;
  // get disc color from current button background
  const currentBg = btn.style.background || btn.style.backgroundColor || '#38bdf8';
  if(running){
    btn.classList.add('running');
    btn.textContent = '⏱ Estudando…';
    btn.style.opacity = '1';
    btn.onclick = (e)=>{ e.stopPropagation(); showReturnBanner(); };
  } else {
    btn.classList.remove('running');
    btn.textContent = '▶ Estudar Agora';
    btn.style.opacity = '1';
  }
}

