/* ── Meta select handler ───────────────────────── */
function sqOnMetaSelect() {
  const metaId = document.getElementById('sq-tec-meta-sel').value;
  const preview = document.getElementById('sq-tec-meta-preview');
  const startBtn = document.getElementById('sq-tec-start-btn');
  const openBtn  = document.getElementById('sq-tec-open-btn');

  if(!metaId) {
    if(preview) preview.style.display='none';
    if(startBtn) startBtn.disabled=true;
    if(openBtn)  openBtn.disabled=true;
    return;
  }

  let meta = null;
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ if(m.id===metaId) meta=m; }));
  if(!meta) return;

  const d = state.disciplines.find(x=>x.id===meta.discId);
  const color = meta.color||d?.color||'#22d3ee';
  const estMin = meta.goal&&meta.discId ? Math.round(meta.goal*getSpeed(meta.discId)) : 0;
  const estStr = estMin>=60 ? `~${Math.floor(estMin/60)}h${(estMin%60).toString().padStart(2,'0')}m` : estMin>0 ? `~${estMin}min` : null;

  if(preview) {
    preview.style.display='';
    const dot = document.getElementById('sq-prev-dot');
    if(dot) dot.style.background = color;
    set('sq-prev-name', meta.name);
    const discChip = document.getElementById('sq-prev-disc');
    if(discChip){ discChip.textContent=meta.disc; discChip.style.color=color; discChip.style.borderColor=color+'44'; discChip.style.background=color+'12'; }
    set('sq-prev-total', meta.total ? `📋 ${meta.total} no banco` : '');
    set('sq-prev-goal',  meta.goal  ? `🎯 Meta: ${meta.goal}q` : '');
    set('sq-prev-est',   estStr ? `⏱ ${estStr}` : '');
  }
  if(startBtn) startBtn.disabled=false;
  if(openBtn)  openBtn.disabled=false;
}

/* ── Tec disc-first handlers ───────────────────── */
function sqTecOnDiscChange() {
  const discId = document.getElementById('sq-tec-disc-sel')?.value;
  const disc   = state.disciplines.find(d => d.id === discId);
  const info   = document.getElementById('sq-tec-disc-info');
  const openBtn  = document.getElementById('sq-tec-open-btn');
  const startBtn = document.getElementById('sq-tec-start-btn');

  if(!discId || !disc) {
    if(info) info.style.display = 'none';
    if(openBtn)  openBtn.disabled = true;
    if(startBtn) startBtn.disabled = true;
    return;
  }

  if(info) info.style.display = '';

  // Disc dot + name
  const dot      = document.getElementById('sq-tec-disc-dot');
  const nameLbl  = document.getElementById('sq-tec-disc-name-lbl');
  const statsLbl = document.getElementById('sq-tec-disc-stats-lbl');
  if(dot)     dot.style.background = disc.color || '#22d3ee';
  if(nameLbl) nameLbl.textContent  = disc.name;

  // Mini stats for this disc
  const sessions = (state.questionSessions||[]).filter(s => s.subjectId === discId);
  const tot = sessions.reduce((a,s) => a+(s.total||0), 0);
  const cor = sessions.reduce((a,s) => a+(s.correct||0), 0);
  if(statsLbl) statsLbl.textContent = tot > 0
    ? `${tot} questões · ${Math.round(cor/tot*100)}% acerto`
    : 'sem histórico';

  // Load saved caderno link
  const linkInp = document.getElementById('sq-tec-link-inp');
  const hint    = document.getElementById('sq-tec-link-saved-hint');
  if(linkInp) linkInp.value = disc.caderno || '';
  if(hint)    hint.style.display = disc.caderno ? '' : 'none';

  // Enable buttons if link exists
  const hasLink = !!(disc.caderno);
  if(openBtn)  { openBtn.disabled = !hasLink; }
  if(startBtn) { startBtn.disabled = !hasLink; }

  // Populate optional meta selector for this discipline
  const metaRow = document.getElementById('sq-tec-meta-row');
  const metaSel = document.getElementById('sq-tec-meta-sel');
  if(metaSel) {
    metaSel.innerHTML = '<option value="">— nenhuma —</option>';
    (state.mwWeeks||[]).forEach(w => w.metas.forEach(m => {
      if(m.discId === discId)
        metaSel.appendChild(new Option(m.name.slice(0,50), m.id));
    }));
    if(metaRow) metaRow.style.display = metaSel.options.length > 1 ? '' : 'none';
  }
  document.getElementById('sq-tec-meta-preview').style.display = 'none';
}

function sqTecOnLinkChange() {
