          <!-- 1. Discipline selector -->
          <div class="frow">
            <label class="flabel">Disciplina</label>
            <select class="inp" id="sq-tec-disc-sel" style="font-size:.8rem;" onchange="sqTecOnDiscChange()">
              <option value="">— selecione a disciplina —</option>
            </select>
          </div>

          <!-- 2. Disc info + link (revealed after disc selection) -->
          <div id="sq-tec-disc-info" style="display:none;">

            <!-- Disc header / stats pill -->
            <div style="display:flex;align-items:center;gap:.6rem;background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.55rem .75rem;margin-bottom:.75rem;flex-wrap:wrap;">
              <div id="sq-tec-disc-dot" style="width:9px;height:9px;border-radius:50%;flex-shrink:0;"></div>
              <span style="font-size:.8rem;font-weight:700;" id="sq-tec-disc-name-lbl">—</span>
              <span style="font-family:var(--mono);font-size:.6rem;color:var(--muted2);margin-left:auto;" id="sq-tec-disc-stats-lbl">—</span>
