function wrongHistoryRender(){
  whEnsure();
  const el = document.getElementById('wh-list');
  if(!el) return;

  const all = Object.values(state.wrongHistory);

  // Filter
  const filter = document.getElementById('wh-filter-sel')?.value || 'all';
  let filtered = filter === 'reinc' ? all.filter(q=>q.erros>=2)
               : filter === 'once'  ? all.filter(q=>q.erros===1)
               : all;

  // Text search
  const search = (document.getElementById('wh-search-inp')?.value || '').trim().toLowerCase();
  if(search) filtered = filtered.filter(q=>
    (q.desc||'').toLowerCase().includes(search) ||
    (q.materia||'').toLowerCase().includes(search) ||
    (q.assunto||'').toLowerCase().includes(search) ||
    (q.qid||'').includes(search)
  );

  // Sort
  const sort = document.getElementById('wh-sort-sel')?.value || 'prioridade';
  const _priScore = q => {
    // Prioridade = (erros × peso_edital) / dias_desde_ultimo + penalidade_taxa_TEC
    const daysAgo = q.lastErro ? (Date.now()-new Date(q.lastErro))/(86400000) : 999;
    const freshness = Math.max(1, 30 - daysAgo); // mais recente = maior urgência
    const disc = state.disciplines.find(d=>d.name.toLowerCase().includes((q.materia||'').toLowerCase().replace(/^dir\.\s*/,'').split(' ')[0]));
    const edW = disc&&state.edital&&state.edital.weights ? (state.edital.weights[disc.id]||1) : 1;
    const tecPenalty = q.myTotal>0 ? Math.max(0,(0.7-(q.myTotal-q.erros)/q.myTotal)*10) : 5;
    return q.erros * 10 + freshness * 2 + edW * 0.5 + tecPenalty;
  };
  filtered.sort((a,b)=>{
    if(sort==='prioridade') return _priScore(b) - _priScore(a);
    if(sort==='recent') return (b.lastErro||'').localeCompare(a.lastErro||'');
    if(sort==='materia') return (a.materia||'').localeCompare(b.materia||'');
    if(sort==='tec'){
      const ra = a.myTotal>0 ? (a.myTotal-a.erros)/a.myTotal : 1;
      const rb = b.myTotal>0 ? (b.myTotal-b.erros)/b.myTotal : 1;
      return ra - rb; // piores acertos primeiro
    }
    return b.erros - a.erros; // default: mais erros
  });

  // Count label
  const lbl = document.getElementById('wh-count-label');
  if(lbl) lbl.textContent = filtered.length + ' questão' + (filtered.length!==1?'s':'') + (search?' encontrada':'');

  if(!filtered.length){
    el.innerHTML = `<div style="font-size:.72rem;color:var(--muted2);text-align:center;padding:1.5rem 0;">
      ${search ? `🔍 Nenhuma questão encontrada para "<strong>${search}</strong>".` :
      `Nenhum erro registrado ainda.<br><span style="font-size:.65rem;color:var(--muted);">O Monitor ⚡ captura automaticamente quando você errar no TEC.</span>`}
    </div>`;
    return;
  }

  el.innerHTML = filtered.map(q=>{
    const isReinc = q.erros >= 2;
    const disc = state.disciplines.find(d=>d.name.toLowerCase().includes((q.materia||'').toLowerCase().replace(/^dir\.\s*/,'').split(' ')[0]));
    const color = disc ? disc.color : '#ef4444';
    const lastDate = q.lastErro ? new Date(q.lastErro).toLocaleDateString('pt-BR') : '—';
    const alreadyInFila = (state.filaRevisao||[]).some(f=>(f.link===q.url||f.qid===q.qid) && f.status!=='done');

    // TEC accuracy badge
    const tecAcerto = q.myTotal>0 ? Math.round((q.myTotal - (q.myErrors||q.erros)) / q.myTotal * 100) : null;
    const tecBadge = q.myTotal>0
      ? `<span style="font-size:.52rem;padding:1px 6px;border-radius:8px;background:${tecAcerto>=70?'rgba(16,185,129,.12)':'rgba(239,68,68,.1)'};color:${tecAcerto>=70?'var(--green)':'#f87171'};border:1px solid ${tecAcerto>=70?'rgba(16,185,129,.25)':'rgba(239,68,68,.2)'};">TEC ${tecAcerto}% (${q.myTotal}q)</span>`
      : '';

    const sevIcon = q.erros>=5?'💀':q.erros>=3?'🔴':q.erros>=2?'⚠️':'📋';
    const sevColor = q.erros>=5?'#ef4444':q.erros>=3?'#f97316':q.erros>=2?'#f59e0b':'var(--muted3)';

