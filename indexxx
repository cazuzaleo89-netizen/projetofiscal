function impEditorUpdateTopic(idx, val){
  const d = impEditorData?.disciplinas[impEditorActiveDiscIdx];
  if(!d) return;
  const realTopics = d.topicos.filter(t=>!t.trim().startsWith('//'));
  // find actual position in d.topicos
  let count=0;
  for(let i=0;i<d.topicos.length;i++){
    if(!d.topicos[i].trim().startsWith('//')){
      if(count===idx){ d.topicos[i]=val; return; }
      count++;
    }
  }
}

function impEditorRemoveTopic(idx){
  const d = impEditorData?.disciplinas[impEditorActiveDiscIdx];
  if(!d) return;
  let count=0, removeAt=-1;
  for(let i=0;i<d.topicos.length;i++){
    if(!d.topicos[i].trim().startsWith('//')){
      if(count===idx){ removeAt=i; break; }
      count++;
    }
  }
  if(removeAt>=0) d.topicos.splice(removeAt,1);
  impEditorRenderTopics();
}

function impEditorAddTopic(){
  const d = impEditorData?.disciplinas[impEditorActiveDiscIdx];
  if(!d) return;
  d.topicos.push('Novo tópico — clique para editar');
  impEditorRenderTopics();
  // Focus last input
  setTimeout(()=>{
    const inputs = document.querySelectorAll('#imp-ed-topics input');
    if(inputs.length) inputs[inputs.length-1].focus();
  },50);
}

function impEditorPasteTopics(){
  const area = document.getElementById('imp-paste-area');
  if(area) area.style.display = area.style.display?'':'block';
  document.getElementById('imp-paste-txt').focus();
}

function impEditorConfirmPaste(){
  const txt = document.getElementById('imp-paste-txt').value.trim();
  if(!txt) return;
  const d = impEditorData?.disciplinas[impEditorActiveDiscIdx];
  if(!d) return;
  const newTopics = txt.split('\n')
    .map(l=>l.replace(/^\d+[\.\)\-]\s*/,'').trim())
    .filter(l=>l.length>2);
  d.topicos.push(...newTopics);
  document.getElementById('imp-paste-txt').value='';
  document.getElementById('imp-paste-area').style.display='none';
  impEditorRenderTopics();
  flash(`${newTopics.length} tópicos adicionados!`,'#10b981');
}

function impEditorAddDisc(){
  if(!impEditorData) return;
  const COLORS=['#22d3ee','#8b5cf6','#10b981','#38bdf8','#ec4899','#f59e0b','#a78bfa','#34d399'];
  const newDisc = {
    nome:'Nova Disciplina',
    cor:COLORS[impEditorData.disciplinas.length%COLORS.length],
    peso:0, weeklyGoal:10,
    topicos:['Tópico 1','Tópico 2']
  };
  impEditorData.disciplinas.push(newDisc);
  impEditorRenderTabs();
  impEditorSelectDisc(impEditorData.disciplinas.length-1);
}

function impEditorSaveAll(){
  if(!impEditorKey||!impEditorData) return;
  // Save field values for active disc
  const d = impEditorData.disciplinas[impEditorActiveDiscIdx];
  if(d){
    d.nome = document.getElementById('imp-ed-name').value.trim()||d.nome;
    d.peso = parseFloat(document.getElementById('imp-ed-peso').value)||0;
    d.weeklyGoal = parseInt(document.getElementById('imp-ed-goal').value)||10;
  }
  // Write back to IMP_TEMPLATES (runtime only — won't persist after reload)
  IMP_TEMPLATES[impEditorKey] = impEditorData;
  // Also update state.edital.topicos
  editalEnsure();
  if(!state.edital.topicos) state.edital.topicos={};
  impEditorData.disciplinas.forEach(disc=>{
    const existing = state.disciplines.find(x=>
      x.name.toLowerCase().includes(disc.nome.toLowerCase().split(' ').slice(-1)[0].toLowerCase())
    );
    if(existing){
      state.edital.topicos[existing.id] = disc.topicos.filter(t=>!t.trim().startsWith('//'));
      state.edital.weights[existing.id] = disc.peso;
    }
  });
  saveState();
  // Refresh template preview
  impRenderTemplates();
  flash('✓ Tópicos salvos!','#10b981');
}

