function mwuid(){return 'mw'+Math.random().toString(36).slice(2,9);}

function mwInit(){
  // Só faz seed se nunca inicializou (primeiro uso do painel)
  if(state.mwWeeks === undefined || state.mwWeeks === null) state.mwWeeks = mwSeedDefault();
  // Se o array está vazio (usuário excluiu), respeitar a decisão
  if(!state.mwWeeks.length){
    const container=document.getElementById('metas-blocks-container');
    if(container) container.innerHTML='<div class="empty" style="padding:2rem;text-align:center;"><div style="font-size:1.5rem;margin-bottom:.5rem;">📋</div><div style="font-size:.82rem;font-weight:700;margin-bottom:.4rem;">Nenhuma semana criada</div><div style="font-size:.68rem;color:var(--muted2);">Clique em <strong>+ Semana</strong> para criar sua primeira semana de metas.</div></div>';
    const sel=document.getElementById('week-selector'); if(sel) sel.innerHTML='';
    try{set('mw-week-title','—');set('mw-week-desc','Crie uma semana para começar');}catch(e){}
    return;
  }
  if(!state.mwResults) state.mwResults = {};
  renderWeekSelector();
  renderMwBlocks();
  renderMwSummary();
  renderMwWeekLog();
}

// ── WEEK SELECTOR ──────────────────────────────
function renderWeekSelector(){
  const sel=document.getElementById('week-selector');if(!sel)return;
  sel.innerHTML='';
  (state.mwWeeks||[]).forEach((w,i)=>{
    const btn=document.createElement('button');
    const done=w.metas.every(m=>state.mwResults&&state.mwResults[m.id]);
    const isActive=i===mwActiveWeek;
    btn.className='psw'+(isActive?' active':'');
    if(isActive){btn.style.background=w.color;btn.style.borderColor=w.color;btn.style.color='#000';}
    btn.textContent=`S${i+1}${done?' ✓':''}`;
    btn.title=w.name+' — '+w.desc;
    btn.onclick=()=>{mwActiveWeek=i;mwActiveBlock=null;renderWeekSelector();renderMwBlocks();renderMwSummary();renderMwWeekLog();updateMwTimerUI();};
    sel.appendChild(btn);
  });
}

// ── BLOCKS LIST ────────────────────────────────
