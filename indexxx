  state.filaRevisao.unshift({id:uid(),qid,link:w.url||'',label:(w.assunto||w.materia||'Q#'+qid).substring(0,50),erros:w.erros,reincidente:w.erros>=2,prioridade:w.erros>=2?'alta':'normal',status:'waiting',addedAt:now,readyAt:now+interval*60000,interval});
  saveState();frRender();frUpdateNavBadge();
  flash('Adicionado à fila! Revisão em '+interval+'min.','#22d3ee',3000);
