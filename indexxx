const _origStopTimer=stopTimer;
stopTimer=function(){
  _origStopTimer();
  if(state.sessions.length){
    const last=state.sessions[state.sessions.length-1];
    const mins=Math.floor(last.seconds/60);
    if(mins>=5) arenaAddXP(Math.ceil(mins*0.3),`Sessão de estudo — ${mins} min`,'📖');
  }
};

// XP when questions registered
const _origRegisterQuestions=registerQuestions;
registerQuestions=function(){
  const prev=state.questionSessions.length;
  _origRegisterQuestions();
  if(state.questionSessions.length>prev){
    const last=state.questionSessions[state.questionSessions.length-1];
    const rate=Math.round(last.correct/last.total*100);
    const xp=Math.ceil(last.total*0.2)+(rate>=70?10:0)+(rate>=80?15:0);
    arenaAddXP(xp,`${last.total} questões — ${rate}% acerto`,'❓');
  }
};

// XP when meta registrada
const _origMwRegisterResult2=mwRegisterResult;
mwRegisterResult=function(){
  const prevCount=Object.keys(state.mwResults||{}).length;
  _origMwRegisterResult2();
  const newCount=Object.keys(state.mwResults||{}).length;
  if(newCount>prevCount){
    const entries=Object.values(state.mwResults||{});
    const last=entries[entries.length-1];
    if(last){
      const rate=Math.round(last.correct/last.resolved*100);
      const xp=20+(rate>=70?15:0)+(rate>=80?20:0);
      arenaAddXP(xp,`Meta concluída — ${rate}% acerto`,'🎯');
    }
  }
};

