function mwCdGetSecs(){
  const h=parseInt(document.getElementById('mw-cd-h').value)||0;
  const m=parseInt(document.getElementById('mw-cd-m').value)||0;
  const s=parseInt(document.getElementById('mw-cd-s').value)||0;
