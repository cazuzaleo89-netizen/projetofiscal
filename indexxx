function coliseuTick() {
  if(!coliseu||coliseu.paused)return;
  coliseu.elapsed++;
  const rem = coliseu.durationSecs - coliseu.elapsed;
  const el = document.getElementById('col-timer');
  if(el){
    el.textContent=coliseuFmt(rem);
    const pct=rem/coliseu.durationSecs;
    el.style.color=pct<.15?'#f87171':pct<.3?'#fbbf24':'#f9fafb';
  }
  // Update topbar pill
  const pill = document.getElementById('missao-topbar-pill');
  const pillTimer = document.getElementById('missao-topbar-timer');
  if(pill) pill.style.display='flex';
  if(pillTimer) pillTimer.textContent = coliseuFmt(Math.max(0,rem));

  if(rem<=0){clearInterval(coliseu.interval);coliseuTimeUp();}
}

