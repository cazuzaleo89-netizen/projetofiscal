// ── Auto-generate missions from disciplines + edital weights ──
function missoesAutoGen() {
  missoesEnsure();
  editalEnsure();

  const perDay    = parseInt(document.getElementById('missoes-cfg-per-day')?.value) || 3;
  const numDays   = parseInt(document.getElementById('missoes-cfg-days')?.value)    || 5;
  const duration  = parseInt(document.getElementById('missoes-cfg-duration')?.value)|| 45;
  const tipo      = document.getElementById('missoes-cfg-tipo')?.value || 'questoes';

  if (!state.disciplines.length) { flash('Adicione disciplinas antes de gerar missões!','#f0b429'); return; }

  // Build weighted discipline list based on edital weights
  const discsWithWeight = state.disciplines.map(d => ({
    ...d, weight: state.edital.weights[d.id] || (100/state.disciplines.length)
  })).sort((a,b) => b.weight - a.weight);

  const today = new Date(); today.setHours(0,0,0,0);
  // Start from Monday of current week
  const dayOfWeek = today.getDay(); // 0=Sun
  const monday = new Date(today);
  monday.setDate(today.getDate() - (dayOfWeek === 0 ? 6 : dayOfWeek - 1));

  const eixos = ['Eixo temático A','Eixo temático B','Eixo temático C'];
  const missions = [];
  let discIdx = 0;

  for (let day = 0; day < numDays; day++) {
    const date = new Date(monday);
    date.setDate(monday.getDate() + day);

    for (let m = 0; m < perDay; m++) {
      const disc = discsWithWeight[discIdx % discsWithWeight.length];
      const eixo = eixos[Math.floor(Math.random() * eixos.length)];
      missions.push({
        id:          uid(),
        dayIdx:      day,
        date:        date.toISOString().split('T')[0],
        discId:      disc.id,
        discName:    disc.name,
        discColor:   disc.color,
        title:       disc.name,
        subtitulo:   eixo,
        tipo:        tipo,
        durationMins:duration,
        status:      'pending',
        completedAt: null,
        link:        '',
      });
      discIdx++;
    }
  }

  state.missoesCiclo = {
    nome: `Ciclo — Semana ${monday.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'})}`,
    startDate: monday.toISOString().split('T')[0],
    endDate: new Date(monday.getTime() + numDays * 86400000).toISOString().split('T')[0],
    missions,
  };

  saveState();
  missoesRender();
  flash(`✅ ${missions.length} missões geradas para ${numDays} dias!`,'#10b981');
}

