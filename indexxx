function dashDiagnostic(){
  const ring = document.getElementById('readiness-ring-fill');
  const num  = document.getElementById('readiness-score-num');
  const msg  = document.getElementById('readiness-msg');
  const badges = document.getElementById('readiness-badges');
  const perfList = document.getElementById('d-perf-list');
  if(!ring||!num) return;

  // Calcula score por disciplina
  const discScores = state.disciplines.map(d=>{
    const qs = (state.questionSessions||[]).filter(s=>s.subjectId===d.id);
    const tot = qs.reduce((a,s)=>a+s.total,0);
    const cor = qs.reduce((a,s)=>a+s.correct,0);
    const rate = tot>0 ? cor/tot : null;
    const secs = (state.sessions||[]).filter(s=>s.subjectId===d.id).reduce((a,s)=>a+s.seconds,0);
    const edW  = (state.edital&&state.edital.weights&&state.edital.weights[d.id])||0;
    const wrongCount = Object.values(state.wrongHistory||{})
      .filter(w=>(w.materia===d.name||w.assunto===d.name)&&w.erros>0).length;
    const reincCount = Object.values(state.wrongHistory||{})
      .filter(w=>(w.materia===d.name||w.assunto===d.name)&&w.erros>=2).length;
    return {d, tot, cor, rate, secs, edW, wrongCount, reincCount};
  }).filter(x=>x.tot>0||x.secs>3600);

  // Score de Prontidão (0-100)
  let score = 0, parts = 0;
  const totSecs = (state.sessions||[]).reduce((a,s)=>a+s.seconds,0);
  const allQ = state.questionSessions||[];
  const totQ = allQ.reduce((a,s)=>a+s.total,0);
  const corQ = allQ.reduce((a,s)=>a+s.correct,0);
  const globalRate = totQ>0 ? corQ/totQ : null;

  // Componente 1: taxa global de acerto (peso 40)
  if(globalRate!==null){ score += globalRate*40; parts+=40; }
  // Componente 2: alinhamento com edital (peso 30)
  const hasWeights = state.disciplines.some(d=>(state.edital&&state.edital.weights&&state.edital.weights[d.id]||0)>0);
  if(hasWeights&&totSecs>0){
    let alignSum=0,alignN=0;
    state.disciplines.forEach(d=>{
      const w=(state.edital.weights[d.id]||0)/100;
      if(w<0.01) return;
      const studySecs=(state.sessions||[]).filter(s=>s.subjectId===d.id).reduce((a,s)=>a+s.seconds,0);
      const sp=studySecs/totSecs;
      const gap=Math.abs(sp-w);
      alignSum+=Math.max(0,1-gap*3);alignN++;
    });
    if(alignN>0){score+=(alignSum/alignN)*30;parts+=30;}
  }
  // Componente 3: questões resolvidas (peso 20, meta 500)
  const qProg = Math.min(1, totQ/500);
  score += qProg*20; parts+=20;
  // Componente 4: consistência (peso 10, meta 30 dias seguidos)
  const strProg = Math.min(1,(state.streak||0)/30);
  score += strProg*10; parts+=10;

  const finalScore = parts>0 ? Math.round(score/parts*100) : 0;
  const circ = 2*Math.PI*33;
  const scoreColor = finalScore>=70?'var(--green)':finalScore>=45?'var(--gold)':'var(--red)';
  ring.style.stroke = scoreColor;
  ring.style.strokeDashoffset = (circ*(1-finalScore/100)).toFixed(1);
  num.textContent = finalScore;
  num.style.color = scoreColor;

  // Mensagem
  const msgs = [
    [80, 'Excelente! Continue mantendo esse ritmo.'],
    [60, 'Bom progresso. Foque nos pontos fracos.'],
    [40, 'Em desenvolvimento. Aumente o volume de questões.'],
    [0,  'Início da preparação. Mantenha consistência!'],
  ];
  msg.textContent = (msgs.find(([t])=>finalScore>=t)||msgs[msgs.length-1])[1];

  // Badges de destaque
  const bs = [];
  if((state.streak||0)>=7) bs.push(['🔥 '+state.streak+'d','green']);
  const reincTotal = Object.values(state.wrongHistory||{}).filter(w=>w.erros>=2).length;
  if(reincTotal>0) bs.push([reincTotal+' reinc.','red']);
  const frDue = (state.filaRevisao||[]).filter(f=>f.status!=='done'&&Date.now()>=(f.readyAt||0)).length;
  if(frDue>0) bs.push([frDue+' revisão','gold']);
  if(globalRate>=.8) bs.push([Math.round(globalRate*100)+'% acerto','green']);
  badges.innerHTML = bs.map(([l,c])=>`<span class="diag-badge ${c}">${l}</span>`).join('');

  // Lista de desempenho por disciplina
  if(!perfList) return;
  if(!discScores.length){perfList.innerHTML='<div class="empty">Registre questões para ver o desempenho 🎯</div>';return;}
  const sorted = [...discScores].sort((a,b)=>(a.rate??1)-(b.rate??1));
  perfList.innerHTML = sorted.map(x=>{
    const rate = x.rate!==null ? Math.round(x.rate*100) : null;
    const rateStr = rate!==null ? rate+'%' : '—';
    const rateColor = rate===null?'var(--muted2)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const warn = x.reincCount>0 ? `<span style="font-size:.55rem;color:var(--red);margin-left:4px;">⚠${x.reincCount}</span>` : '';
    return `<div class="diag-item">
      <div class="diag-item-dot" style="background:${x.d.color}"></div>
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;"><span class="diag-item-name">${x.d.name}</span>${warn}</div>
        <div class="diag-item-bar"><div class="diag-item-bar-fill" style="width:${rate??0}%;background:${rateColor};"></div></div>
      </div>
      <div class="diag-item-rate" style="color:${rateColor}">${rateStr}</div>
    </div>`;
  }).join('');
}

