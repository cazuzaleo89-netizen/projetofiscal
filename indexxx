function cronPipSync() {
  if (!cronPipWin || cronPipWin.closed) return;
  const pd = cronPipWin.document;
  const isTimer = cronState.mode==='timer';
  const secs = isTimer ? (cronState.total-cronState.elapsed) : cronState.elapsed;
  const t=pd.getElementById('pip-t');
  if(t){t.textContent=cronFmt(secs);const pct=isTimer?secs/cronState.total:1;t.style.color=pct<.15?'#f87171':pct<.3?'#fbbf24':'#f9fafb';}
  const r=pd.getElementById('pip-r');if(r)r.textContent=cronState.resolved;
  const a=pd.getElementById('pip-a');if(a)a.textContent=cronState.acertos;
  const e=pd.getElementById('pip-e');if(e)e.textContent=cronState.erros;

  // Investida sync
  const inv = pd.getElementById('pip-inv');
  if (!inv) return;
  const hasInv = _cronInv.total > 0 || (document.getElementById('cron-investida-card') || {}).style?.display !== 'none';
  const cardVisible = document.getElementById('cron-investida-card');
  const invActive = cardVisible && cardVisible.style.display !== 'none';
  if (invActive) {
    inv.style.display = 'block';
    const ace  = cronState.acertos  || 0;
    const err  = cronState.erros    || 0;
    const res  = cronState.resolved || (ace + err);
    const tot  = _cronInv.total;
    const pct  = tot > 0 ? Math.min(100, Math.round(res / tot * 100)) : 0;
    const rate = (ace + err) > 0 ? Math.round(ace / (ace + err) * 100) : null;
    const barColor = rate === null ? 'linear-gradient(90deg,#22d3ee,#8b5cf6)'
      : rate >= 70 ? 'linear-gradient(90deg,#10b981,#22d3ee)'
      : rate >= 50 ? 'linear-gradient(90deg,#f59e0b,#22d3ee)'
      : 'linear-gradient(90deg,#ef4444,#f59e0b)';

    const nm=pd.getElementById('pip-inv-name'); if(nm) nm.textContent=_cronInv.caderno||'';
    const sb=pd.getElementById('pip-inv-sub');  if(sb) sb.textContent=_cronInv.assunto||'';
    const bg=pd.getElementById('pip-inv-badge');if(bg) bg.textContent=tot>0?res+'/'+tot:'—';
    const br=pd.getElementById('pip-inv-bar');  if(br){br.style.width=pct+'%';br.style.background=barColor;}
    const ir=pd.getElementById('pip-inv-resp'); if(ir) ir.textContent=res;
    const ia=pd.getElementById('pip-inv-ace');  if(ia) ia.textContent=ace;
    const ie=pd.getElementById('pip-inv-err');  if(ie) ie.textContent=err;
    const rrow=pd.getElementById('pip-inv-rate-row');
    const rval=pd.getElementById('pip-inv-rate');
    if(rrow) rrow.style.display = rate !== null ? 'flex' : 'none';
    if(rval && rate !== null){rval.textContent=rate+'%';rval.style.color=rate>=70?'#34d399':rate>=50?'#f59e0b':'#f87171';}
  } else {
    inv.style.display = 'none';
  }
}

