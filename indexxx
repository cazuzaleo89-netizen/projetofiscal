function cronManualRegister(){
  const discId=document.getElementById('manual-disc-sel')?.value;
  const hours=parseInt(document.getElementById('manual-hours')?.value)||0;
  const mins=parseInt(document.getElementById('manual-mins')?.value)||0;
  const qTotal=parseInt(document.getElementById('manual-q-total')?.value)||0;
  const qCorrect=parseInt(document.getElementById('manual-q-correct')?.value)||0;
  const dateVal=document.getElementById('manual-date')?.value;
  const obs=document.getElementById('manual-obs')?.value?.trim()||'';

  const totalSecs=hours*3600+mins*60;
  if(totalSecs<60 && qTotal<1){flash('Informe pelo menos o tempo ou as questões!','#f0b429');return;}
  if(!discId){flash('Selecione uma disciplina!','#f0b429');return;}

  const d=state.disciplines.find(x=>x.id===discId);
  const dName=d?d.name:'Geral';
  const date=dateVal?new Date(dateVal+'T12:00:00'):new Date();

  // Registrar sessão de tempo
  if(totalSecs>=60){
    state.sessions.push({
      id:uid(), subjectId:discId, subject:dName,
      seconds:totalSecs, manual:true,
      date:date.toISOString(),
      dateStr:date.toLocaleDateString('pt-BR'),
      timeStr:'manual',
      obs:obs
    });
    updateStreak(date.toDateString());
  }

  // Registrar questões
  if(qTotal>0){
    state.questionSessions.push({
      id:uid(), subjectId:discId, subject:dName,
      total:qTotal, correct:qCorrect,
      banca:'Manual', obs:obs,
      date:date.toISOString(),
      dateStr:date.toLocaleDateString('pt-BR'),
      timeStr:'manual'
    });
  }

  saveState(); updateStats(); cronUpdateTodayLog();
  // Limpar campos
  document.getElementById('manual-hours').value='';
  document.getElementById('manual-mins').value='';
  document.getElementById('manual-q-total').value='';
  document.getElementById('manual-q-correct').value='';
  document.getElementById('manual-obs').value='';

  const parts=[];
  if(totalSecs>=60) parts.push(formatHM(totalSecs));
  if(qTotal>0) parts.push(`${qCorrect}/${qTotal} questões`);
  flash(`✅ Registro manual: ${parts.join(' + ')} — ${dName}`,'#10b981');
}

// ═══ EDITAR / EXCLUIR SESSÕES ═════════════════
function cronEditSession(sessionId){
  const s=state.sessions.find(x=>x.id===sessionId);
  if(!s) return;
  const currentH=Math.floor(s.seconds/3600);
  const currentM=Math.floor((s.seconds%3600)/60);
  const newH=prompt('Horas:', currentH);
  if(newH===null) return;
  const newM=prompt('Minutos:', currentM);
  if(newM===null) return;
  const newSecs=(parseInt(newH)||0)*3600+(parseInt(newM)||0)*60;
  if(newSecs<0){flash('Tempo inválido!','#f0b429');return;}
  s.seconds=newSecs;
  saveState(); updateStats(); cronUpdateTodayLog();
  flash(`✏️ Sessão atualizada: ${formatHM(newSecs)}`,'#10b981');
}

function cronDeleteSession(sessionId){
  const s=state.sessions.find(x=>x.id===sessionId);
  if(!s) return;
  if(!confirm(`Excluir sessão de ${s.subject} (${formatHM(s.seconds)})?`)) return;
  state.sessions=state.sessions.filter(x=>x.id!==sessionId);
  saveState(); updateStats(); cronUpdateTodayLog();
  flash('🗑 Sessão excluída.','#ef4444');
}

function cronEditQSession(sessionId){
  const s=state.questionSessions.find(x=>x.id===sessionId);
  if(!s) return;
  const newTotal=prompt('Total de questões:', s.total);
  if(newTotal===null) return;
  const newCorrect=prompt('Questões corretas:', s.correct);
  if(newCorrect===null) return;
  s.total=parseInt(newTotal)||0;
