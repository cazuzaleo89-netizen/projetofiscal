let arenaFocusTimer={active:false,interval:null,duration:0,remaining:0,mode:'',xp:0,color:'',startTime:null};

const FOCUS_MESSAGES=[
  '🧠 Foco total — sem distrações',
  '💡 Cada minuto conta',
  '⚡ Dopamina da conquista aguarda',
  '🔥 Você está no flow',
