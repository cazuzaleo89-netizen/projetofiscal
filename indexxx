  });
  if(!discs.length){ el.innerHTML='<div class="empty">Registre questões para ver o desempenho 🎯</div>'; return; }

  el.innerHTML = discs.map(d=>{
    const qs = state.questionSessions.filter(s=>s.subjectId===d.id);
    const total = qs.reduce((a,s)=>a+s.total,0);
    const correct = qs.reduce((a,s)=>a+s.correct,0);
    const rate = total>0 ? Math.round(correct/total*100) : 0;
    const pfi = calcProficiencyIndex(d.id);
    const rc = rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const pc = pfi>=70?'var(--green)':pfi>=50?'var(--gold)':'var(--red)';

    return `<div style="margin-bottom:.6rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">
        <div style="display:flex;align-items:center;gap:.4rem;font-size:.72rem;font-weight:700;">
