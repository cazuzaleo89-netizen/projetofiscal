    subInp.type = 'text';
    subInp.placeholder = 'Novo subassunto...';
    subInp.style.cssText = 'flex:1;font-size:.72rem;background:var(--surf);border:1px solid var(--border2);border-radius:6px;color:var(--text);padding:4px 8px;outline:none;font-family:var(--ff);';
    subInp.onfocus = () => { subInp.style.borderColor = 'var(--cyan)'; };
    subInp.onblur = () => { subInp.style.borderColor = 'var(--border2)'; };
    const addSubBtn = document.createElement('button');
    addSubBtn.style.cssText = 'background:rgba(34,211,238,.12);border:1px solid rgba(34,211,238,.3);border-radius:6px;color:var(--cyan);font-size:.7rem;padding:3px 8px;cursor:pointer;white-space:nowrap;';
