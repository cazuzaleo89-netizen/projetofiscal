  });
  // Push disciplines to extension storage so quick-start dropdown works
  function extSyncDisciplines(){
    if(typeof chrome==='undefined'||!chrome?.runtime?.sendMessage) return;
    const discs=state.disciplines.map(d=>({id:d.id,name:d.name,color:d.color}));
    chrome.runtime.sendMessage('pf-ext-id',{type:'SAVE_DISCIPLINES',disciplines:discs}).catch(()=>{
      // Try without extension ID (works when called from extension context)
      try{ chrome.runtime.sendMessage({type:'SAVE_DISCIPLINES',disciplines:discs}); }catch(e){}
    });
  }
  // Poll for pending results every 5s
  setInterval(extCheckPending, 5000);
  setTimeout(extSyncDisciplines, 2000);
  // Also check on triggerImport
  chrome.storage.onChanged?.addListener((changes)=>{
    if(changes.triggerImport) extImportAll();
  });
}

// Keyboard shortcuts: C = certa, X = errada (funciona no cronômetro E na sessão TEC)
document.addEventListener('keydown', function(e){
  if(['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName)) return;

  // ── Atalhos Alt+número para navegar entre abas ──────────────
  if(e.altKey && !e.ctrlKey && !e.metaKey){
    const navMap = {
      '1':'dashboard','2':'cronometro','3':'filarev',
      '4':'problemáticas','5':'sessao','6':'questoes',
      '7':'estatisticas','8':'progresso','9':'arena'
    };
    if(navMap[e.key]){
      const navItem = document.querySelector(`.nav-item[onclick*="'${navMap[e.key]}'"]`);
      goPage(navMap[e.key], navItem);
      e.preventDefault(); return;
    }
    // Alt+F busca em Q. Problemáticas
    if(e.key==='f'||e.key==='F'){
      const inp=document.getElementById('wh-search-inp');
      if(inp){ goPage('problemáticas',null); setTimeout(()=>inp.focus(),200); e.preventDefault(); return; }
    }
  }

  if(e.ctrlKey || e.altKey || e.metaKey) return;

  // Sessão TEC (Metas / bookmarklet flow)
  if(tecSession.active && !tecSession.paused){
    if(e.key === 'c' || e.key === 'C'){ tecKeyQ('correct'); e.preventDefault(); return; }
    if(e.key === 'x' || e.key === 'X'){ tecKeyQ('wrong');   e.preventDefault(); return; }
  }

  // Cronômetro manual
  if(typeof cronState !== 'undefined' && cronState.running && !cronState.paused){
    if(e.key === 'c' || e.key === 'C'){ cronCount('ace'); e.preventDefault(); return; }
    if(e.key === 'x' || e.key === 'X'){ cronCount('err'); e.preventDefault(); return; }
    if(e.key === 'q' || e.key === 'Q'){ cronCount('res'); e.preventDefault(); return; }
  }
});

// Receptor de resultados enviados pelo bookmarklet TecConcursos
window.addEventListener('message', function(e){
  if(!e.data) return;

  // ── Salvar referência ao tab TEC (para postMessage reverso) ──
  if(e.source && e.source !== window && e.data.type && e.data.type.indexOf('TEC_') === 0){
    tecTabWindow = e.source;
  }

  // ── Aba TEC inativa/ativa (auto-pausa do cronômetro) ──
  if(e.data.type === 'TEC_TAB_INACTIVE'){
    if(state.tecAutoPause !== false && typeof cronState !== 'undefined'
       && cronState.running && !cronState.paused){
      try { cronPause(); flash('⏸ Cronômetro pausado (TEC inativo >2min)', '#f0b429', 4000); } catch(x){}
    }
    return;
  }
  if(e.data.type === 'TEC_TAB_ACTIVE'){
    if(state.tecAutoPause !== false && typeof cronState !== 'undefined'
       && cronState.running && cronState.paused){
      try { cronResume(); flash('▶ Cronômetro retomado', '#10b981', 3000); tecPushStats(); } catch(x){}
    }
    return;
  }

  // ── Fim de caderno (todas questões resolvidas) ──
  if(e.data.type === 'TEC_CADERNO_END'){
    tecCadernoEndModal(e.data.stats || {});
    return;
  }

  // ── Pedido de abrir próxima questão da fila (Alt+R no TEC) ──
  if(e.data.type === 'PF_REQUEST_NEXT_FILA'){
    var ready = (state.filaRevisao||[]).filter(function(q){ return q.status==='ready' || (q.due && new Date(q.due)<=new Date() && q.status!=='done'); });
    if(ready.length && tecTabWindow && !tecTabWindow.closed){
      try { tecTabWindow.postMessage({type:'PF_OPEN_QUESTION', url: ready[0].link, desc: ready[0].desc||''}, '*'); } catch(x){}
    } else if(tecTabWindow && !tecTabWindow.closed){
      try { tecTabWindow.postMessage({type:'PF_NO_FILA'}, '*'); } catch(x){}
    }
    return;
  }

  // Tempo real: cada questão respondida no TecConcursos
  if(e.data.type === 'TEC_QUESTION'){
    var r = e.data.result;
    if(r === 'ping') return;
    if(r === 'session_info') { cronInvStart(e.data); setTimeout(tecPushStats, 500); return; }

    // wrong_fast: só atualiza cronômetro/contador (ainda sem dados do modal)
    if(r === 'wrong_fast'){
      if(typeof cronState !== 'undefined' && cronState.running && !cronState.paused) cronCount('err');
      else if(tecSession && tecSession.active && !tecSession.paused) tecKeyQ('wrong');
      return;
    }

    // Atualiza contadores (para 'correct' e 'wrong' com dados completos)
    if(typeof cronState !== 'undefined' && cronState.running && !cronState.paused){
      if(r === 'correct') cronCount('ace');
      // 'wrong' NÃO atualiza cronômetro aqui — já foi feito pelo wrong_fast
    } else if(tecSession && tecSession.active && !tecSession.paused){
      if(r === 'correct') tecKeyQ('correct');
    }

    // Questão errada com URL → rastreia reincidências + adiciona à fila
    if(r === 'wrong' && e.data.url){
      frEnsure();
      var qUrl     = e.data.url;
      var qId      = e.data.qid      || qUrl.replace(/.*\//,'');
      var qDesc    = e.data.desc     || e.data.assunto || 'Questão TecConcursos';
      var qMateria = e.data.materia  || '';
      var qAssunto = e.data.assunto  || '';
      var myTotal  = parseInt(e.data.myTotal)  || 0; // resoluções anteriores no TEC
      var myErrors = parseInt(e.data.myErrors) || 0; // erros anteriores no TEC

      // ── 1. Registrar no wrongHistory ──────────────
      if(!state.wrongHistory) state.wrongHistory = {};
      if(!state.wrongHistory[qId]){
        // Busca entrada anterior na fila por URL OU por qid (garante retrocompatibilidade)
        var prevFila = state.filaRevisao.find(function(q){
          return q.link === qUrl ||
            (qId && q.qid === qId) ||
            (qId && q.link && q.link.indexOf('/questoes/'+qId) !== -1);
        });
        var prevErros = prevFila ? Math.max(prevFila.erros || 1, 1) : 0;
        // myErrors do TEC já inclui o erro atual, então baseline = myErrors - 1
        var tecBaseline = myErrors > 0 ? myErrors - 1 : 0;
        var startErros = Math.max(prevErros, tecBaseline);

        state.wrongHistory[qId] = {
          qid: qId, url: qUrl, desc: qDesc,
          materia: qMateria, assunto: qAssunto,
          erros: startErros, datas: [], myTotal: 0, myErrors: 0,
          firstErro: new Date().toISOString()
        };
        // Retroativamente atribui qid ao item existente da fila se não tiver
        if(prevFila && !prevFila.qid && qId) prevFila.qid = qId;
      }
      var wh = state.wrongHistory[qId];
      wh.erros++;
      wh.datas.push(new Date().toISOString());
      // ── TEC é fonte da verdade ────────────────────
      // Se o TEC informa mais erros do que o painel registra,
      // sincroniza para evitar subcontagem
      if(myErrors > 0 && myErrors > wh.erros){
        wh.erros = myErrors;
      }
      wh.desc    = qDesc    || wh.desc;
      wh.materia = qMateria || wh.materia;
      wh.assunto = qAssunto || wh.assunto;
      if(myTotal  > wh.myTotal)  wh.myTotal  = myTotal;
      if(myErrors > wh.myErrors) wh.myErrors = myErrors;
      wh.lastErro = new Date().toISOString();

      var isReincidente = (wh.erros > 1) || (myErrors > 1);

      // ── 2. Associar disciplina ────────────────────
      var disc = null;
      if(qMateria){
        var matLower = qMateria.toLowerCase().replace(/^dir\.\s*/,'');
        disc = state.disciplines.find(function(d){
          var n = d.name.toLowerCase().replace(/^dir\.\s*/,'');
          return n.includes(matLower) || matLower.includes(n);
        });
      }
      if(!disc && typeof cronState !== 'undefined' && cronState.discId){
        disc = state.disciplines.find(function(d){ return d.id === cronState.discId; });
      }

      // ── 3. Adicionar / atualizar na fila ──────────
      var existente = state.filaRevisao.find(function(q){
        return q.link === qUrl ||
          (qId && q.qid === qId) ||
          (qId && q.link && q.link.indexOf('/questoes/'+qId) !== -1);
      });
      var now = Date.now();
      var mins = isReincidente ? 15 : 30;

      if(existente){
        // Usa wrongHistory como fonte da verdade para o contador de erros
        existente.erros = wh.erros;
        existente.reincidente = isReincidente;
        existente.intervalMins = mins;
        existente.dueAt = now + mins * 60000;
        existente.status = 'waiting';
        existente.qid = existente.qid || qId;
        if(isReincidente) existente.prioridade = 'alta';
      } else {
        state.filaRevisao.unshift({
          id: uid(),
          link: qUrl, qid: qId,
          desc: qDesc, materia: qMateria, assunto: qAssunto,
          discId:    disc ? disc.id    : '',
          discName:  disc ? disc.name  : (qMateria || '—'),
          discColor: disc ? disc.color : '#5a6a8a',
          intervalMins: mins,
          addedAt: now, dueAt: now + mins * 60000,
          status: 'waiting', openedAt: null, doneAt: null,
          erros: wh.erros,
          reincidente: isReincidente,
          prioridade: isReincidente ? 'alta' : 'normal',
          myTotal: myTotal, myErrors: myErrors,
        });
      }

      saveState();
      frUpdateNavBadge();
      wrongHistoryUpdateBadge();

      var label = qAssunto || qMateria || 'Questão';
      if(isReincidente){
        flash('⚠️ Reincidência #'+wh.erros+': ' + label.substring(0,40), '#ef4444', 5000);
      } else {
        flash('📋 Fila: ' + label.substring(0, 50) + (label.length > 50 ? '…' : ''), '#8b5cf6', 4000);
      }
    }

    // Importação passiva: questão navegada no TEC com histórico de erros prévios
    if(r === 'wrong_import' && e.data.qid){
      var qImp = e.data.qid;
      var impErr = parseInt(e.data.myErrors) || 0;
      if(impErr <= 0) return;
      whEnsure();
      var existing = state.wrongHistory[qImp];
      if(existing){
        if(impErr > (existing.erros || 0)){
          existing.erros    = impErr;
          existing.myErrors = Math.max(existing.myErrors||0, impErr);
          existing.myTotal  = Math.max(existing.myTotal||0, parseInt(e.data.myTotal)||0);
          var filaImp = (state.filaRevisao||[]).find(function(q){ return q.qid===qImp || q.link===(existing.url||''); });
          if(filaImp){ filaImp.erros=existing.erros; filaImp.reincidente=existing.erros>1; if(existing.erros>1)filaImp.prioridade='alta'; }
          saveState(); wrongHistoryRender(); wrongHistoryUpdateBadge();
          try{ frRender(); }catch(x){}
        }
      } else {
        var impUrl = e.data.url || ('https://www.tecconcursos.com.br/questoes/'+qImp);
        var impDesc = e.data.desc || ('Questão #'+qImp);
        state.wrongHistory[qImp] = {
          qid: qImp, url: impUrl, desc: impDesc,
          materia: e.data.materia||'', assunto: e.data.assunto||'',
          erros: impErr, myErrors: impErr,
          myTotal: parseInt(e.data.myTotal)||0, datas: [], importado: true
        };
        if(impErr >= 2){
          frEnsure();
          var alreadyF = (state.filaRevisao||[]).some(function(q){ return q.qid===qImp; });
          if(!alreadyF){
            state.filaRevisao.unshift({
              qid:qImp, link:impUrl, desc:impDesc,
              materia:e.data.materia||'', assunto:e.data.assunto||'',
              erros:impErr, reincidente:true, prioridade:'alta',
              status:'waiting', data:new Date().toISOString(), importado:true
            });
            try{ frUpdateNavBadge(); }catch(x){}
          }
        }
        saveState(); wrongHistoryRender(); wrongHistoryUpdateBadge();
        try{ frRender(); }catch(x){}
        flash('📥 TEC: histórico importado — Q#'+qImp+' ('+impErr+'× erro)', '#f59e0b', 4000);
      }
      return;
    }

    // Correção tardia: histórico do TEC carregou após o wrong inicial
    if(r === 'wrong_update' && e.data.url){
      var qId2  = e.data.qid || (e.data.url||'').replace(/.*\//,'');
      var upErr = parseInt(e.data.myErrors) || 0;
      if(qId2 && upErr > 0 && state.wrongHistory && state.wrongHistory[qId2]){
        var whu = state.wrongHistory[qId2];
        if(upErr > whu.erros){
          whu.erros    = upErr;
          whu.myErrors = Math.max(whu.myErrors||0, upErr);
          var filaU = (state.filaRevisao||[]).find(function(q){ return q.link===(whu.url||'') || q.qid===qId2; });
          if(filaU){ filaU.erros=whu.erros; filaU.reincidente=whu.erros>1; if(whu.erros>1)filaU.prioridade='alta'; }
          saveState();
          wrongHistoryRender();
          wrongHistoryUpdateBadge();
          try{ frRender(); }catch(x){}
        }
      }
    }

    return;
  }

  if(e.data.type !== 'TEC_RESULT') return;
  const total   = parseInt(e.data.total)   || 0;
  const correct = parseInt(e.data.correct) || 0;
  const elapsed = parseInt(e.data.elapsed) || 0;
  if(total < 1) return;
  const totInp = document.getElementById('tec-rb-total');
  const corInp = document.getElementById('tec-rb-correct');
  if(totInp) totInp.value = total;
  if(corInp) corInp.value = correct;
  if(elapsed > 0 && tecSession.active && tecSession.seconds < elapsed) tecSession.seconds = elapsed;
  if(tecSession.active){
    showReturnBanner();
  } else {
    // Sessão não ativa — inicia registro rápido via banner
    tecSession.active = true;
    tecSession.seconds = elapsed;
    document.getElementById('tec-return-banner').style.display = '';
  }
  tecUpdateRbRate();
  flash('✅ Resultado importado do TecConcursos!', '#22d3ee');
});

