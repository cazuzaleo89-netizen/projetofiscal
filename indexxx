/* ── Start session ─────────────────────────────── */
function sqStartSession() {
  const discId = document.getElementById('sq-disc-sel').value;
  const total  = parseInt(document.getElementById('sq-total-inp').value)||0;
  const topic  = document.getElementById('sq-topic-inp').value.trim();

  if(!discId)            { flash('Selecione a disciplina!','#f0b429'); return; }
  if(!total || total < 1){ flash('Informe o total de questões!','#f0b429'); return; }

  const disc = state.disciplines.find(d=>d.id===discId);

  sqSession = {
    discId: discId||'',
    discName: disc?.name||'Geral',
    discColor: disc?.color||'#22d3ee',
    topic: topic || disc?.name || 'Sessão de Questões',
    total,
    intervalMins: sqIntervalMins,
    questions: Array.from({length:total},(_,i)=>({
      num: i+1,
      status: 'pending',
      answeredAt: null,
      reviewDueAt: null,
      reviewedAt: null,
    })),
    currentIdx: 0,
    reviewQueue: [],
    startTime: Date.now(),
    timerInterval: null,
    queueInterval: null,
    totalAnswered: 0,
    correct: 0,
    wrong: 0,
  };

  // Show active UI
  document.getElementById('sq-setup').style.display = 'none';
  document.getElementById('sq-active').style.display = '';
  document.getElementById('sq-header-topic').textContent = sqSession.topic;
  document.getElementById('sq-header-disc').textContent  = sqSession.discName;

  // Build grid
  sqBuildGrid();
  sqUpdateStats();
  sqUpdateCurrentIndicator();

  // Start session timer
  sqSession.timerInterval = setInterval(sqTickTimer, 1000);
  // Queue checker every 1s for precise alert timing
  sqSession.queueInterval = setInterval(sqCheckQueue, 1000);

  // Keyboard listener
  document.addEventListener('keydown', sqKeyHandler);
}

/* ── Grid ──────────────────────────────────────── */
function sqBuildGrid() {
  const grid = document.getElementById('sq-grid');
  if(!grid||!sqSession) return;
  grid.innerHTML = '';
  sqSession.questions.forEach(q => {
    const cell = document.createElement('div');
    cell.className = 'sq-cell';
    cell.id = `sq-cell-${q.num}`;
    cell.textContent = q.num;
    cell.title = `Questão ${q.num}`;
    cell.onclick = () => sqJumpTo(q.num - 1);
    grid.appendChild(cell);
  });
}

function sqUpdateCell(q) {
  const cell = document.getElementById(`sq-cell-${q.num}`);
  if(!cell) return;
  cell.className = 'sq-cell';
  cell.textContent = q.num;
  const idx = q.num - 1;
  const isCurrent = sqSession && sqSession.currentIdx === idx;
  if(isCurrent && q.status === 'pending') {
    cell.classList.add('sq-current');
  } else if(q.status === 'correct')            cell.classList.add('sq-correct');
  else if(q.status === 'wrong')                cell.classList.add('sq-wrong');
  else if(q.status === 'review_pending')       cell.classList.add('sq-review-pending');
  else if(q.status === 'reviewed_correct')     cell.classList.add('sq-reviewed-correct');
  else if(q.status === 'reviewed_wrong')       cell.classList.add('sq-reviewed-wrong');
  else if(q.status === 'skipped')              cell.classList.add('sq-skipped');
}

function sqUpdateCurrentIndicator() {
  if(!sqSession) return;
  const num = document.getElementById('sq-current-num');
  if(num) {
    const q = sqSession.questions[sqSession.currentIdx];
    num.textContent = q ? `Q${q.num}` : '—';
    num.style.color = 'var(--cyan)';
  }
  // Refresh all cells (fast)
  sqSession.questions.forEach(q => sqUpdateCell(q));
}

/* ── Mark answer ────────────────────────────────── */
function sqMark(correct) {
  if(!sqSession) return;
  const idx = sqSession.currentIdx;
  const q = sqSession.questions[idx];
  if(!q || q.status !== 'pending') return;

  q.answeredAt = Date.now();
  if(correct) {
    q.status = 'correct';
    sqSession.correct++;
  } else {
    q.status = 'wrong';
    sqSession.wrong++;
    // Schedule review
    q.reviewDueAt = Date.now() + sqSession.intervalMins * 60 * 1000;
    sqSession.reviewQueue.push({ num: q.num, dueAt: q.reviewDueAt });
    sqSession.reviewQueue.sort((a,b) => a.dueAt - b.dueAt);
  }
  sqSession.totalAnswered++;
  sqUpdateCell(q);
  sqUpdateStats();
  sqAdvance();
}

function sqSkip() {
  if(!sqSession) return;
  const q = sqSession.questions[sqSession.currentIdx];
  if(!q || q.status !== 'pending') return;
  q.status = 'skipped';
  sqUpdateCell(q);
  sqAdvance();
}

function sqJumpTo(idx) {
  if(!sqSession) return;
  if(idx < 0 || idx >= sqSession.questions.length) return;
  const prev = sqSession.questions[sqSession.currentIdx];
  sqSession.currentIdx = idx;
  if(prev) sqUpdateCell(prev);
  sqUpdateCurrentIndicator();
}

function sqAdvance() {
  if(!sqSession) return;
  // Find next pending question
  const total = sqSession.questions.length;
  let next = -1;
  for(let i = 1; i <= total; i++) {
    const idx = (sqSession.currentIdx + i) % total;
    if(sqSession.questions[idx].status === 'pending') { next = idx; break; }
  }
  if(next === -1) {
    // All original questions done — check if anything in review queue left
    const anyReview = sqSession.reviewQueue.length > 0;
    if(!anyReview) { sqEndSession(); return; }
    sqSession.currentIdx = -1;
    const num = document.getElementById('sq-current-num');
    if(num) { num.textContent = '⏳'; num.style.color='var(--gold)'; }
  } else {
    sqSession.currentIdx = next;
    sqUpdateCurrentIndicator();
  }
}

/* ── Queue checker ──────────────────────────────── */
// ── Alert system ──────────────────────────────────
function sqPlayAlertSound() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    // Three-note ascending beep — distinct and non-intrusive
    const notes = [660, 880, 1100];
    notes.forEach((freq, i) => {
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(freq, ctx.currentTime + i * 0.18);
      gain.gain.setValueAtTime(0, ctx.currentTime + i * 0.18);
      gain.gain.linearRampToValueAtTime(0.18, ctx.currentTime + i * 0.18 + 0.02);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.18 + 0.22);
      osc.start(ctx.currentTime + i * 0.18);
      osc.stop(ctx.currentTime + i * 0.18 + 0.25);
    });
  } catch(e) {}
}

