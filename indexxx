function missoesApplyDisc(missionId, discId) {
  missoesEnsure();
  const m = state.missoesCiclo.missions.find(x=>x.id===missionId);
  const d = state.disciplines.find(x=>x.id===discId);
  if (!m||!d) return;
  m.discId=d.id; m.discName=d.name; m.discColor=d.color; m.title=d.name;
