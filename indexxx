let coliseu = null;
let coliseuSyncInterval = null;

function missoesStartColiseu(id) {
  missoesEnsure();
  const m = state.missoesCiclo.missions.find(x=>x.id===id);
  if (!m) return;
  document.getElementById('coliseu-widget')?.remove();
  if (coliseu?.interval) clearInterval(coliseu.interval);
  if (coliseuSyncInterval) clearInterval(coliseuSyncInterval);

  coliseu = {
    missionId:m.id, discName:m.discName, discColor:m.discColor||'#22d3ee',
    durationSecs:m.durationMins*60, elapsed:0, paused:false,
    interval:null, resolved:0, acertos:0, erros:0,
    autoSync:false, // true when extension is feeding counts
  };

  // Broadcast session to extension via localStorage
  // (extension content script reads this on Tec Concursos pages)
  try {
    localStorage.setItem('pfx_active_mission', JSON.stringify({
      missionId: m.id,
      discName:  m.discName,
      discColor: m.discColor,
      durationSecs: m.durationMins * 60,
      startedAt: Date.now(),
      link: m.link || '',
    }));
  } catch(e) {}

  buildColiseuWidget();

  // Open link with fragment so extension knows it's a Painel Fiscal mission
  if (m.link) {
    const url = m.link + (m.link.includes('#') ? '&' : '#') + 'pf-mission=' + m.id;
    setTimeout(()=>window.open(url,'_blank'), 200);
  }

  coliseu.interval = setInterval(coliseuTick, 1000);

  // Poll for live question counts from extension every 2s
  coliseuSyncInterval = setInterval(coliseuSyncFromExtension, 2000);
}

// Read live counts from extension via localStorage bridge
function coliseuSyncFromExtension() {
  if (!coliseu) return;
  try {
    const raw = localStorage.getItem('pfx_mission_counts');
    if (!raw) return;
    const data = JSON.parse(raw);
    if (data.missionId !== coliseu.missionId) return;
    let changed = false;
    if (typeof data.resolved === 'number' && data.resolved !== coliseu.resolved) {
      coliseu.resolved = data.resolved; changed = true;
    }
    if (typeof data.acertos === 'number' && data.acertos !== coliseu.acertos) {
      coliseu.acertos = data.acertos; changed = true;
    }
    if (typeof data.erros === 'number' && data.erros !== coliseu.erros) {
      coliseu.erros = data.erros; changed = true;
    }
    if (changed) {
      const r=document.getElementById('col-res'); if(r)r.textContent=coliseu.resolved;
      const a=document.getElementById('col-ace'); if(a)a.textContent=coliseu.acertos;
      const e=document.getElementById('col-err'); if(e)e.textContent=coliseu.erros;
      coliseu.autoSync = true;
      // Show "auto" badge
      const badge = document.getElementById('col-auto-badge');
      if (badge) badge.style.display = 'inline-block';
    }
  } catch(e) {}
}

