function missDragOver(e) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.querySelectorAll('.missoes-card.drag-over').forEach(el => el.classList.remove('drag-over'));
  const card = e.currentTarget;
  if (card && card.id !== 'mcard-'+_missDragId) card.classList.add('drag-over');
}
function missDrop(e, targetId) {
  e.preventDefault();
  document.querySelectorAll('.missoes-card').forEach(el => el.classList.remove('drag-over','dragging'));
  if (!_missDragId || _missDragId === targetId) return;
  const missions = state.missoesCiclo.missions;
  const fromIdx = missions.findIndex(m => m.id === _missDragId);
  const toIdx   = missions.findIndex(m => m.id === targetId);
  if (fromIdx < 0 || toIdx < 0) return;
  const targetMission = missions[toIdx];
  const [moved] = missions.splice(fromIdx, 1);
  moved.date   = targetMission.date   || moved.date;
  moved.dayIdx = targetMission.dayIdx ?? moved.dayIdx;
  missions.splice(toIdx < fromIdx ? toIdx : toIdx, 0, moved);
  _missDragId = null;
  saveState();
  missoesRender();
}
function missDragEnd(e) {
  document.querySelectorAll('.missoes-card').forEach(el => el.classList.remove('drag-over','dragging'));
  _missDragId = null;
}

