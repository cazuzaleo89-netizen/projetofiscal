          <button class="tmt-btn" id="sq-mode-manual-btn" onclick="sqSetMode('manual')">✎ Manual</button>
        </div>
      </div>

      <!-- MODE: TEC CONCURSOS -->
      <div id="sq-mode-tec">
        <div class="card" style="margin-bottom:1.1rem;position:relative;overflow:hidden;">
