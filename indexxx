    const subCount = document.createElement('span');
    subCount.style.cssText = 'font-size:.6rem;color:var(--muted2);font-family:var(--mono);';
    subCount.textContent = (ass.subassuntos||[]).length + ' sub';

    const delAssBtn = document.createElement('button');
    delAssBtn.style.cssText = 'background:none;border:none;color:var(--muted);cursor:pointer;font-size:.8rem;padding:0 3px;line-height:1;';
    delAssBtn.innerHTML = '×';
    delAssBtn.title = 'Remover assunto';
    delAssBtn.onclick = (e) => { e.stopPropagation(); assRemoveAssunto(d.id, ass.id); };

    hdr.appendChild(chevron);
    hdr.appendChild(nameEl);
    hdr.appendChild(subCount);
    hdr.appendChild(delAssBtn);

    // Subassuntos
