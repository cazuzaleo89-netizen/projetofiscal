function tecCadernoEndSave(total, correct, elapsed){
  // Pré-preenche e salva sessão TEC
  const totInp = document.getElementById('tec-rb-total');
  const corInp = document.getElementById('tec-rb-correct');
  if(totInp) totInp.value = total;
  if(corInp) corInp.value = correct;
  if(typeof tecSession !== 'undefined'){
    tecSession.active = true;
    if(elapsed > 0) tecSession.seconds = elapsed;
  }
  // Encerra cronômetro se estiver rodando
  if(typeof cronState !== 'undefined' && cronState.running){
    try { cronStop(); } catch(e) {}
  }
  document.getElementById('tec-end-modal')?.remove();
  flash('💾 Sessão TEC salva: '+correct+'/'+total, '#10b981', 4000);
}

function tecCadernoEndContinue(){
  document.getElementById('tec-end-modal')?.remove();
  flash('▶ Continue resolvendo no TEC — o painel está monitorando.', '#4a6cf7', 4000);
}

