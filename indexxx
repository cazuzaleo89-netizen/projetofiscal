/* ── Tec session ───────────────────────────────── */
function sqStartTecSession() {
  const discId = document.getElementById('sq-tec-disc-sel')?.value;
  const disc   = state.disciplines.find(d => d.id === discId);
  if(!discId || !disc) { flash('Selecione a disciplina!','#f0b429'); return; }

  // Determine link: typed field > saved caderno
  let link = document.getElementById('sq-tec-link-inp')?.value.trim() || disc.caderno || '';
  let metaName = disc.name;
  let metaId   = '';
  let total    = 30;

  // If a meta was optionally selected, prefer its link and data
  const metaId2 = document.getElementById('sq-tec-meta-sel')?.value;
  if(metaId2) {
    let meta = null;
    (state.mwWeeks||[]).forEach(w => w.metas.forEach(m => { if(m.id===metaId2) meta=m; }));
    if(meta) {
      if(meta.link) link = meta.link;
      metaName = meta.name;
      metaId   = meta.id;
      total    = meta.goal || meta.total || 30;
    }
  }

  if(!link) { flash('Informe o link do caderno!','#f0b429'); return; }

  // Auto-save the link to the discipline if changed
  if(link !== disc.caderno) { disc.caderno = link; saveState(); }

  sqTecSession = {
    metaId,
    metaName,
    discId,
    discName:  disc.name,
    discColor: disc.color || '#22d3ee',
    link,
    total,
    startTime: Date.now(),
    returnTimerInterval: null,
    elapsed: 0,
  };

  window.open(link, '_blank');
  _sqShowReturnPanel();
}

function sqOpenTec() {
  const discId = document.getElementById('sq-tec-disc-sel')?.value;
  const disc   = state.disciplines.find(d => d.id === discId);
