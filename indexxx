function mwStartTimer(){if(!mwActiveBlock){flash('Selecione uma meta!','#f0b429');return;}mwTimer={running:true,paused:false,seconds:0,interval:setInterval(mwTick,1000)};updateMwTimerUI();}
function mwPauseTimer(){if(!mwTimer.running||mwTimer.paused)return;mwTimer.paused=true;clearInterval(mwTimer.interval);updateMwTimerUI();}
function mwResumeTimer(){if(!mwTimer.paused)return;mwTimer.paused=false;mwTimer.interval=setInterval(mwTick,1000);updateMwTimerUI();}
function mwStopTimer(){
  if(!mwTimer.running)return;clearInterval(mwTimer.interval);
  if(mwTimer.seconds>5&&mwActiveBlock){
    const now=new Date();
    state.sessions.push({id:uid(),subjectId:mwActiveBlock.discId,subject:mwActiveBlock.disc,seconds:mwTimer.seconds,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
    updateStreak(now.toDateString());
    // auto-fill time fields from timer
    const s=mwTimer.seconds;
    const hEl=document.getElementById('mw-t-h'),mEl=document.getElementById('mw-t-m'),sEl=document.getElementById('mw-t-s');
    if(hEl)hEl.value=Math.floor(s/3600)||0;
    if(mEl)mEl.value=Math.floor((s%3600)/60)||0;
    if(sEl)sEl.value=s%60||0;
    // also fill study hours (total time = question time when using timer)
    const shEl=document.getElementById('mw-study-h'),smEl=document.getElementById('mw-study-m');
    if(shEl)shEl.value=Math.floor(s/3600)||0;
    if(smEl)smEl.value=Math.floor((s%3600)/60)||0;
    mwUpdateStudyPreview();
    flash('Cronômetro salvo! Ajuste os tempos se necessário.','#10b981');
  }
  const kept=mwTimer.seconds;
  mwTimer={running:false,paused:false,seconds:kept,interval:null};
  document.getElementById('mw-timer-dig').textContent=formatTime(kept);
  updateMwTimerUI();updateStats();mwCalcPace();
}
function mwTick(){mwTimer.seconds++;const el=document.getElementById('mw-timer-dig');if(el)el.textContent=formatTime(mwTimer.seconds);}
function updateMwTimerUI(){
