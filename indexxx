function extCheckPending(){
  if(typeof chrome==='undefined'||!chrome?.storage?.local) return;
  chrome.storage.local.get(['pendingResults','triggerImport'], data => {
    const pending = data.pendingResults||[];
    if(!pending.length) return;
    // Show import notification in dashboard
    const banner = document.getElementById('ext-import-banner');
    if(banner){
      banner.style.display='';
      document.getElementById('ext-import-count').textContent = pending.length;
    }
  });
}

function extImportAll(){
  if(typeof chrome==='undefined'||!chrome?.storage?.local) return;
  chrome.storage.local.get(['pendingResults'], data => {
    const pending = data.pendingResults||[];
    if(!pending.length){ flash('Nenhum resultado pendente.','#f0b429'); return; }
    let imported=0;
    pending.forEach(r => {
      // Find meta by metaId
      let metaFound=null;
      (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ if(m.id===r.metaId)metaFound=m; }));
      if(!metaFound){
        // Try to match by name
        (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{
          if(!metaFound&&m.name.toLowerCase().includes((r.metaName||'').toLowerCase().slice(0,20)))metaFound=m;
        }));
      }
      if(!metaFound) return;
      // Register result
      const now=new Date(r.date||Date.now());
      const secs=r.elapsed||0;
      if(!state.mwResults)state.mwResults={};
      state.mwResults[metaFound.id]={
        resolved:r.total, correct:r.correct,
        manualTimeSeconds:secs, timeSeconds:secs,
        studyTimeSeconds:secs, sessionSeconds:secs,
        minPerQuestion:secs>0?+(secs/60/r.total).toFixed(2):null,
        obs:r.obs||'',
        date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
        blockName:metaFound.name, disc:metaFound.disc,
        totalQ:metaFound.total, link:metaFound.link||''
      };
      // Add session
      if(secs>0){
        state.sessions.push({
          id:uid(), subjectId:metaFound.discId, subject:metaFound.disc,
          seconds:secs, blockId:metaFound.id,
          date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
          timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
        });
      }
      // Add question session
      state.questionSessions.push({
        id:uid(), subjectId:metaFound.discId, subject:metaFound.disc,
        total:r.total, correct:r.correct, banca:'Tec Concursos',
        obs:metaFound.name.slice(0,60),
        date:now.toISOString(), dateStr:now.toLocaleDateString('pt-BR'),
        timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
      });
      imported++;
    });
    // Clear pending
    chrome.storage.local.set({ pendingResults:[] });
    saveState(); renderAll(); updateStats();
    const banner=document.getElementById('ext-import-banner');
    if(banner)banner.style.display='none';
    flash(`✅ ${imported} resultado${imported>1?'s':''} importado${imported>1?'s':''}!`,'#22d3ee');
  });
}

