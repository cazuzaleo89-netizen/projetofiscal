            onfocus="this.style.borderColor='rgba(34,211,238,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'"/>
        </div>
        <div>
          <label style="font-size:.68rem;font-weight:700;letter-spacing:1.5px;color:#6b7280;text-transform:uppercase;display:block;margin-bottom:.35rem;">EMAIL</label>
          <input id="auth-email" type="email" placeholder="seu@email.com"
            style="width:100%;background:#1f2937;border:1px solid rgba(255,255,255,.1);border-radius:9px;color:#f9fafb;font-size:.88rem;padding:.65rem .85rem;outline:none;box-sizing:border-box;font-family:inherit;transition:border-color .2s;"
            onfocus="this.style.borderColor='rgba(34,211,238,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'"
            onkeydown="if(event.key==='Enter')document.getElementById('auth-pass').focus()"/>
        </div>
        <div>
          <label style="font-size:.68rem;font-weight:700;letter-spacing:1.5px;color:#6b7280;text-transform:uppercase;display:block;margin-bottom:.35rem;">SENHA</label>
          <div style="position:relative;">
            <input id="auth-pass" type="password" placeholder="••••••••"
              style="width:100%;background:#1f2937;border:1px solid rgba(255,255,255,.1);border-radius:9px;color:#f9fafb;font-size:.88rem;padding:.65rem 2.5rem .65rem .85rem;outline:none;box-sizing:border-box;font-family:inherit;transition:border-color .2s;"
              onfocus="this.style.borderColor='rgba(34,211,238,.5)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'"
              onkeydown="if(event.key==='Enter')authSubmit()"/>
            <button onclick="authTogglePass()" style="position:absolute;right:.6rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:#6b7280;font-size:.75rem;" id="auth-pass-toggle">👁</button>
          </div>
        </div>

        <!-- Error message -->
        <div id="auth-error" style="display:none;background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);border-radius:8px;padding:.6rem .85rem;font-size:.75rem;color:#f87171;line-height:1.5;"></div>

        <!-- Submit button -->
        <button id="auth-submit-btn" onclick="authSubmit()"
          style="width:100%;padding:.85rem;border-radius:9px;border:none;background:linear-gradient(135deg,#4a6cf7,#3b5ae8);color:#fff;font-size:.9rem;font-weight:800;cursor:pointer;font-family:inherit;letter-spacing:.3px;transition:all .2s;margin-top:.25rem;"
          onmouseover="this.style.opacity='.9'" onmouseout="this.style.opacity='1'">
          Entrar
        </button>

        <!-- Forgot password -->
        <div id="auth-forgot-row" style="text-align:center;">
          <button onclick="authForgotPassword()" style="background:none;border:none;cursor:pointer;color:#6b7280;font-size:.72rem;font-family:inherit;text-decoration:underline;">
            Esqueci minha senha
          </button>
        </div>

        <!-- Divider -->
        <div style="display:flex;align-items:center;gap:.75rem;margin:.25rem 0;">
          <div style="flex:1;height:1px;background:rgba(255,255,255,.07);"></div>
          <span style="font-size:.62rem;color:#4b5563;">ou continue sem conta</span>
          <div style="flex:1;height:1px;background:rgba(255,255,255,.07);"></div>
        </div>

        <!-- Offline / demo mode -->
        <button onclick="authOfflineMode()"
          style="width:100%;padding:.75rem;border-radius:9px;border:1px solid rgba(255,255,255,.1);background:transparent;color:#9ca3af;font-size:.82rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;"
          onmouseover="this.style.borderColor='rgba(255,255,255,.25)';this.style.color='#f9fafb'" onmouseout="this.style.borderColor='rgba(255,255,255,.1)';this.style.color='#9ca3af'">
          Usar offline (dados locais)
        </button>
      </div>
    </div>

    <!-- Footer -->
    <div style="text-align:center;margin-top:1.25rem;font-size:.62rem;color:#374151;line-height:1.8;">
      Seus dados ficam salvos na nuvem e sincronizados em qualquer dispositivo.<br>
      Modo offline: dados salvos apenas neste navegador.
    </div>

    <!-- Config notice — shown when Supabase not configured -->
    <div id="auth-config-notice" style="display:none;margin-top:1rem;background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.25);border-radius:10px;padding:.85rem 1rem;font-size:.7rem;color:#fbbf24;line-height:1.7;">
      ⚙️ <strong>Configuração necessária:</strong> Para usar login online, edite o arquivo e insira suas chaves do Supabase nas variáveis <code>SUPABASE_URL</code> e <code>SUPABASE_ANON_KEY</code>.<br>
      <a href="https://supabase.com" target="_blank" style="color:#4a6cf7;">→ Criar conta gratuita no Supabase</a>
    </div>
  </div>
</div>

