// EXPORTAR PLANILHA EXCEL
// ═══════════════════════════════════════════════
function exportarExcel() {
  if (typeof XLSX === 'undefined') {
    flash('Aguarde — carregando biblioteca Excel...', '#f0b429');
    setTimeout(exportarExcel, 1500);
    return;
  }

  flash('⏳ Gerando planilha Excel...', '#22d3ee');

  const wb = XLSX.utils.book_new();
  wb.Props = {
    Title:   'Painel Fiscal — Dados de Estudo',
    Subject: 'Preparação Auditor Fiscal',
    Author:  'Painel Fiscal',
    CreatedDate: new Date(),
  };

  const cyan   = 'FF22D3EE';
  const gold   = 'FFFBBF24';
  const green  = 'FF34D399';
  const red    = 'FFEF4444';
  const purple = 'FFA78BFA';
  const dark   = 'FF0F1420';
  const hdr    = 'FF1C2438';
  const white  = 'FFF9FAFB';
  const gray   = 'FF6B7280';

  // ── Helper: styled header row ──────────────────
  function styledSheet(headers, rows, colWidths, accentColor) {
    const wsData = [headers, ...rows];
    const ws = XLSX.utils.aoa_to_sheet(wsData);

    // Header style
    headers.forEach((_, ci) => {
      const cell = ws[XLSX.utils.encode_cell({r:0, c:ci})];
      if (!cell) return;
      cell.s = {
        font:      { bold:true, color:{rgb:white}, sz:11, name:'Arial' },
        fill:      { patternType:'solid', fgColor:{rgb: accentColor || hdr} },
        alignment: { horizontal:'center', vertical:'center', wrapText:true },
        border:    { bottom:{ style:'thin', color:{rgb:cyan} } },
      };
    });

    // Data rows alternating
    rows.forEach((row, ri) => {
      row.forEach((_, ci) => {
        const cell = ws[XLSX.utils.encode_cell({r:ri+1, c:ci})];
        if (!cell) return;
        cell.s = {
          font:      { sz:10, name:'Arial' },
          fill:      { patternType:'solid', fgColor:{rgb: ri%2===0 ? 'FF161D2E' : 'FF0F1420'} },
          alignment: { vertical:'center', wrapText:true },
          border:    { bottom:{ style:'thin', color:{rgb:'FF1C2438'} } },
        };
      });
    });

    // Column widths
    ws['!cols'] = colWidths.map(w => ({wch:w}));
    ws['!rows'] = [{ hpt:22 }]; // header row height

    return ws;
  }

  // ── 1. RESUMO GERAL ───────────────────────────
  const today = new Date().toDateString();
  const totalSecs   = state.sessions.reduce((a,s)=>a+s.seconds,0);
  const todaySecs   = state.sessions.filter(s=>new Date(s.date).toDateString()===today).reduce((a,s)=>a+s.seconds,0);
  const totalQ      = state.questionSessions.reduce((a,s)=>a+s.total,0);
  const totalC      = state.questionSessions.reduce((a,s)=>a+s.correct,0);
  const taxaGeral   = totalQ > 0 ? (totalC/totalQ*100).toFixed(1)+'%' : '—';
  const missoesDone = (state.missoesCiclo?.missions||[]).filter(m=>m.status==='done').length;
  const missoesTotal= (state.missoesCiclo?.missions||[]).length;
  const geradoEm    = new Date().toLocaleString('pt-BR');

  const resumoData = [
    ['📅 Gerado em',            geradoEm],
    ['⏱ Tempo Total de Estudo', formatHM(totalSecs)],
    ['📅 Tempo Estudado Hoje',  formatHM(todaySecs)],
    ['🔥 Streak Atual',         (state.streak||0) + ' dias'],
    ['📝 Sessões de Estudo',    state.sessions.length],
    ['❓ Questões Resolvidas',  totalQ],
    ['✅ Questões Corretas',    totalC],
    ['📊 Taxa de Acerto Geral', taxaGeral],
    ['⚡ XP Total',             state.xp||0],
    ['🏆 Nível',                state.level||1],
    ['🎖 Conquistas',           (state.achievements||[]).length],
    ['🎯 Missões Concluídas',   missoesDone + ' / ' + missoesTotal],
    ['📚 Disciplinas',          state.disciplines.length],
    ['📖 Resumos',              (state.resumos||[]).length],
    ['🔁 Cartões SRS',          (state.srsCards||[]).length],
  ];

  const wsResumo = XLSX.utils.aoa_to_sheet([
    ['PAINEL FISCAL — RELATÓRIO DE ESTUDOS', ''],
    ['', ''],
    ['Indicador', 'Valor'],
    ...resumoData
  ]);
  wsResumo['!cols'] = [{wch:30},{wch:25}];
  wsResumo['!merges'] = [{ s:{r:0,c:0}, e:{r:0,c:1} }];
  // Title cell style
  if (wsResumo['A1']) wsResumo['A1'].s = {
    font: { bold:true, sz:14, color:{rgb:cyan}, name:'Arial' },
    fill: { patternType:'solid', fgColor:{rgb:dark} },
    alignment: { horizontal:'center' },
  };
  XLSX.utils.book_append_sheet(wb, wsResumo, '📊 Resumo Geral');

  // ── 2. SESSÕES DE ESTUDO ──────────────────────
  const sessoesHeaders = ['Data','Hora','Disciplina','Duração','Horas','Minutos','Segundos'];
  const sessoesRows = [...state.sessions].sort((a,b)=>new Date(b.date)-new Date(a.date)).map(s => {
    const d = state.disciplines.find(x=>x.id===s.subjectId);
    return [
      s.dateStr || new Date(s.date).toLocaleDateString('pt-BR'),
      s.timeStr || '',
      d ? d.name : s.subject || '—',
      formatHM(s.seconds),
      Math.floor(s.seconds/3600),
      Math.floor((s.seconds%3600)/60),
      s.seconds % 60,
    ];
  });

  if (sessoesRows.length) {
    const wsSessoes = styledSheet(sessoesHeaders, sessoesRows,
      [14,8,25,12,8,8,8], cyan);
    // Add totals row
    const lastRow = sessoesRows.length + 2;
    XLSX.utils.sheet_add_aoa(wsSessoes, [
      ['TOTAL', '', `${sessoesRows.length} sessões`, formatHM(totalSecs),
       '=SUM(E2:E'+lastRow+')', '=SUM(F2:F'+lastRow+')', '']
    ], {origin: -1});
    XLSX.utils.book_append_sheet(wb, wsSessoes, '⏱ Sessões de Estudo');
  }

  // ── 3. QUESTÕES ───────────────────────────────
  const qHeaders = ['Data','Hora','Disciplina','Resolvidas','Corretas','Erros','Taxa %','Banca','Observação'];
  const qRows = [...state.questionSessions].sort((a,b)=>new Date(b.date)-new Date(a.date)).map(s => {
    const d = state.disciplines.find(x=>x.id===s.subjectId);
    const erros = s.total - s.correct;
    const taxa  = s.total > 0 ? parseFloat((s.correct/s.total*100).toFixed(1)) : 0;
    return [
      s.dateStr || new Date(s.date).toLocaleDateString('pt-BR'),
      s.timeStr || '',
      d ? d.name : s.subject || '—',
      s.total, s.correct, erros, taxa,
      s.banca || '—',
      s.obs   || '',
    ];
  });

  if (qRows.length) {
    const wsQ = styledSheet(qHeaders, qRows,
      [14,8,25,12,10,8,10,14,30], gold);
    // Format taxa column as percentage
    qRows.forEach((_, ri) => {
      const cell = wsQ[XLSX.utils.encode_cell({r:ri+1, c:6})];
      if (cell) cell.z = '0.0"%"';
    });
    XLSX.utils.book_append_sheet(wb, wsQ, '❓ Questões');
  }

  // ── 4. DESEMPENHO POR DISCIPLINA ─────────────
  const discHeaders = ['Disciplina','Cor','Sessões','Tempo Total','Horas','Questões','Acertos','Taxa %','Meta Semanal (h)'];
  const discRows = state.disciplines.map(d => {
    const sess = state.sessions.filter(s=>s.subjectId===d.id);
    const qs   = state.questionSessions.filter(s=>s.subjectId===d.id);
    const secs = sess.reduce((a,s)=>a+s.seconds,0);
    const qtot = qs.reduce((a,s)=>a+s.total,0);
    const qacc = qs.reduce((a,s)=>a+s.correct,0);
    const taxa = qtot > 0 ? parseFloat((qacc/qtot*100).toFixed(1)) : 0;
    return [
      d.name, d.color,
      sess.length, formatHM(secs),
      parseFloat((secs/3600).toFixed(2)),
      qtot, qacc, taxa,
      d.weeklyGoal || 0,
    ];
  });

  const wsDisc = styledSheet(discHeaders, discRows,
    [25,10,10,14,8,12,10,10,14], purple);
  XLSX.utils.book_append_sheet(wb, wsDisc, '📚 Por Disciplina');

  // ── 5. METAS SEMANAIS ─────────────────────────
  const metaHeaders = ['Semana','Disciplina','Meta','Tipo','Prioridade','Total Qs','Meta Qs','Concluído','Acerto %','Tempo (s)'];
  const metaRows = [];
  (state.mwWeeks||[]).forEach(w => {
    (w.metas||[]).forEach(m => {
      const res = (state.mwResults||{})[m.id];
      const d = state.disciplines.find(x=>x.id===m.discId);
      metaRows.push([
        w.name || '—',
        d ? d.name : m.disc || '—',
        m.name || '—',
        m.tipo === 'reforco' ? 'Reforço' : 'Novo',
        m.priority || '—',
        res ? (res.total||0) : 0,
        m.goal || 0,
        res ? (res.resolved ? 'Sim' : 'Não') : 'Não',
        res && res.total > 0 ? parseFloat((res.correct/res.total*100).toFixed(1)) : 0,
        res ? (res.timeSeconds||0) : 0,
      ]);
    });
  });

  if (metaRows.length) {
    const wsMetas = styledSheet(metaHeaders, metaRows,
      [18,22,30,10,10,10,10,10,10,10], green);
    XLSX.utils.book_append_sheet(wb, wsMetas, '🎯 Metas Semanais');
  }

  // ── 6. MISSÕES ATIVAS ─────────────────────────
  const missHeaders = ['Data','Dia','Disciplina','Título','Tipo','Duração (min)','Status','Concluído em','Questões','Acertos','Erros'];
  const missRows = (state.missoesCiclo?.missions||[]).map(m => [
    m.date || '—',
    m.date ? new Date(m.date+'T12:00:00').toLocaleDateString('pt-BR',{weekday:'long'}) : '—',
    m.discName || '—',
    m.title || '—',
    TIPO_LABELS?.[m.tipo] || m.tipo || '—',
    m.durationMins || 0,
    m.status === 'done' ? 'Concluída' : 'Pendente',
    m.completedAt ? new Date(m.completedAt).toLocaleString('pt-BR') : '—',
    m.resolved || 0,
    m.acertos  || 0,
    m.erros    || 0,
  ]);

  if (missRows.length) {
    const wsMiss = styledSheet(missHeaders, missRows,
      [12,18,22,28,18,14,12,20,10,10,8], gold);
    XLSX.utils.book_append_sheet(wb, wsMiss, '⚡ Missões Ativas');
  }

  // ── 7. REVISÕES ESPAÇADAS (SRS) ───────────────
  if ((state.srsCards||[]).length) {
    const srsHeaders = ['Disciplina','Meta','Intervalo (dias)','Próxima Revisão','Repetições','Facilidade','Criado em'];
    const srsRows = (state.srsCards||[]).map(card => {
      const d = state.disciplines.find(x=>x.id===card.discId);
      return [
        d ? d.name : card.disc || '—',
        card.meta || '—',
        card.interval || 1,
        card.nextReview ? new Date(card.nextReview).toLocaleDateString('pt-BR') : '—',
        card.repetitions || 0,
        card.easeFactor ? card.easeFactor.toFixed(2) : '2.50',
        card.createdAt  ? new Date(card.createdAt).toLocaleDateString('pt-BR') : '—',
      ];
    });
    const wsSRS = styledSheet(srsHeaders, srsRows,
      [25,35,14,18,12,12,14], cyan);
    XLSX.utils.book_append_sheet(wb, wsSRS, '🔁 Revisões Espaçadas');
  }

  // ── 8. FILA DE REVISÃO ────────────────────────
  if ((state.filaRevisao||[]).length) {
    const filaHeaders = ['Descrição','Disciplina','Intervalo (min)','Adicionado em','Vence em','Status','Link'];
    const filaRows = (state.filaRevisao||[]).map(item => [
      item.desc || '—',
      item.discName || '—',
      item.intervalMins || 0,
      item.addedAt ? new Date(item.addedAt).toLocaleString('pt-BR') : '—',
      item.dueAt   ? new Date(item.dueAt).toLocaleString('pt-BR')   : '—',
      item.status === 'done' ? 'Revisada' : item.status === 'ready' ? 'Pronta' : 'Aguardando',
      item.link || '',
    ]);
    const wsFila = styledSheet(filaHeaders, filaRows,
      [30,22,14,20,20,12,50], red);
    XLSX.utils.book_append_sheet(wb, wsFila, '⏱ Fila de Revisão');
  }

  // ── 9. RESUMOS ────────────────────────────────
  if ((state.resumos||[]).length) {
    const resumosHeaders = ['Título','Disciplina','Conteúdo (texto)','Criado em'];
    const resumosRows = (state.resumos||[]).map(r => {
      const d = state.disciplines.find(x=>x.id===r.discId);
      // Strip HTML tags for Excel
      const tmp = document.createElement('div');
      tmp.innerHTML = r.content || '';
      const texto = tmp.textContent || tmp.innerText || '';
      return [
        r.title || '—',
        d ? d.name : '—',
        texto.slice(0, 500),
        r.createdAt ? new Date(r.createdAt).toLocaleDateString('pt-BR') : '—',
      ];
    });
    const wsRes = styledSheet(resumosHeaders, resumosRows,
      [30,22,80,14], purple);
    XLSX.utils.book_append_sheet(wb, wsRes, '📖 Resumos');
  }

  // ── 10. XP & CONQUISTAS ───────────────────────
  const xpHeaders = ['Evento','XP','Data'];
  const xpRows = [...(state.xpHistory||[])].reverse().map(x => [
    x.reason || x.desc || '—',
    x.amount || x.xp || 0,
    x.date ? new Date(x.date).toLocaleString('pt-BR') : '—',
  ]);

  const achHeaders  = ['Conquista','Descrição','Desbloqueada em'];
  const achRows = (state.achievements||[]).map(a => [
    a.name || a.id || '—',
    a.desc || '—',
    a.unlockedAt ? new Date(a.unlockedAt).toLocaleDateString('pt-BR') : '—',
  ]);

  if (xpRows.length || achRows.length) {
    const xpData = [
      ['XP TOTAL', state.xp||0, ''],
      ['NÍVEL',    state.level||1, ''],
      ['', '', ''],
      ...( xpRows.length ? [xpHeaders, ...xpRows] : [] ),
      ['', '', ''],
      ...( achRows.length ? [achHeaders, ...achRows] : [] ),
    ];
    const wsXP = XLSX.utils.aoa_to_sheet(xpData);
    wsXP['!cols'] = [{wch:40},{wch:10},{wch:20}];
    XLSX.utils.book_append_sheet(wb, wsXP, '🏆 XP e Conquistas');
  }

  // ── Gerar e baixar ────────────────────────────
  const now = new Date();
  const stamp = `${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}`;
  const filename = `PainelFiscal_Relatorio_${stamp}.xlsx`;

  XLSX.writeFile(wb, filename);
  flash(`✅ Planilha "${filename}" baixada com sucesso! (${wb.SheetNames.length} abas)`, '#22d3ee');
}

