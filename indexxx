function qH(qs){return+(qs*2.5/60).toFixed(1);}

function dashInitWeekSelector(){
  const sel=document.getElementById('dash-week-select');
  if(!sel)return;
  const weeks=state.mwWeeks||[];
  sel.innerHTML='';
  if(!weeks.length){sel.innerHTML='<option value="0">Sem semanas</option>';return;}
  weeks.forEach((w,i)=>{
    const opt=new Option(`S${i+1} — ${w.name}`,i);
    sel.appendChild(opt);
  });
  // default to active week in metas page
  dashWeekIdx=Math.min(mwActiveWeek,weeks.length-1);
