function cronUpdateTodayLog() {
  const today = new Date().toDateString();

  // === Sessões de estudo ===
  const todaySessions = state.sessions.filter(s => {
    const d = new Date(s.date);
    if (_cronLogRange === '3d') { const cut = Date.now()-3*86400000; return d.getTime()>=cut; }
    if (_cronLogRange === '7d') { const cut = Date.now()-7*86400000; return d.getTime()>=cut; }
    if (_cronLogRange === 'custom') {
      const from = document.getElementById('clog-from')?.value;
      const to   = document.getElementById('clog-to')?.value;
      const ds   = s.date.split('T')[0];
      return (!from || ds>=from) && (!to || ds<=to);
    }
    return d.toDateString() === today;
  });
  const totalSecs = todaySessions.reduce((a,s)=>a+s.seconds,0);
  set('t-today-h', formatHM(totalSecs));
  set('t-today-s', todaySessions.length);
  // Update KPI label based on range
  const studLabel = _cronLogRange==='7d' ? 'Últ. 7 Dias' : _cronLogRange==='3d' ? 'Últ. 3 Dias' : _cronLogRange==='custom' ? 'Período' : 'Estudadas';
  const studLabelEl = document.querySelector('#t-today-h + div');
  if (studLabelEl) studLabelEl.textContent = studLabel;
  const showDate = _cronLogRange !== 'today';
  const list = document.getElementById('t-today-list');
  if (list) {
    if (!todaySessions.length) { list.innerHTML='<div class="empty">Nenhuma sessão hoje.</div>'; }
    else {
      const sorted = [...todaySessions].sort((a,b)=>new Date(b.date)-new Date(a.date));
      let html = '';
      let lastDateStr = null;
      sorted.slice(0,30).forEach(s => {
        const isManual=s.manual||s.timeStr==='manual';
        const qInfo = s.resolved>0 ? `${s.acertos||0}/${s.resolved} acertos` : (s.totalQuestoes>0 ? `${s.totalQuestoes} questões` : '');
        if (showDate) {
          const ds = s.date ? s.date.split('T')[0] : '';
          if (ds !== lastDateStr) {
            lastDateStr = ds;
            const dObj = ds ? new Date(ds+'T12:00:00') : null;
            const dLabel = dObj ? dObj.toLocaleDateString('pt-BR',{weekday:'short',day:'numeric',month:'short'}) : ds;
            html += `<div style="font-size:.55rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#475569;padding:4px 0 2px;border-top:1px solid rgba(255,255,255,.05);margin-top:4px;">${dLabel}</div>`;
          }
        }
        html += `<div class="log-item" style="display:flex;align-items:center;gap:6px;">
          <div style="flex:1;min-width:0;">
            <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" class="log-subj">${s.subject}${isManual?' <span style="font-size:.5rem;color:var(--gold);font-weight:700;">MANUAL</span>':''}${showDate?`<span style="font-size:.5rem;color:#475569;margin-left:4px;">${s.dateStr||''}</span>`:''}</div>
            ${s.assunto?`<div style="font-size:.56rem;color:var(--muted3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:1px;">📌 ${s.assunto}${qInfo?' · '+qInfo:''}</div>`
              :(qInfo?`<div style="font-size:.56rem;color:var(--muted3);margin-top:1px;">📊 ${qInfo}</div>`:'') }
            ${s.cadernoUrl?`<a href="${s.cadernoUrl}" target="_blank" style="font-size:.52rem;color:var(--cyan);display:block;margin-top:1px;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${s.cadernoUrl}">🔗 ${s.cadernoNome||'Caderno TEC'}</a>`:''}
          </div>
          <span class="log-dur">${formatHM(s.seconds)}</span>
          <span style="color:var(--muted2);font-size:.6rem;min-width:38px;text-align:right;">${isManual?'✏️':(s.timeStr||'')}</span>
          <button onclick="cronEditSession('${s.id}')" title="Editar" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:.7rem;padding:1px 3px;transition:color .15s;" onmouseenter="this.style.color='var(--cyan)'" onmouseleave="this.style.color='var(--muted)'">✏️</button>
          <button onclick="cronDeleteSession('${s.id}')" title="Excluir" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:.7rem;padding:1px 3px;transition:color .15s;" onmouseenter="this.style.color='var(--red)'" onmouseleave="this.style.color='var(--muted)'">🗑</button>
        </div>`;
      });
      list.innerHTML = html;
    }
  }

  // === Questões de hoje ===
  const todayQ = (state.questionSessions||[]).filter(s=>new Date(s.date).toDateString()===today);
  const totQ = todayQ.reduce((a,s)=>a+s.total,0);
  const corQ = todayQ.reduce((a,s)=>a+s.correct,0);
  const rateQ = totQ>0?Math.round(corQ/totQ*100)+'%':'—';
  const qtEl=document.getElementById('t-today-qt'); if(qtEl) qtEl.textContent=totQ;
  const qcEl=document.getElementById('t-today-qc'); if(qcEl) qcEl.textContent=corQ;
  const qrEl=document.getElementById('t-today-qr'); if(qrEl) qrEl.textContent=rateQ;

  const qlist = document.getElementById('t-today-qlist');
  if (qlist) {
    if (!todayQ.length) { qlist.innerHTML='<div class="empty">Nenhuma questão hoje.</div>'; }
    else {
      qlist.innerHTML = [...todayQ].reverse().slice(0,15).map(s=>{
        const rate=s.total>0?Math.round(s.correct/s.total*100):0;
        const rc=rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
        const isManual=s.banca==='Manual'||s.timeStr==='manual';
        return `<div class="log-item" style="display:flex;align-items:center;gap:6px;">
          <span class="log-subj" style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${s.subject}${isManual?' <span style="font-size:.5rem;color:var(--gold);font-weight:700;">MANUAL</span>':''}</span>
          <span style="font-family:var(--mono);font-size:.68rem;font-weight:700;color:${rc};">${s.correct}/${s.total} (${rate}%)</span>
          <button onclick="cronEditQSession('${s.id}')" title="Editar" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:.7rem;padding:1px 3px;transition:color .15s;" onmouseenter="this.style.color='var(--cyan)'" onmouseleave="this.style.color='var(--muted)'">✏️</button>
          <button onclick="cronDeleteQSession('${s.id}')" title="Excluir" style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:.7rem;padding:1px 3px;transition:color .15s;" onmouseenter="this.style.color='var(--red)'" onmouseleave="this.style.color='var(--muted)'">🗑</button>
        </div>`;
      }).join('');
    }
  }
}

