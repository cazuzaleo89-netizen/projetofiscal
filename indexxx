    const fullUrl = 'https://www.tecconcursos.com.br/questoes/filtrar?cadernoBase=' + data.cadernoBase + (data.idPasta ? '&idPasta=' + data.idPasta : '');
    state.tecCaderno = { url: fullUrl, cadernoBase: data.cadernoBase, idPasta: data.idPasta || '' };
