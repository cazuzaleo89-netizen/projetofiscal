// ── Helpers ───────────────────────────────────
function consDateKey(d) {
  return d.getFullYear()+'-'+(d.getMonth()+1).toString().padStart(2,'0')+'-'+d.getDate().toString().padStart(2,'0');
}

function consGetDayMap() {
  // Returns {dateKey: {secs, qs, correct}}
  const map = {};
  (state.sessions||[]).forEach(s=>{
    const k = s.date ? s.date.slice(0,10) : '';
    if(!k) return;
    if(!map[k]) map[k]={secs:0,qs:0,correct:0};
    map[k].secs += s.seconds||0;
  });
  (state.questionSessions||[]).forEach(s=>{
    const k = s.date ? s.date.slice(0,10) : '';
    if(!k) return;
    if(!map[k]) map[k]={secs:0,qs:0,correct:0};
    map[k].qs += s.total||0;
    map[k].correct += s.correct||0;
  });
  return map;
}

function consLevel(secs) {
  if(!secs) return 0;
  const m = secs/60;
  if(m<30) return 1;
  if(m<60) return 2;
  if(m<120) return 3;
  if(m<180) return 4;
  return 5;
}

function consCalcStreak(dayMap) {
  const today = new Date(); today.setHours(0,0,0,0);
  let cur=0, best=0, tmp=0, prev=null;
  // Calculate best streak from all data
  const keys = Object.keys(dayMap).sort();
  keys.forEach(k=>{
    const d = new Date(k+'T12:00:00');
    if(prev){
      const diff=(d-prev)/86400000;
      if(diff===1) tmp++;
      else tmp=1;
    } else tmp=1;
    if(tmp>best) best=tmp;
    prev=d;
  });
  // Current streak (from today backwards)
  let check = new Date(today);
  for(let i=0;i<1000;i++){
    const k=consDateKey(check);
    if(dayMap[k]) { cur++; check.setDate(check.getDate()-1); }
    else if(i===0){ check.setDate(check.getDate()-1); const k2=consDateKey(check); if(dayMap[k2]){cur++;check.setDate(check.getDate()-1);}else break; }
    else break;
  }
  return {cur,best};
}

// ── KPIs ──────────────────────────────────────
function consRenderKpis() {
  const dayMap = consGetDayMap();
  const {cur,best} = consCalcStreak(dayMap);

  const totalDays = Object.keys(dayMap).length;

  // This month consistency
  const now = new Date();
  const daysInMonth = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
  let monthDays = 0;
  for(let d=1;d<=now.getDate();d++){
    const k=now.getFullYear()+'-'+(now.getMonth()+1).toString().padStart(2,'0')+'-'+d.toString().padStart(2,'0');
    if(dayMap[k]) monthDays++;
  }
  const consPct = now.getDate()>0 ? Math.round(monthDays/now.getDate()*100) : 0;

  // Average time on study days
  const totalSecs = Object.values(dayMap).reduce((a,d)=>a+d.secs,0);
  const avgSecs = totalDays>0 ? Math.round(totalSecs/totalDays) : 0;
  const avgH = Math.floor(avgSecs/3600);
  const avgM = Math.floor((avgSecs%3600)/60);
  const avgStr = avgH>0 ? `${avgH}h${avgM.toString().padStart(2,'0')}m` : `${avgM}m`;

  const set = (id,v)=>{const e=document.getElementById(id);if(e)e.textContent=v;};
  set('cons-k-streak',cur);
  set('cons-k-streak-sub',cur===1?'1 dia consecutivo':cur+' dias consecutivos');
  set('cons-k-best',best);
  set('cons-k-best-sub',`recorde: ${best} dias`);
  set('cons-k-days',totalDays);
  set('cons-k-days-sub',totalSecs>0?formatHM(totalSecs)+' total':'no total');
  set('cons-k-cons',consPct+'%');
  set('cons-k-avg',avgSecs>0?avgStr:'—');

  // Streak fire color
  const streakEl=document.getElementById('cons-k-streak');
  if(streakEl){
    if(cur>=30) streakEl.style.color='#f0a500';
    else if(cur>=7) streakEl.style.color='#f97316';
    else if(cur>=3) streakEl.style.color='#fb923c';
    else streakEl.style.color='var(--muted2)';
  }
}

// ── Heatmap ───────────────────────────────────
function consRenderHeatmap() {
  const grid = document.getElementById('cons-hmap');
  const monthsEl = document.getElementById('cons-months');
  const subEl = document.getElementById('cons-hmap-subtitle');
  if(!grid) return;

  const dayMap = consGetDayMap();
  const today = new Date(); today.setHours(0,0,0,0);

  // Year range
  const year = today.getFullYear() - _consYear;
  const startDate = new Date(year, 0, 1);
  // Align to Monday of the week containing Jan 1
  const startDow = startDate.getDay(); // 0=Sun
  const startMon = new Date(startDate);
  const adj = startDow===0 ? 1 : (startDow===1 ? 0 : -(startDow-1));
  startMon.setDate(startMon.getDate() + (startDow===0 ? -6 : -(startDow-1)));

  const endDate = new Date(year, 11, 31);

  // Calculate total weeks
  const totalDays = Math.ceil((endDate-startMon)/86400000)+1;
  const totalWeeks = Math.ceil(totalDays/7);

  // Build month label positions
  const months=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  let monthHtml='';
  let curMonth=-1;
  const weekWidths=[];
  let d=new Date(startMon);
  for(let w=0;w<totalWeeks;w++){
    const m=d.getMonth();
    if(m!==curMonth){
      monthHtml+=`<div class="hmap-month-lbl" style="min-width:${16*(w===0?1:1)}px;padding-left:2px;">${months[m]}</div>`;
      curMonth=m;
    } else {
      monthHtml+=`<div class="hmap-month-lbl" style="min-width:16px;"></div>`;
    }
    d.setDate(d.getDate()+7);
  }
  monthsEl.innerHTML=monthHtml;

  // Build grid
  grid.innerHTML='';
  grid.style.gridAutoColumns='13px';

  let studyDays=0, totalStudySecs=0;
  let curW=-1, colEl=null;
  d=new Date(startMon);

  for(let w=0;w<totalWeeks;w++){
    for(let dow=0;dow<7;dow++){
      const cell=document.createElement('div');
      cell.className='hmap-cell';
      const k=consDateKey(d);
      const data=dayMap[k]||{secs:0,qs:0,correct:0};
      const lvl=consLevel(data.secs);
      cell.setAttribute('data-l',lvl);

      const isThisYear=d.getFullYear()===year;
      if(!isThisYear) cell.setAttribute('data-l','0');
      const isFuture=d>today;
      if(isFuture){cell.setAttribute('data-l','0');cell.style.opacity='.25';}

      if(!isFuture && isThisYear && data.secs>0){
        studyDays++;
        totalStudySecs+=data.secs;
      }

      // Tooltip
      const dateStr=d.toLocaleDateString('pt-BR',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
      const timeStr=data.secs>0?formatHM(data.secs):'Sem estudo';
      const qsStr=data.qs>0?`${data.qs} questões`:'';
      cell.addEventListener('mouseenter',function(e){
        const tt=document.getElementById('hmap-tooltip');
        const ttDate=document.getElementById('hmap-tt-date');
        const ttTime=document.getElementById('hmap-tt-time');
        const ttQs=document.getElementById('hmap-tt-qs');
        if(tt){
          ttDate.textContent=dateStr;
          ttTime.textContent='⏱ '+timeStr;
          ttQs.textContent=qsStr?'✎ '+qsStr:'';
          tt.classList.add('show');
        }
      });
      cell.addEventListener('mousemove',function(e){
        const tt=document.getElementById('hmap-tooltip');
        if(tt){tt.style.left=(e.clientX+14)+'px';tt.style.top=(e.clientY-10)+'px';}
      });
      cell.addEventListener('mouseleave',function(){
        const tt=document.getElementById('hmap-tooltip');
        if(tt)tt.classList.remove('show');
      });

      grid.appendChild(cell);
      d.setDate(d.getDate()+1);
    }
  }

  if(subEl){
    const pct=Math.round(studyDays/365*100);
    subEl.textContent=`${year} · ${studyDays} dias estudados · ${pct}% do ano · ${formatHM(totalStudySecs)} total`;
  }
}

// ── Monthly bars ──────────────────────────────
function consRenderMonthly() {
  const barsEl=document.getElementById('cons-mbars');
  const labelsEl=document.getElementById('cons-mbar-labels');
  if(!barsEl) return;

  const dayMap=consGetDayMap();
  const now=new Date();
  const months=['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];

  // Last 12 months
  const data=[];
  for(let i=11;i>=0;i--){
    const d=new Date(now.getFullYear(),now.getMonth()-i,1);
    let secs=0;
    const daysInM=new Date(d.getFullYear(),d.getMonth()+1,0).getDate();
    for(let day=1;day<=daysInM;day++){
      const k=d.getFullYear()+'-'+(d.getMonth()+1).toString().padStart(2,'0')+'-'+day.toString().padStart(2,'0');
      if(dayMap[k]) secs+=dayMap[k].secs;
    }
    data.push({lbl:months[d.getMonth()],secs,month:d.getMonth(),year:d.getFullYear()});
  }

  const maxSecs=Math.max(...data.map(d=>d.secs),1);
  const nowMonth=now.getMonth(),nowYear=now.getFullYear();

  barsEl.innerHTML=data.map(d=>{
    const pct=Math.round(d.secs/maxSecs*100);
    const isCurrent=(d.month===nowMonth&&d.year===nowYear);
    const h=Math.floor(d.secs/3600);
    const mins=Math.floor((d.secs%3600)/60);
    const timeStr=h>0?`${h}h${mins.toString().padStart(2,'0')}m`:(d.secs>0?`${mins}m`:'—');
    const color=isCurrent?'linear-gradient(180deg,var(--cyan),rgba(74,108,247,.3))':'linear-gradient(180deg,var(--green),rgba(52,211,153,.2))';
    return `<div class="mbar" style="height:${Math.max(pct,d.secs>0?4:1)}%;background:${color};${isCurrent?'box-shadow:0 0 8px rgba(74,108,247,.3);':''}" title="${d.lbl}: ${timeStr}"></div>`;
  }).join('');

  labelsEl.innerHTML=data.map((d,i)=>`<div class="mbar-lbl" ${i===11?'style="color:var(--cyan);font-weight:700;"':''}>${d.lbl}</div>`).join('');
}

