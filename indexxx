      caderno:      _cronInv.caderno  || data.caderno  || '',
      materia:      _cronInv.materia  || '',
      assunto:      _cronInv.assunto  || '',
      totalQuestoes: _cronInv.total   || 0,
    });
  }

  // ── 🚀 AUTO-START: cronômetro inicia sozinho se disciplina detectada ──
  tecAutoStartCron(data.materia || '');
}

// Match disciplina pela matéria do TEC e auto-inicia cronômetro
function tecAutoStartCron(materia) {
  if (state.tecAutoStart === false) return;
  if (typeof cronState === 'undefined') return;
  if (cronState.running || cronState.paused) return; // já rodando — não interferir
  if (!materia) return;
  // Match case-insensitive (mesma lógica de ~17319)
  const matLower = materia.toLowerCase().replace(/^dir\.\s*/,'');
  const disc = state.disciplines.find(d => {
    const n = d.name.toLowerCase().replace(/^dir\.\s*/,'');
    return n.includes(matLower) || matLower.includes(n);
  });
  if (!disc) {
    flash('📡 TEC detectou "'+materia+'" mas não há disciplina cadastrada.', '#f0b429', 5000);
    return;
  }
  // Atualiza dropdown e dispara cronStart
  const sel = document.getElementById('cron-disc-sel');
  if (sel) sel.value = disc.id;
  cronUpdateDisc();
  try {
    cronStart();
    flash('▶ Cronômetro iniciado em '+disc.name+' (auto via TEC)', disc.color || '#10b981', 4000);
  } catch(e) { console.warn('Auto-start falhou:', e); }
}

// Envia stats ao tab TEC para o widget rico
function tecPushStats() {
  if (!tecTabWindow || tecTabWindow.closed) return;
  if (state.tecRichWidget === false) return;
  if (typeof cronState === 'undefined') return;
  const stats = {
    type: 'TEC_STATS_UPDATE',
    elapsed: cronState.elapsed || 0,
    acertos: cronState.acertos || 0,
    erros: cronState.erros || 0,
    resolved: cronState.resolved || 0,
    running: !!cronState.running,
    paused: !!cronState.paused,
    discName: cronState.discName || '',
  };
  try { tecTabWindow.postMessage(stats, '*'); } catch(e) {}
}

// Envia notificação de fila ready para o tab TEC
function tecPushFilaReady(items) {
  if (!tecTabWindow || tecTabWindow.closed) return;
  if (!items || !items.length) return;
  try {
    tecTabWindow.postMessage({
      type: 'PF_FILA_READY',
      items: items.map(i => ({
        id: i.id, qid: i.qid || '', link: i.link || '',
        desc: (i.desc || i.assunto || 'Questão').slice(0, 80),
        erros: i.erros || 1,
      }))
    }, '*');
  } catch(e) {}
}

function cronInvUpdate() {
  const card = document.getElementById('cron-investida-card');
  if (!card || card.style.display === 'none') return;

  const ace  = cronState.acertos  || 0;
  const err  = cronState.erros    || 0;
  const res  = cronState.resolved || (ace + err);
  const tot  = _cronInv.total;
  const pct  = tot > 0 ? Math.min(100, Math.round(res / tot * 100)) : 0;
  const rate = (ace + err) > 0 ? Math.round(ace / (ace + err) * 100) : null;

  const respEl = document.getElementById('cron-inv-resp');
  const aceEl  = document.getElementById('cron-inv-ace');
  const errEl  = document.getElementById('cron-inv-err');
  const barEl  = document.getElementById('cron-inv-bar');
  const rateRow = document.getElementById('cron-inv-rate-row');
  const rateEl  = document.getElementById('cron-inv-rate');
  const badge   = document.getElementById('cron-inv-totalbadge');

  if (respEl) respEl.textContent = res;
  if (aceEl)  aceEl.textContent  = ace;
  if (errEl)  errEl.textContent  = err;
  if (barEl)  barEl.style.width  = pct + '%';
  // Cor da barra conforme taxa de acerto
  if (barEl) {
    barEl.style.background = rate === null ? 'linear-gradient(90deg,#22d3ee,#8b5cf6)'
      : rate >= 70 ? 'linear-gradient(90deg,#10b981,#22d3ee)'
      : rate >= 50 ? 'linear-gradient(90deg,#f59e0b,#22d3ee)'
      : 'linear-gradient(90deg,#ef4444,#f59e0b)';
  }
  if (tot > 0 && badge) badge.textContent = res + '/' + tot;
  if (rateRow) rateRow.style.display = rate !== null ? '' : 'none';
  if (rateEl && rate !== null) {
    rateEl.textContent = rate + '%';
    rateEl.style.color = rate >= 70 ? '#34d399' : rate >= 50 ? '#f59e0b' : '#f87171';
  }
}

