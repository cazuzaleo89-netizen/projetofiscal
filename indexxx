  }).join('');
}

// ── Weekly table ──────────────────────────────
function consRenderWeekTable() {
  const tbody=document.getElementById('cons-weeks-body');
  const subEl=document.getElementById('cons-weeks-subtitle');
  if(!tbody) return;

  const dayMap=consGetDayMap();
  const today=new Date(); today.setHours(0,0,0,0);

  // Build weeks (last 16 weeks)
  const weeks=[];
  for(let w=0;w<16;w++){
    // Monday of w weeks ago
    const mon=new Date(today);
    const dow=today.getDay()===0?6:today.getDay()-1;
    mon.setDate(today.getDate()-dow-w*7);
    const sun=new Date(mon); sun.setDate(mon.getDate()+6);

    let secs=0,qs=0,correct=0,days=0;
    for(let d=0;d<7;d++){
      const dd=new Date(mon); dd.setDate(mon.getDate()+d);
      const k=consDateKey(dd);
      if(dayMap[k]){
        secs+=dayMap[k].secs||0;
        qs+=dayMap[k].qs||0;
        correct+=dayMap[k].correct||0;
        if(dayMap[k].secs>0||dayMap[k].qs>0) days++;
      }
    }
    const isCurrentWeek=(w===0);
    weeks.push({mon,sun,secs,qs,correct,days,isCurrentWeek});
  }

  if(subEl) subEl.textContent=`Últimas ${weeks.filter(w=>w.secs>0||w.qs>0).length} semanas com atividade`;

  tbody.innerHTML=weeks.map(w=>{
    if(w.secs===0&&w.qs===0&&!w.isCurrentWeek){
      // Show empty weeks only for recent ones
      if(weeks.indexOf(w)>3) return '';
    }
    const rate=w.qs>0?Math.round(w.correct/w.qs*100):null;
    const rc=rate===null?'var(--muted2)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const score=consWeekScore(w.days,w.secs,w.qs,rate);
    const scoreColor=score>=80?'var(--green)':score>=60?'var(--gold)':score>=40?'var(--orange)':'var(--muted2)';
    const monStr=w.mon.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
    const sunStr=w.sun.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
    return `<tr style="border-bottom:1px solid var(--border);${w.isCurrentWeek?'background:rgba(74,108,247,.05);':''}">
      <td style="padding:.5rem .6rem;">
        <span style="font-size:.72rem;font-weight:600;">${monStr} – ${sunStr}</span>
        ${w.isCurrentWeek?'<span style="font-size:.5rem;background:rgba(74,108,247,.2);color:var(--cyan);border:1px solid rgba(74,108,247,.3);border-radius:4px;padding:1px 5px;margin-left:.4rem;font-weight:700;">ATUAL</span>':''}
      </td>
      <td style="text-align:center;padding:.5rem .6rem;">
        <span style="font-family:var(--mono);font-size:.8rem;font-weight:700;color:${w.days>=5?'var(--green)':w.days>=3?'var(--gold)':w.days>0?'var(--orange)':'var(--muted2)'};">${w.days}</span>
        <span style="font-size:.58rem;color:var(--muted2);">/7</span>
      </td>
      <td style="text-align:center;padding:.5rem .6rem;font-family:var(--mono);font-size:.75rem;color:var(--text);">${w.secs>0?formatHM(w.secs):'—'}</td>
      <td style="text-align:center;padding:.5rem .6rem;font-family:var(--mono);font-size:.75rem;">${w.qs||'—'}</td>
      <td style="text-align:center;padding:.5rem .6rem;"><span style="font-family:var(--mono);font-size:.75rem;font-weight:700;color:${rc};">${rate!==null?rate+'%':'—'}</span></td>
      <td style="text-align:center;padding:.5rem .6rem;"><span style="font-family:var(--mono);font-size:.82rem;font-weight:700;color:${scoreColor};">${score>0?score:'—'}</span></td>
    </tr>`;
  }).filter(Boolean).join('');
}

function consWeekScore(days, secs, qs, rate) {
  if(days===0&&secs===0&&qs===0) return 0;
  let s=0;
  s += Math.min(40, Math.round(days/7*40)); // 40pts for 7 days
  s += Math.min(30, Math.round(secs/3600/14*30)); // 30pts for 14h
  if(qs>0 && rate!==null) s += Math.round(rate*0.3); // 30pts for accuracy
  return Math.min(100,s);
}

