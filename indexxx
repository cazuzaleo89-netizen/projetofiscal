function backupImport(event){
  const file = event.target.files[0];
  if(!file){ return; }

  const reader = new FileReader();
  reader.onload = function(e){
    try{
      const imported = JSON.parse(e.target.result);

      // Validate — must have at least one key we recognise
      const validKeys = ['sessions','questionSessions','mwWeeks','disciplines','xp'];
      const hasValid  = validKeys.some(k => k in imported);
      if(!hasValid) throw new Error('Arquivo não parece ser um backup do Painel Fiscal.');

      // Stats summary for confirm
      const sessions   = imported.sessions?.length||0;
      const questions  = imported.questionSessions?.length||0;
      const metas      = Object.keys(imported.mwResults||{}).length;
      const xp         = imported.xp||0;
      const weeks      = imported.mwWeeks?.length||0;

      if(!confirm(
        `Importar backup?\n\n` +
        `📋 ${sessions} sessões de estudo\n` +
        `❓ ${questions} sessões de questões\n` +
        `🎯 ${metas} metas com resultado\n` +
        `📅 ${weeks} semanas\n` +
        `⚡ ${xp} XP\n\n` +
        `⚠️ Isso VAI SUBSTITUIR todos os dados atuais.`
      )) return;

      // Merge carefully — preserve disciplines and edital if imported doesn't have them
      Object.assign(state, imported);

      // Ensure required arrays exist
      if(!state.disciplines?.length) ensureDisciplines();
      if(!state.mwWeeks)        state.mwWeeks        = [];
      if(!state.questionSessions) state.questionSessions = [];
      if(!state.sessions)       state.sessions       = [];
      if(!state.srsCards)       state.srsCards       = [];
      if(!state.resumos)        state.resumos        = [];
      if(!state.achievements)   state.achievements   = [];
      if(!state.focusHistory)   state.focusHistory   = [];
      if(!state.xpHistory)      state.xpHistory      = [];
      if(!state.edital)         state.edital         = {weights:{},concurso:''};

      saveState();
      renderAll();
      updateStats();
      try{ renderProvaCountdown(); }catch(e){}
      try{ arenaEnsure(); arenaUpdateNavBadge(); }catch(e){}
      backupUpdateStats();

      flash(`✅ Backup restaurado! ${sessions} sessões · ${questions} questões · ${xp} XP`, '#10b981');

    } catch(err){
      alert('Erro ao importar: ' + err.message);
      flash('❌ Erro ao importar backup.', '#ef4444');
    }
    // Reset input so same file can be selected again
    event.target.value = '';
  };
  reader.readAsText(file);
}

