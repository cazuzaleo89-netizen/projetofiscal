function assEditName(discId, assId, el) {
  const d = state.disciplines.find(x => x.id === discId);
  const ass = (d?.assuntos||[]).find(x => x.id === assId);
  if (!ass) return;
  const orig = ass.name;
  const inp = document.createElement('input');
  inp.type = 'text'; inp.value = orig;
  inp.style.cssText = el.style.cssText + 'background:var(--surf);border:1px solid var(--cyan);border-radius:5px;padding:1px 5px;outline:none;width:100%;';
  const save = () => { const v = inp.value.trim(); if (v) { ass.name = v; saveState(); } renderAssuntosModal(); renderDiscFull(); };
  inp.onblur = save;
  inp.onkeydown = e => { if (e.key === 'Enter') save(); if (e.key === 'Escape') renderAssuntosModal(); };
  el.replaceWith(inp); inp.focus(); inp.select();
}

function assEditSubName(discId, assId, subId, el) {
  const d = state.disciplines.find(x => x.id === discId);
  const ass = (d?.assuntos||[]).find(x => x.id === assId);
  const sub = (ass?.subassuntos||[]).find(x => x.id === subId);
  if (!sub) return;
  const inp = document.createElement('input');
  inp.type = 'text'; inp.value = sub.name;
  inp.style.cssText = el.style.cssText + 'background:var(--surf);border:1px solid var(--cyan);border-radius:5px;padding:1px 5px;outline:none;';
  const save = () => { const v = inp.value.trim(); if (v) { sub.name = v; saveState(); } renderAssuntosModal(); };
  inp.onblur = save;
  inp.onkeydown = e => { if (e.key === 'Enter') save(); if (e.key === 'Escape') renderAssuntosModal(); };
  el.replaceWith(inp); inp.focus(); inp.select();
}

function assAddAssunto() {
  const inp = document.getElementById('ass-new-inp');
  const v = inp?.value.trim();
  if (!v) { flash('Digite o nome do assunto.', '#f0b429'); return; }
  const d = state.disciplines.find(x => x.id === _assModalDiscId);
  if (!d) return;
  if (!d.assuntos) d.assuntos = [];
  d.assuntos.push({id: uid(), name: v, subassuntos: []});
  if (inp) inp.value = '';
  saveState(); renderAssuntosModal(); renderDiscFull();
}

function assRemoveAssunto(discId, assId) {
  const d = state.disciplines.find(x => x.id === discId);
  if (!d) return;
  d.assuntos = (d.assuntos||[]).filter(x => x.id !== assId);
  saveState(); renderAssuntosModal(); renderDiscFull();
}

function assRemoveSub(discId, assId, subId) {
  const d = state.disciplines.find(x => x.id === discId);
  const ass = (d?.assuntos||[]).find(x => x.id === assId);
  if (!ass) return;
  ass.subassuntos = (ass.subassuntos||[]).filter(x => x.id !== subId);
  saveState(); renderAssuntosModal();
}

function cronUpdateAssuntosDatalist() {
  const discId = document.getElementById('cron-disc-sel')?.value;
  const d = state.disciplines.find(x => x.id === discId);
  let dl = document.getElementById('cron-assunto-dl');
  if (!dl) {
    dl = document.createElement('datalist');
    dl.id = 'cron-assunto-dl';
    document.getElementById('cron-assunto-inp')?.setAttribute('list', 'cron-assunto-dl');
    document.body.appendChild(dl);
  }
  dl.innerHTML = '';
  (d?.assuntos || []).forEach(ass => {
    dl.appendChild(new Option(ass.name));
    (ass.subassuntos || []).forEach(sub => {
      dl.appendChild(new Option(sub.name));
    });
  });
}

function discUpdateSummary(){
  const totalDisc=state.disciplines.length;
  const totalGoal=state.disciplines.reduce((a,d)=>a+(d.weeklyGoal||0),0);
  const totalSecs=state.sessions.reduce((a,s)=>a+s.seconds,0);
  const totalQ=(state.questionSessions||[]).reduce((a,s)=>a+s.total,0);
  const el=id=>document.getElementById(id);
  if(el('disc-sum-total')) el('disc-sum-total').textContent=totalDisc;
  if(el('disc-sum-hours')) el('disc-sum-hours').textContent=totalGoal+'h';
  if(el('disc-sum-studied')) el('disc-sum-studied').textContent=formatHM(totalSecs);
  if(el('disc-sum-questions')) el('disc-sum-questions').textContent=totalQ;

  // Distribuição de tempo
  const chart=document.getElementById('disc-dist-chart');
  if(!chart) return;
  if(!totalSecs){ chart.innerHTML='<div class="empty" style="font-size:.68rem;">Estude para ver a distribuição.</div>'; return; }
  let html='<div style="display:flex;height:12px;border-radius:6px;overflow:hidden;margin-bottom:.75rem;">';
  state.disciplines.forEach(d=>{
    const s=state.sessions.filter(x=>x.subjectId===d.id).reduce((a,b)=>a+b.seconds,0);
    const pct=totalSecs?Math.round(s/totalSecs*100):0;
    if(pct>0) html+=`<div style="width:${pct}%;background:${d.color};transition:width .3s;" title="${d.name}: ${pct}%"></div>`;
  });
  html+='</div><div style="display:flex;flex-wrap:wrap;gap:.5rem .85rem;">';
  state.disciplines.forEach(d=>{
    const s=state.sessions.filter(x=>x.subjectId===d.id).reduce((a,b)=>a+b.seconds,0);
    const pct=totalSecs?Math.round(s/totalSecs*100):0;
    if(pct>0) html+=`<div style="display:flex;align-items:center;gap:5px;font-size:.65rem;"><span style="width:8px;height:8px;border-radius:50%;background:${d.color};display:inline-block;"></span><span style="color:var(--muted3);">${d.name}</span><span style="font-family:var(--mono);font-weight:700;color:var(--text);">${pct}%</span></div>`;
  });
  html+='</div>';
  chart.innerHTML=html;
}




// ═══ WEEK GRID ════════════════════════════════
const DAYS=['SEG','TER','QUA','QUI','SEX','SAB','DOM'];
const TIMES=['07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00','21:00','22:00'];
function renderWeekGrid(){
  const g=document.getElementById('week-grid');if(!g)return;
  g.innerHTML='';g.appendChild(document.createElement('div'));
  DAYS.forEach(d=>{const h=document.createElement('div');h.className='day-hdr';h.textContent=d;g.appendChild(h);});
  TIMES.forEach((t,ti)=>{
    const tl=document.createElement('div');tl.className='time-lbl';tl.textContent=t;g.appendChild(tl);
    DAYS.forEach((_,di)=>{const key=`${di}-${ti}`;const disc=state.disciplines.find(d=>d.id===state.schedule[key]);const done=state.completedSlots[key];const slot=document.createElement('div');slot.className='slot'+(disc?' filled':'')+(done?' completed':'');if(disc){slot.style.background=disc.color;slot.style.color='#000';slot.textContent=disc.name.slice(0,5);}slot.onclick=e=>{if(e.shiftKey){state.completedSlots[key]=!done;saveState();renderWeekGrid();return;}openSlotModal(key,t,DAYS[di]);};slot.title=disc?disc.name+(done?' ✓':''):'Clique para atribuir';g.appendChild(slot);});
  });
}
function openSlotModal(key,time,day){editingSlot=key;document.getElementById('slot-modal-title').textContent=`${day} — ${time}`;document.getElementById('slot-subject-select').value=state.schedule[key]||'';document.getElementById('slot-modal-overlay').classList.add('open');}
function closeSlotModal(e){if(!e||e.target===document.getElementById('slot-modal-overlay'))document.getElementById('slot-modal-overlay').classList.remove('open');}
function saveSlot(){const v=document.getElementById('slot-subject-select').value;if(v)state.schedule[editingSlot]=v;else delete state.schedule[editingSlot];document.getElementById('slot-modal-overlay').classList.remove('open');saveState();renderWeekGrid();}

// ═══ LOG ══════════════════════════════════════
function renderLog(){
  const list = document.getElementById('log-list');
  if (!list) return;
  const drl = document.getElementById('d-recent-list');
  const ttl = document.getElementById('t-today-list');
  const today = new Date().toDateString();

  list.innerHTML = '';
  if (drl) drl.innerHTML = '';
  if (ttl) ttl.innerHTML = '';

  if (!state.sessions.length) {
    list.innerHTML = '<div class="empty">Nenhuma sessão ainda. 🚀</div>';
    if (drl) drl.innerHTML = '<div class="empty">Nenhuma sessão ainda. 🚀</div>';
    if (ttl) ttl.innerHTML = '<div class="empty">Nenhuma sessão hoje.</div>';
    return;
  }

  let drCount = 0;
  [...state.sessions].reverse().forEach(s => {
    const d = state.disciplines.find(x => x.id === s.subjectId);
    const color = d ? d.color : '#5a6a8a';
    // Build fresh item per list (addEventListener breaks on cloneNode)
    list.appendChild(makeLogItem(s, color));
    if (drl && drCount < 6) { drl.appendChild(makeLogItem(s, color)); drCount++; }
    if (ttl && new Date(s.date).toDateString() === today) ttl.appendChild(makeLogItem(s, color));
  });

  if (drl && !drl.children.length) drl.innerHTML = '<div class="empty">Nenhuma sessão ainda. 🚀</div>';
  if (ttl && !ttl.children.length) ttl.innerHTML = '<div class="empty">Nenhuma sessão hoje.</div>';
}
function makeLogItem(s, color, opts={}){
  const el = document.createElement('div');
  el.className = 'log-item';
  el.dataset.sessionId = s.id;

  const h = Math.floor(s.seconds/3600);
  const m = Math.floor((s.seconds%3600)/60);
  const sec = s.seconds%60;

  el.innerHTML = `
    <div style="display:flex;align-items:center;flex:1;min-width:0">
      <div class="log-dot" style="background:${color}"></div>
      <div style="flex:1;min-width:0">
        <div class="log-name">${s.subject}</div>
        <div class="log-meta">${s.dateStr} às ${s.timeStr}</div>
      </div>
    </div>
    <div class="log-time-view" style="display:flex;align-items:center;gap:.4rem;">
      <span class="log-time">${formatHM(s.seconds)}</span>
      <button class="js-edit-btn" title="Editar tempo"
        style="background:none;border:none;cursor:pointer;color:var(--muted2);font-size:.7rem;padding:2px 5px;border-radius:5px;transition:color .15s;line-height:1;">✏️</button>
      <button class="js-del-btn" title="Excluir sessão"
        style="background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);cursor:pointer;color:var(--red);font-size:.68rem;padding:3px 7px;border-radius:5px;transition:all .15s;line-height:1;font-weight:700;">🗑</button>
    </div>
    <div class="log-time-edit" style="display:none;align-items:center;gap:.3rem;flex-wrap:wrap;">
      <input type="number" min="0" max="23" value="${h}" placeholder="h"
        style="width:42px;text-align:center;font-family:var(--mono);font-size:.8rem;font-weight:700;background:var(--surf3);border:1px solid var(--border2);border-radius:6px;color:var(--text);padding:.2rem .3rem;outline:none;"
        class="log-edit-h"/>
      <span style="color:var(--muted2);font-size:.7rem;font-weight:700;">h</span>
      <input type="number" min="0" max="59" value="${m}" placeholder="m"
        style="width:42px;text-align:center;font-family:var(--mono);font-size:.8rem;font-weight:700;background:var(--surf3);border:1px solid var(--border2);border-radius:6px;color:var(--text);padding:.2rem .3rem;outline:none;"
        class="log-edit-m"/>
      <span style="color:var(--muted2);font-size:.7rem;font-weight:700;">m</span>
      <input type="number" min="0" max="59" value="${sec}" placeholder="s"
        style="width:42px;text-align:center;font-family:var(--mono);font-size:.8rem;font-weight:700;background:var(--surf3);border:1px solid var(--border2);border-radius:6px;color:var(--text);padding:.2rem .3rem;outline:none;"
        class="log-edit-s"/>
      <span style="color:var(--muted2);font-size:.7rem;font-weight:700;">s</span>
      <button class="js-save-btn"
        style="background:var(--green);border:none;cursor:pointer;color:#000;font-size:.65rem;font-weight:800;padding:.22rem .55rem;border-radius:6px;font-family:var(--ff);">✓</button>
      <button class="js-cancel-btn"
        style="background:var(--surf3);border:1px solid var(--border2);cursor:pointer;color:var(--muted2);font-size:.65rem;padding:.22rem .5rem;border-radius:6px;">✕</button>
    </div>`;

  // ── Bind events via addEventListener (works after cloneNode) ──
  el.querySelector('.js-edit-btn').addEventListener('click', e => {
    e.stopPropagation();
    el.querySelector('.log-time-view').style.display = 'none';
    el.querySelector('.log-time-edit').style.display = 'flex';
    el.querySelector('.log-edit-h')?.focus();
  });

  el.querySelector('.js-del-btn').addEventListener('click', e => {
    e.stopPropagation();
    if (!confirm(`Excluir a sessão de "${s.subject}" (${formatHM(s.seconds)})?`)) return;
    state.sessions = state.sessions.filter(x => x.id !== s.id);
    saveState(); renderLog(); updateStats();
    flash('Sessão excluída.', '#ef4444');
  });

  el.querySelector('.js-save-btn').addEventListener('click', e => {
    e.stopPropagation();
    const hv = parseInt(el.querySelector('.log-edit-h').value)||0;
    const mv = parseInt(el.querySelector('.log-edit-m').value)||0;
    const sv = parseInt(el.querySelector('.log-edit-s').value)||0;
    const newSecs = hv*3600 + mv*60 + sv;
    if (newSecs < 1) { flash('Informe um tempo válido!','#f0b429'); return; }
    const sess = state.sessions.find(x => x.id === s.id);
    if (!sess) return;
    sess.seconds = newSecs;
    saveState(); renderLog(); updateStats();
    flash(`Sessão atualizada: ${formatHM(newSecs)}`, '#10b981');
  });

  el.querySelector('.js-cancel-btn').addEventListener('click', e => {
    e.stopPropagation();
    el.querySelector('.log-time-view').style.display = 'flex';
    el.querySelector('.log-time-edit').style.display = 'none';
  });

  return el;
}

function sessionEditStart(id){
  // Find ALL log items with this session ID across all lists and toggle them
  document.querySelectorAll(`[data-session-id="${id}"]`).forEach(el=>{
    el.querySelector('.log-time-view').style.display = 'none';
    el.querySelector('.log-time-edit').style.display = 'flex';
    el.style.alignItems = 'flex-start';
    el.style.flexWrap = 'wrap';
    el.querySelector('.log-edit-h')?.focus();
  });
}

function sessionEditCancel(id){
  document.querySelectorAll(`[data-session-id="${id}"]`).forEach(el=>{
    el.querySelector('.log-time-view').style.display = 'flex';
    el.querySelector('.log-time-edit').style.display = 'none';
    el.style.alignItems = '';
    el.style.flexWrap = '';
  });
}

function sessionEditSave(id, btn){
  // Get values from whichever edit row was clicked
  const editRow = btn.closest('.log-time-edit');
  const hVal = parseInt(editRow.querySelector('.log-edit-h').value)||0;
  const mVal = parseInt(editRow.querySelector('.log-edit-m').value)||0;
  const sVal = parseInt(editRow.querySelector('.log-edit-s').value)||0;
  const newSecs = hVal*3600 + mVal*60 + sVal;
  if(newSecs < 1){ flash('Informe um tempo válido!','#f0b429'); return; }

  const sess = state.sessions.find(s=>s.id===id);
  if(!sess){ flash('Sessão não encontrada.','#ef4444'); return; }
  sess.seconds = newSecs;
  saveState();
  renderLog();
  updateStats();
  flash(`Sessão atualizada: ${formatHM(newSecs)}`,'#10b981');
}

function sessionDelete(id){
  if(!confirm('Excluir esta sessão?')) return;
  state.sessions = state.sessions.filter(s=>s.id!==id);
  saveState();
  renderLog();
  updateStats();
  flash('Sessão excluída.','#ef4444');
}
function clearLog(){if(!confirm('Apagar histórico?'))return;state.sessions=[];state.streak=0;saveState();renderAll();}

// ═══ PROGRESS ═════════════════════════════════
// ═══ PROGRESS (RICH) ════════════════════════════
let progFilterDisc = null; // null = all
let progSort = 'rate_desc'; // 'rate_desc'|'rate_asc'|'qs_desc'|'time_desc'

function toggleProgSort(){
  const cycle=['rate_desc','rate_asc','qs_desc','time_desc'];
  const labels={'rate_desc':'Maior acerto','rate_asc':'Menor acerto','qs_desc':'Mais questões','time_desc':'Mais tempo'};
  const icons={'rate_desc':'↓','rate_asc':'↑','qs_desc':'↓','time_desc':'↓'};
  const idx=cycle.indexOf(progSort);
  progSort=cycle[(idx+1)%cycle.length];
  const lbl=document.getElementById('prog-sort-label');const ico=document.getElementById('prog-sort-icon');
  if(lbl)lbl.textContent=labels[progSort];if(ico)ico.textContent=icons[progSort];
  renderProgress();
}

function renderProgress(){
  const list=document.getElementById('progress-list');
  if(!state.disciplines.length){list.innerHTML='<div class="empty">Adicione disciplinas para começar!</div>';return;}

  // ── Aggregate per discipline ──────────────────
  const timeMap={};state.sessions.forEach(s=>{timeMap[s.subjectId]=(timeMap[s.subjectId]||0)+s.seconds;});

  const qMap={}; // {discId: {total,correct}}
  state.questionSessions.forEach(s=>{
    if(!qMap[s.subjectId])qMap[s.subjectId]={total:0,correct:0};
    qMap[s.subjectId].total+=s.total;qMap[s.subjectId].correct+=s.correct;
  });

  // ── Aggregate topics from mwResults + questionSessions obs ──
  // Each mwResult has blockName, disc, discId, resolved, correct, minPerQuestion, timeSeconds
  const topicMap={}; // {discId: [{name, resolved, correct, timeSec, pace}]}
  if(state.mwResults){
    Object.values(state.mwResults).forEach(r=>{
      if(!r||!r.resolved)return;
      // find the meta to get discId
      let discId=null;
      (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{if(state.mwResults[m.id]===r)discId=m.discId;}));
      // fallback: search by blockName match
      if(!discId)(state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{if(m.name===r.blockName)discId=m.discId;}));
      if(!discId)return;
      if(!topicMap[discId])topicMap[discId]=[];
      topicMap[discId].push({
        name:r.blockName||'—',resolved:r.resolved,correct:r.correct,
        timeSec:r.timeSeconds||0,pace:r.minPerQuestion||null,date:r.dateStr||'—'
      });
    });
  }

  // Also collect topics from questionSessions that have obs (non-mwResults)
  state.questionSessions.forEach(s=>{
    if(!s.obs||s.obs.trim()==='')return;
    // skip if already in mwResults (same obs text)
    const discId=s.subjectId;
    if(!topicMap[discId])topicMap[discId]=[];
    // avoid duplicates from mwResults block
    const alreadyExists=topicMap[discId].some(t=>t.name===s.obs);
    if(!alreadyExists)topicMap[discId].push({name:s.obs,resolved:s.total,correct:s.correct,timeSec:0,pace:null,date:s.dateStr||'—'});
  });

  // ── Global KPIs ────────────────────────────────
  const allQ=state.questionSessions;
  const totalQ=allQ.reduce((a,s)=>a+s.total,0);
  const totalC=allQ.reduce((a,s)=>a+s.correct,0);
  const globalRate=totalQ?Math.round(totalC/totalQ*100):null;
  const totalTime=Object.values(timeMap).reduce((a,b)=>a+b,0);
  const totalTopics=Object.values(topicMap).reduce((a,arr)=>a+arr.length,0);
  set('prog-k-total-q',totalQ);
  set('prog-k-rate',globalRate!==null?globalRate+'%':'—');
  set('prog-k-time',formatHM(totalTime));
  set('prog-k-topics',totalTopics);

  // ── Filter chips ───────────────────────────────
  const filters=document.getElementById('prog-disc-filters');
  if(filters&&filters.children.length===0){
    // all chip
    const allChip=document.createElement('div');
    allChip.className='prog-filter-chip active';
    allChip.style.cssText='color:var(--text);background:var(--surf3);border-color:var(--border2)';
    allChip.textContent='Todas';
    allChip.onclick=()=>{progFilterDisc=null;document.querySelectorAll('.prog-filter-chip').forEach(c=>c.classList.remove('active'));allChip.classList.add('active');renderProgress();};
    filters.appendChild(allChip);
    state.disciplines.forEach(d=>{
      const chip=document.createElement('div');
      chip.className='prog-filter-chip';
      chip.style.cssText=`color:${d.color};background:${d.color}18;`;
      chip.textContent=d.name.replace('Dir. ','').replace('Contabilidade ','Cont. ');
      chip.onclick=()=>{progFilterDisc=d.id;document.querySelectorAll('.prog-filter-chip').forEach(c=>c.classList.remove('active'));chip.classList.add('active');renderProgress();};
      filters.appendChild(chip);
    });
  }

  // ── Build discipline list ──────────────────────
  const discsToShow=progFilterDisc?state.disciplines.filter(d=>d.id===progFilterDisc):state.disciplines;

  // sort disciplines
  const sortedDiscs=[...discsToShow].sort((a,b)=>{
    const qa=qMap[a.id]||{total:0,correct:0};const qb=qMap[b.id]||{total:0,correct:0};
    const ra=qa.total?Math.round(qa.correct/qa.total*100):0;const rb=qb.total?Math.round(qb.correct/qb.total*100):0;
    if(progSort==='rate_desc')return rb-ra;
    if(progSort==='rate_asc')return ra-rb;
    if(progSort==='qs_desc')return qb.total-qa.total;
    if(progSort==='time_desc')return (timeMap[b.id]||0)-(timeMap[a.id]||0);
    return 0;
  });

  list.innerHTML='';

  if(sortedDiscs.every(d=>!qMap[d.id]&&!timeMap[d.id])){
    list.innerHTML='<div class="empty">Registre questões e sessões de estudo para ver o progresso! 📊</div>';return;
  }

  sortedDiscs.forEach(d=>{
    const secs=timeMap[d.id]||0;
    const qd=qMap[d.id]||{total:0,correct:0};
    const rate=qd.total?Math.round(qd.correct/qd.total*100):null;
    const wrong=qd.total-qd.correct;
    const weekPct=Math.min(100,Math.round(secs/(d.weeklyGoal||10)/3600*100));
    const rc=rate===null?'var(--muted)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const topics=topicMap[d.id]||[];

    // Open by default if only one disc showing or has data
    const isOpen=progFilterDisc===d.id||(discsToShow.length===1);

    const block=document.createElement('div');
    block.className='prog-disc-block'+(isOpen?' open':'');
    block.id='prog-block-'+d.id;

    // Sort topics by rate desc
    const sortedTopics=[...topics].sort((a,b)=>{
      const ra=a.resolved?Math.round(a.correct/a.resolved*100):0;
      const rb=b.resolved?Math.round(b.correct/b.resolved*100):0;
      return rb-ra;
    });

    block.innerHTML=`
      <!-- Header -->
      <div class="prog-disc-header" onclick="toggleProgBlock('${d.id}')">
        <div style="width:10px;height:10px;border-radius:50%;background:${d.color};flex-shrink:0;box-shadow:0 0 8px ${d.color}88"></div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:.88rem;font-weight:800">${d.name}</div>
          <div style="font-size:.62rem;color:var(--muted);margin-top:1px">${qd.total} questões · ${formatHM(secs)} estudadas · ${topics.length} assunto${topics.length!==1?'s':''} registrado${topics.length!==1?'s':''}</div>
        </div>
        <!-- Mini stats -->
        <div style="display:flex;gap:.6rem;align-items:center;flex-shrink:0;">
          ${rate!==null?`<div style="text-align:center">
            <div style="font-family:var(--mono);font-size:1.1rem;font-weight:700;color:${rc}">${rate}%</div>
            <div style="font-size:.52rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted)">Acerto</div>
          </div>`:''}
          <div style="text-align:center">
            <div style="font-family:var(--mono);font-size:1.1rem;font-weight:700;color:${d.color}">${qd.total||'—'}</div>
            <div style="font-size:.52rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted)">Questões</div>
          </div>
        </div>
        <span class="prog-disc-chevron">▶</span>
      </div>

      <!-- Body -->
      <div class="prog-disc-body">
        <!-- Overview boxes -->
        <div class="prog-overview">
          <div class="prog-ov-box">
            <span class="prog-ov-val" style="color:${d.color}">${qd.total||0}</span>
            <div class="prog-ov-lbl">Resolvidas</div>
          </div>
          <div class="prog-ov-box">
            <span class="prog-ov-val" style="color:var(--green)">${qd.correct||0}</span>
            <div class="prog-ov-lbl">Corretas</div>
          </div>
          <div class="prog-ov-box">
            <span class="prog-ov-val" style="color:var(--red)">${wrong||0}</span>
            <div class="prog-ov-lbl">Erradas</div>
          </div>
          <div class="prog-ov-box">
            <span class="prog-ov-val" style="color:var(--gold)">${formatHM(secs)}</span>
            <div class="prog-ov-lbl">Tempo Total</div>
          </div>
        </div>

        <!-- Progress bar vs weekly goal -->
        <div style="margin-bottom:1rem;">
          <div style="display:flex;justify-content:space-between;font-size:.65rem;margin-bottom:4px;">
            <span style="color:var(--muted)">Meta semanal de horas</span>
            <span style="font-family:var(--mono);color:${d.color}">${Math.floor(secs/3600)}h / ${d.weeklyGoal}h (${weekPct}%)</span>
          </div>
          <div class="pbar"><div class="pfill" style="background:${d.color};width:${weekPct}%"></div></div>
        </div>

        <!-- Acerto rate visual bar (only if questions exist) -->
        ${qd.total?`<div style="margin-bottom:1rem;background:var(--surf2);border-radius:10px;padding:.75rem 1rem;border:1px solid var(--border);">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem;">
            <span style="font-size:.65rem;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:2px">Taxa de Acerto</span>
            <span style="font-family:var(--mono);font-size:1rem;font-weight:700;color:${rc}">${rate}%</span>
          </div>
          <div style="height:8px;background:var(--surf3);border-radius:4px;overflow:hidden;">
            <div style="height:100%;border-radius:4px;background:${rc};width:${rate}%;transition:width .6s;"></div>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:.6rem;color:var(--muted);margin-top:.35rem;">
            <span>✅ ${qd.correct} corretas</span><span>❌ ${wrong} erradas</span>
          </div>
        </div>`:''}

        <!-- Topics list -->
        ${sortedTopics.length?`
        <div style="font-size:.6rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:.6rem;">
          Assuntos Estudados <span style="color:${d.color}">(${sortedTopics.length})</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:.3rem;">
          ${sortedTopics.map((t,i)=>{
            const tr=t.resolved?Math.round(t.correct/t.resolved*100):null;
            const trc=tr===null?'var(--muted)':tr>=70?'var(--green)':tr>=50?'var(--gold)':'var(--red)';
            const paceStr=t.pace?`${t.pace.toFixed(1)} min/q`:'';
            const rankColor=i===0&&tr!==null&&tr>=70?d.color:tr===null?'var(--surf3)':trc;
            return `<div class="prog-topic-row" style="border-left:3px solid ${rankColor}44;">
              <div style="width:20px;height:20px;border-radius:50%;background:${rankColor}22;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.6rem;font-weight:800;color:${rankColor}">${i+1}</div>
              <div class="prog-topic-name" title="${t.name}">${t.name.length>55?t.name.slice(0,55)+'…':t.name}</div>
              <div class="prog-topic-stats">
                ${tr!==null?`<span class="prog-topic-badge" style="background:${trc}18;color:${trc}">${tr}%</span>`:'<span style="font-size:.6rem;color:var(--muted)">sem dados</span>'}
                ${t.resolved?`<span style="font-family:var(--mono);font-size:.62rem;color:var(--muted)">${t.correct}/${t.resolved}</span>`:''}
                ${paceStr?`<span style="font-family:var(--mono);font-size:.6rem;color:var(--cyan)">${paceStr}</span>`:''}
                ${t.timeSec?`<span style="font-size:.6rem;color:var(--muted)">${formatHM(t.timeSec)}</span>`:''}
              </div>
              <div class="prog-topic-pbar">
                <div class="pbar"><div class="pfill" style="background:${trc};width:${tr||0}%"></div></div>
              </div>
            </div>`;
          }).join('')}
        </div>`:`<div style="text-align:center;padding:1.25rem;color:var(--muted);font-size:.78rem;background:var(--surf2);border-radius:10px;border:1px dashed var(--border);">
          Nenhum assunto registrado ainda.<br>
          <span style="font-size:.7rem;">Registre questões na aba <strong>Metas Semanais</strong> para ver os assuntos aqui.</span>
        </div>`}
      </div>`;

    list.appendChild(block);
  });
}

function toggleProgBlock(discId){
  const block=document.getElementById('prog-block-'+discId);
  if(block)block.classList.toggle('open');
