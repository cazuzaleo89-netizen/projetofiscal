// ═══ COUNTDOWN TIMER ════════════════════════════
const cd={running:false,paused:false,totalSecs:0,remainSecs:0,interval:null};
const CD_CIRC=2*Math.PI*70; // r=70 → ~439.8

function cdPreset(m,s){
  document.getElementById('cd-h').value=0;
  document.getElementById('cd-m').value=m;
  document.getElementById('cd-s').value=s||0;
  set('cd-status','Pronto para iniciar');
}
function cdGetInputSecs(){
  const h=parseInt(document.getElementById('cd-h').value)||0;
  const m=parseInt(document.getElementById('cd-m').value)||0;
  const s=parseInt(document.getElementById('cd-s').value)||0;
  return h*3600+m*60+s;
}
function cdStart(){
  const secs=cdGetInputSecs();
  if(secs<=0){flash('Defina um tempo maior que zero!','#f0b429');return;}
  cd.totalSecs=secs;cd.remainSecs=secs;cd.running=true;cd.paused=false;
  cd.interval=setInterval(cdTick,1000);
  cdShowRunning();cdUpdateDisplay();cdUpdateUI();
  // also log session start in main timer tracking
}
function cdPause(){if(!cd.running||cd.paused)return;cd.paused=true;clearInterval(cd.interval);cdUpdateUI();}
function cdResume(){if(!cd.paused)return;cd.paused=false;cd.interval=setInterval(cdTick,1000);cdUpdateUI();}
function cdStop(){
  clearInterval(cd.interval);
  // save elapsed time as session if running with a discipline selected
  const elapsed=cd.totalSecs-cd.remainSecs;
  if(elapsed>5){
    const sel=document.getElementById('active-subject-select').value;
    const disc=state.disciplines.find(x=>x.id===sel);
    if(disc){
      const now=new Date();
      state.sessions.push({id:uid(),subjectId:disc.id,subject:disc.name,seconds:elapsed,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
      updateStreak(now.toDateString());saveState();
      flash(`Sessão salva: ${formatHM(elapsed)}`,'#10b981');
    }
  }
  cd.running=false;cd.paused=false;cd.remainSecs=0;
  cdShowSetup();cdUpdateUI();
  set('cd-status','Configure o tempo acima');
}
function cdTick(){
  if(cd.remainSecs<=0){cdFinished();return;}
  cd.remainSecs--;
  cdUpdateDisplay();
  if(cd.remainSecs<=0)cdFinished();
}
function cdFinished(){
  clearInterval(cd.interval);cd.running=false;cd.paused=false;
  // alarm
  const wrap=document.getElementById('timer-wrap-el');
  wrap.classList.add('alarm');
  setTimeout(()=>wrap.classList.remove('alarm'),3200);
  // sound alert using AudioContext
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    [0,0.25,0.5,0.75,1.0].forEach((t,i)=>{
      const osc=ctx.createOscillator();const gain=ctx.createGain();
      osc.connect(gain);gain.connect(ctx.destination);
      osc.frequency.value=i%2===0?880:660;
      gain.gain.setValueAtTime(0.4,ctx.currentTime+t);
      gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+t+0.2);
      osc.start(ctx.currentTime+t);osc.stop(ctx.currentTime+t+0.22);
    });
  }catch(e){}
  // save full session
  const sel=document.getElementById('active-subject-select').value;
  const disc=state.disciplines.find(x=>x.id===sel);
  if(disc&&cd.totalSecs>5){
    const now=new Date();
    state.sessions.push({id:uid(),subjectId:disc.id,subject:disc.name,seconds:cd.totalSecs,date:now.toISOString(),dateStr:now.toLocaleDateString('pt-BR'),timeStr:now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})});
    updateStreak(now.toDateString());saveState();
  }
  set('cd-digits','00:00');set('cd-status','⏰ Tempo esgotado!');
  set('cd-label','concluído');
  cdUpdateUI();cdShowSetup();
  flash('⏰ Tempo esgotado! Sessão registrada.','#10b981');
}
function cdUpdateDisplay(){
  const h=Math.floor(cd.remainSecs/3600);
  const m=Math.floor((cd.remainSecs%3600)/60);
  const s=cd.remainSecs%60;
  const str=h>0?`${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`:`${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  set('cd-digits',str);
  const ring=document.getElementById('cd-ring');
  const digEl=document.getElementById('cd-digits');
  if(ring){
    const pct=cd.totalSecs>0?cd.remainSecs/cd.totalSecs:0;
    ring.style.strokeDashoffset=CD_CIRC*(1-pct);
    ring.style.stroke=pct>0.5?'var(--purple)':pct>0.2?'var(--gold)':'var(--red)';
    if(digEl)digEl.className='t-digits'+(pct<=0.2?' cd-urgent':'');
  }
  const pct=cd.totalSecs>0?Math.round(cd.remainSecs/cd.totalSecs*100):0;
  set('cd-label',cd.paused?'pausado':`${pct}% restante`);
}
function cdShowRunning(){
  document.getElementById('cd-setup-panel').style.display='none';
  document.getElementById('cd-running-panel').style.display='';
}
function cdShowSetup(){
  document.getElementById('cd-setup-panel').style.display='';
  document.getElementById('cd-running-panel').style.display='none';
  // reset ring
  const ring=document.getElementById('cd-ring');
  if(ring){ring.style.strokeDashoffset=0;ring.style.stroke='var(--gold)';}
}
function cdUpdateUI(){
  const ss=document.getElementById('cd-btn-start');
  const sp=document.getElementById('cd-btn-pause');
  const sr=document.getElementById('cd-btn-resume');
  const st=document.getElementById('cd-btn-stop');
  if(!cd.running){
    if(ss)ss.style.display='';if(sp)sp.style.display='none';if(sr)sr.style.display='none';if(st)st.style.display='none';
    set('cd-status','Configure o tempo acima');
  } else if(cd.paused){
    if(ss)ss.style.display='none';if(sp)sp.style.display='none';if(sr)sr.style.display='';if(st)st.style.display='';
    set('cd-status','Pausado');
  } else {
    if(ss)ss.style.display='none';if(sp)sp.style.display='';if(sr)sr.style.display='none';if(st)st.style.display='';
    set('cd-status','Contagem em andamento…');
  }
}

