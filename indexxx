          ${d.name.replace('Dir. ','')}
        </div>
        <div style="display:flex;gap:.5rem;align-items:center;">
          <span style="font-family:var(--mono);font-size:.68rem;color:${rc};font-weight:700;">${rate}%</span>
          ${pfi!==null?`<span title="Índice de Proficiência" style="font-family:var(--mono);font-size:.62rem;background:${pc}18;color:${pc};border:1px solid ${pc}40;border-radius:10px;padding:0 5px;font-weight:700;">IQ ${pfi}</span>`:''}
        </div>
      </div>
      <div style="height:5px;background:var(--surf3);border-radius:3px;overflow:hidden;">
        <div style="height:100%;border-radius:3px;background:${rc};width:${rate}%;transition:width .5s;"></div>
      </div>
      <div style="font-size:.58rem;color:var(--muted2);margin-top:2px;">${correct}/${total} questões · ${qs.length} sessões</div>
    </div>`;
  }).join('');
}

