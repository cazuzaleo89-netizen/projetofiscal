// Default speed in min/question per discipline id
const DEFAULT_SPEEDS={'adm-fixed':2.5,'const-fixed':2.5,'trib-fixed':2.5,'cont-fixed':4.0,'audit-fixed':2.5,'_default':2.5};

function getSpeed(discId){
  if(state.speedSettings&&state.speedSettings[discId]!=null)return parseFloat(state.speedSettings[discId]);
  return DEFAULT_SPEEDS[discId]||DEFAULT_SPEEDS['_default'];
}
function setSpeed(discId,val){
  if(!state.speedSettings)state.speedSettings={};
  state.speedSettings[discId]=Math.max(0.5,val||2.5);
  saveState();
}
function renderSpeedSettings(){
  const list=document.getElementById('speed-settings-list');if(!list)return;list.innerHTML='';
  state.disciplines.forEach(d=>{
    const spd=getSpeed(d.id);
    const row=document.createElement('div');
    row.style.cssText='display:flex;align-items:center;gap:.6rem;padding:.5rem .75rem;background:var(--surf3);border-radius:9px;border:1px solid var(--border);';
    row.innerHTML=`<div style="width:8px;height:8px;border-radius:50%;background:${d.color};flex-shrink:0"></div>
      <div style="flex:1;font-size:.78rem;font-weight:700;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${d.name}">${d.name}</div>
      <div style="display:flex;align-items:center;gap:.3rem;flex-shrink:0">
        <input type="number" min="0.5" max="15" step="0.5" value="${spd}"
          style="width:52px;text-align:center;font-family:var(--mono);font-size:.85rem;font-weight:700;padding:.25rem .2rem;border-radius:7px;border:1px solid var(--border);background:var(--surf2);color:var(--text);outline:none;transition:border-color .2s;"
          onchange="setSpeed('${d.id}',parseFloat(this.value));updateQTimeEstimate();"
          onfocus="this.style.borderColor='var(--cyan)'" onblur="this.style.borderColor='var(--border)'"/>
        <span style="font-size:.6rem;color:var(--muted)">min/q</span>
      </div>`;
    list.appendChild(row);
  });
}
function updateQTimeEstimate(){
  const disc=document.getElementById('q-discipline-select').value;
  const qty=parseInt(document.getElementById('q-total').value)||0;
  const banner=document.getElementById('q-time-estimate');
  const valEl=document.getElementById('q-est-value');
  const detailEl=document.getElementById('q-est-detail');
  if(!disc||!qty||qty<1){if(banner)banner.style.display='none';return;}
  const spd=getSpeed(disc);
  const totalMin=Math.round(qty*spd);
  const h=Math.floor(totalMin/60);const m=totalMin%60;
  const timeStr=h>0?`${h}h ${m.toString().padStart(2,'0')}min`:`${totalMin} min`;
  const minTime=Math.round(qty*Math.max(0.5,spd-0.5));const maxTime=Math.round(qty*(spd+0.5));
  if(valEl)valEl.textContent=timeStr;
  if(detailEl)detailEl.textContent=`${qty} questões × ${spd} min/q · intervalo: ${minTime}–${maxTime} min`;
  if(banner)banner.style.display='flex';
}

