function renderDashMetas(){
  const sel=document.getElementById('dash-week-select');
  if(sel&&sel.value!=='')dashWeekIdx=parseInt(sel.value);
  const weeks=state.mwWeeks||[];
  const list=document.getElementById('dash-metas-list');
  const summary=document.getElementById('dash-metas-summary');
  const weekLabel=document.getElementById('dash-week-label');
  const weekPct=document.getElementById('dash-week-pct');
  const weekBar=document.getElementById('dash-week-bar');
  if(!list)return;

  if(!weeks.length){
    list.innerHTML='<div class="empty">Nenhuma semana configurada.</div>';
    return;
  }

  const week=weeks[dashWeekIdx];
  if(!week){list.innerHTML='<div class="empty">Semana não encontrada.</div>';return;}

  // Week progress
  const done=week.metas.filter(m=>state.mwResults&&state.mwResults[m.id]).length;
  const total=week.metas.length;
  const pct=total?Math.round(done/total*100):0;
  if(weekLabel)weekLabel.textContent=`${week.name} — ${week.desc||''}`;
  if(weekPct)weekPct.textContent=pct+'%';
  if(weekBar)weekBar.style.width=pct+'%';

  // Sort: pending high priority first, then mid, then done
  const sorted=[...week.metas].sort((a,b)=>{
    const aDone=!!(state.mwResults&&state.mwResults[a.id]);
    const bDone=!!(state.mwResults&&state.mwResults[b.id]);
    if(aDone!==bDone)return aDone?1:-1; // done go last
    const po={high:0,mid:1,low:2};
    return (po[a.priority]||1)-(po[b.priority]||1);
  });

  list.innerHTML='';
  sorted.forEach(meta=>{
    const res=state.mwResults&&state.mwResults[meta.id];
    const isDone=!!res;
    const rate=res?Math.round(res.correct/res.resolved*100):null;
    const rc=rate!==null?(rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)'):'var(--muted2)';
    const priClass=meta.priority==='high'?'pri-high':meta.priority==='mid'?'pri-mid':'pri-low';
    const discColor=meta.color||'#5a6a8a';

    const item=document.createElement('div');
    item.className=`dash-meta-item ${priClass}${isDone?' done':''}`;
    item.title=meta.name+(meta.tip?'\n💡 '+meta.tip:'');

    // estimated time
    const spd=getSpeed(meta.discId);
    const estMin=meta.goal&&spd?Math.round(meta.goal*spd):0;
    const estStr=estMin>=60?`${Math.floor(estMin/60)}h${(estMin%60).toString().padStart(2,'0')}m`:`${estMin}min`;

    item.innerHTML=`
      <div class="dash-meta-check">${isDone?'✓':''}</div>
      <div class="dash-meta-disc-dot" style="background:${discColor}"></div>
      <div class="dash-meta-name">${meta.name}</div>
      <div class="dash-meta-right">
        ${isDone&&rate!==null
          ?`<div class="dash-meta-rate" style="color:${rc}">${rate}%</div>
            <div class="dash-meta-sub">${res.correct}/${res.resolved}</div>`
          :`<div class="dash-meta-sub" style="color:var(--muted2)">${meta.goal||0}q</div>
            <div class="dash-meta-sub" style="color:var(--cyan)">~${estStr}</div>`
        }
      </div>`;

    // Click → go to metas page and select this week
    item.onclick=()=>{
      mwActiveWeek=dashWeekIdx;
      goPage('metas',document.querySelector('.nav-item[onclick*=metas]'));
      setTimeout(()=>{renderWeekSelector();renderMwBlocks();renderMwSummary();renderMwWeekLog();},50);
    };

    list.appendChild(item);
  });

  // Summary
  if(summary){
    const pending=total-done;
    const totalQ=week.metas.filter(m=>!state.mwResults||!state.mwResults[m.id]).reduce((a,m)=>a+(m.goal||0),0);
    summary.textContent=`${done}/${total} concluídas · ${pending} pendentes · ${totalQ} questões restantes`;
  }
}



