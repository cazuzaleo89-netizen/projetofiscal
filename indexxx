// ESTATÍSTICAS — Motor Completo
// ═══════════════════════════════════════════════
let estPeriodDays = 7;
let estSortKey = 'rate';
let estSortDir = -1;

/* ── helpers ─── */
function estCutoff(days){
  if(!days) return new Date(0);
  const d = new Date();
  d.setDate(d.getDate() - days);
  return d;
}

function estFilterSessions(days){
  const cut = estCutoff(days);
  const disc = document.getElementById('est-disc-filter')?.value||'';
  return state.sessions.filter(s=>{
    if(disc && s.subjectId !== disc) return false;
    return new Date(s.date) >= cut;
  });
}
function estFilterQSessions(days){
  const cut = estCutoff(days);
  const disc = document.getElementById('est-disc-filter')?.value||'';
  return state.questionSessions.filter(s=>{
    if(disc && s.subjectId !== disc) return false;
    return new Date(s.date) >= cut;
  });
}
function estFilterMwResults(days){
  const cut = estCutoff(days);
  const disc = document.getElementById('est-disc-filter')?.value||'';
  const results=[];
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{
    if(disc && m.discId !== disc) return;
    const r = state.mwResults&&state.mwResults[m.id];
    if(!r) return;
    if(new Date(r.date) >= cut) results.push({...r, meta:m});
  }));
  return results;
}

/* ── init ─── */
function estInit(){
  // populate discipline filter
  const sel = document.getElementById('est-disc-filter');
  if(!sel) return;
  const prev = sel.value;
  sel.innerHTML = '<option value="">Todas as Disciplinas</option>';
  state.disciplines.forEach(d => sel.appendChild(new Option(d.name, d.id)));
  if(prev) sel.value = prev;
  renderEstatisticas();
}

function estSetPeriod(days, btn){
  estPeriodDays = days;
  document.querySelectorAll('.est-chip').forEach(b => b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  renderEstatisticas();
}

function estSortTable(key){
  if(estSortKey===key) estSortDir*=-1;
  else {estSortKey=key;estSortDir=-1;}
  renderEstatisticas();
}

/* ── MAIN RENDER ─── */
function renderEstatisticas(){
  const days = estPeriodDays;
  const sessions   = estFilterSessions(days);
  const qSessions  = estFilterQSessions(days);
  const mwResults  = estFilterMwResults(days);

  // Aggregates
  const totalTimeSec = sessions.reduce((a,s)=>a+s.seconds,0);
  const totalQ       = qSessions.reduce((a,s)=>a+s.total,0);
  const totalCorrect = qSessions.reduce((a,s)=>a+s.correct,0);
  const globalRate   = totalQ ? Math.round(totalCorrect/totalQ*100) : null;
  const sessionCount = sessions.length;
  const mwDone       = mwResults.length;
  const avgPace      = mwResults.filter(r=>r.minPerQuestion).length ?
    (mwResults.filter(r=>r.minPerQuestion).reduce((a,r)=>a+r.minPerQuestion,0) /
     mwResults.filter(r=>r.minPerQuestion).length).toFixed(1) : null;

  renderEstKPIs(totalTimeSec, totalQ, globalRate, sessionCount, mwDone, avgPace);
  renderEstQsChart(days);
  renderEstTimeChart(days);
  renderEstRateChart(days);
  renderEstDonut(days);
  renderEstTable(days);
  renderEstTimeline(days);
  renderEstPaceList(days);
}

/* ── KPIs ─── */
function renderEstKPIs(timeSec, totalQ, rate, sessCount, mwDone, avgPace){
  const el = document.getElementById('est-kpis');
  if(!el) return;
  const rc = rate===null?'var(--muted)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
  const h = Math.floor(timeSec/3600), m = Math.floor((timeSec%3600)/60);
  const timeStr = h > 0 ? `${h}h${m.toString().padStart(2,'0')}m` : `${m}m`;
  el.innerHTML = `
    <div class="est-kpi c1"><div class="est-kpi-val">${totalQ||0}</div><div class="est-kpi-lbl">Questões</div><div class="est-kpi-sub">${totalQ-Math.round((rate||0)*totalQ/100)||0} erradas</div></div>
    <div class="est-kpi c2"><div class="est-kpi-val" style="color:${rc}">${rate!==null?rate+'%':'—'}</div><div class="est-kpi-lbl">Acerto Médio</div><div class="est-kpi-sub">${Math.round((rate||0)*totalQ/100)||0} corretas</div></div>
    <div class="est-kpi c3"><div class="est-kpi-val">${timeStr||'0m'}</div><div class="est-kpi-lbl">Tempo Estudado</div><div class="est-kpi-sub">${sessCount} sessões</div></div>
    <div class="est-kpi c4"><div class="est-kpi-val">${mwDone}</div><div class="est-kpi-lbl">Metas Concluídas</div><div class="est-kpi-sub">do período</div></div>
    <div class="est-kpi c5"><div class="est-kpi-val">${avgPace||'—'}${avgPace?'<span style="font-size:.9rem">min/q</span>':''}</div><div class="est-kpi-lbl">Ritmo Médio</div><div class="est-kpi-sub">questões/hora: ${avgPace?(60/avgPace).toFixed(0):'—'}</div></div>`;
}

/* ── DAY GROUPER ─── */
function estGroupByDay(items, days, valFn, labelFn){
  const n = days || 30;
  const buckets = [];
  const today = new Date(); today.setHours(0,0,0,0);
  for(let i=n-1; i>=0; i--){
    const d = new Date(today); d.setDate(d.getDate()-i);
    const label = labelFn(d, i, n);
    const dayItems = items.filter(s=>{
      const sd = new Date(s.date); sd.setHours(0,0,0,0);
      return sd.getTime()===d.getTime();
    });
    buckets.push({label, value: dayItems.reduce((a,s)=>a+valFn(s),0), count: dayItems.length});
  }
  return buckets;
}

function estDayLabel(d, i, n){
  if(n<=14) return d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
  if(n<=31) return d.getDate().toString();
  // for 90 days, only show every ~7
  if(i%7===0) return d.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
  return '';
}

/* ── BAR CHART (generic SVG-free, CSS-based) ─── */
function renderEstBarChart(containerId, buckets, colorFn, tooltipFn){
  const el = document.getElementById(containerId);
  if(!el) return;
  const max = Math.max(...buckets.map(b=>b.value), 1);
  const LABELS_HEIGHT = 20;

  el.innerHTML = `<div class="est-bar-wrap">${
    buckets.map(b => {
      const pct = Math.round((b.value/max)*100);
      const color = colorFn(b);
      return `<div class="est-bar-col">
        <div class="est-bar-tooltip">${tooltipFn(b)}</div>
        <div class="est-bar" style="height:${Math.max(pct,b.value>0?2:0)}%;background:${color};"></div>
        <div class="est-bar-lbl">${b.label}</div>
      </div>`;
    }).join('')
  }</div>`;
}

/* ── QUESTÕES POR DIA ─── */
function renderEstQsChart(days){
  const qs = estFilterQSessions(days);
  const n = days || 30;
  const buckets = estGroupByDay(qs, n, s=>s.total, estDayLabel);
  renderEstBarChart('est-qs-chart', buckets,
    b => b.value > 0 ? 'var(--cyan)' : 'var(--surf3)',
    b => `${b.value} questões`
  );
}

/* ── HORAS POR DIA ─── */
function renderEstTimeChart(days){
  const ss = estFilterSessions(days);
  const n = days || 30;
  const buckets = estGroupByDay(ss, n, s=>s.seconds/3600, estDayLabel);
  renderEstBarChart('est-time-chart', buckets,
    b => b.value > 0 ? 'var(--gold)' : 'var(--surf3)',
    b => `${b.value.toFixed(1)}h`
  );
}

/* ── TAXA DE ACERTO POR DISCIPLINA ─── */
function renderEstRateChart(days){
  const el = document.getElementById('est-rate-chart');
  if(!el) return;
  const qs = estFilterQSessions(days);
  const disc = document.getElementById('est-disc-filter')?.value||'';

  // group by discipline
  const map = {};
  qs.forEach(s=>{
    if(!map[s.subjectId]) map[s.subjectId]={total:0,correct:0,name:s.subject};
    map[s.subjectId].total += s.total;
    map[s.subjectId].correct += s.correct;
  });
  const entries = Object.entries(map).map(([id,d])=>({
    id, name:d.name, total:d.total, correct:d.correct,
    rate: d.total ? Math.round(d.correct/d.total*100) : 0,
    color: state.disciplines.find(x=>x.id===id)?.color||'#5a6a8a'
  })).sort((a,b)=>b.rate-a.rate);

  if(!entries.length){el.innerHTML='<div class="empty">Sem dados no período.</div>';return;}

  el.innerHTML = entries.map(e=>{
    const rc = e.rate>=70?'var(--green)':e.rate>=50?'var(--gold)':'var(--red)';
    return `<div class="est-rate-row">
      <div style="width:8px;height:8px;border-radius:50%;background:${e.color};flex-shrink:0;"></div>
      <div class="est-rate-disc">${e.name}</div>
      <div class="est-rate-bar-bg"><div class="est-rate-bar-fill" style="width:${e.rate}%;background:${rc};"></div></div>
      <div class="est-rate-val" style="color:${rc}">${e.rate}%</div>
      <div class="est-rate-sub">${e.correct}/${e.total}</div>
    </div>`;
  }).join('');
}

/* ── DONUT CHART ─── */
function renderEstDonut(days){
  const ss = estFilterSessions(days);
  const svg = document.getElementById('est-donut');
  const legend = document.getElementById('est-donut-legend');
  if(!svg||!legend) return;

  // group by discipline
  const map = {};
  ss.forEach(s=>{
    if(!map[s.subjectId]) map[s.subjectId]={secs:0,name:s.subject};
    map[s.subjectId].secs += s.seconds;
  });
  const total = ss.reduce((a,s)=>a+s.seconds,0);
  if(!total){svg.innerHTML='';legend.innerHTML='<div style="font-size:.72rem;color:var(--muted2)">Sem dados.</div>';return;}

  const entries = Object.entries(map).map(([id,d])=>({
    id, name:d.name, secs:d.secs,
    pct: Math.round(d.secs/total*100),
    color: state.disciplines.find(x=>x.id===id)?.color||'#5a6a8a'
  })).sort((a,b)=>b.secs-a.secs);

  // SVG donut
  const cx=70,cy=70,r=52,stroke=14;
  const circ = 2*Math.PI*r;
  let offset = 0;
  let paths = '';
  entries.forEach(e=>{
    const dash = (e.secs/total)*circ;
    paths += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none"
      stroke="${e.color}" stroke-width="${stroke}"
      stroke-dasharray="${dash.toFixed(1)} ${(circ-dash).toFixed(1)}"
      stroke-dashoffset="${-offset.toFixed(1)}"
      transform="rotate(-90 ${cx} ${cy})">
      <title>${e.name}: ${formatHM(e.secs)} (${e.pct}%)</title>
    </circle>`;
    offset += dash;
  });
  const topDisc = entries[0];
  svg.innerHTML = `
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--surf3)" stroke-width="${stroke}"/>
    ${paths}
    <text x="${cx}" y="${cy-4}" text-anchor="middle" font-family="var(--mono)" font-size="14" font-weight="700" fill="var(--text)">${topDisc.pct}%</text>
    <text x="${cx}" y="${cy+12}" text-anchor="middle" font-family="var(--ff)" font-size="8" fill="var(--muted3)">${topDisc.name.split(' ').pop()}</text>`;

  legend.innerHTML = entries.map(e=>`
    <div class="est-legend-item">
      <div class="est-legend-dot" style="background:${e.color}"></div>
      <div class="est-legend-name">${e.name.replace('Dir. ','')}</div>
      <div class="est-legend-pct" style="color:${e.color}">${e.pct}%</div>
      <div style="font-size:.58rem;color:var(--muted2);min-width:45px;text-align:right;">${formatHM(e.secs)}</div>
    </div>`).join('');
}

/* ── TABELA RESUMO ─── */
function renderEstTable(days){
  const el = document.getElementById('est-table');
  if(!el) return;
  const ss   = estFilterSessions(days);
  const qs   = estFilterQSessions(days);
  const mwrs = estFilterMwResults(days);

  // per discipline
  const map = {};
  state.disciplines.forEach(d=>{ map[d.id]={id:d.id,name:d.name,color:d.color,secs:0,q:0,correct:0,sessions:0,mwDone:0,pace:null,paceSum:0,paceN:0}; });
  ss.forEach(s=>{ if(map[s.subjectId]){map[s.subjectId].secs+=s.seconds;map[s.subjectId].sessions++;} });
  qs.forEach(s=>{ if(map[s.subjectId]){map[s.subjectId].q+=s.total;map[s.subjectId].correct+=s.correct;} });
  mwrs.forEach(r=>{ const id=r.meta?.discId; if(id&&map[id]){map[id].mwDone++;if(r.minPerQuestion){map[id].paceSum+=r.minPerQuestion;map[id].paceN++;}} });
  Object.values(map).forEach(d=>{ if(d.paceN) d.pace=(d.paceSum/d.paceN).toFixed(1); });

  let entries = Object.values(map).filter(d=>d.secs>0||d.q>0);
  if(!entries.length){el.innerHTML='<div class="empty">Sem dados no período.</div>';return;}

  const sortFn = {
    rate:(a,b)=>{ const ra=a.q?a.correct/a.q:0,rb=b.q?b.correct/b.q:0; return estSortDir*(rb-ra); },
    qs:  (a,b)=> estSortDir*(b.q-a.q),
    time:(a,b)=> estSortDir*(b.secs-a.secs),
  };
  entries.sort(sortFn[estSortKey]||sortFn.rate);

  const rows = entries.map(d=>{
    const rate = d.q ? Math.round(d.correct/d.q*100) : null;
    const rc = rate===null?'var(--muted)':rate>=70?'var(--green)':rate>=50?'var(--gold)':'var(--red)';
    const h=Math.floor(d.secs/3600),m=Math.floor((d.secs%3600)/60);
    const timeStr = h?`${h}h${m.toString().padStart(2,'0')}m`:`${m}m`;
    return `<tr>
      <td><div style="display:flex;align-items:center;gap:.5rem;">
        <div style="width:7px;height:7px;border-radius:50%;background:${d.color};flex-shrink:0;"></div>
        <span style="font-weight:700">${d.name}</span>
      </div></td>
      <td class="num">${d.q||0}</td>
      <td class="num" style="color:${rc}"><span class="est-rate-pill" style="background:${rc}18;color:${rc}">${rate!==null?rate+'%':'—'}</span></td>
      <td class="num">${d.correct||0} / ${d.q-d.correct||0}</td>
      <td class="num" style="color:var(--gold)">${timeStr||'—'}</td>
      <td class="num">${d.sessions}</td>
      <td class="num">${d.mwDone}</td>
      <td class="num" style="color:var(--cyan)">${d.pace?d.pace+' min/q':'—'}</td>
    </tr>`;
  }).join('');

  el.innerHTML = `<table class="est-table" style="width:100%;"><thead><tr>
    <th>Disciplina</th>
    <th class="num">Questões</th>
    <th class="num">Acerto</th>
    <th class="num">✅ / ❌</th>
    <th class="num">Tempo</th>
    <th class="num">Sessões</th>
    <th class="num">Metas</th>
    <th class="num">Ritmo</th>
  </tr></thead><tbody>${rows}</tbody></table>`;
}

