function dmUpdateCounts() {
  const s = state;
  const set2 = (id, txt) => { const e=document.getElementById(id); if(e) e.textContent=txt; };
  set2('dm-count-sessions',  `${s.sessions.length} registro${s.sessions.length!==1?'s':''}`);
  set2('dm-count-questions', `${s.questionSessions.length} registro${s.questionSessions.length!==1?'s':''}`);
  const nMetas = (s.mwWeeks||[]).reduce((a,w)=>a+w.metas.length,0);
  const nRes   = Object.keys(s.mwResults||{}).length;
  set2('dm-count-metas',    `${(s.mwWeeks||[]).length} semanas · ${nMetas} metas · ${nRes} resultados`);
  const nMiss  = (s.missoesCiclo?.missions||[]).length;
  set2('dm-count-missoes',   `${nMiss} missão${nMiss!==1?'ões':''}`);
  set2('dm-count-srs',       `${(s.srsCards||[]).length} cartões`);
  set2('dm-count-fila',      `${(s.filaRevisao||[]).length} itens`);
  set2('dm-count-resumos',   `${(s.resumos||[]).length} resumos`);
  set2('dm-count-xp',        `${s.xp||0} XP · ${(s.achievements||[]).length} conquistas`);
  // Also update backup stats
  set2('bk-sessions',  s.sessions.length);
  set2('bk-questions', s.questionSessions.length);
  set2('bk-xp',        s.xp||0);
}

function dmDelete(type) {
  const labels = {
    sessions:  'todas as sessões de estudo',
    questions: 'todas as sessões de questões',
    metas:     'todas as metas semanais e resultados',
    missoes:   'o ciclo atual de missões',
    srs:       'todos os cartões de revisão espaçada',
    fila:      'toda a fila de revisão por link',
    resumos:   'todos os resumos',
    xp:        'todo o XP, nível e conquistas',
    all:       'TODOS OS DADOS (reset completo)',
  };
  const label = labels[type] || type;
  if (!confirm(`⚠️ Tem certeza que deseja excluir ${label}?\n\nEsta ação é IRREVERSÍVEL.`)) return;
  // Double confirm for all
  if (type === 'all' && !confirm('Último aviso: isso vai apagar absolutamente tudo. Continuar?')) return;

  switch(type) {
    case 'sessions':
      state.sessions = []; state.streak = 0; state.lastStudyDate = null;
      state.focusHistory = []; state.xpHistory = [];
      break;
    case 'questions':
      state.questionSessions = []; state.questionGoals = [];
      break;
    case 'metas':
      state.mwWeeks = []; state.mwResults = {}; state.planDone = {};
      break;
    case 'missoes':
      state.missoesCiclo = null;
      break;
    case 'srs':
      state.srsCards = [];
      break;
    case 'fila':
      state.filaRevisao = [];
      break;
    case 'resumos':
      state.resumos = [];
      break;
    case 'xp':
      state.xp = 0; state.level = 1; state.achievements = [];
      state.arenaData = {missionsCompleted:0};
      break;
    case 'all':
      const discBak = [...state.disciplines];
      const editalBak = {...state.edital};
      // Reset entire state
      Object.assign(state, {
        sessions:[], questionSessions:[], mwWeeks:[], mwResults:{}, planDone:{},
        missoesCiclo:null, srsCards:[], filaRevisao:[], resumos:[],
        xp:0, level:1, achievements:[], focusHistory:[], xpHistory:[],
        streak:0, lastStudyDate:null, arenaData:{missionsCompleted:0},
        schedule:{}, completedSlots:{}, questionGoals:[],
        disciplines: discBak, edital: editalBak, // keep discipline/edital config
      });
      break;
  }

  saveState();
  renderAll();
  dmUpdateCounts();
  flash(`🗑 ${label.charAt(0).toUpperCase()+label.slice(1)} excluídos com sucesso.`, '#ef4444');
}

