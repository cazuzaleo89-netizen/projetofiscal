      sr.style.cssText = 'display:flex;align-items:center;gap:5px;padding:3px 0;';
      const dot = document.createElement('span');
      dot.style.cssText = 'width:5px;height:5px;border-radius:50%;background:var(--muted2);flex-shrink:0;';
      const sn = document.createElement('span');
      sn.style.cssText = 'flex:1;font-size:.73rem;color:var(--muted3);cursor:pointer;';
      sn.textContent = sub.name;
      sn.title = 'Duplo-clique para editar';
      sn.ondblclick = () => assEditSubName(d.id, ass.id, sub.id, sn);
      const ds = document.createElement('button');
      ds.style.cssText = 'background:none;border:none;color:var(--muted);cursor:pointer;font-size:.75rem;padding:0 2px;line-height:1;';
      ds.innerHTML = '×';
      ds.title = 'Remover subassunto';
      ds.onclick = () => assRemoveSub(d.id, ass.id, sub.id);
