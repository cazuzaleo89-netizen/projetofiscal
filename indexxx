    const inp = document.getElementById('tec-cadr-url-inp');
    if (inp) inp.value = fullUrl;
    tecCadrStatusShow('✓ Caderno #' + data.cadernoBase + (data.idPasta ? ' / pasta #' + data.idPasta : '') + ' detectado automaticamente');
  }

  const card = document.getElementById('cron-investida-card');
  if (!card) return;

  const nameEl    = document.getElementById('cron-inv-name');
  const assEl     = document.getElementById('cron-inv-assunto');
  const totalBadge = document.getElementById('cron-inv-totalbadge');

  if (nameEl)    nameEl.textContent    = _cronInv.caderno;
  if (assEl)     assEl.textContent     = _cronInv.assunto;
  if (totalBadge) totalBadge.textContent = _cronInv.total > 0 ? _cronInv.total + ' questões' : 'Caderno TEC';

  card.style.display = '';

  // ── Auto-preencher campo de assunto se ainda estiver vazio ──
  const assuntoInp = document.getElementById('cron-assunto-inp');
  const badge      = document.getElementById('cron-assunto-tec-badge');
  const hint       = document.getElementById('cron-assunto-hint');
  if (assuntoInp && !assuntoInp.value.trim()) {
    const val = _cronInv.assunto || _cronInv.materia || '';
    if (val) {
      assuntoInp.value = val;
      cronState.assunto = val;
      if (badge) badge.style.display = '';
      if (hint) { hint.textContent = '✓ Assunto capturado automaticamente do TecConcursos'; hint.style.color = '#4a6cf7'; }
      setTimeout(() => { if (hint) hint.textContent = ''; }, 4000);
    }
  } else if (assuntoInp && assuntoInp.value.trim()) {
    // Campo já preenchido manualmente — mostrar badge do TEC na mesma posição como info
    if (hint && _cronInv.assunto) {
      hint.textContent = `📡 TEC detectou: "${_cronInv.assunto}"`;
      hint.style.color = '#64748b';
      setTimeout(() => { if (hint) hint.textContent = ''; }, 5000);
    }
