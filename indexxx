];

function arenaStartFocus(minutes, mode, color){
  if(arenaFocusTimer.active){ flash('Já há um bloco de foco ativo!','#f0b429'); return; }
  const xpReward = Math.round(minutes*0.6);
  arenaFocusTimer={active:true,interval:null,duration:minutes*60,remaining:minutes*60,mode,xp:xpReward,color,startTime:new Date()};

  // Show active panel
  document.getElementById('arena-presets').style.display='none';
  document.getElementById('arena-focus-active').style.display='';
  document.getElementById('arena-focus-mode-label').textContent=mode.toUpperCase();
  document.getElementById('arena-focus-mode-label').style.color=color;
  document.getElementById('arena-focus-card').classList.add('active-focus');
  document.getElementById('arena-focus-timer').style.color=color;

  arenaFocusTimer.interval=setInterval(arenaFocusTick,1000);
  arenaUpdateFocusUI();
}

function arenaStartCustomFocus(){
  const min=parseInt(prompt('Quantos minutos de foco?','60'))||0;
  if(min<5||min>240){ flash('Defina entre 5 e 240 minutos.','#f0b429'); return; }
  arenaStartFocus(min,'🔮 Custom','#34d399');
}

function arenaFocusTick(){
  arenaFocusTimer.remaining--;
  arenaUpdateFocusUI();
  if(arenaFocusTimer.remaining<=0) arenaCompleteFocus();
}

function arenaUpdateFocusUI(){
  const {remaining,duration,mode,color,xp}=arenaFocusTimer;
  const m=Math.floor(remaining/60),s=remaining%60;
  const el=document.getElementById('arena-focus-timer');
  const bar=document.getElementById('arena-focus-bar');
  const msg=document.getElementById('arena-focus-msg');
  if(el) el.textContent=`${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  if(bar) bar.style.width=(remaining/duration*100)+'%';
  if(msg){
    const idx=Math.floor((1-remaining/duration)*FOCUS_MESSAGES.length);
    msg.textContent=FOCUS_MESSAGES[Math.min(idx,FOCUS_MESSAGES.length-1)]+` · +${xp} XP ao concluir`;
  }
  // Urgent color at end
  if(remaining<=60&&el) el.style.color='var(--red)';
}

function arenaCompleteFocus(){
  if(!arenaFocusTimer.active) return;
  clearInterval(arenaFocusTimer.interval);
  const elapsed=arenaFocusTimer.duration-arenaFocusTimer.remaining;
  const completed=elapsed>=arenaFocusTimer.duration*0.8; // 80% counts
  const xpEarned=completed?arenaFocusTimer.xp:Math.floor(elapsed/60*0.4);

  // Log to focusHistory
  if(!state.focusHistory) state.focusHistory=[];
  state.focusHistory.unshift({
    mode:arenaFocusTimer.mode,
    duration:arenaFocusTimer.duration/60,
    elapsed:Math.floor(elapsed/60),
    completed,
    xp:xpEarned,
    date:new Date().toISOString()
  });

  arenaFocusTimer={active:false,interval:null,duration:0,remaining:0,mode:'',xp:0,color:'',startTime:null};
  document.getElementById('arena-presets').style.display='';
  document.getElementById('arena-focus-active').style.display='none';
  document.getElementById('arena-focus-card').classList.remove('active-focus');

  if(xpEarned>0) arenaAddXP(xpEarned, completed?`${arenaFocusTimer.mode||'Bloco de foco'} completo`:'Bloco parcial','🎯');
  else flash('Bloco muito curto — nenhum XP ganho.','#f0b429');

  if(completed) flash(`⚡ Bloco concluído! +${xpEarned} XP`,'#a78bfa');
  arenaRender();
}

function arenaAbortFocus(){
  if(!confirm('Desistir do bloco de foco? Você não ganhará XP.')) return;
  clearInterval(arenaFocusTimer.interval);
  arenaFocusTimer={active:false,interval:null,duration:0,remaining:0,mode:'',xp:0,color:'',startTime:null};
  document.getElementById('arena-presets').style.display='';
  document.getElementById('arena-focus-active').style.display='none';
  document.getElementById('arena-focus-card').classList.remove('active-focus');
  flash('Bloco cancelado. Tente de novo!','#f0b429');
  arenaRender();
}

// ── Achievements checker ──────────────────────
function arenaCheckAchievements(){
  arenaEnsure();
  let newUnlocks=[];
  ARENA_ACHIEVEMENTS.forEach(ach=>{
    if(state.achievements.includes(ach.id)) return;
    try{
      if(ach.condition(state)){
        state.achievements.push(ach.id);
        newUnlocks.push(ach);
      }
    }catch(e){}
  });
  if(newUnlocks.length){
    newUnlocks.forEach(ach=>{
      arenaAddXP(ach.xp, `Conquista: ${ach.name}`, ach.icon);
      setTimeout(()=>flash(`${ach.icon} Conquista desbloqueada: "${ach.name}" +${ach.xp} XP`,'#f0a500'),200);
    });
  }
}

// ── Missions render ───────────────────────────
function arenaRenderMissions(){
  const el=document.getElementById('arena-missions');
  if(!el) return;
  const missions=arenaGetDailyMissions();
  let allDone=true;
  el.innerHTML='';
  missions.forEach(m=>{
    const done=m.check();
    if(!done) allDone=false;
    const row=document.createElement('div');
    row.className=`arena-mission${done?' done':''}`;
    row.innerHTML=`
      <div class="arena-mission-check">${done?'✓':''}</div>
      <span class="arena-mission-icon" style="font-size:.9rem;">${m.icon}</span>
      <span class="arena-mission-name">${m.name}</span>
      <span class="arena-mission-xp">+${m.xp} XP</span>`;
    el.appendChild(row);
  });

  const bonusEl=document.getElementById('arena-daily-bonus');
  if(bonusEl) bonusEl.style.display=allDone?'':'none';

  // Award bonus if all done and not yet awarded today
  if(allDone){
    const todayKey='arena_bonus_'+new Date().toDateString();
    if(!localStorage.getItem(todayKey)){
      localStorage.setItem(todayKey,'1');
      setTimeout(()=>arenaAddXP(50,'Todas as missões do dia!','🏆'),500);
      if(!state.arenaData) state.arenaData={};
      state.arenaData.missionsCompleted=(state.arenaData.missionsCompleted||0)+1;
      saveState();
    }
  }
}

// ── Full render ───────────────────────────────
function arenaRender(){
  arenaEnsure();
  arenaCheckAchievements();

  const xp=state.xp||0;
  const levelData=arenaGetLevel(xp);
  const levelIdx=ARENA_LEVELS.indexOf(levelData);
  const nextLevel=arenaXpToNextLevel(xp);
  const streak=state.streak||0;

  // Hero
  set('arena-level-label',`Nível ${levelIdx+1}`);
  set('arena-rank-label',levelData.rank?.toUpperCase()||'BRONZE');
  set('arena-title-label',levelData.title);
  set('arena-xp-val',xp.toLocaleString('pt-BR'));
  set('arena-streak-val',`${streak}🔥`);
  const avatarEl=document.getElementById('arena-avatar-el');
  if(avatarEl) avatarEl.textContent=levelData.avatar||'⚔';

  // XP bar
  set('arena-xp-progress',`${nextLevel.progress} / ${nextLevel.needed} XP`);
  const barPct=nextLevel.needed>0?(nextLevel.progress/nextLevel.needed*100):100;
  setStyle('arena-xp-bar','width',barPct+'%');

  // Next reward hint
  if(levelIdx<ARENA_LEVELS.length-1){
    const next=ARENA_LEVELS[levelIdx+1];
    const needed=next.min-xp;
    set('arena-next-reward',`Faltam ${needed} XP para desbloquear: ${next.avatar} ${next.label}`);
  } else {
    set('arena-next-reward','🏆 Você atingiu o nível máximo!');
  }

  // Protocol
  arenaRenderProtocol();

  // Missions
  arenaRenderMissions();

  // Achievements
  const achEl=document.getElementById('arena-achievements');
  if(achEl){
    achEl.innerHTML='';
    // Sort: unlocked first
    const sorted=[...ARENA_ACHIEVEMENTS].sort((a,b)=>{
      const au=state.achievements.includes(a.id);
      const bu=state.achievements.includes(b.id);
      return au===bu?0:au?-1:1;
    });
    sorted.forEach(ach=>{
      const unlocked=state.achievements.includes(ach.id);
      const card=document.createElement('div');
      card.className=`arena-ach ${unlocked?'unlocked':'locked'}`;
      card.innerHTML=`
        ${unlocked?'<div class="arena-ach-badge">✓</div>':''}
        <div class="arena-ach-icon">${ach.icon}</div>
        <div class="arena-ach-name">${ach.name}</div>
        <div class="arena-ach-desc">${ach.desc}</div>
        <div class="arena-ach-xp">+${ach.xp} XP</div>`;
      achEl.appendChild(card);
    });
  }

  // XP History
  const histEl=document.getElementById('arena-xp-history');
  if(histEl){
    const hist=state.xpHistory||[];
    if(!hist.length){
      histEl.innerHTML='<div class="empty">Nenhum XP ganho ainda. Comece a estudar!</div>';
    } else {
      histEl.innerHTML=hist.slice(0,30).map(h=>`
        <div class="arena-xp-row">
          <span class="arena-xp-icon">${h.icon||'⚡'}</span>
          <span class="arena-xp-desc">${h.reason}</span>
          <span class="arena-xp-amount">+${h.amount} XP</span>
          <span class="arena-xp-date">${h.dateStr||'—'}</span>
        </div>`).join('');
    }
  }
}

function arenaUpdateNavBadge(){
  const badge=document.getElementById('arena-nav-badge');
  if(!badge) return;
  const lvl=state.level||1;
  badge.textContent=`Nv.${lvl}`;
  badge.style.display='';
}

