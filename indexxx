// ── Cloud Sync ─────────────────────────────────
let _lastSync = null;
let _syncPending = false;

async function cloudSave(showFlash=false) {
  if (!_authUser || _offlineMode) return;
  const sb = sbInit();
  if (!sb) return;
  _syncPending = true;

  try {
    const payload = JSON.stringify(state);
    const { error } = await sb.from('user_states').upsert({
      user_id:    _authUser.id,
      state_data: payload,
      updated_at: new Date().toISOString(),
    }, { onConflict: 'user_id' });

    if (error) throw error;
    _lastSync = Date.now();
    _syncPending = false;
    if (showFlash) flash('☁ Dados sincronizados com a nuvem!', '#22d3ee');
    // Update sync indicator
    const si = document.getElementById('sync-indicator');
    if (si) { si.textContent = '☁'; si.style.color = '#22d3ee'; si.title = 'Sincronizado às ' + new Date().toLocaleTimeString('pt-BR'); }
  } catch(e) {
    console.error('Cloud save error:', e);
    _syncPending = false;
    if (showFlash) flash('⚠ Erro ao sincronizar: ' + e.message, '#f0b429');
  }
}

async function cloudLoad() {
  if (!_authUser) return;
  const sb = sbInit();
  if (!sb) return;

  try {
    const { data, error } = await sb.from('user_states')
      .select('state_data')
      .eq('user_id', _authUser.id)
      .single();

    if (error && error.code !== 'PGRST116') throw error; // PGRST116 = no rows found

    if (data?.state_data) {
      const cloudState = JSON.parse(data.state_data);
      // Merge: prefer cloud data but keep local if cloud is empty
      Object.assign(state, cloudState);
      saveState(); // also save to localStorage
      renderAll();
      _lastSync = Date.now();
    }
  } catch(e) {
    console.error('Cloud load error:', e);
    // Fall back to local state silently
  }
}

// Hook saveState to also trigger cloud sync
const _origSaveState = saveState;
saveState = function() {
  _origSaveState();
  // Debounce cloud sync (don't hammer Supabase on every keystroke)
  if (_authUser && !_offlineMode && !_syncPending) {
    clearTimeout(saveState._debounce);
    saveState._debounce = setTimeout(() => cloudSave(), 3000);
  }
};

// ── Auto-login on page load ────────────────────
async function authInit() {
  const sb = sbInit();

  if (!SUPABASE_CONFIGURED) {
    // Show config notice but allow offline
    document.getElementById('auth-config-notice').style.display = '';
    return; // overlay stays visible, user can click "offline"
  }

  try {
    // Check if user is already logged in (session token in storage)
    const { data: { session } } = await sb.auth.getSession();
    if (session?.user) {
      await authOnLogin(session.user);
      return;
    }

    // Listen for auth state changes (e.g. password reset redirect)
    sb.auth.onAuthStateChange(async (event, session) => {
      if (event === 'SIGNED_IN' && session?.user) {
        await authOnLogin(session.user);
      }
    });
  } catch(e) {
    console.error('Auth init error:', e);
    // Show overlay so user can try again
  }
}

