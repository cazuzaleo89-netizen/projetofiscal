function editalEnsure(){
  if(!state.edital) state.edital = {weights:{}, concurso:''};
  if(!state.edital.weights) state.edital.weights = {};
}

function saveConcurso(){
  editalEnsure();
  state.edital.concurso = document.getElementById('cfg-concurso')?.value||'';
  saveState();
}

function saveEdital(){
  editalEnsure();
  const rows = document.querySelectorAll('.edital-pct-inp');
  let total = 0;
  rows.forEach(inp=>{
    const id = inp.dataset.discId;
    const val = parseFloat(inp.value)||0;
    state.edital.weights[id] = val;
    total += val;
  });
  saveState();
  renderEdital();
  renderEditalAnalysis();
  flash(Math.abs(total-100)<0.1 ? '✓ Edital salvo! Total = 100%' : `⚠ Salvo — total = ${total.toFixed(1)}% (ajuste para 100%)`, Math.abs(total-100)<0.1?'#10b981':'#f0a500');
}

function editalAutoDistribute(){
  editalEnsure();
  if(!state.disciplines.length) return;
  const pct = +(100/state.disciplines.length).toFixed(1);
  state.disciplines.forEach(d=>{ state.edital.weights[d.id]=pct; });
  saveState();
  renderEdital();
  renderEditalAnalysis();
}

function renderEdital(){
  editalEnsure();
  const container = document.getElementById('edital-rows');
  const distBar   = document.getElementById('edital-dist-bar');
  const totalEl   = document.getElementById('edital-total-pct');
  const badgeEl   = document.getElementById('edital-total-badge');
  const concEl    = document.getElementById('cfg-concurso');
  if(!container) return;

  if(concEl && state.edital.concurso) concEl.value = state.edital.concurso;

  if(!state.disciplines.length){
    container.innerHTML='<div class="empty">Adicione disciplinas para configurar o edital.</div>';
    return;
  }

  let total = 0;
  state.disciplines.forEach(d=>{ total += (state.edital.weights[d.id]||0); });

  // Total badge
  if(totalEl) totalEl.textContent = total.toFixed(1)+'%';
  if(badgeEl){
    const diff = Math.abs(total-100);
    if(diff < 0.5){
      badgeEl.textContent='✓ OK'; badgeEl.style.cssText='background:rgba(52,211,153,.15);color:var(--green);font-size:.6rem;padding:1px 8px;border-radius:10px;font-weight:700;';
    } else {
      badgeEl.textContent=total<100?`faltam ${(100-total).toFixed(1)}%`:`excede ${(total-100).toFixed(1)}%`;
      badgeEl.style.cssText='background:rgba(248,113,113,.15);color:var(--red);font-size:.6rem;padding:1px 8px;border-radius:10px;font-weight:700;';
    }
  }

  // Distribution bar
  if(distBar){
    distBar.innerHTML = state.disciplines.map(d=>{
      const w = state.edital.weights[d.id]||0;
      const pct = total>0 ? (w/total*100) : 0;
      return `<div style="width:${pct}%;background:${d.color};transition:width .4s;" title="${d.name}: ${w}%"></div>`;
    }).join('');
  }

  // Per-discipline input rows
  container.innerHTML='';
  state.disciplines.forEach(d=>{
    const w = state.edital.weights[d.id]||0;
    const barPct = Math.min(w, 100);

    const row = document.createElement('div');
    row.className = 'edital-row';
    row.innerHTML = `
      <div class="edital-disc-dot" style="background:${d.color};box-shadow:0 0 5px ${d.color}66;"></div>
      <div class="edital-disc-name">${d.name}</div>
      <div class="edital-bar-bg">
        <div class="edital-bar-fill" style="width:${barPct}%;background:${d.color};opacity:.7;"></div>
      </div>
      <input type="number" min="0" max="100" step="0.5"
        value="${w||''}" placeholder="0"
        class="edital-pct-inp" data-disc-id="${d.id}"
        oninput="editalLiveUpdate(this)"/>
      <span class="edital-pct-lbl">%</span>`;
    container.appendChild(row);
  });
}

function editalLiveUpdate(inp){
  // Live-update bar and total as user types
  const id = inp.dataset.discId;
  const val = parseFloat(inp.value)||0;

  // Update this row's bar
  const bar = inp.closest('.edital-row')?.querySelector('.edital-bar-fill');
  if(bar) bar.style.width = Math.min(val,100)+'%';

  // Recompute total
  let total = 0;
  document.querySelectorAll('.edital-pct-inp').forEach(i=>{ total+=parseFloat(i.value)||0; });

  const totalEl = document.getElementById('edital-total-pct');
  const badgeEl = document.getElementById('edital-total-badge');
  const distBar = document.getElementById('edital-dist-bar');

  if(totalEl) totalEl.textContent = total.toFixed(1)+'%';
  if(badgeEl){
    const diff = Math.abs(total-100);
    if(diff<0.5){ badgeEl.textContent='✓ OK'; badgeEl.style.cssText='background:rgba(52,211,153,.15);color:var(--green);font-size:.6rem;padding:1px 8px;border-radius:10px;font-weight:700;'; }
    else{ badgeEl.textContent=total<100?`faltam ${(100-total).toFixed(1)}%`:`excede ${(total-100).toFixed(1)}%`; badgeEl.style.cssText='background:rgba(248,113,113,.15);color:var(--red);font-size:.6rem;padding:1px 8px;border-radius:10px;font-weight:700;'; }
  }

  // Update dist bar using current input values
  if(distBar && total > 0){
    const rows = document.querySelectorAll('.edital-pct-inp');
    distBar.innerHTML = '';
    rows.forEach(i=>{
      const dId = i.dataset.discId;
      const d = state.disciplines.find(x=>x.id===dId);
      if(!d) return;
      const pct = (parseFloat(i.value)||0)/total*100;
      const seg = document.createElement('div');
      seg.style.cssText=`width:${pct}%;background:${d.color};transition:width .2s;`;
      distBar.appendChild(seg);
    });
  }
}

/* ── Analysis panel ─────────────────────────── */
function renderEditalAnalysis(){
  editalEnsure();
  const el = document.getElementById('edital-analysis');
  if(!el) return;

  // Check if we have weights configured
  const hasWeights = state.disciplines.some(d=>(state.edital.weights[d.id]||0)>0);
  if(!hasWeights){
    el.innerHTML='<div class="empty" style="padding:1rem;">Configure os pesos do edital para ver a análise.</div>';
    return;
  }

  // Compute actual study % per discipline
  const totalSecs = state.sessions.reduce((a,s)=>a+s.seconds,0);
  const totalQ    = state.questionSessions.reduce((a,s)=>a+s.total,0);

  // Build analysis rows
  const rows = state.disciplines.map(d=>{
    const weight  = state.edital.weights[d.id]||0;
    const studySecs = state.sessions.filter(s=>s.subjectId===d.id).reduce((a,s)=>a+s.seconds,0);
    const studyPct  = totalSecs>0 ? studySecs/totalSecs*100 : 0;
    const discQ     = state.questionSessions.filter(s=>s.subjectId===d.id).reduce((a,s)=>a+s.total,0);
    const qPct      = totalQ>0 ? discQ/totalQ*100 : 0;

    // Gap = actual - expected
    const gap = studyPct - weight;
    const absGap = Math.abs(gap);
    const gapLabel = absGap<2 ? 'em dia' : gap>0 ? `+${absGap.toFixed(0)}%` : `-${absGap.toFixed(0)}%`;
    const gapClass = absGap<2 ? 'edital-gap-ok' : gap>0 ? 'edital-gap-over' : 'edital-gap-under';

    return {d, weight, studyPct, qPct, gap, gapLabel, gapClass, studySecs, discQ};
  }).filter(r=>r.weight>0).sort((a,b)=>b.weight-a.weight);

  if(!rows.length){
    el.innerHTML='<div class="empty">Nenhuma disciplina com peso configurado.</div>';
    return;
  }

  // Overall alignment score
  const totalGap = rows.reduce((a,r)=>a+Math.abs(r.gap),0)/rows.length;
  const alignScore = Math.max(0,100-totalGap*2);
  const scoreColor = alignScore>=80?'var(--green)':alignScore>=60?'var(--gold)':'var(--red)';
  const scoreLabel = alignScore>=80?'Bem alinhado':alignScore>=60?'Razoável':'Desalinhado';

  el.innerHTML = `
    <!-- Score -->
    <div style="text-align:center;padding:.85rem;background:var(--surf2);border-radius:var(--r);margin-bottom:.9rem;border:1px solid var(--border);">
      <div style="font-family:var(--mono);font-size:2rem;font-weight:700;color:${scoreColor};line-height:1;">${alignScore.toFixed(0)}</div>
      <div style="font-size:.55rem;text-transform:uppercase;letter-spacing:2.5px;color:var(--muted2);margin-top:2px;">Índice de Alinhamento</div>
      <div style="font-size:.68rem;color:${scoreColor};font-weight:700;margin-top:.3rem;">${scoreLabel}</div>
    </div>

    <!-- Per-discipline rows -->
    ${rows.map(r=>`
      <div class="edital-analysis-row">
        <div style="display:flex;flex-direction:column;gap:1px;min-width:110px;">
          <div class="edital-analysis-name">
            <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${r.d.color};margin-right:4px;"></span>
            ${r.d.name.replace('Dir. ','').replace('Contabilidade ','Cont.')}
          </div>
          <div style="font-size:.58rem;color:var(--muted2);">${formatHM(r.studySecs)} · ${r.discQ}q</div>
        </div>
        <div class="edital-cmp-bars">
          <div class="edital-cmp-bar-wrap">
            <span class="edital-cmp-lbl">edital</span>
            <div class="edital-cmp-bar-bg">
              <div class="edital-cmp-bar-fill" style="width:${r.weight}%;background:${r.d.color};opacity:.5;"></div>
            </div>
            <span style="font-family:var(--mono);font-size:.6rem;color:var(--muted2);min-width:30px;text-align:right;">${r.weight}%</span>
          </div>
          <div class="edital-cmp-bar-wrap">
            <span class="edital-cmp-lbl">estudo</span>
            <div class="edital-cmp-bar-bg">
              <div class="edital-cmp-bar-fill" style="width:${r.studyPct}%;background:${r.d.color};"></div>
            </div>
            <span style="font-family:var(--mono);font-size:.6rem;color:${r.d.color};font-weight:700;min-width:30px;text-align:right;">${r.studyPct.toFixed(0)}%</span>
          </div>
        </div>
        <span class="edital-gap-badge ${r.gapClass}">${r.gapLabel}</span>
      </div>`).join('')}

    <!-- Recommendation -->
    ${(()=>{
      const under = rows.filter(r=>r.gap<-3).sort((a,b)=>a.gap-b.gap);
      const over  = rows.filter(r=>r.gap>5).sort((a,b)=>b.gap-a.gap);
      if(!under.length && !over.length) return '<div style="font-size:.68rem;color:var(--green);margin-top:.75rem;padding:.6rem;background:rgba(52,211,153,.07);border-radius:var(--r);border:1px solid rgba(52,211,153,.2);">✅ Seu estudo está bem alinhado com o edital!</div>';
      const lines = [];
      if(under.length) lines.push(`📌 Dedique mais tempo a: <strong>${under.map(r=>r.d.name.replace('Dir. ','')).join(', ')}</strong>`);
      if(over.length)  lines.push(`⚠️ Você está estudando demais: <strong>${over.map(r=>r.d.name.replace('Dir. ','')).join(', ')}</strong>`);
      return `<div style="font-size:.68rem;color:var(--muted2);margin-top:.75rem;padding:.65rem;background:var(--surf2);border-radius:var(--r);border:1px solid var(--border);line-height:1.7;">${lines.join('<br>')}</div>`;
    })()}`;
}

