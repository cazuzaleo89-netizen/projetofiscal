function mwCdUpdateAccent(){
  const accent=document.getElementById('mw-timer-accent');
  if(!accent)return;
  const isRunning=(mwCdMode==='chrono'&&mwTimer.running&&!mwTimer.paused)||(mwCdMode==='countdown'&&mwCd.running&&!mwCd.paused);
  const isPaused=(mwCdMode==='chrono'&&mwTimer.paused)||(mwCdMode==='countdown'&&mwCd.paused);
  const isCountdown=mwCdMode==='countdown';
  let color='var(--gold)';
  if(isRunning&&isCountdown)color='var(--purple)';
  else if(isRunning)color='var(--green)';
  else if(isPaused)color='var(--gold)';
  else if(isCountdown)color='var(--purple)';
  accent.style.background=`linear-gradient(90deg,transparent,${color},transparent)`;
}

