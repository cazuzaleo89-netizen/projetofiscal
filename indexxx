function discEditName(id, el){
  const d=state.disciplines.find(x=>x.id===id); if(!d) return;
  const inp=document.createElement('input');
  inp.type='text'; inp.value=d.name;
  inp.style.cssText='font-size:.82rem;font-weight:700;background:var(--surf);border:1px solid var(--cyan);border-radius:5px;color:var(--text);padding:2px 6px;outline:none;width:100%;font-family:var(--ff);';
  const save=()=>{
    const v=inp.value.trim();
    if(v){ d.name=v; saveState(); renderDisciplines(); renderDiscFull(); }
    else { el.textContent=d.name; el.style.display=''; }
  };
  inp.onblur=save;
  inp.onkeydown=e=>{ if(e.key==='Enter') save(); if(e.key==='Escape'){ el.textContent=d.name; el.style.display=''; }};
  el.textContent=''; el.style.display='none';
  el.parentNode.insertBefore(inp, el);
  inp.focus(); inp.select();
}

function discEditGoal(id, el){
  const d=state.disciplines.find(x=>x.id===id); if(!d) return;
  const inp=document.createElement('input');
  inp.type='number'; inp.value=d.weeklyGoal||0; inp.min=0; inp.max=80;
  inp.style.cssText='width:50px;font-size:.75rem;font-weight:600;background:var(--surf);border:1px solid var(--gold);border-radius:5px;color:var(--gold);padding:2px 4px;outline:none;text-align:center;font-family:var(--mono);';
  const save=()=>{
    d.weeklyGoal=parseInt(inp.value)||0; saveState(); renderDiscFull(); renderDisciplines();
  };
  inp.onblur=save;
  inp.onkeydown=e=>{ if(e.key==='Enter') save(); if(e.key==='Escape'){ renderDiscFull(); }};
  el.textContent=''; el.style.display='none';
  el.parentNode.insertBefore(inp, el);
  inp.focus(); inp.select();
}

function discPickColor(id, el){
  const d=state.disciplines.find(x=>x.id===id); if(!d) return;
  // Create inline color picker dropdown
  const existing=document.getElementById('disc-color-popup');
  if(existing) existing.remove();
  const popup=document.createElement('div');
  popup.id='disc-color-popup';
  popup.style.cssText='position:absolute;z-index:500;background:var(--surf);border:1px solid var(--border2);border-radius:10px;padding:8px;display:flex;flex-wrap:wrap;gap:5px;width:180px;box-shadow:0 8px 24px rgba(0,0,0,.5);';
  COLORS.forEach(c=>{
    const dot=document.createElement('div');
    dot.style.cssText=`width:20px;height:20px;border-radius:50%;background:${c};cursor:pointer;border:2px solid ${c===d.color?'#fff':'transparent'};transition:transform .1s;`;
    dot.onmouseenter=()=>{dot.style.transform='scale(1.2)';};
    dot.onmouseleave=()=>{dot.style.transform='scale(1)';};
    dot.onclick=(ev)=>{
      ev.stopPropagation();
      d.color=c; saveState(); renderDisciplines(); renderDiscFull();
      popup.remove();
    };
    popup.appendChild(dot);
  });
  el.style.position='relative';
  el.parentNode.style.position='relative';
  el.parentNode.appendChild(popup);
  popup.style.top=(el.offsetTop+el.offsetHeight+4)+'px';
  popup.style.left=el.offsetLeft+'px';
  setTimeout(()=>{
    const close=e=>{if(!popup.contains(e.target)){popup.remove();document.removeEventListener('click',close);}};
    document.addEventListener('click',close);
  },10);
}

function discDelete(id, name){
  if(!confirm('Excluir a disciplina "'+name+'"?\n\nOs registros de estudo e questões vinculados a ela serão mantidos, mas ficarão sem disciplina associada.')) return;
  state.disciplines=state.disciplines.filter(x=>x.id!==id);
  saveState(); renderDisciplines(); renderDiscFull();
  flash('Disciplina excluída!','var(--red)');
}

// ═══ ASSUNTOS / SUBASSUNTOS ════════════════════
let _assModalDiscId = null;

function openAssuntosModal(discId) {
  _assModalDiscId = discId;
  const d = state.disciplines.find(x => x.id === discId);
  if (!d) return;
  if (!d.assuntos) d.assuntos = [];
  document.getElementById('ass-disc-name').textContent = d.name;
  document.getElementById('ass-disc-color').style.background = d.color;
  document.getElementById('ass-disc-color').style.boxShadow = '0 0 8px ' + d.color + '66';
  document.getElementById('ass-new-inp').value = '';
  renderAssuntosModal();
  document.getElementById('assuntos-modal-overlay').classList.add('open');
  setTimeout(() => document.getElementById('ass-new-inp').focus(), 120);
}

function closeAssuntosModal() {
  document.getElementById('assuntos-modal-overlay').classList.remove('open');
  _assModalDiscId = null;
}

