// ── Time of day ───────────────────────────────
function consRenderTimeOfDay() {
  const el=document.getElementById('cons-tod');
  const labelsEl=document.getElementById('cons-tod-labels');
  const peakEl=document.getElementById('cons-tod-peak');
  if(!el) return;

  // Last 90 days sessions with timeStr
  const cutoff=new Date(); cutoff.setDate(cutoff.getDate()-90);
  const hours=new Array(24).fill(0); // seconds per hour

  (state.sessions||[]).forEach(s=>{
    if(!s.date) return;
    const d=new Date(s.date);
    if(d<cutoff) return;
    const h=d.getHours();
    hours[h]+=s.seconds||0;
  });

  const maxH=Math.max(...hours,1);
  const peakHour=hours.indexOf(Math.max(...hours));

  el.innerHTML=hours.map((secs,h)=>{
    const pct=Math.round(secs/maxH*100);
    const isNight=(h>=22||h<=5);
    const isMorning=(h>=6&&h<=11);
    const isAfternoon=(h>=12&&h<=17);
    const isEvening=(h>=18&&h<=21);
    const color=isNight?'#4a3060':isMorning?'#f0a500':isAfternoon?'#22c55e':'#4a6cf7';
    return `<div class="tod-bar" style="height:${Math.max(pct,secs>0?5:2)}%;background:${color};opacity:${secs>0?.8:.2};" title="${h}h: ${secs>0?formatHM(secs):'—'}"></div>`;
  }).join('');

  // Labels: show every 6h
  labelsEl.innerHTML=hours.map((_,h)=>`<div class="tod-hour-lbl">${h%6===0?h+'h':''}</div>`).join('');

  if(peakEl && hours[peakHour]>0){
    const partOfDay=peakHour<6?'🌙 Madrugada':peakHour<12?'🌅 Manhã':peakHour<18?'☀️ Tarde':'🌆 Noite';
    peakEl.innerHTML=`<span style="color:var(--gold);">${partOfDay}</span><span style="color:var(--muted2);">Pico: ${peakHour}h–${peakHour+1}h · ${formatHM(hours[peakHour])}</span>`;
  }
}

