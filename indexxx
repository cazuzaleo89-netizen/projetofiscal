<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
<meta name="theme-color" content="#4a6cf7"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="Painel Fiscal"/>
<meta name="application-name" content="Painel Fiscal"/>
<meta name="msapplication-TileColor" content="#0a0d14"/>
<meta name="description" content="Sistema completo de preparação para Auditor Fiscal"/>
<link rel="manifest" href="manifest.json"/>
<link rel="apple-touch-icon" href="icon-180.png"/>
<link rel="icon" type="image/svg+xml" href="icon-192.svg"/>
<title>Auditor Fiscal — Painel de Preparação</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════════════════════════════════
   AUDITOR FISCAL — Design System v3
   Aesthetic: Premium Executive Dashboard
   Fonts: Space Grotesk (body) + Sora (display) + JetBrains Mono (code)
   Philosophy: Ink-deep surfaces, warm amber accent,
   generous whitespace, razor-sharp type hierarchy
═══════════════════════════════════════════════ */

:root{
  --bg:#080c18;
  --bg2:#0c1120;
  --surf:#111827;
  --surf2:#161f30;
  --surf3:#1d2840;
  --surf4:#243250;
  --border:#1e2d4a;
  --border2:#263a60;
  --border3:#304775;
  --gold:#f0a500;
  --gold2:#fbbf24;
  --gold-dim:#a87018;
  --cyan:#4a6cf7;
  --cyan2:#3b5ae8;
  --purple:#818cf8;
  --purple2:#6366f1;
  --green:#34d399;
  --green2:#059669;
  --red:#f87171;
  --red2:#dc2626;
  --orange:#fb923c;
  --orange2:#ea580c;
  --teal:#60a5fa;
  --rose:#fb7185;
  --amber:#f59e0b;
  --text:#e8edf8;
  --text2:#b8c4e0;
  --muted:#2a3a5c;
  --muted2:#445878;
  --muted3:#6b80a8;
  --ff:'Space Grotesk',sans-serif;
  --display:'Sora',sans-serif;
  --mono:'JetBrains Mono',monospace;
  --r:10px;--r2:7px;--r3:14px;
}

/* ── LIGHT THEME ─────────────────────────────── */
[data-theme="light"]{
  --bg:#f0f3f9;
  --bg2:#ffffff;
  --surf:#ffffff;
  --surf2:#f2f5fc;
  --surf3:#e8ecf6;
  --surf4:#dde3f0;
  --border:#d4dbed;
  --border2:#c4cfe3;
  --border3:#b0bfd6;
  --gold:#b8720a;
  --gold2:#d48e14;
  --gold-dim:#8a5208;
  --cyan:#0284c7;
  --cyan2:#0369a1;
  --purple:#6d28d9;
  --purple2:#5b21b6;
  --green:#059669;
  --green2:#047857;
  --red:#dc2626;
  --red2:#b91c1c;
  --orange:#c2410c;
  --teal:#0d9488;
  --text:#0f172a;
  --text2:#1e293b;
  --muted:#9aafcc;
  --muted2:#6b7a9a;
  --muted3:#4a5a78;
}

/* ── RESET & BASE ─────────────────────────────── */
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:14px;}
body{
  background:var(--bg);color:var(--text);
  font-family:var(--ff);min-height:100vh;overflow-x:hidden;
  transition:background .3s,color .3s;
  -webkit-font-smoothing:antialiased;
  -moz-osx-font-smoothing:grayscale;
  line-height:1.5;
}

/* Premium noise texture overlay */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 55% 65% at 10% 0%,rgba(74,108,247,.07) 0%,transparent 55%),
    radial-gradient(ellipse 45% 55% at 90% 100%,rgba(99,102,241,.06) 0%,transparent 55%);
}
[data-theme="light"] body::before{
  background:radial-gradient(ellipse 50% 60% at 0% 0%,rgba(74,108,247,.04) 0%,transparent 55%);
}

/* Fine dot grid for depth */
body::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(rgba(255,255,255,.018) 1px,transparent 1px);
  background-size:28px 28px;
  left:240px;
}
[data-theme="light"] body::after{display:none;}

/* ── SIDEBAR ─────────────────────────────────── */
/* sidebar neon */
.sidebar::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(74,108,247,.4),transparent);z-index:1;}

.sidebar{
  position:fixed;left:0;top:0;bottom:0;width:240px;
  background:linear-gradient(180deg,#0a0f1e 0%,#080c18 100%);
  border-right:1px solid rgba(74,108,247,.12);
  z-index:200;display:flex;flex-direction:column;
  box-shadow:4px 0 24px rgba(0,0,0,.5);
  transition:width .25s cubic-bezier(.4,0,.2,1);
}
.sidebar.collapsed{width:60px;}
.sidebar.collapsed .sb-title,
.sidebar.collapsed .sb-sub,
.sidebar.collapsed .sb-badge,
.sidebar.collapsed .nav-sec,
.sidebar.collapsed .nav-item span:not(.nav-icon){display:none;}
.sidebar.collapsed .nav-item{justify-content:center;padding:.55rem 0;}
.sidebar.collapsed .nav-item .nav-icon{margin:0;}
.sidebar.collapsed .sb-brand{padding:1rem .8rem;text-align:center;}
.sidebar.collapsed .sb-brand::after{content:'⚔';display:block;font-size:1.4rem;color:var(--green);text-shadow:0 0 12px rgba(74,108,247,.5);}

.sb-toggle{
  position:absolute;top:1rem;right:-12px;
  width:24px;height:24px;border-radius:50%;
  background:#0c1120;border:1px solid rgba(74,108,247,.4);
  color:var(--green);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;z-index:10;
  transition:transform .25s,background .15s;
}
.sb-toggle:hover{background:rgba(74,108,247,.15);}
.sidebar.collapsed .sb-toggle{transform:rotate(180deg);}

.main{margin-left:240px;position:relative;z-index:1;min-height:100vh;transition:margin-left .25s cubic-bezier(.4,0,.2,1);}
.sidebar.collapsed ~ .main{margin-left:60px;}
[data-theme="light"] .sidebar{box-shadow:1px 0 12px rgba(0,0,0,.05);}

/* Brand section */
.sb-brand{padding:1.6rem 1.3rem 1.2rem;border-bottom:1px solid rgba(74,108,247,.12);position:relative;}

.sb-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(74,108,247,.07);
  border:1px solid rgba(74,108,247,.28);
  border-radius:5px;padding:3px 10px;margin-bottom:.75rem;
}
.sb-badge-dot{
  width:5px;height:5px;border-radius:50%;
  background:#4a6cf7;
  box-shadow:0 0 10px #4a6cf7,0 0 20px rgba(74,108,247,.4);
  animation:pulseDot 2.5s ease infinite;
}
@keyframes pulseDot{0%,100%{opacity:1;box-shadow:0 0 8px var(--gold);}50%{opacity:.4;box-shadow:none;}}
.sb-badge span{
  font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--gold);font-weight:600;font-family:var(--mono);
}

.sb-title{
  font-size:1.1rem;font-weight:800;letter-spacing:-.025em;
  line-height:1.2;color:var(--text);
}
.sb-title em{font-style:normal;color:#4a6cf7;text-shadow:0 0 12px rgba(74,108,247,.4);}
.sb-sub{font-size:.63rem;color:var(--muted3);margin-top:.2rem;letter-spacing:.03em;font-weight:400;}

/* Navigation */
.nav{flex:1;padding:.7rem 0;overflow-y:auto;scrollbar-width:none;}
.nav::-webkit-scrollbar{display:none;}

.nav-sec{
  padding:.8rem 1.3rem .25rem;
  font-size:.48rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--muted);font-weight:700;font-family:var(--mono);
}

.nav-item{
  display:flex;align-items:center;gap:11px;
  padding:.55rem 1.3rem;cursor:pointer;
  font-size:.8rem;font-weight:500;color:var(--muted3);
  transition:all .15s;position:relative;margin:1px 0;
  border-left:2px solid transparent;
}
.nav-item:hover{color:var(--text);background:rgba(255,255,255,.05);}
.nav-item.active{
  color:#4a6cf7;
  background:linear-gradient(90deg,rgba(74,108,247,.12),transparent);
  border-left-color:#4a6cf7;
  font-weight:600;
}
.nav-item.active .nav-icon{filter:drop-shadow(0 0 6px rgba(74,108,247,.7));color:#4a6cf7;}
.nav-icon{font-size:.88rem;width:18px;text-align:center;flex-shrink:0;}

/* Sidebar footer */
.sb-footer{
  padding:.9rem 1.3rem;border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.sb-f-left{display:flex;flex-direction:column;gap:1px;}
.sb-f-label{font-size:.5rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-family:var(--mono);}
.sb-f-val{font-family:var(--mono);font-size:.72rem;font-weight:500;color:var(--gold);}
.sb-f-streak{
  font-family:var(--mono);font-size:.62rem;color:var(--muted3);
  display:flex;align-items:center;gap:4px;
}

/* ── MAIN AREA ────────────────────────────────── */

/* ── TOPBAR ───────────────────────────────────── */
.topbar{
  position:sticky;top:0;z-index:100;
  background:rgba(5,8,18,.88);
  backdrop-filter:blur(28px) saturate(1.6);
  -webkit-backdrop-filter:blur(28px) saturate(1.6);
  border-bottom:1px solid var(--border);
  padding:.72rem 1.85rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
}
[data-theme="light"] .topbar{background:rgba(242,245,252,.92);}

.topbar-left{display:flex;align-items:center;gap:.6rem;}
.topbar-crumb{
  font-size:.58rem;color:var(--muted3);font-family:var(--mono);
  letter-spacing:.08em;text-transform:uppercase;
}
.topbar-sep{color:var(--border3);font-size:.8rem;margin:0 .1rem;}
.topbar-title{
  font-size:.92rem;font-weight:700;color:var(--text);
  letter-spacing:-.015em;
}

.topbar-right{display:flex;gap:1.1rem;align-items:center;}

/* Stat pills in topbar */
.tstat-pill{
  display:flex;align-items:center;gap:.35rem;
  background:var(--surf2);border:1px solid var(--border);
  border-radius:20px;padding:.22rem .7rem;
  font-family:var(--mono);font-size:.62rem;color:var(--muted3);
  transition:border-color .2s;
}
.tstat-pill:hover{border-color:var(--border3);}
.tstat-pip{width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.tstat-pip.live{background:var(--green);box-shadow:0 0 6px var(--green);animation:pulseDot 2s infinite;}
.tstat-val{color:var(--text2);font-weight:500;}
.tstat{font-size:.65rem;color:var(--muted3);}
.tstat strong{color:var(--cyan);font-family:var(--mono);font-weight:700;}

/* Theme toggle */
.theme-toggle{
  display:flex;align-items:center;gap:.38rem;cursor:pointer;
  background:var(--surf2);border:1px solid var(--border2);
  border-radius:20px;padding:.25rem .7rem;
  font-size:.65rem;font-weight:600;color:var(--muted3);
  transition:all .2s;user-select:none;
}
.theme-toggle:hover{border-color:#4a6cf7;color:var(--text);box-shadow:0 0 8px rgba(74,108,247,.15);}
.theme-toggle .tt-icon{font-size:.85rem;transition:transform .4s;}
[data-theme="light"] .theme-toggle .tt-icon{transform:rotate(180deg);}

/* ── PAGES ────────────────────────────────────── */

/* ── CONSISTÊNCIA ─────────────────────────────── */
.cons-kpi-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:.85rem;margin-bottom:1.5rem;}
@media(max-width:1100px){.cons-kpi-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:700px){.cons-kpi-grid{grid-template-columns:repeat(2,1fr);}}

.cons-kpi{
  background:var(--surf);border:1px solid var(--border);border-radius:var(--r3);
  padding:1.1rem 1.2rem;position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s,box-shadow .3s;
}
.cons-kpi:hover{transform:translateY(-2px);border-color:var(--border3);box-shadow:0 8px 24px rgba(0,0,0,.25);}
.cons-kpi-icon{font-size:1.4rem;margin-bottom:.4rem;display:block;}
.cons-kpi-val{font-family:var(--mono);font-size:1.9rem;font-weight:500;line-height:1;margin-bottom:.25rem;letter-spacing:-.03em;}
.cons-kpi-lbl{font-size:.52rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted2);font-weight:700;}
.cons-kpi-sub{font-size:.62rem;color:var(--muted3);margin-top:.2rem;}
.cons-kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--ck-accent,var(--green)),transparent);opacity:.7;}
.cons-kpi.ck-fire{--ck-accent:#f97316;}
.cons-kpi.ck-gold{--ck-accent:var(--gold);}
.cons-kpi.ck-cyan{--ck-accent:var(--cyan);}
.cons-kpi.ck-green{--ck-accent:var(--green);}
.cons-kpi.ck-purple{--ck-accent:var(--purple);}

/* Heatmap */
.hmap-wrap{overflow-x:auto;padding-bottom:.5rem;}
.hmap-grid{display:inline-grid;grid-template-rows:repeat(7,13px);grid-auto-flow:column;gap:3px;grid-auto-columns:13px;min-width:max-content;}
.hmap-cell{
  width:13px;height:13px;border-radius:3px;cursor:pointer;
  transition:transform .12s,box-shadow .12s;
  position:relative;
}
.hmap-cell:hover{transform:scale(1.4);z-index:10;box-shadow:0 0 8px rgba(255,255,255,.2);}
.hmap-cell[data-l="0"]{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.04);}
.hmap-cell[data-l="1"]{background:#1d4c3a;}
.hmap-cell[data-l="2"]{background:#166534;}
.hmap-cell[data-l="3"]{background:#15803d;}
.hmap-cell[data-l="4"]{background:#22c55e;}
.hmap-cell[data-l="5"]{background:#f0a500;box-shadow:0 0 8px rgba(240,165,0,.4);}
[data-theme="light"] .hmap-cell[data-l="0"]{background:rgba(0,0,0,.06);border:1px solid rgba(0,0,0,.06);}

.hmap-months{display:flex;padding-left:28px;margin-bottom:4px;min-width:max-content;}
.hmap-month-lbl{font-size:.55rem;color:var(--muted2);font-family:var(--mono);letter-spacing:.05em;white-space:nowrap;}

.hmap-days{display:grid;grid-template-rows:repeat(7,13px);gap:3px;margin-right:6px;flex-shrink:0;}
.hmap-day-lbl{font-size:.55rem;color:var(--muted2);font-family:var(--mono);height:13px;display:flex;align-items:center;}

/* Tooltip */
.hmap-tooltip{
  position:fixed;z-index:9999;pointer-events:none;
  background:#0a0d14;border:1px solid var(--border2);border-radius:8px;
  padding:.55rem .85rem;font-size:.7rem;color:var(--text);
  box-shadow:0 8px 24px rgba(0,0,0,.5);
  opacity:0;transition:opacity .15s;white-space:nowrap;
}
.hmap-tooltip.show{opacity:1;}
.hmap-tooltip-date{font-weight:700;margin-bottom:.2rem;color:var(--gold);}
.hmap-tooltip-row{display:flex;gap:.6rem;color:var(--muted3);font-size:.65rem;}

/* Legend */
.hmap-legend{display:flex;align-items:center;gap:.5rem;margin-top:.65rem;justify-content:flex-end;flex-wrap:wrap;}
.hmap-legend-lbl{font-size:.58rem;color:var(--muted3);}
.hmap-legend-dots{display:flex;gap:3px;}
.hmap-legend-dot{width:13px;height:13px;border-radius:3px;}

/* Month bars */
.mbar-row{display:flex;align-items:flex-end;gap:6px;height:80px;margin-bottom:.5rem;}
.mbar{
  flex:1;border-radius:4px 4px 0 0;min-height:2px;cursor:pointer;
  background:linear-gradient(180deg,var(--green),rgba(52,211,153,.3));
  transition:opacity .2s,filter .2s;position:relative;
}
.mbar:hover{filter:brightness(1.2);}
.mbar-labels{display:flex;gap:6px;}
.mbar-lbl{flex:1;text-align:center;font-size:.5rem;color:var(--muted2);font-family:var(--mono);letter-spacing:.05em;}

/* Weekday heatmap */
.wday-row{display:flex;align-items:center;gap:.65rem;margin-bottom:.5rem;}
.wday-lbl{font-size:.62rem;color:var(--muted2);font-family:var(--mono);width:28px;text-align:right;flex-shrink:0;}
.wday-bar-bg{flex:1;height:10px;background:rgba(255,255,255,.04);border-radius:5px;overflow:hidden;position:relative;}
.wday-bar-fill{height:100%;border-radius:5px;transition:width .8s cubic-bezier(.4,0,.2,1);}
.wday-val{font-size:.6rem;font-family:var(--mono);color:var(--muted3);min-width:38px;text-align:right;}

/* Streak milestones */
.streak-milestone{display:flex;align-items:center;gap:.75rem;padding:.6rem .85rem;background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);margin-bottom:.4rem;transition:border-color .15s;}
.streak-milestone:hover{border-color:var(--border2);}
.streak-milestone-icon{font-size:1.2rem;flex-shrink:0;}
.streak-milestone-name{font-size:.78rem;font-weight:700;}
.streak-milestone-sub{font-size:.6rem;color:var(--muted2);}
.streak-milestone-val{font-family:var(--mono);font-size:.88rem;font-weight:700;margin-left:auto;flex-shrink:0;}
.streak-milestone.unlocked{border-color:rgba(240,165,0,.3);background:rgba(240,165,0,.04);}
.streak-milestone.locked{opacity:.5;}

/* Time-of-day chart */
.tod-grid{display:grid;grid-template-columns:repeat(24,1fr);gap:2px;height:40px;}
.tod-bar{border-radius:2px;min-height:2px;transition:filter .2s;}
.tod-bar:hover{filter:brightness(1.3);}
.tod-hours{display:flex;gap:0;margin-top:3px;}
.tod-hour-lbl{flex:1;text-align:center;font-size:.45rem;color:var(--muted2);font-family:var(--mono);}

.page{display:none;padding:1.5rem 2rem 2.5rem;animation:fadeIn .25s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}

/* ── SECTION LABELS ──────────────────────────── */
.slabel{
  font-size:.52rem;letter-spacing:.18em;text-transform:uppercase;
  color:var(--muted2);font-weight:700;margin-bottom:.78rem;
  display:flex;align-items:center;gap:.65rem;
  font-family:var(--display);
}
.slabel::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── CARDS ────────────────────────────────────── */
.card{
  background:var(--surf);border:1px solid var(--border);
  border-radius:var(--r3);padding:1.4rem;
  transition:border-color .25s,box-shadow .25s;
}
.card:hover{border-color:var(--border2);}
.card+.card{margin-top:1.1rem;}
[data-theme="light"] .card{box-shadow:0 1px 4px rgba(0,0,0,.06);}
[data-theme="light"] .card:hover{box-shadow:0 2px 8px rgba(0,0,0,.08);}

/* Card with top accent line */
.card-accent{position:relative;overflow:hidden;}
.card-accent::before{
  content:'';position:absolute;top:0;left:10%;right:10%;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold3),transparent);
  opacity:.6;
}

/* ── KPI GRID ─────────────────────────────────── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem;}
@media(max-width:1100px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}

.kpi{
  background:linear-gradient(145deg,var(--surf),var(--surf2));
  border:1px solid var(--border);
  border-radius:var(--r3);padding:1.4rem 1.35rem;
  position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s,box-shadow .3s;
  cursor:default;
}
.kpi:hover{transform:translateY(-3px);border-color:var(--border3);box-shadow:0 8px 24px rgba(0,0,0,.25);}

/* Top accent bar — always visible */
.kpi::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--kpi-accent,var(--gold)),transparent);
  opacity:.5;transition:opacity .3s;
}
.kpi:hover::before{opacity:1;}
.kpi.gold{--kpi-accent:var(--gold);}
.kpi.cyan{--kpi-accent:var(--cyan);}
.kpi.green{--kpi-accent:var(--green);}
.kpi.purple{--kpi-accent:var(--purple);}

/* Subtle corner glow — enhanced */
.kpi::after{
  content:'';position:absolute;top:-50px;right:-50px;
  width:120px;height:120px;border-radius:50%;
  background:radial-gradient(circle,var(--kpi-accent,.06),transparent 70%);
  opacity:.4;pointer-events:none;transition:opacity .3s;
}
.kpi:hover::after{opacity:.7;}

.kpi-icon{font-size:1.15rem;margin-bottom:.7rem;display:block;opacity:.8;filter:drop-shadow(0 0 4px var(--kpi-accent));}
.kpi-val{
  font-family:var(--mono);font-size:2rem;font-weight:500;
  line-height:1;margin-bottom:.3rem;letter-spacing:-.03em;
  text-shadow:0 0 20px var(--kpi-accent);
}
.kpi.gold .kpi-val{color:var(--gold);}
.kpi.cyan .kpi-val{color:var(--cyan);}
.kpi.green .kpi-val{color:var(--green);}
.kpi.purple .kpi-val{color:var(--purple);}
.kpi-label{
  font-size:.56rem;letter-spacing:.15em;text-transform:uppercase;
  color:var(--muted2);font-weight:600;font-family:var(--mono);
}
.kpi-sub{font-size:.65rem;color:var(--muted3);margin-top:.3rem;}

/* ── GRID LAYOUTS ─────────────────────────────── */
.two-col{display:grid;grid-template-columns:1fr 320px;gap:1.25rem;align-items:start;}
@media(max-width:960px){.two-col{grid-template-columns:1fr;}}

/* ── PROGRESS BARS ────────────────────────────── */
.pbar{height:5px;background:var(--surf3);border-radius:3px;overflow:hidden;}
.pfill{height:100%;border-radius:3px;transition:width .7s cubic-bezier(.4,0,.2,1);}
.pbar.tall{height:8px;}
.pbar.thick{height:10px;}

/* ── TIMER ────────────────────────────────────── */
.timer-wrap{
  background:var(--surf);border:1px solid var(--border);
  border-radius:var(--r3);padding:1.5rem;
  text-align:center;position:relative;overflow:hidden;
}
.timer-wrap::before{display:none;}
.timer-wrap::after{
  content:'';position:absolute;top:0;left:15%;right:15%;height:1px;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
  opacity:.5;transition:background .4s;
}
.timer-wrap.mode-running::after{background:linear-gradient(90deg,transparent,var(--green),transparent);}
.timer-wrap.mode-paused::after{background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.timer-wrap.mode-countdown::after{background:linear-gradient(90deg,transparent,var(--purple),transparent);}

.t-disc{font-size:.55rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted3);font-family:var(--mono);min-height:1em;margin-bottom:.5rem;transition:color .3s;}
.t-disc.active{color:var(--green);}
.t-disc.paused{color:var(--gold);}
.timer-digits-wrap{position:relative;display:inline-block;margin:.4rem 0 .5rem;}
.t-digits{font-family:var(--mono);font-size:clamp(2.8rem,7vw,4.5rem);font-weight:300;letter-spacing:.04em;color:var(--text);line-height:1;transition:color .3s;}
.t-digits.running{color:var(--green);}
.t-digits.paused{color:var(--gold);}
.t-digits.cd-urgent{color:var(--red);}
.t-status{font-size:.55rem;color:var(--muted3);letter-spacing:.12em;text-transform:uppercase;font-family:var(--mono);margin-bottom:1rem;}
.t-btns{display:flex;gap:.42rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.1rem;}
.t-sel-lbl{font-size:.52rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);margin-bottom:.3rem;text-align:left;font-family:var(--mono);}

/* ── TIMER TABS ──────────────────────────────── */
.timer-mode-tabs{display:flex;gap:2px;background:var(--surf3);padding:3px;border-radius:9px;margin-bottom:1.25rem;}
.tmt-btn{flex:1;padding:.35rem;border:none;border-radius:7px;background:transparent;color:var(--muted2);cursor:pointer;font-family:var(--ff);font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;transition:all .18s;}
.tmt-btn.active{background:var(--surf2);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.3);}

/* ── COUNTDOWN ────────────────────────────────── */
.countdown-ring-wrap{position:relative;display:flex;align-items:center;justify-content:center;margin:.2rem auto .8rem;width:160px;height:160px;}
.countdown-ring-wrap svg{position:absolute;top:0;left:0;transform:rotate(-90deg);}
.countdown-ring-bg{fill:none;stroke:var(--surf4);stroke-width:5;}
.countdown-ring-fill{fill:none;stroke:var(--purple);stroke-width:5;stroke-linecap:round;transition:stroke-dashoffset .8s linear,stroke .5s;}
.countdown-inner{position:relative;z-index:1;text-align:center;}
.cd-setup{display:flex;align-items:center;gap:.5rem;justify-content:center;flex-wrap:wrap;margin-bottom:.75rem;}
.cd-unit{display:flex;flex-direction:column;align-items:center;gap:3px;}
.cd-inp{width:56px;text-align:center;font-family:var(--mono);font-size:1.4rem;font-weight:300;padding:.3rem .25rem;border-radius:9px;border:1px solid var(--border2);background:var(--surf3);color:var(--text);outline:none;transition:border-color .2s,box-shadow .2s;}
.cd-inp:focus{border-color:var(--purple);box-shadow:0 0 0 3px rgba(167,139,250,.12);}
.cd-lbl{font-size:.5rem;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);font-family:var(--mono);}
.cd-sep{font-size:1.8rem;font-weight:200;color:var(--border3);margin-top:-8px;}
.cd-presets{display:flex;gap:.32rem;justify-content:center;flex-wrap:wrap;margin-bottom:.9rem;}
.cd-preset-btn{font-family:var(--mono);font-size:.62rem;font-weight:500;padding:.22rem .6rem;border-radius:16px;cursor:pointer;background:var(--surf3);color:var(--muted3);border:1px solid var(--border2);transition:all .15s;}
.cd-preset-btn:hover{border-color:var(--purple2);color:var(--text);}
@keyframes alarmPulse{0%,100%{box-shadow:none}50%{box-shadow:0 0 0 4px rgba(248,113,113,.25)}}
.timer-wrap.alarm{animation:alarmPulse .5s ease 6;}

/* ── BUTTONS ──────────────────────────────────── */
.btn{
  font-family:var(--ff);font-size:.73rem;font-weight:600;
  letter-spacing:.02em;border:none;border-radius:var(--r);
  padding:.52rem 1rem;cursor:pointer;
  display:inline-flex;align-items:center;gap:5px;
  transition:all .15s;white-space:nowrap;
}
.btn:active{transform:scale(.96);}
.btn-gold{background:var(--gold);color:#000;box-shadow:0 2px 10px rgba(240,165,0,.3);}
.btn-gold:hover{background:var(--gold2);box-shadow:0 4px 18px rgba(240,165,0,.45);}
.btn-org{background:var(--orange);color:#fff;box-shadow:0 2px 10px rgba(251,146,60,.25);}
.btn-green{background:var(--green);color:#fff;box-shadow:0 2px 10px rgba(16,185,129,.25);}
.btn-green:hover{box-shadow:0 4px 16px rgba(16,185,129,.4);}
.btn-amber{background:#d97706;color:#fff;box-shadow:0 2px 10px rgba(217,119,6,.25);}
.btn-amber:hover{box-shadow:0 4px 16px rgba(217,119,6,.4);}
.btn-purple{background:var(--purple2);color:#fff;box-shadow:0 2px 10px rgba(124,58,237,.25);}
.btn-purple:hover{box-shadow:0 4px 16px rgba(124,58,237,.4);}
.btn-ghost{background:transparent;color:var(--muted3);border:1px solid var(--border2);}
.btn-ghost:hover{color:var(--text);border-color:var(--border3);background:rgba(255,255,255,.03);}
.btn-danger{background:transparent;color:var(--red);border:1px solid rgba(248,113,113,.3);}
.btn-danger:hover{background:rgba(248,113,113,.07);border-color:var(--red);}
.btn-full{width:100%;justify-content:center;}

/* ── INPUTS ────────────────────────────────────── */
.inp{
  width:100%;background:var(--surf2);color:var(--text);
  border:1px solid var(--border2);border-radius:var(--r);
  padding:.55rem .85rem;font-family:var(--ff);font-size:.84rem;
  transition:border-color .2s,box-shadow .2s;
}
.inp:focus{outline:none;border-color:var(--gold);box-shadow:0 0 0 3px rgba(240,165,0,.1);}
.inp::placeholder{color:var(--muted);}
select.inp{appearance:none;cursor:pointer;}
.flabel{
  font-size:.52rem;text-transform:uppercase;letter-spacing:.14em;
  color:var(--muted2);margin-bottom:.3rem;display:block;
  font-weight:600;font-family:var(--mono);
}
.frow{margin-bottom:.85rem;}

/* ── WEEK GRID ────────────────────────────────── */
.week-grid{display:grid;grid-template-columns:68px repeat(7,1fr);gap:3px;font-size:.63rem;}
.day-hdr{
  text-align:center;padding:6px 2px;
  font-size:.52rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  color:#4a6cf7;text-shadow:0 0 8px rgba(74,108,247,.5);
  font-family:var(--mono);
}
.time-lbl{
  display:flex;align-items:center;font-family:var(--mono);
  color:rgba(74,108,247,.45);font-size:.57rem;padding-right:5px;justify-content:flex-end;
}
.slot{
  border-radius:var(--r2);min-height:30px;cursor:pointer;
  background:rgba(74,108,247,.03);
  border:1px solid rgba(74,108,247,.1);
  transition:all .18s;
  display:flex;align-items:center;justify-content:center;overflow:hidden;
  font-size:.52rem;font-weight:700;text-align:center;padding:2px;
  position:relative;
}
.slot:hover{
  border-color:rgba(74,108,247,.6);
  background:rgba(74,108,247,.08);
  box-shadow:0 0 10px rgba(74,108,247,.18),inset 0 0 8px rgba(74,108,247,.06);
  transform:scale(1.04);
}
.slot.filled{color:#000!important;}
.slot.filled::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.08),transparent);
  pointer-events:none;
}
.slot.completed{opacity:.3;text-decoration:line-through;}

/* ── LOG LIST ─────────────────────────────────── */
.log-list{display:flex;flex-direction:column;gap:.38rem;max-height:320px;overflow-y:auto;padding-right:2px;}
.log-list::-webkit-scrollbar{width:2px;}
.log-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.log-item{
  background:var(--surf2);border:1px solid var(--border);
  border-radius:var(--r);padding:.6rem .88rem;
  display:flex;justify-content:space-between;align-items:center;
  animation:sIn .2s ease;transition:border-color .15s;
}
.log-item:hover{border-color:var(--border2);}
@keyframes sIn{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.log-dot{width:6px;height:6px;border-radius:50%;margin-right:8px;flex-shrink:0;}
.log-name{font-size:.78rem;font-weight:600;}
.log-meta{font-family:var(--mono);font-size:.58rem;color:var(--muted2);}
.log-time{font-family:var(--mono);font-size:.9rem;font-weight:500;color:var(--gold);}

/* ── QPERF ────────────────────────────────────── */
.qperf-item{background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.85rem;margin-bottom:.4rem;}
.qperf-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem;flex-wrap:wrap;gap:.5rem;}
.qperf-nums{display:flex;gap:.85rem;}
.qperf-num .v{font-family:var(--mono);font-size:.88rem;font-weight:500;display:block;}
.qperf-num .l{font-size:.54rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted2);}

/* ── DISC ITEM ────────────────────────────────── */
.disc-item{display:flex;align-items:center;gap:8px;padding:.55rem .8rem;background:var(--surf2);border-radius:var(--r2);border:1px solid var(--border);transition:all .15s;}
.disc-item:hover{border-color:var(--border2);background:var(--surf3);}

/* ── Q STAT ───────────────────────────────────── */
.qstat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;margin-bottom:1.2rem;}
@media(max-width:700px){.qstat-row{grid-template-columns:repeat(2,1fr);}}
.qsbox{background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:.88rem;text-align:center;}
.qsval{font-family:var(--mono);font-size:1.5rem;font-weight:400;display:block;}
.qslbl{font-size:.53rem;text-transform:uppercase;letter-spacing:.12em;color:var(--muted2);margin-top:3px;}

/* ── Q FORM ───────────────────────────────────── */
.qfg{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;}
@media(max-width:600px){.qfg{grid-template-columns:1fr;}}

/* ── GOAL ITEM ────────────────────────────────── */
.goal-item{background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.75rem .9rem;margin-bottom:.42rem;}

/* ── MODAL ────────────────────────────────────── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);z-index:500;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--surf);border:1px solid var(--border2);border-radius:var(--r3);padding:1.75rem;width:380px;max-width:95vw;transform:translateY(12px);transition:transform .2s;box-shadow:0 32px 64px rgba(0,0,0,.5);}
.overlay.open .modal{transform:translateY(0);}
.modal h3{font-size:1rem;font-weight:700;margin-bottom:1.1rem;color:var(--text);}
.mactions{display:flex;gap:.5rem;margin-top:1.1rem;}

/* ── PLAN ─────────────────────────────────────── */
.plan-hero{
  background:var(--surf);border:1px solid var(--border2);
  border-radius:var(--r3);padding:1.5rem;margin-bottom:1.2rem;
  position:relative;overflow:hidden;
}
.plan-hero::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(240,165,0,.4),transparent);
}
.plan-sw{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.9rem;}
.psw{font-family:var(--ff);font-size:.68rem;font-weight:600;padding:.35rem .8rem;border-radius:6px;cursor:pointer;background:var(--surf2);color:var(--muted3);border:1px solid var(--border2);transition:all .18s;}
.psw:hover{border-color:var(--gold);color:var(--text);}
.psw.active{background:var(--gold);color:#000;border-color:var(--gold);}

/* Plan items */
.week-hdr{display:flex;align-items:center;gap:.75rem;padding:.62rem .9rem;margin:.9rem 0 .35rem;background:var(--surf2);border-radius:8px;border-left:2px solid var(--gold3);}
.wnum{font-family:var(--mono);font-size:.56rem;font-weight:500;color:var(--gold);letter-spacing:.1em;}
.wdesc{font-size:.76rem;font-weight:600;}
.pi{display:flex;align-items:flex-start;gap:.7rem;padding:.62rem .9rem;border-radius:8px;cursor:pointer;border:1px solid transparent;transition:all .15s;margin-bottom:.22rem;background:var(--surf2);}
.pi:hover{border-color:var(--border2);}
.pi.done{opacity:.45;text-decoration:line-through;}
.ph{border-left:2px solid rgba(248,113,113,.6);}
.pm{border-left:2px solid rgba(240,165,0,.45);}
.pl{border-left:2px solid var(--border3);}
.ps{border-left:2px solid rgba(34,211,238,.45);}
.pi-check{width:16px;height:16px;border-radius:4px;border:1.5px solid var(--border3);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;font-size:.62rem;transition:all .15s;}
.pi.done .pi-check{background:var(--green);border-color:var(--green);color:#fff;}
.pi-body{flex:1;min-width:0;}
.pi-name{font-size:.77rem;font-weight:600;margin-bottom:.2rem;}
.pi-meta{display:flex;gap:.65rem;flex-wrap:wrap;font-size:.59rem;color:var(--muted3);}
.pi-right{text-align:right;flex-shrink:0;}
.pi-w{font-family:var(--mono);font-size:.68rem;font-weight:500;}
.pi-qs{font-family:var(--mono);font-size:.6rem;color:var(--muted3);}
.pi-time{font-family:var(--mono);font-size:.57rem;color:var(--muted);}
.dbage{background:var(--surf3);border:1px solid var(--border);border-radius:4px;padding:1px 5px;font-family:var(--mono);font-size:.55rem;}

/* Strategy */
.strat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.75rem;}
@media(max-width:600px){.strat-grid{grid-template-columns:1fr;}}
.strat-card{background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.9rem;}
.strat-lbl{font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.38rem;font-family:var(--mono);}
.strat-txt{font-size:.72rem;color:var(--muted3);line-height:1.65;}

/* ── COLOR DOTS ───────────────────────────────── */
.cdots{display:flex;gap:5px;flex-wrap:wrap;}
.cdot{width:18px;height:18px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .15s,border-color .15s;}
.cdot:hover{transform:scale(1.2);}
.cdot.sel{border-color:var(--text);transform:scale(1.2);}

/* ── PROGRESS ACCORDION ─────────────────────── */
.prog-disc-block{background:var(--surf);border:1px solid var(--border);border-radius:var(--r3);margin-bottom:.85rem;overflow:hidden;transition:border-color .2s;}
.prog-disc-block:hover{border-color:var(--border2);}
.prog-disc-header{display:flex;align-items:center;gap:.75rem;padding:1.05rem 1.25rem;cursor:pointer;user-select:none;}
.prog-disc-block.open .prog-disc-chevron{transform:rotate(90deg)!important;}
.prog-disc-chevron{font-size:.62rem;color:var(--muted);transition:transform .22s;flex-shrink:0;}
.prog-disc-body{display:none;padding:0 1.25rem 1.25rem;}
.prog-disc-block.open .prog-disc-body{display:block;}
.prog-topic-row{display:flex;align-items:center;gap:.65rem;padding:.46rem .6rem;border-radius:7px;margin-bottom:.28rem;background:var(--surf2);border:1px solid transparent;transition:border-color .15s;}
.prog-topic-row:hover{border-color:var(--border2);}
.prog-topic-name{flex:1;font-size:.73rem;font-weight:500;min-width:0;}
.prog-topic-stats{display:flex;gap:.52rem;align-items:center;flex-shrink:0;}
.prog-topic-badge{font-family:var(--mono);font-size:.62rem;font-weight:600;padding:1px 7px;border-radius:16px;}
.prog-topic-pbar{width:62px;flex-shrink:0;}
.prog-overview{display:grid;grid-template-columns:repeat(4,1fr);gap:.52rem;margin-bottom:1rem;}
@media(max-width:600px){.prog-overview{grid-template-columns:repeat(2,1fr);}}
.prog-ov-box{background:var(--surf2);border:1px solid var(--border);border-radius:8px;padding:.58rem;text-align:center;}
.prog-ov-val{font-family:var(--mono);font-size:1.05rem;font-weight:500;display:block;}
.prog-ov-lbl{font-size:.52rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted2);margin-top:2px;}
.prog-filter-chip{font-size:.62rem;font-weight:600;padding:.24rem .68rem;border-radius:16px;cursor:pointer;border:1.5px solid transparent;transition:all .15s;}
.prog-filter-chip.active{border-color:currentColor;}

/* ── METAS PAGE ───────────────────────────────── */
.mw-pace-ring{stroke:var(--purple2);}

/* ── LIGHT MODE OVERRIDES ─────────────────────── */
[data-theme="light"] .sidebar{background:#fff;box-shadow:1px 0 10px rgba(0,0,0,.05);}
[data-theme="light"] .sb-badge{background:rgba(74,108,247,.07);border-color:rgba(74,108,247,.25);}
[data-theme="light"] .nav-item:hover{background:rgba(0,0,0,.03);}
[data-theme="light"] .nav-item.active{ /* active nav */background:rgba(74,108,247,.07);}
[data-theme="light"] body::after{display:none;}
[data-theme="light"] .plan-hero{background:#fff;}
[data-theme="light"] .timer-wrap{background:#fff;}
[data-theme="light"] .card{background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.05);}
[data-theme="light"] .modal{box-shadow:0 20px 40px rgba(0,0,0,.15);}

/* ── MISC ─────────────────────────────────────── */
@keyframes flicker{0%,100%{opacity:1}50%{opacity:.6}}
.fire{animation:flicker 1.4s ease infinite;}
.empty{text-align:center;padding:1.75rem;color:var(--muted2);font-size:.78rem;line-height:1.65;}


/* ══ FLOATING TIMER WINDOW ════════════════════════ */
.fw-win{
  position:fixed;
  width:300px;
  background:var(--surf);
  border:1px solid var(--border2);
  border-radius:12px;
  box-shadow:0 20px 60px rgba(0,0,0,.5),0 0 0 1px rgba(255,255,255,.04);
  z-index:9000;/* above everything */
  overflow:hidden;
  bottom:24px;right:24px;/* default: bottom-right corner */
  top:auto;left:auto;
  user-select:none;
  transition:box-shadow .2s,opacity .2s,width .2s,height .2s;
  resize:none;
}
.fw-win:hover{box-shadow:0 24px 70px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.06);}
.fw-win.fw-pinned{z-index:9999;}
.fw-win.fw-compact{width:220px;}

/* NANO mode — tiny pill in corner */
.fw-win.fw-nano{
  width:auto;min-width:120px;max-width:180px;
  border-radius:30px;
  overflow:hidden;
}
.fw-win.fw-nano #fw-body{display:none;}
.fw-win.fw-nano #fw-mini{display:block!important;}
.fw-win.fw-nano .fw-titlebar{
  border-radius:30px;border-bottom:none;height:auto;
  padding:.3rem .75rem;
}
.fw-win.fw-nano .fw-title{display:none;}
.fw-win.fw-nano .fw-titlebar-right{display:none;}
.fw-win.fw-nano .fw-titlebar-left{gap:5px;}
.fw-win.fw-nano #fw-mini{padding:.1rem .5rem .3rem;}
.fw-win.fw-nano .fw-digits{font-size:1rem!important;letter-spacing:1px;}

/* Title bar */
.fw-titlebar{
  display:flex;align-items:center;justify-content:space-between;
  padding:.5rem .75rem;
  background:var(--surf2);
  border-bottom:1px solid var(--border);
  cursor:grab;
  height:36px;
}
.fw-titlebar:active{cursor:grabbing;}
.fw-titlebar-left{display:flex;align-items:center;gap:6px;}
.fw-dot{width:12px;height:12px;border-radius:50%;cursor:pointer;transition:opacity .15s;flex-shrink:0;}
.fw-dot:hover{opacity:.75;}
.fw-dot-red{background:#ff5f57;}
.fw-dot-yellow{background:#febc2e;}
.fw-dot-green{background:#28c840;}
.fw-title{
  position:absolute;left:50%;transform:translateX(-50%);
  font-family:var(--display);font-size:.68rem;font-weight:700;
  color:var(--muted3);letter-spacing:.5px;pointer-events:none;
}
.fw-titlebar-right{display:flex;align-items:center;}
.fw-pin-btn{
  background:none;border:none;cursor:pointer;
  font-size:.85rem;color:var(--muted);transition:color .15s;
  padding:0;line-height:1;
}
.fw-pin-btn:hover{color:var(--gold);}
.fw-pin-btn.pinned{color:var(--gold);}

/* Popout toggle button on timer-wrap */
.fw-popout-btn{
  background:var(--surf3);border:1px solid var(--border2);
  border-radius:var(--r);padding:.35rem .55rem;
  font-size:.8rem;cursor:pointer;color:var(--muted2);
  transition:all .15s;flex-shrink:0;line-height:1;
}
.fw-popout-btn:hover{color:var(--text);border-color:var(--gold);background:rgba(232,160,32,.08);}
.fw-popout-btn.active{color:var(--gold);border-color:var(--gold);background:rgba(232,160,32,.1);}

/* Body */
#fw-body{padding:.85rem;}

/* Digits */
.fw-digits{
  font-family:var(--mono);font-size:2.8rem;font-weight:300;
  letter-spacing:1px;color:var(--text);line-height:1;
  text-align:center;margin:.2rem 0;transition:color .3s;
}
.fw-digits.running{color:var(--green);}
.fw-digits.paused{color:var(--gold);}
.fw-digits.urgent{color:var(--red);}

.fw-disc{font-size:.58rem;letter-spacing:2.5px;text-transform:uppercase;color:var(--muted2);font-family:var(--mono);text-align:center;margin-bottom:.2rem;transition:color .3s;min-height:1em;}
.fw-disc.active{color:var(--green);}
.fw-disc.paused{color:var(--gold);}

.fw-status{font-size:.52rem;color:var(--muted2);letter-spacing:2px;text-transform:uppercase;font-family:var(--mono);text-align:center;margin-bottom:.65rem;}

.fw-btns{display:flex;gap:.35rem;justify-content:center;flex-wrap:wrap;margin:.1rem 0;}
.fw-btn{padding:.42rem .75rem!important;font-size:.7rem!important;}

.fw-disc-lbl{font-size:.5rem;text-transform:uppercase;letter-spacing:2.5px;color:var(--muted2);font-weight:700;margin-bottom:.3rem;font-family:var(--display);}
.fw-select{font-size:.75rem!important;padding:.45rem .7rem!important;}

.fw-tabs{margin-bottom:.75rem!important;}
.fw-cd-setup .cd-inp{width:46px!important;font-size:1.1rem!important;}
.fw-presets{gap:.25rem!important;}
.fw-presets .cd-preset-btn{font-size:.58rem!important;padding:.2rem .5rem!important;}

/* Compact mode */
.fw-compact #fw-body{padding:.6rem .75rem;}
.fw-compact .fw-digits{font-size:2rem;}
.fw-compact .fw-tabs{gap:2px!important;}
.fw-compact .tmt-btn{font-size:.58rem!important;padding:.28rem!important;}

/* Minimized → becomes nano pill */
.fw-win.minimized #fw-body{display:none;}
.fw-win.minimized #fw-mini{display:block!important;}
.fw-win.minimized{
  width:auto;min-width:130px;max-width:200px;
  border-radius:30px;
}
.fw-win.minimized .fw-titlebar{
  border-radius:30px;border-bottom:none;
  padding:.3rem .75rem;
}
.fw-win.minimized .fw-title{font-size:.62rem;}
.fw-win.minimized #fw-mini .fw-digits{font-size:1.1rem!important;letter-spacing:1px;}

/* Dragging state */
.fw-win.dragging{opacity:.92;box-shadow:0 28px 80px rgba(0,0,0,.7);}

/* Accent line while running */
.fw-win::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;z-index:1;
  background:linear-gradient(90deg,transparent,var(--cyan),transparent);
  transition:background .4s;
}
.fw-win.fw-running::before{background:linear-gradient(90deg,transparent,var(--green),transparent);}
.fw-win.fw-paused::before{background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.fw-win.fw-countdown::before{background:linear-gradient(90deg,transparent,var(--purple),transparent);}

/* ── DASHBOARD METAS LIST ─────────────────────── */
.dash-meta-item{display:flex;align-items:center;gap:.55rem;padding:.48rem .62rem;border-radius:var(--r2);border:1px solid var(--border);background:var(--surf2);transition:border-color .15s;cursor:pointer;position:relative;overflow:hidden;}
.dash-meta-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;}
.dash-meta-item.pri-high::before{background:var(--red);}
.dash-meta-item.pri-mid::before{background:var(--gold);}
.dash-meta-item.pri-low::before{background:var(--muted);}
.dash-meta-item:hover{border-color:var(--border3);}
.dash-meta-item.done{opacity:.5;background:rgba(52,211,153,.04);border-color:rgba(52,211,153,.18);}
.dash-meta-item.done::before{background:var(--green)!important;}
.dash-meta-check{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:.55rem;flex-shrink:0;transition:all .2s;}
.dash-meta-item.done .dash-meta-check{background:var(--green);border-color:var(--green);color:#fff;}
.dash-meta-name{flex:1;font-size:.73rem;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.dash-meta-item.done .dash-meta-name{text-decoration:line-through;}
.dash-meta-right{flex-shrink:0;text-align:right;}
.dash-meta-rate{font-family:var(--mono);font-size:.75rem;font-weight:700;}
.dash-meta-sub{font-size:.52rem;color:var(--muted2);}
.dash-meta-disc-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}


  position:fixed;bottom:1.75rem;left:50%;
  transform:translateX(-50%) translateY(10px);
  padding:.6rem 1.4rem;border-radius:20px;
  font-size:.78rem;font-weight:700;font-family:var(--ff);
  box-shadow:0 8px 32px rgba(0,0,0,.4);
  opacity:0;pointer-events:none;
  transition:opacity .25s,transform .25s;
  z-index:9999;white-space:nowrap;
  letter-spacing:.3px;
}
.flash.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── COLOR DOT PICKER ─────────────────────────── */
.cdots{display:flex;gap:.4rem;flex-wrap:wrap;}
.cdot{width:21px;height:21px;border-radius:50%;cursor:pointer;transition:transform .15s,box-shadow .15s;border:2px solid transparent;flex-shrink:0;}
.cdot:hover{transform:scale(1.18);}
.cdot.sel{border-color:rgba(255,255,255,.7);box-shadow:0 0 0 2px rgba(255,255,255,.2);}

/* Dash metas list scrollbar */
#dash-metas-list::-webkit-scrollbar{width:2px;}
#dash-metas-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

/* ── SCORE DE PRONTIDÃO ──────────────────────── */
.readiness-ring{position:relative;width:80px;height:80px;flex-shrink:0;}
.readiness-ring svg{transform:rotate(-90deg);}
.readiness-ring .ring-bg{fill:none;stroke:var(--surf3);stroke-width:7;}
.readiness-ring .ring-fill{fill:none;stroke-width:7;stroke-linecap:round;transition:stroke-dashoffset .8s cubic-bezier(.4,0,.2,1);}
.readiness-score-val{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1;}
.readiness-score-num{font-family:var(--mono);font-size:1.2rem;font-weight:800;}
.readiness-score-pct{font-size:.42rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted2);}

/* ── DIAGNÓSTICO ITEMS ───────────────────────── */
.diag-item{display:flex;align-items:center;gap:.5rem;padding:.42rem .55rem;border-radius:var(--r2);border:1px solid var(--border);background:var(--surf2);margin-bottom:.3rem;transition:border-color .15s;cursor:default;}
.diag-item:hover{border-color:var(--border2);}
.diag-item-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.diag-item-name{flex:1;font-size:.71rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.diag-item-rate{font-family:var(--mono);font-size:.72rem;font-weight:700;flex-shrink:0;}
.diag-item-bar{height:3px;border-radius:2px;background:var(--surf3);margin-top:3px;overflow:hidden;}
.diag-item-bar-fill{height:100%;border-radius:2px;transition:width .5s;}
.diag-badge{display:inline-flex;align-items:center;gap:3px;font-size:.55rem;font-weight:700;padding:2px 7px;border-radius:20px;letter-spacing:.5px;}
.diag-badge.red{background:rgba(248,113,113,.12);color:var(--red);border:1px solid rgba(248,113,113,.25);}
.diag-badge.gold{background:rgba(240,165,0,.12);color:var(--gold);border:1px solid rgba(240,165,0,.25);}
.diag-badge.green{background:rgba(52,211,153,.12);color:var(--green);border:1px solid rgba(52,211,153,.25);}
.diag-badge.purple{background:rgba(129,140,248,.12);color:var(--purple);border:1px solid rgba(129,140,248,.25);}

/* ── PLANO DO DIA ────────────────────────────── */
.plan-item{display:flex;align-items:center;gap:.5rem;padding:.4rem .55rem;border-radius:var(--r2);border:1px solid var(--border);background:var(--surf2);cursor:pointer;transition:all .15s;margin-bottom:.28rem;}
.plan-item:hover{border-color:var(--border2);background:var(--surf3);}
.plan-item-num{font-family:var(--mono);font-size:.65rem;font-weight:800;width:16px;text-align:center;flex-shrink:0;}
.plan-item-name{flex:1;font-size:.72rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.plan-item-why{font-size:.58rem;color:var(--muted2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.plan-item-time{font-family:var(--mono);font-size:.65rem;font-weight:700;flex-shrink:0;}

/* ══ ESTATÍSTICAS ══════════════════════════════ */
.est-chip{
  font-size:.68rem;font-weight:700;padding:.3rem .75rem;border-radius:20px;
  cursor:pointer;border:1.5px solid var(--border2);
  background:var(--surf2);color:var(--muted3);
  transition:all .15s;font-family:var(--ff);
}
.est-chip:hover{border-color:var(--cyan);color:var(--text);}
.est-chip.active{background:var(--cyan);border-color:var(--cyan);color:#000;font-weight:800;}

.est-kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:.85rem;margin-bottom:1.25rem;}
@media(max-width:1100px){.est-kpi-row{grid-template-columns:repeat(3,1fr);}}
@media(max-width:700px){.est-kpi-row{grid-template-columns:repeat(2,1fr);}}
.est-kpi{background:var(--surf);border:1px solid var(--border);border-radius:var(--r3);padding:1.1rem;position:relative;overflow:hidden;}
.est-kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.est-kpi.c1::after{background:linear-gradient(90deg,transparent,var(--cyan),transparent);}
.est-kpi.c2::after{background:linear-gradient(90deg,transparent,var(--green),transparent);}
.est-kpi.c3::after{background:linear-gradient(90deg,transparent,var(--gold),transparent);}
.est-kpi.c4::after{background:linear-gradient(90deg,transparent,var(--purple),transparent);}
.est-kpi.c5::after{background:linear-gradient(90deg,transparent,var(--orange),transparent);}
.est-kpi-val{font-family:var(--mono);font-size:1.75rem;font-weight:700;line-height:1;margin-bottom:.2rem;letter-spacing:-1px;}
.est-kpi.c1 .est-kpi-val{color:var(--cyan);}
.est-kpi.c2 .est-kpi-val{color:var(--green);}
.est-kpi.c3 .est-kpi-val{color:var(--gold);}
.est-kpi.c4 .est-kpi-val{color:var(--purple);}
.est-kpi.c5 .est-kpi-val{color:var(--orange);}
.est-kpi-lbl{font-size:.52rem;text-transform:uppercase;letter-spacing:2.5px;color:var(--muted2);font-weight:700;font-family:var(--display);}
.est-kpi-sub{font-size:.63rem;color:var(--muted3);margin-top:.25rem;}

/* Bar chart */
.est-bar-wrap{display:flex;align-items:flex-end;gap:2px;height:140px;position:relative;overflow:hidden;}
.est-bar-col{display:flex;flex-direction:column;align-items:center;flex:1;height:100%;justify-content:flex-end;cursor:default;position:relative;}
.est-bar-col:hover .est-bar-tooltip{display:block;}
.est-bar{width:100%;border-radius:3px 3px 0 0;min-height:2px;transition:opacity .15s;}
.est-bar-col:hover .est-bar{opacity:.8;}
.est-bar-lbl{font-size:.46rem;color:var(--muted2);margin-top:3px;text-align:center;font-family:var(--mono);}
.est-bar-tooltip{display:none;position:absolute;bottom:calc(100% + 4px);left:50%;transform:translateX(-50%);background:var(--surf4);border:1px solid var(--border2);border-radius:6px;padding:4px 8px;font-size:.65rem;font-family:var(--mono);color:var(--text);white-space:nowrap;z-index:10;pointer-events:none;}
.est-yaxis{position:absolute;left:0;top:0;bottom:20px;width:30px;display:flex;flex-direction:column;justify-content:space-between;align-items:flex-end;padding-right:4px;}
.est-yaxis span{font-size:.46rem;color:var(--muted2);font-family:var(--mono);}

/* Rate bars */
.est-rate-row{display:flex;align-items:center;gap:.65rem;margin-bottom:.55rem;}
.est-rate-disc{font-size:.72rem;font-weight:700;min-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.est-rate-bar-bg{flex:1;height:8px;background:var(--surf3);border-radius:4px;overflow:hidden;}
.est-rate-bar-fill{height:100%;border-radius:4px;transition:width .6s;}
.est-rate-val{font-family:var(--mono);font-size:.72rem;font-weight:700;min-width:36px;text-align:right;}
.est-rate-sub{font-size:.58rem;color:var(--muted2);min-width:60px;text-align:right;}

/* Donut legend */
.est-legend-item{display:flex;align-items:center;gap:.45rem;margin-bottom:.38rem;}
.est-legend-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.est-legend-name{font-size:.7rem;font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.est-legend-pct{font-family:var(--mono);font-size:.68rem;font-weight:700;flex-shrink:0;}

/* Table */
.est-table{width:100%;border-collapse:collapse;}
.est-table th{font-size:.5rem;text-transform:uppercase;letter-spacing:2.5px;color:var(--muted2);font-weight:700;padding:.5rem .7rem;text-align:left;border-bottom:1px solid var(--border);font-family:var(--display);}
.est-table th.num{text-align:right;}
.est-table td{font-size:.75rem;padding:.6rem .7rem;border-bottom:1px solid var(--border);vertical-align:middle;}
.est-table td.num{text-align:right;font-family:var(--mono);font-weight:700;}
.est-table tr:last-child td{border-bottom:none;}
.est-table tr:hover td{background:var(--surf2);}
.est-rate-pill{display:inline-block;padding:1px 8px;border-radius:20px;font-family:var(--mono);font-size:.68rem;font-weight:700;}

/* Timeline */
.est-tl-item{display:flex;align-items:flex-start;gap:.75rem;padding:.6rem 0;border-bottom:1px solid var(--border);position:relative;}
.est-tl-item:last-child{border-bottom:none;}
.est-tl-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.est-tl-date{font-family:var(--mono);font-size:.6rem;color:var(--muted2);flex-shrink:0;min-width:70px;margin-top:2px;}
.est-tl-name{font-size:.73rem;font-weight:600;flex:1;min-width:0;}
.est-tl-sub{font-size:.6rem;color:var(--muted2);margin-top:1px;}
.est-tl-right{text-align:right;flex-shrink:0;}

/* Pace list */
.est-pace-row{display:flex;align-items:center;gap:.65rem;padding:.5rem .65rem;border-radius:var(--r2);margin-bottom:.3rem;background:var(--surf2);border:1px solid transparent;transition:border-color .15s;}
.est-pace-row:hover{border-color:var(--border2);}
.est-pace-name{flex:1;font-size:.72rem;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.est-pace-val{font-family:var(--mono);font-size:.88rem;font-weight:700;flex-shrink:0;}
.est-pace-sub{font-size:.58rem;color:var(--muted2);flex-shrink:0;}
.est-pace-bar-bg{width:80px;height:6px;background:var(--surf3);border-radius:3px;overflow:hidden;flex-shrink:0;}
.est-pace-bar-fill{height:100%;border-radius:3px;transition:width .5s;}

/* ══ TEC CONCURSOS INTEGRATION ════════════════ */

/* "Estudar Agora" button inside meta cards */
.tec-launch-btn{
  display:inline-flex;align-items:center;gap:5px;
  font-size:.68rem;font-weight:700;padding:.38rem .8rem;
  border-radius:20px;cursor:pointer;border:none;
  color:#000;transition:all .2s;white-space:nowrap;
  font-family:var(--ff);
  /* color set inline per-card via discColor */
}
.tec-launch-btn:hover{transform:translateY(-1px);filter:brightness(1.1);}
.tec-launch-btn:active{transform:scale(.96);}
.tec-launch-btn.running{
  animation:tec-pulse 2s ease infinite;
  filter:brightness(1.05);
}
@keyframes tec-pulse{0%,100%{filter:brightness(1);}50%{filter:brightness(1.2);}}

/* Return floating notification */
#tec-return-banner{
  position:fixed;bottom:1.5rem;right:1.5rem;
  background:var(--surf);border:1px solid var(--border2);
  border-radius:16px;padding:1.1rem 1.3rem;
  box-shadow:0 12px 40px rgba(0,0,0,.5);
  z-index:850;
  display:none;
  width:320px;
  animation:slideUp .3s cubic-bezier(.34,1.56,.64,1);
}
@keyframes slideUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
#tec-return-banner::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:16px 16px 0 0;
  background:linear-gradient(90deg,#0ea5e9,#6366f1);
}

.tec-rb-header{
  display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;
}
.tec-rb-title{font-size:.78rem;font-weight:700;color:var(--text);}
.tec-rb-close{background:none;border:none;cursor:pointer;color:var(--muted2);font-size:1rem;padding:0;line-height:1;transition:color .15s;}
.tec-rb-close:hover{color:var(--text);}
.tec-rb-meta{font-size:.65rem;color:var(--muted2);margin-bottom:.85rem;line-height:1.4;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.tec-rb-timer{
  font-family:var(--mono);font-size:1.8rem;font-weight:300;
  color:var(--green);text-align:center;letter-spacing:2px;
  margin-bottom:.75rem;
}
.tec-rb-actions{display:flex;gap:.5rem;flex-direction:column;}
.tec-rb-row{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;}

/* Active studying indicator in topbar */
.tec-studying-pill{
  display:none;align-items:center;gap:.4rem;
  background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.3);
  border-radius:20px;padding:.25rem .7rem;cursor:pointer;
}
.tec-studying-pill.visible{display:flex;}
.tec-studying-pip{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);animation:tec-pulse 1.5s ease infinite;}
.tec-studying-text{font-size:.62rem;font-weight:700;color:var(--green);font-family:var(--mono);}

/* ══ RESUMOS ══════════════════════════════════ */
.res-card{
  background:var(--surf);border:1px solid var(--border);
  border-radius:var(--r3);overflow:hidden;
  transition:border-color .2s,transform .2s,box-shadow .2s;
  cursor:pointer;display:flex;flex-direction:column;
  position:relative;
}
.res-card:hover{transform:translateY(-3px);border-color:var(--border2);box-shadow:0 8px 28px rgba(0,0,0,.28);}
.res-card-accent{height:3px;width:100%;}
.res-card-body{padding:1.1rem;flex:1;}
.res-card-disc{font-size:.52rem;letter-spacing:3px;text-transform:uppercase;font-weight:700;font-family:var(--display);margin-bottom:.45rem;}
.res-card-title{font-size:.88rem;font-weight:800;line-height:1.3;margin-bottom:.5rem;color:var(--text);}
.res-card-preview{font-size:.72rem;color:var(--muted3);line-height:1.55;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;}
.res-card-img{width:100%;height:140px;object-fit:cover;border-bottom:1px solid var(--border);}
.res-card-footer{padding:.6rem 1.1rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.35rem;background:var(--surf2);}
.res-card-date{font-size:.58rem;color:var(--muted2);font-family:var(--mono);}
.res-card-tags{display:flex;gap:.28rem;flex-wrap:wrap;}
.res-tag{font-size:.52rem;font-weight:700;padding:1px 7px;border-radius:20px;background:var(--surf3);color:var(--muted3);border:1px solid var(--border);}
.res-card-actions{display:flex;gap:.3rem;opacity:0;transition:opacity .2s;}
.res-card:hover .res-card-actions{opacity:1;}
.res-card-btn{background:none;border:none;cursor:pointer;color:var(--muted2);font-size:.7rem;padding:2px 6px;border-radius:5px;transition:color .15s,background .15s;}
.res-card-btn:hover{color:var(--text);background:var(--surf3);}

/* Editor toolbar */
.res-fmt-btn{
  background:var(--surf3);border:1px solid var(--border);border-radius:5px;
  padding:2px 8px;font-size:.7rem;cursor:pointer;color:var(--muted3);
  transition:all .15s;font-family:var(--ff);line-height:1.5;
}
.res-fmt-btn:hover{color:var(--text);border-color:var(--gold);}
.res-fmt-clr{font-weight:900;font-size:.78rem;}

/* Editor content styles */
#res-editor:empty::before{content:attr(placeholder);color:var(--muted);pointer-events:none;}
#res-editor h2{font-size:1.05rem;font-weight:800;margin:.6rem 0 .3rem;color:var(--text);font-family:var(--display);}
#res-editor h3{font-size:.9rem;font-weight:700;margin:.5rem 0 .2rem;color:var(--text2);}
#res-editor ul{padding-left:1.2rem;margin:.3rem 0;}
#res-editor ol{padding-left:1.2rem;margin:.3rem 0;}
#res-editor li{margin:.2rem 0;font-size:.82rem;}
#res-editor blockquote{border-left:3px solid var(--gold);padding:.3rem .75rem;background:rgba(240,165,0,.06);border-radius:0 6px 6px 0;margin:.4rem 0;font-style:italic;color:var(--muted3);}
#res-editor code{background:var(--surf3);border:1px solid var(--border);border-radius:4px;padding:1px 6px;font-family:var(--mono);font-size:.78rem;color:var(--cyan);}
#res-editor mark{background:rgba(240,165,0,.25);color:var(--gold);border-radius:3px;padding:0 2px;}

/* Image drop zone hover */
#res-img-drop:hover{border-color:var(--gold);background:rgba(240,165,0,.04);}

/* Stats strip */
.res-stat-chip{
  background:var(--surf);border:1px solid var(--border);border-radius:20px;
  padding:.3rem .85rem;font-size:.68rem;font-weight:700;color:var(--muted3);
  display:flex;align-items:center;gap:.4rem;
}
.res-stat-chip span{color:var(--cyan);font-family:var(--mono);}

/* Viewer */
#res-viewer-content{padding:2rem;}
.res-viewer-title{font-family:var(--display);font-size:1.4rem;font-weight:800;margin-bottom:.5rem;}
.res-viewer-meta{font-size:.65rem;color:var(--muted2);margin-bottom:1.2rem;display:flex;gap:.75rem;flex-wrap:wrap;}
.res-viewer-body{font-size:.85rem;line-height:1.75;color:var(--text2);}
.res-viewer-body h2{font-size:1.05rem;font-weight:800;margin:.8rem 0 .35rem;color:var(--text);font-family:var(--display);}
.res-viewer-body h3{font-size:.92rem;font-weight:700;margin:.65rem 0 .25rem;}
.res-viewer-body ul{padding-left:1.3rem;margin:.35rem 0;}
.res-viewer-body ol{padding-left:1.3rem;margin:.35rem 0;}
.res-viewer-body li{margin:.25rem 0;}
.res-viewer-body blockquote{border-left:3px solid var(--gold);padding:.35rem .85rem;background:rgba(240,165,0,.06);border-radius:0 8px 8px 0;margin:.5rem 0;font-style:italic;}
.res-viewer-body code{background:var(--surf3);border:1px solid var(--border);border-radius:4px;padding:1px 6px;font-family:var(--mono);font-size:.8rem;color:var(--cyan);}
.res-viewer-body mark{background:rgba(240,165,0,.25);color:var(--gold);border-radius:3px;padding:0 3px;}
.res-viewer-img{width:100%;border-radius:var(--r);margin:1rem 0;border:1px solid var(--border);}

/* ══ REVISÃO ESPAÇADA ═════════════════════════ */
.rev-item{
  background:var(--surf);border:1px solid var(--border);
  border-radius:var(--r3);padding:1rem 1.2rem;margin-bottom:.65rem;
  position:relative;overflow:hidden;
  transition:border-color .2s,transform .15s;
}
.rev-item:hover{transform:translateX(3px);}
.rev-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.rev-item.status-overdue::before{background:var(--red);}
.rev-item.status-today::before{background:var(--gold);}
.rev-item.status-week::before{background:var(--cyan);}
.rev-item.status-ok::before{background:var(--green);}

.rev-item.status-overdue{border-color:rgba(248,113,113,.2);}
.rev-item.status-today{border-color:rgba(240,165,0,.2);}

.rev-badge{
  display:inline-flex;align-items:center;gap:4px;
  font-size:.55rem;font-weight:700;padding:2px 8px;border-radius:20px;
  font-family:var(--display);text-transform:uppercase;letter-spacing:1px;flex-shrink:0;
}
.rev-badge.overdue{background:rgba(248,113,113,.15);color:var(--red);border:1px solid rgba(248,113,113,.3);}
.rev-badge.today{background:rgba(240,165,0,.15);color:var(--gold);border:1px solid rgba(240,165,0,.3);}
.rev-badge.week{background:rgba(56,189,248,.12);color:var(--cyan);border:1px solid rgba(56,189,248,.25);}
.rev-badge.ok{background:rgba(52,211,153,.1);color:var(--green);border:1px solid rgba(52,211,153,.2);}

/* SM-2 interval ring */
.rev-ring-wrap{position:relative;width:52px;height:52px;flex-shrink:0;}
.rev-ring-wrap svg{transform:rotate(-90deg);}
.rev-ring-bg{fill:none;stroke:var(--surf3);stroke-width:4;}
.rev-ring-fill{fill:none;stroke-width:4;stroke-linecap:round;transition:stroke-dashoffset .5s;}
.rev-ring-label{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  font-family:var(--mono);font-size:.55rem;font-weight:700;line-height:1.1;text-align:center;
}

/* Calendar dot */
.rev-cal-row{display:flex;align-items:center;gap:.6rem;padding:.42rem 0;border-bottom:1px solid var(--border);}
.rev-cal-row:last-child{border-bottom:none;}
.rev-cal-date{font-family:var(--mono);font-size:.65rem;font-weight:700;min-width:55px;color:var(--muted3);}
.rev-cal-items{flex:1;display:flex;flex-wrap:wrap;gap:.25rem;}
.rev-cal-dot{font-size:.55rem;font-weight:700;padding:1px 7px;border-radius:10px;}

/* Mastery bar */
.rev-mastery-bar{height:5px;background:var(--surf3);border-radius:3px;overflow:hidden;margin-top:.4rem;}
.rev-mastery-fill{height:100%;border-radius:3px;transition:width .6s;}

/* Result buttons row */
.rev-result-row{display:flex;gap:.35rem;margin-top:.65rem;flex-wrap:wrap;}
.rev-result-btn{
  flex:1;min-width:60px;
  font-size:.65rem;font-weight:700;padding:.32rem .5rem;border-radius:8px;
  cursor:pointer;border:1px solid transparent;font-family:var(--ff);
  transition:all .15s;text-align:center;
}
.rev-result-btn:hover{transform:translateY(-1px);}
.rev-result-btn.r-fail{background:rgba(248,113,113,.12);color:var(--red);border-color:rgba(248,113,113,.3);}
.rev-result-btn.r-fail:hover{background:var(--red);color:#fff;}
.rev-result-btn.r-hard{background:rgba(251,146,60,.12);color:var(--orange);border-color:rgba(251,146,60,.3);}
.rev-result-btn.r-hard:hover{background:var(--orange);color:#fff;}
.rev-result-btn.r-ok{background:rgba(240,165,0,.12);color:var(--gold);border-color:rgba(240,165,0,.3);}
.rev-result-btn.r-ok:hover{background:var(--gold);color:#000;}
.rev-result-btn.r-good{background:rgba(56,189,248,.12);color:var(--cyan);border-color:rgba(56,189,248,.25);}
.rev-result-btn.r-good:hover{background:var(--cyan);color:#000;}
.rev-result-btn.r-easy{background:rgba(52,211,153,.12);color:var(--green);border-color:rgba(52,211,153,.25);}
.rev-result-btn.r-easy:hover{background:var(--green);color:#000;}

/* ══ PESO DO EDITAL ═══════════════════════════ */
.edital-row{
  display:flex;align-items:center;gap:.65rem;
  padding:.55rem .75rem;border-radius:var(--r);
  background:var(--surf2);border:1px solid var(--border);
  transition:border-color .2s;
}
.edital-row:hover{border-color:var(--border2);}
.edital-disc-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.edital-disc-name{flex:1;font-size:.78rem;font-weight:700;min-width:0;}
.edital-pct-inp{
  width:62px;text-align:center;
  font-family:var(--mono);font-size:.9rem;font-weight:700;
  background:var(--surf3);border:1px solid var(--border2);
  border-radius:var(--r2);color:var(--text);padding:.3rem .25rem;
  outline:none;transition:border-color .2s,box-shadow .2s;
}
.edital-pct-inp:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(240,165,0,.1);}
.edital-pct-lbl{font-size:.72rem;color:var(--muted2);font-weight:700;}
.edital-bar-bg{flex:1;height:6px;background:var(--surf3);border-radius:3px;overflow:hidden;min-width:60px;}
.edital-bar-fill{height:100%;border-radius:3px;transition:width .4s;}

/* Alignment analysis */
.edital-analysis-row{
  display:flex;align-items:center;gap:.6rem;
  padding:.55rem 0;border-bottom:1px solid var(--border);
}
.edital-analysis-row:last-child{border-bottom:none;}
.edital-analysis-name{font-size:.75rem;font-weight:700;min-width:0;flex:1;}
.edital-cmp-bars{flex:2;display:flex;flex-direction:column;gap:3px;}
.edital-cmp-bar-wrap{display:flex;align-items:center;gap:.4rem;}
.edital-cmp-lbl{font-size:.52rem;color:var(--muted2);width:36px;text-align:right;flex-shrink:0;}
.edital-cmp-bar-bg{flex:1;height:5px;background:var(--surf3);border-radius:3px;overflow:hidden;}
.edital-cmp-bar-fill{height:100%;border-radius:3px;transition:width .5s;}
.edital-gap-badge{
  font-size:.58rem;font-weight:700;padding:2px 7px;border-radius:10px;
  flex-shrink:0;font-family:var(--mono);
}
.edital-gap-over{background:rgba(52,211,153,.15);color:var(--green);}
.edital-gap-under{background:rgba(248,113,113,.15);color:var(--red);}
.edital-gap-ok{background:rgba(56,189,248,.1);color:var(--cyan);}

/* Dashboard edital strip */
.edital-strip-item{
  display:flex;align-items:center;gap:.5rem;
  padding:.5rem 0;border-bottom:1px solid var(--border);
}
.edital-strip-item:last-child{border-bottom:none;}

/* ══ ARENA — MODO FOCO & GAMIFICAÇÃO ═══════════ */

/* Hero */
.arena-hero{
  background:var(--surf);border:1px solid var(--border);
  border-radius:var(--r3);padding:1.5rem;margin-bottom:1.25rem;
  position:relative;overflow:hidden;
}
.arena-hero::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--purple),var(--cyan),transparent);
}

/* Avatar */
.arena-avatar{
  width:60px;height:60px;border-radius:16px;
  background:linear-gradient(135deg,rgba(167,139,250,.2),rgba(56,189,248,.1));
  border:2px solid rgba(167,139,250,.4);
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;flex-shrink:0;
  box-shadow:0 4px 16px rgba(167,139,250,.2);
}

/* Focus presets grid */
.arena-preset{
  background:var(--surf2);border:1.5px solid var(--border2);
  border-radius:12px;padding:.65rem .5rem;
  text-align:center;cursor:pointer;
  transition:all .2s;position:relative;overflow:hidden;
}
.arena-preset:hover{transform:translateY(-2px);border-color:var(--purple);box-shadow:0 4px 16px rgba(167,139,250,.2);}
.arena-preset:active{transform:scale(.96);}
.arena-preset-featured{
  border-color:rgba(167,139,250,.5)!important;
  background:rgba(167,139,250,.08)!important;
}
.arena-preset-featured::before{
  content:'★';position:absolute;top:4px;right:6px;font-size:.5rem;color:var(--purple);
}
.arena-preset-time{font-family:var(--mono);font-size:1.3rem;font-weight:700;color:var(--text);line-height:1;}
.arena-preset-label{font-size:.48rem;color:var(--muted2);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:2px;}
.arena-preset-name{font-size:.65rem;font-weight:700;color:var(--text2);}
.arena-preset-xp{font-size:.55rem;color:var(--gold);font-family:var(--mono);font-weight:700;margin-top:2px;}

/* Mission items */
.arena-mission{
  display:flex;align-items:center;gap:.6rem;
  padding:.48rem .65rem;border-radius:var(--r2);
  background:var(--surf2);border:1px solid var(--border);
  transition:all .2s;
}
.arena-mission.done{opacity:.6;background:rgba(52,211,153,.05);border-color:rgba(52,211,153,.2);}
.arena-mission-check{
  width:18px;height:18px;border-radius:50%;
  border:1.5px solid var(--border2);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;transition:all .2s;
}
.arena-mission.done .arena-mission-check{background:var(--green);border-color:var(--green);color:#fff;}
.arena-mission-name{flex:1;font-size:.73rem;font-weight:600;}
.arena-mission.done .arena-mission-name{text-decoration:line-through;}
.arena-mission-xp{font-size:.6rem;color:var(--gold);font-family:var(--mono);font-weight:700;flex-shrink:0;}

/* Achievement cards */
.arena-ach{
  background:var(--surf2);border:1.5px solid var(--border);
  border-radius:12px;padding:.75rem;text-align:center;
  transition:all .2s;position:relative;overflow:hidden;
}
.arena-ach.unlocked{border-color:rgba(240,165,0,.4);background:rgba(240,165,0,.05);}
.arena-ach.unlocked:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(240,165,0,.15);}
.arena-ach.locked{opacity:.45;filter:grayscale(.8);}
.arena-ach-icon{font-size:1.6rem;margin-bottom:.35rem;}
.arena-ach-name{font-size:.68rem;font-weight:700;margin-bottom:.15rem;}
.arena-ach-desc{font-size:.58rem;color:var(--muted2);line-height:1.4;}
.arena-ach-xp{font-size:.55rem;color:var(--gold);font-family:var(--mono);margin-top:.3rem;}
.arena-ach.unlocked .arena-ach-badge{
  position:absolute;top:6px;right:6px;width:14px;height:14px;
  background:var(--gold);border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-size:.5rem;color:#000;
}

/* XP history */
.arena-xp-row{
  display:flex;align-items:center;gap:.55rem;
  padding:.4rem 0;border-bottom:1px solid var(--border);font-size:.7rem;
}
.arena-xp-row:last-child{border-bottom:none;}
.arena-xp-icon{font-size:.9rem;flex-shrink:0;}
.arena-xp-desc{flex:1;color:var(--text2);}
.arena-xp-amount{font-family:var(--mono);font-weight:700;color:var(--gold);flex-shrink:0;}
.arena-xp-date{font-size:.58rem;color:var(--muted2);flex-shrink:0;}

/* XP popup animation */
@keyframes xpFloat{0%{opacity:1;transform:translate(-50%,-10px);}100%{opacity:0;transform:translate(-50%,-60px);}}
.arena-xp-popup{
  position:fixed;z-index:9999;pointer-events:none;
  font-family:var(--mono);font-size:1.1rem;font-weight:800;color:var(--gold);
  text-shadow:0 2px 8px rgba(240,165,0,.5);
  animation:xpFloat 1.5s ease forwards;
}

/* Focus card pulse when active */
.arena-focus-card.active-focus{
  border-color:rgba(167,139,250,.4);
  box-shadow:0 0 0 3px rgba(167,139,250,.08);
}

/* ══ HUBERMAN PROTOCOL ════════════════════════ */
.hub-tabs{display:flex;gap:3px;background:var(--surf3);padding:3px;border-radius:var(--r);margin-bottom:1rem;}
.hub-tab{flex:1;padding:.38rem .5rem;border:none;border-radius:var(--r2);background:transparent;color:var(--muted2);cursor:pointer;font-family:var(--ff);font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;transition:all .2s;}
.hub-tab.active{background:var(--surf);color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.3);}

.hub-protocol-step{
  display:flex;align-items:flex-start;gap:.75rem;
  padding:.65rem .8rem;margin-bottom:.4rem;
  background:var(--surf2);border-radius:var(--r);
  border-left:3px solid transparent;
  transition:all .2s;
}
.hub-protocol-step.active-step{border-left-color:var(--green);background:rgba(52,211,153,.06);}
.hub-protocol-step.done-step{opacity:.55;border-left-color:var(--green);}
.hub-step-num{
  width:26px;height:26px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:800;flex-shrink:0;
  border:1.5px solid var(--border2);color:var(--muted2);
  font-family:var(--mono);transition:all .2s;
}
.hub-protocol-step.active-step .hub-step-num{background:var(--green);border-color:var(--green);color:#000;}
.hub-protocol-step.done-step .hub-step-num{background:var(--surf3);color:var(--green);border-color:var(--green);}
.hub-step-body{flex:1;min-width:0;}
.hub-step-title{font-size:.75rem;font-weight:700;margin-bottom:.18rem;}
.hub-step-desc{font-size:.63rem;color:var(--muted2);line-height:1.55;}
.hub-step-science{font-size:.58rem;color:var(--purple);font-style:italic;margin-top:.2rem;}
.hub-step-action{font-size:.62rem;color:var(--cyan);font-weight:700;margin-top:.28rem;}
.hub-step-timer{font-family:var(--mono);font-size:.65rem;color:var(--gold);flex-shrink:0;font-weight:700;}

/* Procrastination breaker */
.hub-break-btn{
  width:100%;padding:1rem;border-radius:var(--r3);border:none;cursor:pointer;
  background:linear-gradient(135deg,rgba(167,139,250,.15),rgba(56,189,248,.1));
  border:1.5px solid rgba(167,139,250,.3);color:var(--text);
  font-family:var(--display);font-size:.88rem;font-weight:700;
  transition:all .2s;text-align:center;
}
.hub-break-btn:hover{background:linear-gradient(135deg,rgba(167,139,250,.22),rgba(56,189,248,.16));transform:translateY(-1px);}

/* State chips */
.hub-state-chip{
  display:inline-flex;align-items:center;gap:.3rem;
  padding:.2rem .6rem;border-radius:20px;font-size:.6rem;font-weight:700;
  font-family:var(--display);cursor:pointer;transition:all .15s;
  border:1px solid transparent;
}
.hub-state-chip.selected{border-color:currentColor;}

/* ══ SESSÃO DE QUESTÕES ════════════════════════ */

/* Question grid cells */
.sq-cell{
  width:38px;height:38px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--mono);font-size:.72rem;font-weight:700;
  cursor:pointer;transition:all .2s;border:1.5px solid var(--border2);
  background:var(--surf2);color:var(--muted2);
  position:relative;overflow:hidden;
}
.sq-cell:hover:not(.sq-answered){border-color:var(--cyan);color:var(--text);background:var(--surf3);}
.sq-cell.sq-current{
  border-color:var(--cyan);color:var(--cyan);
  background:rgba(56,189,248,.1);
  box-shadow:0 0 10px rgba(56,189,248,.2);
  animation:sq-pulse-current 1.5s ease infinite;
}
@keyframes sq-pulse-current{0%,100%{box-shadow:0 0 10px rgba(56,189,248,.2);}50%{box-shadow:0 0 18px rgba(56,189,248,.4);}}

.sq-cell.sq-correct{
  border-color:var(--green);color:#000;
  background:var(--green);
  box-shadow:0 2px 8px rgba(52,211,153,.3);
}
.sq-cell.sq-correct::after{content:'✓';position:absolute;font-size:.9rem;}
.sq-cell.sq-wrong{
  border-color:var(--red);color:#fff;
  background:var(--red);
  box-shadow:0 2px 8px rgba(248,113,113,.3);
}
.sq-cell.sq-wrong::after{content:'✕';position:absolute;font-size:.9rem;}
.sq-cell.sq-review-pending{
  border-color:var(--gold);color:var(--gold);
  background:rgba(240,165,0,.1);
  animation:sq-pulse-review .8s ease infinite;
}
@keyframes sq-pulse-review{0%,100%{border-color:rgba(240,165,0,.6);}50%{border-color:var(--gold);box-shadow:0 0 10px rgba(240,165,0,.25);}}
.sq-cell.sq-reviewed-correct{
  border-color:rgba(52,211,153,.5);color:var(--green);
  background:rgba(52,211,153,.08);
}
.sq-cell.sq-reviewed-correct::after{content:'✓²';position:absolute;font-size:.55rem;bottom:3px;right:3px;color:var(--green);}
.sq-cell.sq-reviewed-wrong{
  border-color:rgba(248,113,113,.5);color:var(--red);
  background:rgba(248,113,113,.08);
}
.sq-cell.sq-reviewed-wrong::after{content:'✕²';position:absolute;font-size:.55rem;bottom:3px;right:3px;color:var(--red);}
.sq-cell.sq-skipped{border-color:var(--border);color:var(--muted);opacity:.5;}

/* Queue items */
.sq-queue-item{
  display:flex;align-items:center;gap:.6rem;
  padding:.42rem .6rem;border-radius:var(--r2);
  background:var(--surf2);border:1px solid var(--border);
  font-size:.7rem;
}
.sq-queue-item.ready{border-color:rgba(240,165,0,.35);background:rgba(240,165,0,.05);}
.sq-queue-timer{font-family:var(--mono);font-size:.65rem;color:var(--muted2);flex-shrink:0;min-width:45px;text-align:right;}
.sq-queue-timer.urgent{color:var(--gold);font-weight:700;}

/* btn-green utility */
.btn-green{background:var(--green);color:#000;box-shadow:0 3px 12px rgba(52,211,153,.25);}
.btn-green:hover{box-shadow:0 4px 18px rgba(52,211,153,.4);}

/* pulse border animation */
@keyframes pulse-border{0%,100%{box-shadow:0 0 0 2px rgba(240,165,0,.2);}50%{box-shadow:0 0 0 4px rgba(240,165,0,.1);}}

/* ══ FILA DE REVISÃO POR LINK ════════════════ */
.fr-item{
  display:flex;align-items:flex-start;gap:.75rem;
  padding:.85rem 1rem;border-radius:var(--r3);
  border:1px solid var(--border);background:var(--surf);
  margin-bottom:.55rem;position:relative;overflow:hidden;
  transition:all .2s;
}
.fr-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.fr-item.fr-waiting::before{background:var(--border2);}
.fr-item.fr-ready::before{background:var(--red);}
.fr-item.fr-done::before{background:var(--green);}
.fr-item.fr-ready{border-color:rgba(248,113,113,.25);background:rgba(248,113,113,.04);animation:frPulse 2s ease infinite;}
.fr-item.fr-done{opacity:.5;}
@keyframes frPulse{0%,100%{box-shadow:none;}50%{box-shadow:0 0 0 3px rgba(248,113,113,.08);}}

.fr-countdown{
  font-family:var(--mono);font-size:1rem;font-weight:700;
  min-width:52px;text-align:center;flex-shrink:0;
  line-height:1.2;
}
.fr-open-btn{
  background:var(--red);color:#fff;border:none;border-radius:var(--r);
  padding:.35rem .75rem;cursor:pointer;font-size:.72rem;font-weight:700;
  font-family:var(--ff);transition:all .15s;flex-shrink:0;
  animation:frBtnPulse 1s ease infinite;
}
.fr-open-btn:hover{background:#ef4444;}
@keyframes frBtnPulse{0%,100%{box-shadow:0 0 0 2px rgba(248,113,113,.2);}50%{box-shadow:0 0 0 5px rgba(248,113,113,.08);}}
@keyframes slideUp{from{transform:translateY(24px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* ══ MISSÕES ATIVAS ════════════════════════════ */
.missoes-day-section { margin-bottom:1.4rem; }
.missoes-day-header {
  display:flex;align-items:center;gap:.75rem;
  padding:.65rem .9rem;background:var(--surf2);
  border-radius:var(--r3) var(--r3) 0 0;
  border:1px solid var(--border);border-bottom:none;
}
.missoes-day-name { font-size:.88rem;font-weight:800;min-width:100px; }
.missoes-day-date { font-size:.68rem;color:var(--muted2); }
.missoes-day-prog { flex:1;height:4px;background:var(--surf3);border-radius:2px;overflow:hidden;margin:0 .75rem; }
.missoes-day-prog-fill { height:100%;border-radius:2px;background:var(--green);transition:width .5s; }
.missoes-day-count { font-size:.62rem;color:var(--muted2);flex-shrink:0; }

.missoes-cards-row {
  display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:.65rem;padding:.75rem;
  background:var(--surf2);border:1px solid var(--border);
  border-radius:0 0 var(--r3) var(--r3);
}
.missoes-card {
  background:var(--surf);border:1px solid var(--border2);
  border-radius:var(--r3);padding:.85rem .9rem;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.missoes-card:hover { transform:translateY(-2px);border-color:var(--border3); }
.missoes-card.done { opacity:.55; }
.missoes-card.done::after { content:'✓';position:absolute;top:8px;right:10px;font-size:1rem;color:var(--green); }
.missoes-card[draggable]{cursor:grab;}
.missoes-card.dragging{opacity:.4;transform:scale(.97);}
.missoes-card.drag-over{border-top:2px solid #4a6cf7 !important;background:rgba(74,108,247,.05);}
.missoes-drag-handle{color:#374151;font-size:.75rem;cursor:grab;padding:2px 4px;flex-shrink:0;transition:color .15s;}
.missoes-drag-handle:hover{color:#6b80a8;}
.missoes-card-tag {
  display:inline-flex;align-items:center;gap:4px;
  font-size:.55rem;font-weight:700;padding:2px 8px;border-radius:20px;
  text-transform:uppercase;letter-spacing:1.5px;margin-bottom:.5rem;
}
.missoes-card-title { font-size:.82rem;font-weight:700;margin-bottom:.25rem;line-height:1.3; }
.missoes-card-sub { font-size:.65rem;color:var(--muted2);margin-bottom:.5rem; }
.missoes-card-meta { display:flex;align-items:center;gap:.5rem;font-size:.6rem;color:var(--muted2); }
.missoes-card-type { font-size:.58rem;padding:1px 7px;border-radius:10px;background:var(--surf3);border:1px solid var(--border); }

/* Today highlight */
.missoes-day-section.today .missoes-day-header { background:rgba(240,165,0,.07);border-color:rgba(240,165,0,.25); }
.missoes-day-section.today .missoes-day-name { color:var(--gold); }
.missoes-day-section.today .missoes-cards-row { border-color:rgba(240,165,0,.2); }

/* ══ CRONÔMETRO LAYOUT ══════════════════════ */
.cron-layout{display:grid;grid-template-columns:minmax(0,340px) 1fr;gap:1.25rem;align-items:start;}
@media(max-width:960px){.cron-layout{grid-template-columns:1fr;}}
@media(min-width:961px){.cron-layout>div:first-child{position:sticky;top:1rem;}}

/* ══ CRONÔMETRO NOVO ════════════════════════ */
.cron-preset{padding:5px 11px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:#1f2937;color:#9ca3af;cursor:pointer;font-size:11px;font-weight:700;font-family:inherit;transition:all .15s;}
.cron-preset:hover,.cron-preset.active{background:rgba(74,108,247,.12);border-color:rgba(74,108,247,.4);color:#4a6cf7;}
</style>
