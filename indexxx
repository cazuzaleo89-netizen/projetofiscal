function cadrAddLink(cadrId, url, desc, discId, discName, discColor) {
  cadrEnsure();
  const c = state.cadernos.find(c => c.id === cadrId);
  if (!c) return;
  if (c.links.some(l => l.url === url)) return; // deduplicate
  c.links.push({
    id: uid(), url,
    desc: desc || url,
    discId: discId || '',
    discName: discName || '',
    discColor: discColor || '',
    addedAt: new Date().toISOString()
  });
  saveState();
}

function cadrRemoveLink(cadrId, linkId) {
  cadrEnsure();
