      <!-- Top accent -->
      <div style="position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#4a6cf7,transparent);border-radius:16px 16px 0 0;pointer-events:none;"></div>

      <!-- Tabs -->
      <div style="display:flex;gap:0;margin-bottom:1.5rem;background:#0f1420;border-radius:10px;padding:3px;">
        <button id="auth-tab-login" onclick="authSwitchTab('login')"
          style="flex:1;padding:8px;border:none;border-radius:8px;background:#1c2438;color:#f9fafb;font-size:.82rem;font-weight:700;cursor:pointer;font-family:inherit;transition:all .2s;">
