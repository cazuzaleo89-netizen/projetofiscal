            <!-- Link do caderno -->
            <div class="frow">
              <label class="flabel">Link do Caderno TecConcursos</label>
              <div style="display:flex;gap:.4rem;">
                <input class="inp" id="sq-tec-link-inp" type="url"
                  placeholder="https://www.tecconcursos.com.br/cadernos/..."
                  style="flex:1;font-size:.75rem;"
