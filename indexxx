function frCheckQueue() {
  frEnsure();
  const now = Date.now();
  const newlyReady = [];

  state.filaRevisao.forEach(item => {
    if (item.status === 'waiting' && item.dueAt <= now) {
      item.status = 'ready';
      newlyReady.push(item);
    }
  });

  if (newlyReady.length > 0) {
    saveState();
    frPlayAlert();
    // Show modal for each ready item (one at a time)
    frShowAlertModal(newlyReady);
    frUpdateNavBadge();
    // Browser notification
    if (Notification.permission === 'granted') {
      const n = new Notification('⏰ Revisão disponível — Painel Fiscal', {
        body: `${newlyReady.length} questão${newlyReady.length>1?'ões':''} pronta${newlyReady.length>1?'s':''} para refazer!`,
        tag: 'filarev',
        requireInteraction: true,
      });
      n.onclick = () => { window.focus(); frShowAlertModal(newlyReady); };
    }
    // Push para o tab TEC para o usuário ver sem trocar de aba
    try { tecPushFilaReady(newlyReady); } catch(e) {}
    const page = document.getElementById('page-filarev');
    if (page && page.classList.contains('active')) frRender();
  }
}

