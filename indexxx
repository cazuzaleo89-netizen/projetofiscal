function frPlayAlert() {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    [523, 659, 784, 1047].forEach((f, i) => {
      const o = ctx.createOscillator(), g = ctx.createGain();
      o.connect(g); g.connect(ctx.destination);
      o.type = 'sine'; o.frequency.value = f;
      g.gain.setValueAtTime(0, ctx.currentTime + i*.2);
      g.gain.linearRampToValueAtTime(.2, ctx.currentTime + i*.2 + .04);
      g.gain.exponentialRampToValueAtTime(.001, ctx.currentTime + i*.2 + .28);
      o.start(ctx.currentTime + i*.2); o.stop(ctx.currentTime + i*.2 + .3);
    });
  } catch(e) {}
}

function frUpdateNavBadge() {
  frEnsure();
  const ready = state.filaRevisao.filter(q => q.status === 'ready').length;
  const badge = document.getElementById('filarev-nav-badge');
  if (badge) {
    badge.textContent = ready;
    badge.style.display = ready > 0 ? '' : 'none';
  }
}

function frRender() {
  frEnsure();
  const now = Date.now();

  // Populate disc select
  const sel = document.getElementById('fr-disc-sel');
  if (sel && sel.options.length <= 1) {
    state.disciplines.forEach(d => sel.appendChild(new Option(d.name, d.id)));
  }

  // Update KPIs
  const overdue = state.filaRevisao.filter(q => q.status === 'ready').length;
  const waiting = state.filaRevisao.filter(q => q.status === 'waiting').length;
  const todayStr = new Date().toDateString();
  const done = state.filaRevisao.filter(q => q.status === 'done' && q.doneAt && new Date(q.doneAt).toDateString() === todayStr).length;
  set('fr-kpi-overdue', overdue);
  set('fr-kpi-waiting', waiting);
  set('fr-kpi-done', done);
  frUpdateNavBadge();

  // Render list
  const list = document.getElementById('fr-queue-list');
  if (!list) return;

  if (!state.filaRevisao.length) {
    list.innerHTML = `<div class="empty">Nenhuma questão na fila. Adicione links de questões que você errou! 📋</div>`;
    return;
  }

  // Sort: ready first, then waiting by dueAt, then done
  const sorted = [...state.filaRevisao].sort((a, b) => {
    const order = {ready:0, waiting:1, done:2};
    if (order[a.status] !== order[b.status]) return order[a.status] - order[b.status];
    if(a.status==='waiting' && b.status==='waiting'){
      // reincidentes primeiro dentro de waiting
      if((b.reincidente?1:0) !== (a.reincidente?1:0)) return (b.reincidente?1:0)-(a.reincidente?1:0);
    }
    return a.dueAt - b.dueAt;
  });

  // Collapse de revisadas: agrupa done num toggle
  const doneItems = sorted.filter(i=>i.status==='done');
  const activeItems = sorted.filter(i=>i.status!=='done');
  list.innerHTML = '';
  activeItems.forEach(item => {
    const msLeft = item.dueAt - now;
    const secsLeft = Math.max(0, Math.ceil(msLeft / 1000));
    const minsLeft = Math.floor(secsLeft / 60);
    const secsRem  = secsLeft % 60;
    const isReady  = item.status === 'ready';
    const isDone   = item.status === 'done';

    const countdownStr = isDone
      ? '✓'
      : isReady
        ? '⏰'
        : `${minsLeft}:${secsRem.toString().padStart(2,'0')}`;

    const countdownColor = isDone ? 'var(--green)' : isReady ? 'var(--red)' : minsLeft < 2 ? 'var(--gold)' : 'var(--muted2)';

    const el = document.createElement('div');
    el.className = `fr-item fr-${item.status}`;
    if(item.reincidente) el.style.borderColor = 'rgba(239,68,68,.35)';
    el.innerHTML = `
      <!-- Countdown -->
      <div class="fr-countdown" style="color:${countdownColor};">
        ${countdownStr}
        ${!isDone ? `<div style="font-size:.5rem;color:var(--muted2);text-transform:uppercase;letter-spacing:1px;margin-top:1px;">${isReady?'PRONTO':'restam'}</div>` : ''}
      </div>

      <!-- Info -->
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;gap:.35rem;margin-bottom:.2rem;flex-wrap:wrap;">
          ${item.reincidente ? `<span style="font-size:.5rem;padding:1px 5px;border-radius:4px;background:rgba(239,68,68,.2);color:#ef4444;border:1px solid rgba(239,68,68,.4);font-weight:800;flex-shrink:0;">⚠️ ${item.erros||2}× ERRO</span>` : ''}
          <div style="font-size:.8rem;font-weight:700;${isDone?'text-decoration:line-through;color:var(--muted3)':'color:var(--text)'};overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">
            ${item.desc || 'Questão'}
          </div>
        </div>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;font-size:.6rem;color:var(--muted2);">
          ${item.discName !== '—' ? `<span style="color:${item.discColor};font-weight:700;">${item.discName.replace('Dir. ','')}</span>` : ''}
          <span>⏱ ${item.intervalMins} min</span>
          <span>Vence: ${new Date(item.dueAt).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}</span>
        </div>
        <div style="font-size:.6rem;color:var(--muted);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
          🔗 <a href="${item.link}" target="_blank" style="color:var(--cyan);text-decoration:none;" onclick="event.stopPropagation()">${item.link.slice(0,60)}${item.link.length>60?'…':''}</a>
        </div>
      </div>

      <!-- Actions -->
      <div style="display:flex;flex-direction:column;gap:.3rem;flex-shrink:0;align-items:flex-end;">
        ${isReady
          ? `<button onclick="frOpenQuestion('${item.id}')" class="fr-open-btn">▶ Refazer</button>`
          : isDone
            ? `<span style="font-size:.6rem;color:var(--green);font-weight:700;">✓ Feita</span>`
            : `<button onclick="frOpenQuestion('${item.id}')" style="background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);padding:.28rem .6rem;cursor:pointer;font-size:.62rem;color:var(--muted2);font-family:var(--ff);" title="Abrir agora sem esperar">↗ Abrir</button>`
        }
        <div style="display:flex;gap:.25rem;">
          ${!isDone ? `<button onclick="frMarkDone('${item.id}')" title="Marcar como revisada" style="background:none;border:1px solid rgba(52,211,153,.3);border-radius:6px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:var(--green);">✓</button>` : ''}
          <button onclick="cadrOpenModal('${item.id}')" title="Salvar no caderno" style="background:none;border:1px solid rgba(139,92,246,.3);border-radius:6px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:#a78bfa;">📚</button>
          <button onclick="tecCadrSearch('${(item.materia||item.discName||'').replace(/'/g,'&apos;')}','${(item.assunto||'').replace(/'/g,'&apos;')}','${(item.desc||'').replace(/'/g,'&apos;').replace(/"/g,'&quot;').slice(0,300)}')" title="Buscar similares no TecConcursos (assunto + palavras-chave do enunciado)" style="background:none;border:1px solid rgba(34,211,238,.3);border-radius:6px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:#22d3ee;">🔍</button>
          <button onclick="frRemove('${item.id}')" title="Remover" style="background:none;border:1px solid rgba(248,113,113,.25);border-radius:6px;padding:2px 6px;cursor:pointer;font-size:.6rem;color:var(--red);">✕</button>
        </div>
      </div>`;
    list.appendChild(el);
  });

  // Bloco colapsável de revisadas
  if(doneItems.length > 0){
    const doneWrap = document.createElement('div');
    doneWrap.style.cssText = 'margin-top:.5rem;border-top:1px solid var(--border);padding-top:.5rem;';
    doneWrap.innerHTML = `<button onclick="frToggleDone(this)" style="background:none;border:none;cursor:pointer;font-size:.65rem;color:var(--muted2);font-family:var(--ff);display:flex;align-items:center;gap:.35rem;padding:.2rem 0;width:100%;">
      <span>▶</span><span>✓ ${doneItems.length} revisada${doneItems.length>1?'s':''} — clique para ver</span>
      <button onclick="event.stopPropagation();frClearDone()" style="margin-left:auto;background:none;border:1px solid rgba(248,113,113,.2);border-radius:5px;padding:1px 6px;cursor:pointer;font-size:.57rem;color:var(--red);font-family:var(--ff);">🧹 Limpar</button>
    </button>
    <div id="fr-done-list" style="display:none;margin-top:.35rem;display:flex;flex-direction:column;gap:.3rem;overflow:hidden;max-height:0;transition:max-height .3s ease;"></div>`;
    list.appendChild(doneWrap);
    // Preenche a lista de feitas
    const doneList = doneWrap.querySelector('#fr-done-list');
    doneItems.forEach(item => {
      const d = document.createElement('div');
      d.style.cssText = 'display:flex;align-items:center;gap:.5rem;background:rgba(16,185,129,.04);border:1px solid rgba(16,185,129,.1);border-radius:8px;padding:.4rem .65rem;opacity:.7;';
      d.innerHTML = `<span style="font-size:.65rem;color:var(--green);">✓</span>
        <span style="font-size:.65rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--muted2);">${item.desc||'Questão'}</span>
        <a href="${item.link}" target="_blank" style="font-size:.58rem;color:var(--cyan);text-decoration:none;">🔗</a>
        <button onclick="frRemove('${item.id}')" style="background:none;border:none;cursor:pointer;font-size:.6rem;color:var(--muted);font-family:var(--ff);">✕</button>`;
      doneList.appendChild(d);
    });
  }
}

function frToggleDone(btn){
  const list = btn.parentElement.querySelector('#fr-done-list');
  if(!list) return;
  const isOpen = list.style.maxHeight && list.style.maxHeight !== '0px';
  if(isOpen){
    list.style.maxHeight = '0px';
    btn.querySelector('span').textContent = '▶';
  } else {
    list.style.display='flex';list.style.flexDirection='column';
    list.style.maxHeight = list.scrollHeight + 'px';
    btn.querySelector('span').textContent = '▼';
  }
}



