// ── Persistência de sessão ────────────────────────
function cronPersist() {
  if (!cronState.running && !cronState.paused) return;
  try {
    localStorage.setItem('pf_cron_persist', JSON.stringify({
      mode:      cronState.mode,
      elapsed:   cronState.elapsed,
      total:     cronState.total,
      paused:    cronState.paused,
      discId:    cronState.discId,
      discName:  cronState.discName,
      discColor: cronState.discColor,
      assunto:   cronState.assunto || document.getElementById('cron-assunto-inp')?.value?.trim() || '',
      presetMins:cronState.presetMins,
      resolved:  cronState.resolved,
      acertos:   cronState.acertos,
      erros:     cronState.erros,
      invTotal:  _cronInv.total,
      invMateria:_cronInv.materia,
      invAssunto:_cronInv.assunto,
      invCaderno:_cronInv.caderno,
      savedAt:   Date.now()
    }));
  } catch(e) {}
}

function cronCheckResume() {
  let saved;
  try { saved = JSON.parse(localStorage.getItem('pf_cron_persist')); } catch(e) {}
  if (!saved || !saved.discName) return;
  // Ignorar sessões salvas há mais de 24 horas
  if (saved.savedAt && (Date.now() - saved.savedAt) > 86400000) {
    localStorage.removeItem('pf_cron_persist'); return;
  }
  const displaySecs = saved.mode === 'timer'
    ? Math.max(0, saved.total - saved.elapsed)
    : saved.elapsed;
  const banner = document.getElementById('cron-resume-banner');
  const info   = document.getElementById('cron-resume-info');
  if (!banner) return;
  const parts = [saved.discName];
  if (saved.assunto) parts.push(saved.assunto);
  parts.push(formatHM(displaySecs));
  if (saved.resolved > 0) parts.push(`${saved.acertos}/${saved.resolved} questões`);
  if (info) info.textContent = parts.join(' · ');
  banner.style.display = '';
}

function cronResumeSaved() {
  let saved;
  try { saved = JSON.parse(localStorage.getItem('pf_cron_persist')); } catch(e) {}
  if (!saved) return;

  // Restaurar state
  cronState.mode       = saved.mode  || 'chrono';
  cronState.elapsed    = saved.elapsed || 0;
  cronState.total      = saved.total   || 0;
  cronState.discId     = saved.discId  || '';
  cronState.discName   = saved.discName || '';
  cronState.discColor  = saved.discColor || '#4a6cf7';
  cronState.assunto    = saved.assunto   || '';
  cronState.presetMins = saved.presetMins || 45;
  cronState.resolved   = saved.resolved  || 0;
  cronState.acertos    = saved.acertos   || 0;
  cronState.erros      = saved.erros     || 0;
  cronState.running    = true;
  cronState.paused     = false;
  cronState.startTs    = Date.now();

  // Restaurar investida
  if (saved.invTotal) {
    _cronInv.total   = saved.invTotal;
    _cronInv.materia = saved.invMateria || '';
    _cronInv.assunto = saved.invAssunto || '';
    _cronInv.caderno = saved.invCaderno || '';
    const invCard = document.getElementById('cron-investida-card');
    if (invCard) invCard.style.display = '';
    cronInvUpdate();
  }

  // Preencher campo de assunto
  const assuntoInp = document.getElementById('cron-assunto-inp');
  if (assuntoInp && saved.assunto) {
    assuntoInp.value = saved.assunto;
    const badge = document.getElementById('cron-assunto-tec-badge');
    if (badge && saved.invAssunto === saved.assunto) badge.style.display = '';
  }

  // Sincronizar seletor de disciplina
  const sel = document.getElementById('cron-disc-sel');
  if (sel && saved.discId) sel.value = saved.discId;

  // Modo de exibição correto
  cronSwitchMode(cronState.mode);

  // Iniciar tick
  clearInterval(cronState.interval);
  cronState.interval = setInterval(cronTick, 1000);
  cronUpdateUI();
  cronUpdateBtns('running');
  cronSetBadge('ATIVO','rgba(74,108,247,.15)','#4a6cf7','rgba(74,108,247,.3)');

  // Esconder banner
  const banner = document.getElementById('cron-resume-banner');
  if (banner) banner.style.display = 'none';

  flash('▶ Sessão retomada!', '#4a6cf7');
}

