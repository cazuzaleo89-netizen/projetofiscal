// ÍNDICE DE PROFICIÊNCIA
// Score = acerto_ponderado × volume × recência
// ═══════════════════════════════════════════════
function calcProficiencyIndex(discId){
  const qs = state.questionSessions.filter(s=>s.subjectId===discId);
  if(!qs.length) return null;

  const now = Date.now();
  const DAY = 1000*60*60*24;

  let weightedRate = 0, totalWeight = 0;
  qs.forEach(s=>{
    const age = (now - new Date(s.date).getTime()) / DAY;
    const recency = Math.exp(-age/30); // decay over 30 days
    const w = s.total * recency;
    weightedRate += (s.correct/s.total) * w;
    totalWeight += w;
  });

  const rate = totalWeight>0 ? weightedRate/totalWeight : 0;
  const totalQ = qs.reduce((a,s)=>a+s.total,0);
  const volumeScore = Math.min(totalQ/200, 1); // saturates at 200 questões

  // Final index: 0–100
  return Math.round(rate * 70 + volumeScore * 30);
}

