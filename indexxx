  d.assuntos.forEach((ass, ai) => {
    const block = document.createElement('div');
    block.style.cssText = 'background:var(--surf2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;';

    // Header do assunto
    const hdr = document.createElement('div');
    hdr.style.cssText = 'display:flex;align-items:center;gap:6px;padding:.5rem .65rem;cursor:pointer;';
    hdr.onclick = () => {
      const sub = block.querySelector('.sub-list');
      if (sub) sub.style.display = sub.style.display === 'none' ? 'block' : 'none';
    };

    const chevron = document.createElement('span');
    chevron.style.cssText = 'font-size:.65rem;color:var(--muted);transition:transform .15s;user-select:none;';
