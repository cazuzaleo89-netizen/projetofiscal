function impApplyTemplate(key){
  const t = IMP_TEMPLATES[key];
  if(!t) return;

  const total = t.disciplinas.reduce((a,d)=>a+d.topicos.length,0);
  if(!confirm(`Importar "${t.nome}"?\n\n• ${t.disciplinas.length} disciplinas serão adicionadas/atualizadas\n• Pesos do edital configurados automaticamente\n• ${total} tópicos carregados\n\nAs disciplinas existentes com mesmo nome serão preservadas.`)) return;

  editalEnsure();

  t.disciplinas.forEach(d=>{
    // Add discipline if not exists (match by name)
    let disc = state.disciplines.find(x=>x.name.toLowerCase().includes(d.nome.toLowerCase().split(' ').slice(-1)[0]));
    if(!disc){
      disc = {id:uid(), name:d.nome, color:d.cor, weeklyGoal:d.weeklyGoal};
      state.disciplines.push(disc);
    } else {
      disc.weeklyGoal = d.weeklyGoal;
    }
    // Set edital weight
    state.edital.weights[disc.id] = d.peso;
    // Store topics in edital metadata
    if(!state.edital.topicos) state.edital.topicos = {};
    state.edital.topicos[disc.id] = d.topicos;
  });

  state.edital.concurso = t.nome.split('—')[0].trim();
  saveState();
  renderDisciplines();
  renderEdital();
  renderEditalAnalysis();

  impShowResult({
    title:'✅ Edital importado com sucesso!',
    body:`<strong>${t.nome}</strong><br>${t.disciplinas.length} disciplinas · ${t.disciplinas.reduce((a,d)=>a+d.topicos.length,0)} tópicos · pesos configurados`,
    color:'var(--green)'
  });
  flash('Edital importado! Verifique as disciplinas.','#10b981');
}

// ── Text parser ─────────────────────────────────
function impParseText(){
  const text = document.getElementById('imp-text-input')?.value.trim()||'';
  if(!text){ flash('Cole o texto do edital primeiro!','#f0b429'); return; }

  // Identify discipline headers (lines in CAPS or with numbers like "1 - DIREITO TRIBUTÁRIO")
  const lines = text.split('\n').map(l=>l.trim()).filter(Boolean);
  const COLORS_CYCLE = ['#22d3ee','#8b5cf6','#10b981','#38bdf8','#ec4899','#a78bfa','#34d399','#fb923c'];

  const disciplines = [];
  let current = null;

  const isHeader = (line) => {
    const upper = line.toUpperCase();
    const keywords = ['DIREITO','CONTABILIDADE','AUDITORIA','LEGISLAÇÃO','PORTUGUÊS','MATEMÁTICA','RACIOCÍNIO','INFORMÁTICA','ADMINISTRAÇÃO','ECONOMIA','ESTATÍSTICA','FISCAL','TRIBUTÁRIO','FINANCEIRO','CONSTITUCIONAL'];
    const hasKeyword = keywords.some(k=>upper.includes(k));
    const isAllCaps = line === upper && line.length > 5 && line.length < 80;
    const startsWithNum = /^\d+[\.\-\s]/.test(line) && line.length < 60;
    return (isAllCaps || (hasKeyword && line.length < 80)) && !line.match(/^\d+\./);
  };

  lines.forEach(line=>{
    // Strip numbering
    const clean = line.replace(/^\d+[\.\-\)]\s*/,'').trim();
    if(isHeader(clean)){
      current = {name: clean.replace(/[:\-–]+$/,'').trim(), topicos:[], color: COLORS_CYCLE[disciplines.length % COLORS_CYCLE.length]};
      disciplines.push(current);
    } else if(current && clean.length > 5 && clean.length < 200){
      // Split by numbered items within same line
      const parts = clean.split(/\d+[\.\)]\s+/).filter(p=>p.trim().length>5);
      if(parts.length > 1) parts.forEach(p=>current.topicos.push(p.trim()));
      else current.topicos.push(clean);
    }
  });

  const valid = disciplines.filter(d=>d.topicos.length>0);
  if(!valid.length){
    flash('Não foi possível identificar disciplinas. Tente um formato mais claro.','#f0b429');
    return;
  }

  // Show preview
  const resultEl = document.getElementById('imp-text-result');
  resultEl.style.display = '';
  resultEl.innerHTML = `
    <div class="card">
      <div class="slabel">Resultado da Análise — ${valid.length} disciplinas encontradas</div>
      <div style="display:flex;flex-direction:column;gap:.5rem;margin-bottom:1rem;" id="imp-text-discs">
        ${valid.map((d,i)=>`
          <div style="background:var(--surf2);border:1px solid ${d.color}44;border-radius:var(--r);padding:.65rem .85rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.3rem;">
              <div style="width:8px;height:8px;border-radius:50%;background:${d.color};"></div>
              <input value="${d.name}" data-idx="${i}" class="imp-disc-name-inp"
                style="flex:1;background:transparent;border:none;border-bottom:1px solid var(--border2);color:var(--text);font-size:.78rem;font-weight:700;outline:none;padding:.1rem .2rem;"
                oninput="impTextDiscs[${i}].name=this.value"/>
              <span style="font-size:.62rem;color:var(--muted2);">${d.topicos.length} tópicos</span>
            </div>
            <div style="font-size:.62rem;color:var(--muted2);line-height:1.6;">${d.topicos.slice(0,4).join(' · ')}${d.topicos.length>4?` · +${d.topicos.length-4} mais...`:''}</div>
          </div>`).join('')}
      </div>
      <button class="btn btn-gold" onclick="impApplyParsed()">⬆ Importar ${valid.length} disciplinas</button>
      <button class="btn btn-ghost" style="margin-left:.5rem;" onclick="document.getElementById('imp-text-result').style.display='none'">Cancelar</button>
    </div>`;

  // Store in temp variable for editing
  window.impTextDiscs = valid;
}

function impApplyParsed(){
  const discs = window.impTextDiscs||[];
  if(!discs.length) return;
  editalEnsure();
  const COLORS = ['#22d3ee','#8b5cf6','#10b981','#38bdf8','#ec4899','#a78bfa','#34d399','#fb923c'];
  discs.forEach((d,i)=>{
    let disc = state.disciplines.find(x=>x.name.toLowerCase()===d.name.toLowerCase());
    if(!disc){ disc={id:uid(),name:d.name,color:d.color||COLORS[i%COLORS.length],weeklyGoal:10}; state.disciplines.push(disc); }
    if(!state.edital.topicos) state.edital.topicos={};
    state.edital.topicos[disc.id] = d.topicos;
  });
  saveState(); renderDisciplines();
  impShowResult({title:'✅ Disciplinas importadas!',body:`${discs.length} disciplinas e seus tópicos foram adicionados.`,color:'var(--green)'});
  flash('Importação concluída!','#10b981');
}

// ── JSON parser ─────────────────────────────────
function impParseJSON(){
  let raw = document.getElementById('imp-json-input')?.value.trim()||'';
  if(!raw){ flash('Cole o JSON primeiro!','#f0b429'); return; }
  try{
    const data = JSON.parse(raw);
    if(!Array.isArray(data)) throw new Error('Deve ser um array');
    editalEnsure();
    const COLORS=['#22d3ee','#8b5cf6','#10b981','#38bdf8','#ec4899','#a78bfa'];
    let count=0;
    data.forEach((item,i)=>{
      const name = item.disciplina||item.name||item.nome||'Disciplina '+(i+1);
      const peso = parseFloat(item.peso||item.weight||item.percentual)||0;
      const topicos = item.topicos||item.topics||item.tópicos||[];
      let disc = state.disciplines.find(x=>x.name.toLowerCase()===name.toLowerCase());
      if(!disc){ disc={id:uid(),name,color:item.cor||item.color||COLORS[i%COLORS.length],weeklyGoal:item.weeklyGoal||10}; state.disciplines.push(disc); }
      if(peso>0) state.edital.weights[disc.id]=peso;
      if(topicos.length){ if(!state.edital.topicos)state.edital.topicos={}; state.edital.topicos[disc.id]=topicos; }
      count++;
    });
    saveState(); renderDisciplines(); renderEdital(); renderEditalAnalysis();
    impShowResult({title:'✅ JSON importado!',body:`${count} disciplinas processadas.`,color:'var(--green)'});
    flash('JSON importado!','#10b981');
  } catch(e){
    flash('JSON inválido: '+e.message,'#ef4444');
    impShowResult({title:'❌ Erro no JSON',body:e.message,color:'var(--red)'});
  }
}

// ── CSV parser ──────────────────────────────────
function impParseCSV(){
  const raw = document.getElementById('imp-csv-input')?.value.trim()||'';
  if(!raw){ flash('Cole o CSV primeiro!','#f0b429'); return; }
  editalEnsure();
  const COLORS=['#22d3ee','#8b5cf6','#10b981','#38bdf8','#ec4899','#a78bfa'];
  const map={};
  raw.split('\n').forEach(line=>{
    const parts = line.split(/[;,\t]/);
    if(parts.length<2) return;
    const name = parts[0].trim();
    const peso = parseFloat(parts[1])||0;
    const topico = parts.slice(2).join(';').trim();
    if(!name) return;
    if(!map[name]) map[name]={peso,topicos:[]};
    if(topico) map[name].topicos.push(topico);
    if(peso>0) map[name].peso=peso;
  });

  const entries = Object.entries(map);
  if(!entries.length){ flash('Nenhum dado encontrado no CSV.','#f0b429'); return; }

  entries.forEach(([name,data],i)=>{
    let disc = state.disciplines.find(x=>x.name.toLowerCase()===name.toLowerCase());
    if(!disc){ disc={id:uid(),name,color:COLORS[i%COLORS.length],weeklyGoal:10}; state.disciplines.push(disc); }
    if(data.peso>0) state.edital.weights[disc.id]=data.peso;
    if(data.topicos.length){ if(!state.edital.topicos)state.edital.topicos={}; state.edital.topicos[disc.id]=data.topicos; }
  });
  saveState(); renderDisciplines(); renderEdital(); renderEditalAnalysis();
  impShowResult({title:'✅ CSV importado!',body:`${entries.length} disciplinas processadas.`,color:'var(--green)'});
  flash('CSV importado!','#10b981');
}

