// ── Step timer state ───────────────────────────
let hubActiveStep = null;
let hubStepTimer = null;
let hubStepRemaining = 0;
let hubCompletedSteps = new Set();

function hubSetTab(tab){
  hubTab = tab;
  hubCompletedSteps = new Set();
  hubActiveStep = null;
  clearInterval(hubStepTimer);
  hubStepTimer = null;
  arenaRenderProtocol();
}

function hubActivateStep(stepId, durMin){
  if(hubActiveStep===stepId){ return; }
  clearInterval(hubStepTimer);
  hubActiveStep = stepId;

  if(durMin>0){
    hubStepRemaining = durMin*60;
    hubStepTimer = setInterval(()=>{
      hubStepRemaining--;
      const btn = document.querySelector(`[data-hub-step="${stepId}"] .hub-step-timer`);
      if(btn){
        const m=Math.floor(hubStepRemaining/60),s=hubStepRemaining%60;
        btn.textContent=`${m}:${s.toString().padStart(2,'0')}`;
      }
      if(hubStepRemaining<=0){
        clearInterval(hubStepTimer);
        hubCompletedSteps.add(stepId);
        hubActiveStep = null;
        arenaRenderProtocol();
        flash(`✓ Etapa concluída! Continue para a próxima.`,'#10b981');
      }
    },1000);
  } else {
    // No timer — just mark as active
    setTimeout(()=>{ hubCompletedSteps.add(stepId); hubActiveStep=null; arenaRenderProtocol(); }, 500);
  }
  arenaRenderProtocol();
}

function hubStartAll(){
  hubCompletedSteps = new Set();
  hubActiveStep = null;
  clearInterval(hubStepTimer);
  const protocol = HUB_PROTOCOLS[hubTab];
  if(protocol?.steps?.length) hubActivateStep(protocol.steps[0].id, protocol.steps[0].durMin);
}

function arenaRenderProtocol(){
  const el = document.getElementById('arena-protocol-content');
  if(!el) return;

  const protocol = HUB_PROTOCOLS[hubTab];

  el.innerHTML = `
    <div class="hub-tabs">
      <button class="hub-tab${hubTab==='foco'?' active':''}" onclick="hubSetTab('foco')">🧠 Hiperfoco</button>
      <button class="hub-tab${hubTab==='procrastinacao'?' active':''}" onclick="hubSetTab('procrastinacao')">⚡ Anti-Procrastinação</button>
      <button class="hub-tab${hubTab==='estado'?' active':''}" onclick="hubSetTab('estado')">🎛 Regulação do Estado</button>
    </div>

    <p style="font-size:.7rem;color:var(--muted2);line-height:1.65;margin-bottom:.85rem;padding:.6rem .75rem;background:rgba(167,139,250,.06);border-radius:var(--r);border-left:3px solid ${protocol.cor};">${protocol.intro}</p>

    <div style="margin-bottom:.9rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;">
      <div style="font-size:.62rem;color:var(--muted2);">${hubCompletedSteps.size}/${protocol.steps.length} etapas concluídas</div>
      <div style="display:flex;gap:.4rem;">
        <button class="btn btn-ghost" style="font-size:.65rem;padding:.28rem .7rem;" onclick="hubSetTab('${hubTab}')">↺ Reiniciar</button>
        <button class="btn btn-purple" style="font-size:.65rem;padding:.28rem .8rem;" onclick="hubStartAll()">▶ Iniciar Protocolo</button>
      </div>
    </div>

    ${protocol.steps.map(step=>{
      const isActive = hubActiveStep===step.id;
      const isDone   = hubCompletedSteps.has(step.id);
      const m=Math.floor(hubStepRemaining/60),s=hubStepRemaining%60;
      return `<div class="hub-protocol-step${isActive?' active-step':isDone?' done-step':''}" data-hub-step="${step.id}" onclick="hubActivateStep('${step.id}',${step.durMin})">
        <div class="hub-step-num">${isDone?'✓':`${protocol.steps.indexOf(step)+1}`}</div>
        <div class="hub-step-body">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div class="hub-step-title">${step.icon} ${step.title}</div>
            ${isActive&&step.durMin>0?`<div class="hub-step-timer">${m}:${s.toString().padStart(2,'0')}</div>`:step.durMin>0?`<div style="font-size:.58rem;color:var(--muted2);">${step.durMin} min</div>`:''}
          </div>
          <div class="hub-step-desc">${step.desc}</div>
          <div class="hub-step-science">${step.science}</div>
          ${isActive?`<div class="hub-step-action">👉 ${step.action}</div>`:''}
        </div>
      </div>`;
    }).join('')}

    <div style="margin-top:.75rem;padding:.6rem .8rem;background:var(--surf2);border-radius:var(--r);border:1px solid var(--border);">
      <div style="font-size:.6rem;color:var(--muted2);line-height:1.6;">
        📚 <strong style="color:var(--text);">Fonte:</strong> Huberman Lab Podcast — episódios sobre dopamina, foco, procrastinação e regulação de estados cognitivos. Acesse <strong style="color:var(--cyan);">hubermanlab.com</strong> para aprofundar.
      </div>
    </div>`;
}

