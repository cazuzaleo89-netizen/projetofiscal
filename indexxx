/* ── Auto-fill disc when meta selected ─── */
function resAutoFillDisc(){
  const metaId = document.getElementById('res-modal-meta')?.value;
  if(!metaId) return;
  let found = null;
  (state.mwWeeks||[]).forEach(w=>w.metas.forEach(m=>{ if(m.id===metaId) found=m; }));
