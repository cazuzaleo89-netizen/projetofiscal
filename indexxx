}

function frAddQuestion() {
  frEnsure();
  const link = document.getElementById('fr-link-inp')?.value.trim();
  if (!link) { flash('Cole o link da questão!', '#f0b429'); return; }
  if (!link.startsWith('http')) { flash('Link inválido — deve começar com http', '#f0b429'); return; }

  const mins = frIntervalMins === 0
    ? (parseInt(document.getElementById('fr-custom-mins')?.value) || 11)
    : frIntervalMins;

  const discId   = document.getElementById('fr-disc-sel')?.value || '';
  const disc     = state.disciplines.find(d => d.id === discId);
  const desc     = document.getElementById('fr-desc-inp')?.value.trim() || '';
  const now      = Date.now();

  const item = {
    id:         uid(),
    link,
    desc:       desc || frExtractDesc(link),
    discId,
    discName:   disc?.name || '—',
    discColor:  disc?.color || '#5a6a8a',
    intervalMins: mins,
    addedAt:    now,
    dueAt:      now + mins * 60000,
    status:     'waiting',
    openedAt:   null,
    doneAt:     null,
  };

  state.filaRevisao.unshift(item);
  saveState();

  // Clear inputs
  document.getElementById('fr-link-inp').value = '';
  document.getElementById('fr-desc-inp').value = '';

  flash(`✅ Adicionado! Abrirá em ${mins} min às ${new Date(item.dueAt).toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}`, '#10b981');
  frRender();
}

function frExtractDesc(link) {
  // Try to extract question number from URL
  const m = link.match(/\/(\d{5,})/);
  return m ? `Questão #${m[1]}` : 'Questão';
}

function frOpenQuestion(id) {
  frEnsure();
  const item = state.filaRevisao.find(q => q.id === id);
  if (!item) return;
  item.openedAt = Date.now();
