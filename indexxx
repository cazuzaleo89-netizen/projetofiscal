/* ── Render grid ─── */
function renderResumos(){
  resEnsure();
  const discF  = document.getElementById('res-disc-filter')?.value||'';
  const metaF  = document.getElementById('res-meta-filter')?.value||'';
  const search = (document.getElementById('res-search')?.value||'').toLowerCase();
  const sort   = document.getElementById('res-sort')?.value||'date_desc';

  let items = [...state.resumos];

  // filters
  if(discF) items = items.filter(r => r.discId === discF);
  if(metaF) items = items.filter(r => r.metaId === metaF);
  if(search) items = items.filter(r =>
    r.title.toLowerCase().includes(search) ||
    (r.content||'').toLowerCase().includes(search) ||
    (r.tags||[]).some(t => t.toLowerCase().includes(search))
  );

  // sort
  const sortFns = {
    date_desc: (a,b) => new Date(b.date)-new Date(a.date),
    date_asc:  (a,b) => new Date(a.date)-new Date(b.date),
    disc:      (a,b) => (a.discName||'').localeCompare(b.discName||''),
    title:     (a,b) => a.title.localeCompare(b.title),
  };
  items.sort(sortFns[sort]||sortFns.date_desc);

  // stats strip
  const strip = document.getElementById('res-stats-strip');
  if(strip){
    const total = state.resumos.length;
    const texts = state.resumos.filter(r=>r.type==='text').length;
    const imgs  = state.resumos.filter(r=>r.type==='image').length;
    const discs = [...new Set(state.resumos.map(r=>r.discId))].length;
    strip.innerHTML = `
      <div class="res-stat-chip">Total <span>${total}</span></div>
      <div class="res-stat-chip">✎ Textos <span>${texts}</span></div>
      <div class="res-stat-chip">🖼 Imagens <span>${imgs}</span></div>
      <div class="res-stat-chip">Disciplinas <span>${discs}</span></div>
      ${search||discF||metaF?`<div class="res-stat-chip" style="color:var(--gold);">Filtrados <span style="color:var(--gold)">${items.length}</span></div>`:''}`;
  }

  const grid = document.getElementById('res-grid');
  if(!grid) return;

  if(!items.length){
    grid.innerHTML = `<div class="empty" style="grid-column:1/-1;">${state.resumos.length?'Nenhum resumo encontrado para este filtro.':'Nenhum resumo ainda. Clique em <strong>+ Novo Resumo</strong> para começar!'}</div>`;
    return;
  }

  grid.innerHTML = '';
  items.forEach(r => {
    const color = r.color||'var(--cyan)';
    const card = document.createElement('div');
    card.className = 'res-card';
    // plain text preview (strip HTML)
    const plainText = r.type==='text' ? (r.content||'').replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim() : '';

    card.innerHTML = `
      <div class="res-card-accent" style="background:linear-gradient(90deg,${color},${color}88);"></div>
      ${r.type==='image'&&(r.imageData||r.imageUrl)?`<img class="res-card-img" src="${r.imageData||r.imageUrl}" alt="${r.title}" loading="lazy"/>`:''}
      <div class="res-card-body">
        <div class="res-card-disc" style="color:${color};">${r.discName||'—'}</div>
        <div class="res-card-title">${r.title}</div>
        ${r.metaName?`<div style="font-size:.6rem;color:var(--muted2);margin-bottom:.4rem;">📎 ${r.metaName.slice(0,55)}</div>`:''}
        ${r.type==='text'&&plainText?`<div class="res-card-preview">${plainText}</div>`:''}
        ${r.type==='image'&&!r.imageData&&!r.imageUrl?`<div style="font-size:.72rem;color:var(--muted2);">🖼 Imagem vinculada</div>`:''}
      </div>
      <div class="res-card-footer">
        <div>
          <div class="res-card-date">${r.dateStr||'—'}</div>
          <div class="res-card-tags">${(r.tags||[]).map(t=>`<span class="res-tag">${t}</span>`).join('')}</div>
        </div>
        <div class="res-card-actions">
          <button class="res-card-btn" data-res-edit="${r.id}" title="Editar">✏️</button>
          <button class="res-card-btn" data-res-del="${r.id}" title="Excluir" style="color:var(--red);">🗑</button>
        </div>
      </div>`;

    // Click to view (delegated on card body)
    card.addEventListener('click', function(e){
      const editId = e.target.closest('[data-res-edit]')?.dataset.resEdit;
      const delId  = e.target.closest('[data-res-del]')?.dataset.resDel;
      if(editId){ openResumoModal(editId); return; }
      if(delId) { deleteResumo(delId); return; }
      openResumoViewer(r.id);
    });

    grid.appendChild(card);
  });
}

/* ── Modal open/close ─── */
function openResumoModal(editId){
  resEnsure();
  resEditingId = editId||null;
  resImageData = null;

  // populate selects
  const msel = document.getElementById('res-modal-meta');
  if(msel){
    msel.innerHTML = '<option value="">— selecione uma meta —</option>';
    (state.mwWeeks||[]).forEach(w => w.metas.forEach(m => {
      msel.appendChild(new Option(`${m.disc.replace('Dir. ','')} — ${m.name.slice(0,50)}`, m.id));
    }));
  }
  const dsel = document.getElementById('res-modal-disc');
  if(dsel){
    dsel.innerHTML = '<option value="">— escolha —</option>';
    state.disciplines.forEach(d => dsel.appendChild(new Option(d.name, d.id)));
  }

  // color picker
  const cp = document.getElementById('res-color-picker');
  if(cp){
    cp.innerHTML = '';
    RES_COLORS.forEach(c => {
      const d = document.createElement('div');
      d.className = 'cdot';
      d.style.background = c;
