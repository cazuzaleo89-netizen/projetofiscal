}

function dashPlanoDia(){
  const el = document.getElementById('dash-plano-list');
  if(!el) return;
  if(!state.disciplines.length){el.innerHTML='<div class="empty" style="font-size:.7rem;">Cadastre disciplinas para gerar o plano.</div>';return;}

  const totSecs = (state.sessions||[]).reduce((a,s)=>a+s.seconds,0);
  const hasWeights = state.disciplines.some(d=>(state.edital&&state.edital.weights&&state.edital.weights[d.id]||0)>0);

  const items = state.disciplines.map(d=>{
    const qs = (state.questionSessions||[]).filter(s=>s.subjectId===d.id);
    const tot = qs.reduce((a,s)=>a+s.total,0);
    const cor = qs.reduce((a,s)=>a+s.correct,0);
    const rate = tot>0 ? cor/tot : null;
    const secs = (state.sessions||[]).filter(s=>s.subjectId===d.id).reduce((a,s)=>a+s.seconds,0);
    const edW  = hasWeights ? ((state.edital&&state.edital.weights&&state.edital.weights[d.id])||0)/100 : 1/state.disciplines.length;
    const studyPct = totSecs>0 ? secs/totSecs : 0;
    const alignGap = edW - studyPct;
    const reincCount = Object.values(state.wrongHistory||{})
      .filter(w=>(w.materia===d.name||w.assunto===d.name)&&w.erros>=2).length;

    // Priority score: edital gap (positive=under-studied) + low accuracy penalty + reincidências
    let priority = alignGap*2;
    if(rate!==null && rate<0.65) priority += (0.65-rate)*1.5;
    if(reincCount>0) priority += reincCount*0.05;
    if(rate===null) priority += 0.3;

    // Tempo sugerido: proporcional ao edital weight, mínimo 30min
    const goalSecs = (state.dailyGoal||4)*3600;
    const suggested = Math.max(1800, Math.round(goalSecs*edW/600)*600);

    let why = '';
    if(alignGap>0.05) why = 'Abaixo do peso do edital';
    else if(rate!==null&&rate<0.6) why = 'Taxa de acerto baixa ('+Math.round(rate*100)+'%)';
    else if(reincCount>0) why = reincCount+' reincidência'+(reincCount>1?'s':'');
    else if(rate===null) why = 'Sem questões registradas';
    else why = 'Manutenção de desempenho';

    return {d, priority, suggested, why, rate, reincCount};
  }).sort((a,b)=>b.priority-a.priority).slice(0,4);

  if(!items.length){el.innerHTML='<div class="empty" style="font-size:.7rem;">Sem dados suficientes.</div>';return;}

  el.innerHTML = items.map((x,i)=>{
    const rateColor = x.rate===null?'var(--muted2)':x.rate>=0.7?'var(--green)':x.rate>=0.5?'var(--gold)':'var(--red)';
    const numColor = i===0?'var(--gold)':i===1?'var(--cyan)':'var(--muted3)';
    const mins = Math.round(x.suggested/60);
    const timeStr = mins>=60?(Math.floor(mins/60)+'h'+(mins%60?String(mins%60).padStart(2,'0')+'m':'')):(mins+'min');
    return `<div class="plan-item" onclick="goPage('cronometro',document.querySelector('.nav-item[onclick*=cronometro]'));setTimeout(()=>{const sel=document.getElementById('active-subject-select');if(sel){for(let i=0;i<sel.options.length;i++)if(sel.options[i].text.includes('${x.d.name.substring(0,15)}')){sel.selectedIndex=i;break;}}},300)">
      <div class="plan-item-num" style="color:${numColor}">${i+1}.</div>
      <div style="flex:1;min-width:0;">
        <div class="plan-item-name" style="color:${x.d.color}">${x.d.name}</div>
        <div class="plan-item-why">${x.why}</div>
      </div>
      <div class="plan-item-time" style="color:${rateColor}">${timeStr}</div>
    </div>`;
  }).join('');
  const sub = document.getElementById('dash-plan-subtitle');
  if(sub) sub.textContent = hasWeights?'Baseado no edital + desempenho':'Configure pesos do edital para melhorar';
}

