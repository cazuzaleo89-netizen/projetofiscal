let impEditorKey = null;
let impEditorData = null; // deep copy of template being edited
let impEditorActiveDiscIdx = 0;

function impOpenEditor(key){
  impEditorKey = key;
  const t = IMP_TEMPLATES[key];
  if(!t) return;
  // Deep copy so edits don't mutate the original
  impEditorData = JSON.parse(JSON.stringify(t));
  document.getElementById('imp-topics-editor').style.display = '';
  document.getElementById('imp-editor-subtitle').textContent =
    `${t.nome} — ${t.disciplinas.length} disciplinas`;
  // scroll to editor
  document.getElementById('imp-topics-editor').scrollIntoView({behavior:'smooth'});
  impEditorRenderTabs();
  impEditorSelectDisc(0);
}

function impEditorRenderTabs(){
  const el = document.getElementById('imp-editor-tabs');
  if(!el||!impEditorData) return;
  el.innerHTML = '';
  impEditorData.disciplinas.forEach((d,i)=>{
    const btn = document.createElement('button');
    btn.className = 'est-chip'+(i===impEditorActiveDiscIdx?' active':'');
    btn.style.cssText = i===impEditorActiveDiscIdx
      ? `background:${d.cor};color:#000;border-color:${d.cor};`
      : `color:${d.cor};border-color:${d.cor}44;background:${d.cor}10;`;
    btn.textContent = d.nome.replace('Dir. ','').replace('Contabilidade ','Cont.').replace(' e Custos','');
    btn.title = `${d.nome} — ${d.topicos.filter(t=>!t.startsWith('//')).length} tópicos`;
    btn.onclick = ()=>impEditorSelectDisc(i);
    el.appendChild(btn);
  });
}

function impEditorSelectDisc(idx){
  impEditorActiveDiscIdx = idx;
  const d = impEditorData?.disciplinas[idx];
  if(!d) return;
  impEditorRenderTabs();
  document.getElementById('imp-editor-active').style.display = '';
  document.getElementById('imp-editor-empty').style.display = 'none';
  document.getElementById('imp-ed-name').value = d.nome;
  document.getElementById('imp-ed-peso').value = d.peso||0;
  document.getElementById('imp-ed-goal').value = d.weeklyGoal||10;
  impEditorRenderTopics();
}

function impEditorRenderTopics(){
  const el = document.getElementById('imp-ed-topics');
  if(!el) return;
  const d = impEditorData?.disciplinas[impEditorActiveDiscIdx];
  if(!d){el.innerHTML='';return;}
  // Filter out JS comments (// lines)
  const topics = d.topicos.filter(t=>!t.trim().startsWith('//'));
  el.innerHTML = '';
  topics.forEach((topic, i)=>{
    const row = document.createElement('div');
    row.style.cssText='display:flex;align-items:center;gap:.4rem;';
    row.innerHTML = `
      <div style="width:22px;height:22px;border-radius:6px;background:var(--surf3);border:1px solid var(--border);
        display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.55rem;
        color:var(--muted2);font-family:var(--mono);font-weight:700;">${i+1}</div>
      <input value="${topic.replace(/"/g,'&quot;')}" data-topic-idx="${i}"
        style="flex:1;background:var(--surf2);border:1px solid var(--border2);border-radius:var(--r2);
          color:var(--text);font-size:.75rem;padding:.3rem .6rem;outline:none;transition:border-color .2s;font-family:var(--ff);"
        onfocus="this.style.borderColor='var(--cyan)'" onblur="this.style.borderColor='var(--border2)'"
        oninput="impEditorUpdateTopic(${i},this.value)"/>
      <button onclick="impEditorRemoveTopic(${i})"
        style="background:none;border:none;cursor:pointer;color:var(--muted);font-size:.8rem;padding:2px 5px;
          border-radius:5px;transition:color .15s;flex-shrink:0;"
        onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--muted)'">×</button>`;
    el.appendChild(row);
  });
