}

function cronStop() {
  if (!cronState.running) return;
  clearInterval(cronState.interval);
  const secs = cronState.mode === 'chrono' ? cronState.elapsed : (cronState.total - cronState.elapsed);
  cronState.running = false;
  cronState.paused  = false;
  cronInvReset();

  // Determina assunto final: manual > TEC assunto > TEC matéria > vazio
  const _finalAssunto = cronState.assunto || _cronInv.assunto || _cronInv.materia || '';

  if (secs > 30) {
    const now = new Date();
    state.sessions.push({
      id:uid(),
      subjectId:   cronState.discId,
      subject:     cronState.discName || 'Geral',
      assunto:     _finalAssunto,
      materia:     _cronInv.materia  || cronState.discName || '',
      cadernoUrl:  (state.tecCaderno && state.tecCaderno.url) || '',
      cadernoNome: _cronInv.caderno  || '',
      totalQuestoes: _cronInv.total  || 0,
      acertos:     cronState.acertos,
      erros:       cronState.erros,
      resolved:    cronState.resolved,
      seconds:     secs,
      date:        now.toISOString(),
      dateStr:     now.toLocaleDateString('pt-BR'),
      timeStr:     now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})
    });
    // Limpa sessão persistida
    try { localStorage.removeItem('pf_cron_persist'); } catch(e) {}

    // Pré-preencher formulário "Registrar Questões" com contagem ao vivo
    const _liveTotal = cronState.resolved || (cronState.acertos + cronState.erros);
    const _liveCorr  = cronState.acertos || 0;
    if (_liveTotal > 0) {
      const qTot = document.getElementById('cron-q-total');
      const qCor = document.getElementById('cron-q-correct');
      if (qTot) qTot.value = _liveTotal;
      if (qCor) qCor.value = _liveCorr;
      // Destacar o card de registro
      const regCard = document.getElementById('cron-register-card');
      if (regCard) {
        regCard.style.borderColor = 'rgba(34,211,238,.55)';
        regCard.style.boxShadow   = '0 0 0 3px rgba(34,211,238,.12)';
        setTimeout(() => { regCard.style.borderColor = ''; regCard.style.boxShadow = ''; }, 3000);
        setTimeout(() => regCard.scrollIntoView({behavior:'smooth', block:'nearest'}), 250);
      }
    }

    updateStreak(now.toDateString());
    try { arenaAddXP(Math.ceil(secs/60), 'Sessão: '+( cronState.discName||'Geral'), '⏱'); } catch(e){}
    saveState(); updateStats(); renderLog(); cronUpdateTodayLog();
    const qMsg  = (cronState.resolved>0||cronState.acertos>0) ? ` | ${cronState.acertos}/${cronState.resolved||cronState.acertos+cronState.erros} questões` : '';
    const assMsg = _finalAssunto ? ` · ${_finalAssunto.slice(0,40)}` : '';
    flash(`✅ Sessão encerrada: ${formatHM(secs)} — ${cronState.discName||'Geral'}${assMsg}${qMsg}`, '#10b981');
  }

  // Reset UI
  cronState.elapsed = 0;
  cronState.assunto = '';
  const assuntoBadge = document.getElementById('cron-assunto-tec-badge');
  if (assuntoBadge) assuntoBadge.style.display = 'none';
  cronUpdateBtns('idle');
  cronSetBadge('PRONTO','rgba(90,106,138,.2)','#6b7280','rgba(90,106,138,.25)');
  const digs = document.getElementById('cron-digits'); if(digs){digs.textContent='00:00:00';digs.style.color='#f9fafb';}
  const lbl=document.getElementById('cron-status-lbl'); if(lbl)lbl.textContent='PRONTO PARA ESTUDAR';
  const stats=document.getElementById('cron-stats-row'); if(stats)stats.style.display='none';
  const counts=document.getElementById('cron-count-row'); if(counts)counts.style.display='none';
  cronUpdateTodayLog();
  // Close PiP
  if (cronPipWin && !cronPipWin.closed) cronPipWin.close();
  document.getElementById('missao-topbar-pill').style.display = 'none';
}

let _cronPersistTick = 0;
function cronTick() {
  if (cronState.paused) return;
  if (cronState.mode === 'chrono') {
    cronState.elapsed++;
  } else {
    cronState.elapsed++;
    if (cronState.elapsed >= cronState.total) {
      cronTimeUp(); return;
    }
  }
  // Persistir a cada 30 segundos
  _cronPersistTick++;
  if (_cronPersistTick % 30 === 0) cronPersist();
  // Push stats ao TEC tab a cada 5s
  if (_cronPersistTick % 5 === 0) { try { tecPushStats(); } catch(e) {} }
  cronUpdateUI();
}

function cronUpdateUI() {
  const isTimer = cronState.mode === 'timer';
  const secs    = isTimer ? (cronState.total - cronState.elapsed) : cronState.elapsed;
  const digs = document.getElementById('cron-digits');
  if (digs) {
    digs.textContent = cronFmt(secs);
    if (isTimer) {
      const pct = secs / cronState.total;
      digs.style.color = pct<.15?'#f87171':pct<.3?'#fbbf24':'#f9fafb';
    }
  }
  // Ring update
  if (isTimer) {
    const ring = document.getElementById('cron-ring-fill');
    const pct  = (cronState.total - cronState.elapsed) / cronState.total;
    if (ring) {
      const circ = 439.8;
      ring.style.strokeDashoffset = circ * (1 - pct);
      ring.style.stroke = pct<.15?'#f87171':pct<.3?'#fbbf24':'#4a6cf7';
    }
    const rd = document.getElementById('cron-ring-digits');
    if (rd) rd.textContent = cronFmtShort(secs);
  }
  // Status label
  const lbl = document.getElementById('cron-status-lbl');
  if (lbl && cronState.running && !cronState.paused) lbl.textContent = 'EM ANDAMENTO';
  // Stats
  set('cron-s-res', cronState.resolved);
  set('cron-s-ace', cronState.acertos);
  set('cron-s-err', cronState.erros);
  // Topbar pill
  const pill = document.getElementById('missao-topbar-pill');
  const pillT = document.getElementById('missao-topbar-timer');
  if (pill && cronState.running) { pill.style.display='flex'; if(pillT) pillT.textContent = isTimer ? cronFmtShort(secs) : cronFmtShort(cronState.elapsed); }
  // PiP sync
  cronPipSync();
}

