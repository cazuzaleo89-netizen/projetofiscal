          <div class="missoes-day-prog-fill" style="width:${progPct}%;${isPast&&progPct<100?'background:var(--red)':''}"></div>
        </div>
        <div class="missoes-day-count">${doneCnt} de ${totalCnt} concluídas</div>
      </div>
      <div class="missoes-cards-row">
        ${group.missions.map(m => missoesCardHTML(m)).join('')}
      </div>`;

    el.appendChild(section);
  });
}

