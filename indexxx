let _cronInv = { total: 0, materia: '', assunto: '', caderno: '' };

function cronInvStart(data) {
  _cronInv.total   = parseInt(data.total)   || 0;
  _cronInv.materia = data.materia  || '';
  _cronInv.assunto = data.assunto  || '';
  _cronInv.caderno = data.caderno  || data.materia || 'TecConcursos';

